dotnet_diagnostic.CA1848.severity = none       # LoggerMessage delegates (premature optimization)
dotnet_diagnostic.CA1716.severity = none       # Identifier naming (intentional)
dotnet_diagnostic.CA1711.severity = none       # Suffix naming conventions (Queue, Stack etc. intentional)
# I-11 GOREV 6: Suppress remaining Application layer warnings
dotnet_diagnostic.MA0011.severity = none       # IFormatProvider: CQRS handler formatting
dotnet_diagnostic.CA1305.severity = none       # IFormatProvider: application layer formatting
dotnet_diagnostic.CA1008.severity = none       # Enum default value: domain enums used in DTOs
dotnet_diagnostic.MA0051.severity = none       # Method too long: complex CQRS handlers
dotnet_diagnostic.MA0002.severity = none       # StringComparer: application layer simplicity

