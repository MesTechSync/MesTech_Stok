root = true

[*.cs]
charset = utf-8-bom
indent_style = space
indent_size = 4
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.private_field_style.required_prefix = _
dotnet_naming_style.private_field_style.capitalization = camel_case
dotnet_naming_rule.private_fields_prefixed.symbols = private_fields
dotnet_naming_rule.private_fields_prefixed.style = private_field_style
dotnet_naming_rule.private_fields_prefixed.severity = warning

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_style.interface_prefix_style.required_prefix = I
dotnet_naming_style.interface_prefix_style.capitalization = pascal_case
dotnet_naming_rule.interfaces_should_begin_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_should_begin_with_i.style = interface_prefix_style
dotnet_naming_rule.interfaces_should_begin_with_i.severity = warning

csharp_prefer_braces = true:error
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion
csharp_style_var_elsewhere = false:suggestion
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

dotnet_diagnostic.IDE0055.severity = error

# ── Domain Layer: EF Core entity patterns are intentional ──
[src/MesTech.Domain/**.cs]
dotnet_diagnostic.NX0002.severity = none       # null! on EF Core navigation properties
dotnet_diagnostic.CA2227.severity = none       # Collection property setters needed by EF Core
dotnet_diagnostic.CA1822.severity = none       # Domain methods are instance by design (may use state later)
dotnet_diagnostic.CA1032.severity = none       # Domain exceptions: only needed constructors
dotnet_diagnostic.CA1056.severity = none       # URI as string in domain entities
dotnet_diagnostic.CA1054.severity = none       # URI parameters as string
dotnet_diagnostic.CA1062.severity = none       # EF Core entity internals don't validate args
dotnet_diagnostic.CA1819.severity = none       # Array properties in domain models
dotnet_diagnostic.CA1805.severity = none       # Default value initialization for clarity
dotnet_diagnostic.CA1716.severity = none       # Identifier names matching keywords (intentional)
dotnet_diagnostic.CA1711.severity = none       # Suffix naming conventions (domain-specific)
dotnet_diagnostic.CA1069.severity = none       # Duplicate enum values (backward compat aliases)
dotnet_diagnostic.CA1030.severity = none       # Raise/Fire method naming is intentional
dotnet_diagnostic.CA1024.severity = none       # Methods over properties for domain operations
dotnet_diagnostic.MA0006.severity = none       # String equality: domain layer uses simple ==

# ── Application Layer: CQRS + DTO patterns ──
[src/MesTech.Application/**.cs]
dotnet_diagnostic.MA0048.severity = none       # CQRS: Command + Handler in same file
dotnet_diagnostic.MA0016.severity = none       # List<T> in DTOs (serialization)
dotnet_diagnostic.CA1002.severity = none       # Generic lists in DTOs
dotnet_diagnostic.MA0004.severity = none       # ConfigureAwait not needed in app layer
dotnet_diagnostic.CA2007.severity = none       # ConfigureAwait not needed in app layer
dotnet_diagnostic.CA2227.severity = none       # DTO collection property setters
dotnet_diagnostic.CA1056.severity = none       # URI as string in DTOs
dotnet_diagnostic.CA1054.severity = none       # URI parameters as string
dotnet_diagnostic.CA1062.severity = none       # MediatR handlers: DI-injected, non-null
dotnet_diagnostic.CA1848.severity = none       # LoggerMessage delegates (premature optimization)
dotnet_diagnostic.CA1716.severity = none       # Identifier naming (intentional)
dotnet_diagnostic.CA1711.severity = none       # Suffix naming conventions (Queue, Stack etc. intentional)

# ── Desktop Layer: WPF needs SynchronizationContext ──
[src/MesTechStok.Desktop/**.cs]
dotnet_diagnostic.MA0004.severity = none       # ConfigureAwait(false) is WRONG in WPF (breaks UI thread)
dotnet_diagnostic.CA2007.severity = none       # Same: WPF needs SynchronizationContext
dotnet_diagnostic.CA1848.severity = none       # LoggerMessage delegates (premature optimization for desktop app)
dotnet_diagnostic.MA0048.severity = none       # File name != type name (XAML code-behind pattern)
dotnet_diagnostic.CA1062.severity = none       # WPF event handlers: sender/e are framework-provided
dotnet_diagnostic.MA0051.severity = none       # Method length: WPF event handlers are naturally long
dotnet_diagnostic.MA0011.severity = none       # IFormatProvider: WPF display formatting is locale-aware by design
dotnet_diagnostic.MA0006.severity = none       # String equality: UI string comparisons
dotnet_diagnostic.MA0002.severity = none       # StringComparer: UI code simplicity
dotnet_diagnostic.MA0016.severity = none       # Collection return types: WPF data binding uses concrete types
dotnet_diagnostic.CS0618.severity = none       # Obsolete: migration markers from prior waves
dotnet_diagnostic.NX0001.severity = none       # NuGet-related false positives
dotnet_diagnostic.NX0002.severity = none       # NuGet-related false positives

# ── Infrastructure Layer: Adapter + Integration patterns ──
[src/MesTech.Infrastructure/**.cs]
dotnet_diagnostic.MA0004.severity = none       # ConfigureAwait: library code, not critical
dotnet_diagnostic.CA2007.severity = none       # Same as MA0004
dotnet_diagnostic.CA1848.severity = none       # LoggerMessage delegates (premature optimization)
dotnet_diagnostic.MA0048.severity = none       # Multiple types per file (adapter + helper)
dotnet_diagnostic.MA0051.severity = none       # Method length: DI registration methods are naturally long
dotnet_diagnostic.MA0011.severity = none       # IFormatProvider: internal adapter code
dotnet_diagnostic.MA0006.severity = none       # String equality: adapter internals
dotnet_diagnostic.MA0002.severity = none       # StringComparer: internal collections
dotnet_diagnostic.MA0016.severity = none       # Collection return types: adapter results
dotnet_diagnostic.NX0001.severity = none       # NuGet-related false positives
dotnet_diagnostic.NX0002.severity = none       # NuGet-related false positives

# ── Core Layer (legacy): Reduced strictness ──
[src/MesTechStok.Core/**.cs]
dotnet_diagnostic.MA0004.severity = none       # ConfigureAwait
dotnet_diagnostic.CA2007.severity = none       # ConfigureAwait
dotnet_diagnostic.CA1848.severity = none       # LoggerMessage delegates
dotnet_diagnostic.MA0048.severity = none       # File naming
dotnet_diagnostic.NX0001.severity = none       # NuGet
dotnet_diagnostic.NX0002.severity = none       # NuGet

# ── Test Projects: Focus on test logic, not code style ──
[src/MesTech.Tests.*/**.cs]
dotnet_diagnostic.MA0004.severity = none       # ConfigureAwait irrelevant in tests
dotnet_diagnostic.CA2007.severity = none       # ConfigureAwait irrelevant in tests
dotnet_diagnostic.CA1848.severity = none       # LoggerMessage in tests: unnecessary
dotnet_diagnostic.MA0048.severity = none       # File naming: test organization is flexible
dotnet_diagnostic.MA0016.severity = none       # Return types: test helpers use concrete types
dotnet_diagnostic.MA0011.severity = none       # IFormatProvider: test data doesn't need culture
dotnet_diagnostic.CA1062.severity = none       # Parameter validation: xUnit framework handles
dotnet_diagnostic.MA0006.severity = none       # String equality: test assertions use ==
dotnet_diagnostic.MA0002.severity = none       # StringComparer: test code simplicity
dotnet_diagnostic.CA2234.severity = none       # URI overloads: test URLs are strings
dotnet_diagnostic.CA2000.severity = none       # Dispose: test fixtures handle cleanup
dotnet_diagnostic.CA1307.severity = none       # StringComparison: test code simplicity
dotnet_diagnostic.NX0001.severity = none       # NuGet
dotnet_diagnostic.NX0002.severity = none       # NuGet

# ── WebApi: Minimal API patterns ──
[src/MesTech.WebApi/**.cs]
dotnet_diagnostic.MA0004.severity = none       # ConfigureAwait: ASP.NET Core handles
dotnet_diagnostic.CA2007.severity = none       # Same
dotnet_diagnostic.CA1848.severity = none       # LoggerMessage delegates
dotnet_diagnostic.NX0001.severity = none       # NuGet
dotnet_diagnostic.NX0002.severity = none       # NuGet

[*.{csproj,props,targets}]
indent_style = space
indent_size = 2

[*.yml]
indent_style = space
indent_size = 2