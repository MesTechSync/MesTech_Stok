# MesTech Stok - Docker Compose Environment Variables
# Bu dosyayi .env olarak kopyalayip gercek degerleri girin
# cp .env.example .env
#
# CHANGE_ME isaretli tum degerleri gercek credential ile degistirin.
# Varsayilan portlar dev ortami icindir — production icin docker-compose.production.yml kullanin.

# ═══════════════════════════════════════════
# PostgreSQL (pgvector/pgvector:pg17)
# ═══════════════════════════════════════════
POSTGRES_USER=mestech_user
POSTGRES_PASSWORD=CHANGE_ME
PG_DATABASE=mestech_stok
PG_PORT=3432
PG_HOST=localhost
PG_CONTAINER=mestech-postgres

# ═══════════════════════════════════════════
# Redis (redis:7.4-alpine)
# ═══════════════════════════════════════════
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=3679

# ═══════════════════════════════════════════
# RabbitMQ (rabbitmq:3.13-management-alpine)
# ═══════════════════════════════════════════
RABBITMQ_USER=mestech
RABBITMQ_PASSWORD=CHANGE_ME

# ═══════════════════════════════════════════
# MySQL — OpenCart (mysql:8.0)
# ═══════════════════════════════════════════
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=opencart_stok

# ═══════════════════════════════════════════
# Seq — Structured Logging (datalust/seq:2024.1)
# ═══════════════════════════════════════════
SEQ_ADMIN_PASSWORD=CHANGE_ME

# ═══════════════════════════════════════════
# MinIO — Object Storage (minio/minio)
# ═══════════════════════════════════════════
MINIO_ROOT_USER=mestech
MINIO_ROOT_PASSWORD=CHANGE_ME

# ═══════════════════════════════════════════
# Grafana — Monitoring Dashboard
# ═══════════════════════════════════════════
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME

# ═══════════════════════════════════════════
# ASP.NET Core WebAPI
# ═══════════════════════════════════════════
ASPNETCORE_ENVIRONMENT=Development

# ═══════════════════════════════════════════
# Backup (Scripts/backup-postgres.sh)
# ═══════════════════════════════════════════
BACKUP_DIR=/backups/postgres
RETENTION_DAYS=30
BACKUP_ENCRYPT=false
# BACKUP_GPG_PASSPHRASE=CHANGE_ME
# RCLONE_REMOTE=s3:mestech-backups

# ═══════════════════════════════════════════
# Docker Mode (backup script)
# ═══════════════════════════════════════════
USE_DOCKER=true

# ═══════════════════════════════════════════
# V5 — Fulfillment (Amazon FBA + Hepsilojistik)
# ═══════════════════════════════════════════
# AmazonFba__LwaClientId=CHANGE_ME
# AmazonFba__LwaClientSecret=CHANGE_ME
# AmazonFba__RefreshToken=CHANGE_ME
# AmazonFba__SellerId=CHANGE_ME
# AmazonFba__MarketplaceId=A33AVAJ2PDY3EV
# AmazonFba__UseSandbox=true
# Hepsilojistik__MerchantId=CHANGE_ME
# Hepsilojistik__ApiKey=CHANGE_ME
# Hepsilojistik__SecretKey=CHANGE_ME

# ═══════════════════════════════════════════
# V5 — ERP Entegrasyonlari
# ═══════════════════════════════════════════
# Parasut__ClientId=CHANGE_ME
# Parasut__ClientSecret=CHANGE_ME
# Parasut__CompanyId=CHANGE_ME
# Parasut__RedirectUri=https://staging.mestech.tr/callback/parasut
# BizimHesap__ApiKey=CHANGE_ME
# BizimHesap__BaseUrl=https://api.bizimhesap.com
# LogoERP__BaseUrl=http://logo-rest-server:8080
# LogoERP__Username=CHANGE_ME
# LogoERP__Password=CHANGE_ME
# NetsisERP__ConnectionString=Server=sql-server;Database=NETSIS_TEST;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=true

# ═══════════════════════════════════════════
# V5 — Grafana + Prometheus
# ═══════════════════════════════════════════
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
PROMETHEUS_PORT=3090
GRAFANA_PORT=3000

# ═══════════════════════════════════════════
# V5 — Nginx
# ═══════════════════════════════════════════
NGINX_HTTP_PORT=3080
NGINX_HTTPS_PORT=3443
WEBAPI_PORT=3100
