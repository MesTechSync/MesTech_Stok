@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: var(--mestech-modal-overlay);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    <button type="button" class="btn-close" @onclick="Cancel"></button>
                </div>
                <div class="modal-body"><p>@Message</p></div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="Cancel">Iptal</button>
                    <button class="btn btn-@ButtonVariant btn-sm" @onclick="Confirm">@ConfirmText</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = "Onay";
    [Parameter] public string Message { get; set; } = "Bu islemi onayliyor musunuz?";
    [Parameter] public string ConfirmText { get; set; } = "Onayla";
    [Parameter] public string ButtonVariant { get; set; } = "danger";
    [Parameter] public EventCallback OnConfirmed { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }

    private async Task Confirm() => await OnConfirmed.InvokeAsync();
    private async Task Cancel() => await OnCancelled.InvokeAsync();
}
