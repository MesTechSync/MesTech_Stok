@* Premium KPI Card with trend indicator — I-03 *@

<div class="card border-0 shadow-sm h-100">
  <div class="card-body p-3">
    <div class="d-flex justify-content-between align-items-start mb-2">
      <span class="text-muted small text-uppercase">@Label</span>
      <span class="badge @IconBgClass rounded-circle p-2">
        <i class="@Icon"></i>
      </span>
    </div>
    @if (IsLoading)
    {
      <div class="placeholder-glow">
        <span class="placeholder col-8 mb-1" style="height: 1.5rem;"></span>
        <span class="placeholder col-5" style="height: 0.8rem;"></span>
      </div>
    }
    else
    {
      <h3 class="mb-1 fw-bold @ValueClass">@Value</h3>
      @if (!string.IsNullOrEmpty(TrendText))
      {
        <div class="d-flex align-items-center gap-1">
          <span class="badge @TrendBadgeClass small">
            <i class="fas @TrendIcon"></i> @TrendText
          </span>
          <span class="text-muted" style="font-size: 0.7rem;">@ComparisonPeriod</span>
        </div>
      }
    }
  </div>
</div>

@code {
  [Parameter] public string Label { get; set; } = "";
  [Parameter] public string Value { get; set; } = "0";
  [Parameter] public string Icon { get; set; } = "fas fa-chart-bar";
  [Parameter] public string IconBgClass { get; set; } = "bg-primary bg-opacity-10 text-primary";
  [Parameter] public string ValueClass { get; set; } = "";
  [Parameter] public string TrendText { get; set; } = "";
  [Parameter] public bool IsPositiveTrend { get; set; } = true;
  [Parameter] public string ComparisonPeriod { get; set; } = "vs dun";
  [Parameter] public bool IsLoading { get; set; }

  private string TrendIcon => IsPositiveTrend ? "fa-arrow-up" : "fa-arrow-down";
  private string TrendBadgeClass => IsPositiveTrend
    ? "bg-success bg-opacity-10 text-success"
    : "bg-danger bg-opacity-10 text-danger";
}
