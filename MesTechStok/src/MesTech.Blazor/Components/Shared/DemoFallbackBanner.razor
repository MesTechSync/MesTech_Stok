@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Environment

@if (IsDemoMode)
{
  @if (Environment.IsDevelopment())
  {
    <div class="alert alert-warning alert-dismissible fade show mb-3" role="alert">
      <i class="fas fa-flask me-2"></i>
      <strong>Demo Modu (DEV):</strong> @Message
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
  }
  else
  {
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i>
      <strong>Baglanti Hatasi:</strong> Veri kaynagina ulasilamiyor. Gosterilen veriler guncel olmayabilir.
      Lutfen sistem yoneticinize basvurun.
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
    </div>
  }
}

@code {
  [Parameter] public bool IsDemoMode { get; set; }
  [Parameter] public string Message { get; set; } = "Backend baglantisi yok — demo veri gosteriliyor";
}
