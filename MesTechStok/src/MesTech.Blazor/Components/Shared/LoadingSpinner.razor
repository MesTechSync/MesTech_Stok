@if (IsLoading)
{
    <div class="d-flex justify-content-center align-items-center p-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsLoading { get; set; } = true;
}
