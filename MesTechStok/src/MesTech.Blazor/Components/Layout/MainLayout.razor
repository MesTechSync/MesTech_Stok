@inherits LayoutComponentBase
@inject MesTech.Blazor.Services.JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Environment

<a class="visually-hidden-focusable" href="#main-content">Ana icerige atla</a>

<div class="d-flex" style="min-height: 100vh;">
  <!-- Sidebar overlay for mobile -->
  <div class="sidebar-overlay @(sidebarOpen ? "show" : "")" @onclick="CloseSidebar"></div>

  <aside class="@(sidebarOpen ? "show" : "")" role="navigation" aria-label="Ana navigasyon">
    <NavMenu />
  </aside>

  <main class="flex-grow-1 bg-light" role="main" style="overflow-y: auto;">
    <header class="top-bar d-flex align-items-center justify-content-between px-3 px-md-4 py-2 bg-white border-bottom" role="banner">
      <div class="d-flex align-items-center">
        <button class="btn btn-sm btn-outline-secondary d-md-none me-2" @onclick="ToggleSidebar" aria-label="Menu ac/kapat">
          <i class="fas fa-bars"></i>
        </button>
        <h5 class="mb-0 text-muted d-none d-sm-block">MesTech Kurumsal Yonetim</h5>
        <h6 class="mb-0 text-muted d-sm-none">MesTech</h6>
      </div>
      <div class="d-flex align-items-center gap-2 gap-md-3">
        <span class="badge text-dark d-none d-sm-inline-block" style="background-color: rgba(40,85,172,0.1); color: #2855AC !important;">
          <i class="fas fa-rocket me-1"></i> Dalga 11
        </span>
        <div class="d-flex align-items-center">
          <div class="rounded-circle d-flex align-items-center justify-content-center me-2"
               style="width: 32px; height: 32px; background-color: #2855AC;">
            <i class="fas fa-user text-white" style="font-size: 0.75rem;"></i>
          </div>
          <div class="d-none d-sm-flex flex-column lh-sm">
            <small class="fw-semibold">@GetUsername()</small>
            <small class="text-muted" style="font-size: 0.7rem;">Yonetici</small>
          </div>
        </div>
        <NotificationBell />
        <LanguageSelector />
        <ThemeToggle />
        <button class="btn btn-outline-secondary btn-sm" title="Cikis Yap" aria-label="Cikis Yap" @onclick="HandleLogout">
          <i class="fas fa-sign-out-alt"></i>
        </button>
      </div>
    </header>
    <div id="main-content" class="p-2 p-md-4">
      <ErrorBoundary @ref="errorBoundary">
        <ChildContent>
          @Body
        </ChildContent>
        <ErrorContent Context="ex">
          <div class="container py-5">
            <div class="row justify-content-center">
              <div class="col-md-8 col-lg-6">
                <div class="card border-danger shadow-sm">
                  <div class="card-body text-center p-4 p-md-5">
                    <div class="mb-3">
                      <i class="fas fa-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="card-title text-danger mb-3">Beklenmeyen Bir Hata Olustu</h4>
                    <p class="text-muted mb-4">
                      Sayfa yuklenirken bir sorun meydana geldi. Lutfen sayfayi yenilemeyi deneyin veya ana sayfaya donun.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                      <button class="btn btn-danger" @onclick="RecoverError">
                        <i class="fas fa-redo me-2"></i>Sayfayi Yenile
                      </button>
                      <button class="btn btn-outline-secondary" @onclick="GoHome">
                        <i class="fas fa-home me-2"></i>Ana Sayfa
                      </button>
                    </div>
                    @if (IsDevelopment)
                    {
                      <div class="mt-4 text-start">
                        <hr />
                        <details>
                          <summary class="text-muted fw-semibold mb-2" style="cursor: pointer;">
                            <i class="fas fa-bug me-1"></i> Hata Detaylari (Gelistirici)
                          </summary>
                          <div class="bg-dark text-light rounded p-3 mt-2" style="font-size: 0.8rem; max-height: 300px; overflow-y: auto;">
                            <p class="mb-1"><strong>Hata:</strong> @ex.Message</p>
                            @if (ex.InnerException != null)
                            {
                              <p class="mb-1"><strong>Ic Hata:</strong> @ex.InnerException.Message</p>
                            }
                            <p class="mb-0"><strong>Stack Trace:</strong></p>
                            <pre class="text-warning mb-0" style="white-space: pre-wrap; word-break: break-all;">@ex.StackTrace</pre>
                          </div>
                        </details>
                      </div>
                    }
                  </div>
                </div>
              </div>
            </div>
          </div>
        </ErrorContent>
      </ErrorBoundary>
    </div>
  </main>
</div>

<!-- KVKK Cookie Consent Banner -->
<CookieConsent />

<!-- Mobile floating sidebar toggle -->
<button class="sidebar-toggle d-md-none" @onclick="ToggleSidebar" title="Menu" aria-label="Menu ac/kapat">
  <i class="fas @(sidebarOpen ? "fa-times" : "fa-bars")"></i>
</button>

@code {
  private ErrorBoundary? errorBoundary;
  private bool sidebarOpen;
  private bool IsDevelopment => Environment.IsDevelopment();

  private void ToggleSidebar() => sidebarOpen = !sidebarOpen;
  private void CloseSidebar() => sidebarOpen = false;

  private void RecoverError() => errorBoundary?.Recover();

  private void GoHome()
  {
    errorBoundary?.Recover();
    Navigation.NavigateTo("/", forceLoad: false);
  }

  private void HandleLogout()
  {
    // Clear JWT auth state
    AuthStateProvider.MarkUserAsLoggedOut();
    // Clear legacy AuthTokenStore for backward compatibility
    MesTech.Blazor.Components.Pages.Auth.Login.AuthTokenStore.Token = null;
    MesTech.Blazor.Components.Pages.Auth.Login.AuthTokenStore.Username = null;
    Navigation.NavigateTo("/login", forceLoad: false);
  }

  private string GetUsername()
  {
    // Prefer JwtAuthenticationStateProvider, fall back to legacy AuthTokenStore
    if (AuthStateProvider.IsAuthenticated)
    {
      return AuthStateProvider.Username ?? "Kullanici";
    }
    if (MesTech.Blazor.Components.Pages.Auth.Login.AuthTokenStore.IsAuthenticated)
    {
      return MesTech.Blazor.Components.Pages.Auth.Login.AuthTokenStore.Username ?? "Kullanici";
    }
    return "Demo Kullanici";
  }
}
