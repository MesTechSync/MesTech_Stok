@page "/raporlar"
@attribute [Authorize]
@inject MesTechApiClient ApiClient

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-warning" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@errorMessage
    </div>
}
else
{
    <div class="d-flex align-items-center mb-4">
      <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
           style="width: 48px; height: 48px; background-color: #2855AC;">
        <i class="fas fa-chart-bar text-white"></i>
      </div>
      <div>
        <h3 class="mb-0" style="color: #2855AC;">Raporlar</h3>
        <small class="text-muted">Detayli analiz ve raporlama merkezi</small>
      </div>
    </div>

    <!-- Report Categories -->
    <div class="row g-3 mb-4">
      @foreach (var r in reportCategories)
      {
        <div class="col-md-4">
          <div class="card shadow-sm h-100 stat-card">
            <div class="card-body">
              <div class="d-flex align-items-center mb-3">
                <div class="stat-icon @r.BgClass @r.TextClass">
                  <i class="@r.Icon"></i>
                </div>
                <h6 class="ms-3 mb-0 fw-semibold">@r.Name</h6>
              </div>
              <p class="text-muted small mb-0">@r.Description</p>
            </div>
          </div>
        </div>
      }
    </div>

    <div class="alert alert-secondary" role="alert">
      <i class="fas fa-clock me-2"></i>
      <strong>Dalga 11:</strong> Bu sayfa Dalga 11'de tamamlanacak. Excel/PDF export,
      zamanlayici raporlar, grafik gorunumleri ve e-posta gonderim eklenecek.
    </div>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;

    private record ReportCategory(string Name, string Description, string Icon, string BgClass, string TextClass);

    private List<ReportCategory> reportCategories =
    [
        new("Satis Raporu", "Platform bazli satis ozeti, siparis adetleri ve ciro analizi",
            "fas fa-shopping-cart", "bg-success bg-opacity-10", "text-success"),
        new("Kar / Zarar", "Aylik ve yillik gelir-gider karsilastirmasi, net kar trendi",
            "fas fa-chart-line", "bg-primary bg-opacity-10", "text-primary"),
        new("Stok Raporu", "Stok durumu, kritik seviye uyarilari, hareket ozeti",
            "fas fa-boxes-stacked", "bg-warning bg-opacity-10", "text-warning"),
        new("CRM Raporu", "Lead donusum oranlari, pipeline analizi, musteri segmentasyonu",
            "fas fa-users", "bg-info bg-opacity-10", "text-info"),
        new("Platform Performans", "Platform bazli siparis, iade ve komisyon karsilastirmasi",
            "fas fa-globe", "bg-danger bg-opacity-10", "text-danger"),
        new("Finans Raporu", "Nakit akisi, banka mutabakat, vergi hesaplamalari",
            "fas fa-coins", "bg-secondary bg-opacity-10", "text-secondary"),
    ];

    private bool _isDemoMode;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await ApiClient.SafeGetAsync<object>("reports/financial");
            if (result.IsSuccess) { }
            else { _isDemoMode = true; }
        }
        catch (Exception ex)
        {
            errorMessage = $"Veri yuklenirken hata: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
