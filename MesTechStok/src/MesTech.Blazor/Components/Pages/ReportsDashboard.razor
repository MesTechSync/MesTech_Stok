@page "/raporlar"
@attribute [Authorize]
@inject MesTechApiClient ApiClient

<PageTitle>MesTech - Raporlar</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger d-flex align-items-center justify-content-between" role="alert">
        <span><i class="fas fa-exclamation-triangle me-2"></i>@errorMessage</span>
        <button class="btn btn-sm btn-outline-danger" @onclick="OnInitializedAsync">
            <i class="fas fa-sync-alt me-1"></i>Tekrar Dene
        </button>
    </div>
}
else
{
    <div class="d-flex align-items-center mb-4">
      <div class="rounded-circle d-flex align-items-center justify-content-center me-3" >
        <i class="fas fa-chart-bar text-white"></i>
      </div>
      <div>
        <h3 class="mb-0" >Raporlar</h3>
        <small class="text-muted">Detayli analiz ve raporlama merkezi</small>
      </div>
    </div>

    <!-- Report Categories -->
    <div class="row g-3 mb-4">
      @foreach (var r in reportCategories)
      {
        <div class="col-md-4">
          <a href="@r.Link" class="text-decoration-none">
            <div class="card shadow-sm h-100 stat-card" style="cursor: pointer; transition: transform 0.15s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">
              <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                  <div class="stat-icon @r.BgClass @r.TextClass">
                    <i class="@r.Icon"></i>
                  </div>
                  <h6 class="ms-3 mb-0 fw-semibold">@r.Name</h6>
                </div>
                <p class="text-muted small mb-2">@r.Description</p>
                <span class="badge @r.BgClass @r.TextClass">@r.ReportCount rapor</span>
              </div>
            </div>
          </a>
        </div>
      }
    </div>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;

    private record ReportCategory(string Name, string Description, string Icon, string BgClass, string TextClass, string Link, int ReportCount);

    private List<ReportCategory> reportCategories =
    [
        new("Satis Raporu", "Platform bazli satis ozeti, siparis adetleri ve ciro analizi",
            "fas fa-shopping-cart", "bg-success bg-opacity-10", "text-success", "/raporlar/satis", 4),
        new("Kar / Zarar", "Aylik ve yillik gelir-gider karsilastirmasi, net kar trendi",
            "fas fa-chart-line", "bg-primary bg-opacity-10", "text-primary", "/raporlar/kar-zarar", 3),
        new("Stok Raporu", "Stok durumu, kritik seviye uyarilari, hareket ozeti",
            "fas fa-boxes-stacked", "bg-warning bg-opacity-10", "text-warning", "/raporlar/stok", 5),
        new("CRM Raporu", "Lead donusum oranlari, pipeline analizi, musteri segmentasyonu",
            "fas fa-users", "bg-info bg-opacity-10", "text-info", "/crm/dashboard", 3),
        new("Platform Performans", "Platform bazli siparis, iade ve komisyon karsilastirmasi",
            "fas fa-globe", "bg-danger bg-opacity-10", "text-danger", "/raporlar/platform", 4),
        new("Finans Raporu", "Nakit akisi, banka mutabakat, vergi hesaplamalari",
            "fas fa-coins", "bg-secondary bg-opacity-10", "text-secondary", "/raporlar/finans", 6),
    ];

    private bool _isDemoMode;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await ApiClient.SafeGetAsync<object>("reports/financial");
            if (result.IsSuccess) { }
            else { _isDemoMode = true; }
        }
        catch (Exception ex)
        {
            errorMessage = $"Veri yuklenirken hata: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
