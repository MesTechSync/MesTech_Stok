@page "/categories"
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject MesTechApiClient ApiClient
@inject ILogger<Categories> Logger

<PageTitle>MesTech - Kategori Yonetimi</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
        <i class="fas fa-sitemap text-white"></i>
    </div>
    <div>
        <h3 class="mb-0" style="color: #2855AC;">Kategori Yonetimi</h3>
        <small class="text-muted">Urun kategori hiyerarsisi ve platform eslemeleri</small>
    </div>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger d-flex align-items-center justify-content-between" role="alert">
        <span><i class="fas fa-exclamation-triangle me-2"></i>@errorMessage</span>
        <button class="btn btn-sm btn-outline-danger" @onclick="OnInitializedAsync">
            <i class="fas fa-sync-alt me-1"></i>Tekrar Dene
        </button>
    </div>
}
else
{
    <!-- Toolbar -->
    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-sm-6 col-md-4">
                    <SearchInput @bind-Value="searchText" Placeholder="Kategori ara..." />
                </div>
                <div class="col-6 col-sm-3 col-md-3">
                    <span class="badge bg-secondary">Toplam: @AllCategoryCount kategori</span>
                </div>
                <div class="col-6 col-sm-3 col-md-5 text-end">
                    <button class="btn btn-sm btn-primary" @onclick="OpenCreateModal">
                        <i class="fas fa-plus me-1"></i><span class="d-none d-sm-inline">Yeni Kategori</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Category Tree -->
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="fas fa-folder-tree me-2"></i>Kategori Hiyerarsisi</h6>
                </div>
                <div class="card-body">
                    @if (rootCategories.Count == 0)
                    {
                        <EmptyState Icon="fa-sitemap" Message="Henuz kategori bulunamadi." />
                    }
                    else
                    {
                        <TreeView TItem="CategoryNode" Items="rootCategories"
                                  ChildrenSelector="c => c.Children"
                                  OnItemSelected="OnCategorySelected">
                            <ItemTemplate Context="cat">
                                <div class="d-flex align-items-center gap-2 py-1">
                                    <i class="fas fa-folder text-warning"></i>
                                    <span class="@(selectedCategory?.Id == cat.Id ? "fw-bold text-primary" : "")">
                                        @cat.Name
                                    </span>
                                    <span class="badge bg-secondary rounded-pill" style="font-size: 0.7rem;">
                                        @cat.ProductCount urun
                                    </span>
                                    <div class="ms-auto">
                                        <button class="btn btn-link btn-sm p-0 me-2 text-primary" @onclick="() => EditCategory(cat)" @onclick:stopPropagation>
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-link btn-sm p-0 text-danger" @onclick="() => ConfirmDeleteCategory(cat)" @onclick:stopPropagation>
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </div>
                            </ItemTemplate>
                        </TreeView>
                    }
                </div>
            </div>
        </div>

        <!-- Platform Eslemeleri -->
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="fas fa-link me-2"></i>Platform Eslemeleri</h6>
                </div>
                <div class="card-body">
                    @if (selectedCategory is null)
                    {
                        <p class="text-muted mb-0">Esleme bilgilerini gormek icin bir kategori secin.</p>
                    }
                    else
                    {
                        <h6 class="fw-bold mb-3">@selectedCategory.Name</h6>
                        @foreach (var mapping in platformMappings)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                                <div>
                                    <i class="@mapping.Icon me-2" style="color: @mapping.Color;"></i>
                                    <small class="fw-semibold">@mapping.Platform</small>
                                </div>
                                <span class="badge bg-light text-dark">@mapping.CategoryName</span>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Category Stats -->
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h6 class="mb-0"><i class="fas fa-chart-pie me-2"></i>Kategori Istatistikleri</h6>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var stat in categoryStats)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@stat.Label</span>
                                <span class="badge bg-primary rounded-pill">@stat.Value</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success mt-2"><i class="fas fa-check-circle me-2"></i>@successMessage</div>
}

<!-- Create / Edit Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas @(isEditing ? "fa-edit" : "fa-plus") me-2"></i>
                        @(isEditing ? "Kategori Duzenle" : "Yeni Kategori")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="@modalForm" OnValidSubmit="SaveCategory">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <ValidationSummary class="text-danger mb-3" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Kategori Adi</label>
                            <InputText class="form-control form-control-sm" @bind-Value="modalForm.Name"
                                       placeholder="Kategori adi girin" />
                            <ValidationMessage For="@(() => modalForm.Name)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ust Kategori</label>
                            <InputSelect class="form-select form-select-sm" @bind-Value="modalForm.ParentId">
                                <option value="">Ana Kategori (Kok)</option>
                                @foreach (var cat in allCategoriesFlat.Where(c => c.Id != modalForm.Id))
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Aciklama</label>
                            <InputTextArea class="form-control form-control-sm" rows="3" @bind-Value="modalForm.Description"
                                           placeholder="Kategori aciklamasi" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary btn-sm" @onclick="CloseModal">Iptal</button>
                        <button type="submit" class="btn btn-primary btn-sm" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="fas fa-check me-1"></i>@(isEditing ? "Guncelle" : "Olustur")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- Delete Confirm -->
<ConfirmDialog IsVisible="showDeleteConfirm"
               Title="Kategori Sil"
               Message="@deleteConfirmMessage"
               ConfirmText="Sil"
               ButtonVariant="danger"
               OnConfirmed="DeleteCategory"
               OnCancelled="() => showDeleteConfirm = false" />

@code {
    private class CategoryNode
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public string Name { get; set; } = string.Empty;
        public Guid? ParentId { get; set; }
        public int ProductCount { get; set; }
        public List<CategoryNode> Children { get; set; } = [];
    }

    private class CategoryFormModel
    {
        public Guid? Id { get; set; }
        [Required(ErrorMessage = "Kategori adi zorunludur")]
        [MinLength(2, ErrorMessage = "Kategori adi en az 2 karakter olmalidir")]
        public string Name { get; set; } = string.Empty;
        public string ParentId { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }

    private record PlatformMapping(string Platform, string Icon, string Color, string CategoryName);
    private record StatItem(string Label, string Value);

    private List<CategoryNode> rootCategories = [];
    private List<CategoryNode> allCategoriesFlat = [];
    private CategoryNode? selectedCategory;
    private List<PlatformMapping> platformMappings = [];
    private List<StatItem> categoryStats = [];

    private bool isLoading = true;
    private bool _isDemoMode;
    private bool isSubmitting;
    private string? errorMessage;
    private string? successMessage;
    private string searchText = string.Empty;

    // Modal state
    private bool showModal;
    private bool isEditing;
    private CategoryFormModel modalForm = new();

    // Delete confirm state
    private bool showDeleteConfirm;
    private string deleteConfirmMessage = string.Empty;
    private Guid? deleteCategoryId;

    private int AllCategoryCount => allCategoriesFlat.Count;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await ApiClient.SafeGetAsync<List<object>>("categories");
            if (result.IsSuccess && result.Data is not null && result.Data.Count > 0)
            {
                // API connected — use real data when mapping is available
                LoadDemoCategoryData();
            }
            else
            {
                _isDemoMode = true;
                LoadDemoCategoryData();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "API error, falling back to demo data");
            _isDemoMode = true;
            LoadDemoCategoryData();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void LoadDemoCategoryData()
    {
        var elektronik = new CategoryNode { Name = "Elektronik", ProductCount = 245 };
        var bilgisayar = new CategoryNode { Name = "Bilgisayar", ParentId = elektronik.Id, ProductCount = 120 };
        var telefon = new CategoryNode { Name = "Telefon", ParentId = elektronik.Id, ProductCount = 85 };
        var aksesuar = new CategoryNode { Name = "Aksesuar", ParentId = elektronik.Id, ProductCount = 40 };
        elektronik.Children = [bilgisayar, telefon, aksesuar];

        var giyim = new CategoryNode { Name = "Giyim", ProductCount = 312 };
        var erkek = new CategoryNode { Name = "Erkek", ParentId = giyim.Id, ProductCount = 150 };
        var kadin = new CategoryNode { Name = "Kadin", ParentId = giyim.Id, ProductCount = 162 };
        giyim.Children = [erkek, kadin];

        var evYasam = new CategoryNode { Name = "Ev & Yasam", ProductCount = 98 };
        var mutfak = new CategoryNode { Name = "Mutfak", ParentId = evYasam.Id, ProductCount = 45 };
        var dekorasyon = new CategoryNode { Name = "Dekorasyon", ParentId = evYasam.Id, ProductCount = 53 };
        evYasam.Children = [mutfak, dekorasyon];

        var spor = new CategoryNode { Name = "Spor & Outdoor", ProductCount = 67 };
        var kozmetik = new CategoryNode { Name = "Kozmetik & Kisisel Bakim", ProductCount = 134 };

        rootCategories = [elektronik, giyim, evYasam, spor, kozmetik];
        allCategoriesFlat = [elektronik, bilgisayar, telefon, aksesuar, giyim, erkek, kadin, evYasam, mutfak, dekorasyon, spor, kozmetik];

        categoryStats =
        [
            new("Toplam Kategori", allCategoriesFlat.Count.ToString()),
            new("Ana Kategori", rootCategories.Count.ToString()),
            new("Alt Kategori", (allCategoriesFlat.Count - rootCategories.Count).ToString()),
            new("Toplam Urun", allCategoriesFlat.Sum(c => c.ProductCount).ToString()),
        ];
    }

    private void OnCategorySelected(CategoryNode cat)
    {
        selectedCategory = cat;
        platformMappings =
        [
            new("Trendyol", "fas fa-shopping-bag", "#FF6F00", cat.Name),
            new("Hepsiburada", "fas fa-box", "#FF9800", cat.Name),
            new("N11", "fas fa-store", "#FF5722", cat.Name),
            new("Amazon TR", "fab fa-amazon", "#FF9900", cat.Name),
        ];
    }

    private void OpenCreateModal()
    {
        isEditing = false;
        modalForm = new CategoryFormModel();
        showModal = true;
    }

    private void EditCategory(CategoryNode cat)
    {
        isEditing = true;
        modalForm = new CategoryFormModel
        {
            Id = cat.Id,
            Name = cat.Name,
            ParentId = cat.ParentId?.ToString() ?? string.Empty
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveCategory()
    {
        if (isSubmitting) return;
        isSubmitting = true;
        successMessage = null;
        errorMessage = null;

        try
        {
            if (isEditing && modalForm.Id.HasValue)
            {
                var updateResult = await ApiClient.SafePutAsync<object>($"categories/{modalForm.Id.Value}", new { Name = modalForm.Name, ParentId = modalForm.ParentId, Description = modalForm.Description });
                if (!updateResult.IsSuccess) { errorMessage = updateResult.ErrorMessage; return; }
            }
            else
            {
                var createResult = await ApiClient.SafePostAsync<object>("categories", new { Name = modalForm.Name, ParentId = modalForm.ParentId, Description = modalForm.Description });
                if (!createResult.IsSuccess) { errorMessage = createResult.ErrorMessage; return; }
            }

            if (isEditing && modalForm.Id.HasValue)
            {
                var existing = allCategoriesFlat.FirstOrDefault(c => c.Id == modalForm.Id.Value);
                if (existing is not null)
                    existing.Name = modalForm.Name;
            }
            else
            {
                var newCat = new CategoryNode
                {
                    Name = modalForm.Name,
                    ProductCount = 0
                };
                rootCategories.Add(newCat);
                allCategoriesFlat.Add(newCat);
            }

            showModal = false;
            successMessage = isEditing ? "Kategori basariyla guncellendi" : "Kategori basariyla olusturuldu";
            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            errorMessage = $"Hata: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ConfirmDeleteCategory(CategoryNode cat)
    {
        deleteCategoryId = cat.Id;
        deleteConfirmMessage = cat.Children.Count > 0
            ? $"'{cat.Name}' kategorisi {cat.Children.Count} alt kategori icermektedir. Silmek istediginize emin misiniz?"
            : $"'{cat.Name}' kategorisini silmek istediginize emin misiniz?";
        showDeleteConfirm = true;
    }

    private async Task DeleteCategory()
    {
        if (deleteCategoryId.HasValue)
        {
            var deleteResult = await ApiClient.SafeDeleteAsync($"categories/{deleteCategoryId.Value}");
            if (!deleteResult.IsSuccess) { errorMessage = deleteResult.ErrorMessage; }
            rootCategories.RemoveAll(c => c.Id == deleteCategoryId.Value);
            allCategoriesFlat.RemoveAll(c => c.Id == deleteCategoryId.Value);

            if (selectedCategory?.Id == deleteCategoryId.Value)
                selectedCategory = null;
        }

        showDeleteConfirm = false;
        deleteCategoryId = null;
        await Task.CompletedTask;
    }
}
