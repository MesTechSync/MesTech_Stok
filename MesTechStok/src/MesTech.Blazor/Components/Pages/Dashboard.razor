  private static string FormatCurrency(decimal amount)
  {
    return amount >= 1_000_000
      ? $"{amount / 1_000_000:N1}M TL"
      : amount >= 1_000
        ? $"{amount / 1_000:N1}K TL"
        : $"{amount:N0} TL";
  }

  private static string GetOrderStatusBadge(string status) => status switch
  {
    "Yeni" => "bg-primary",
    "Hazirlaniyor" => "bg-warning text-dark",
    "Kargoda" => "bg-info",
    "Teslim Edildi" => "bg-success",
    "Iptal" => "bg-danger",
    _ => "bg-secondary"
  };

  private static string GetStockAlertColor(int current, int minimum)
  {
    var ratio = (double)current / Math.Max(minimum, 1);
    return ratio switch
    {
      <= 0.25 => "var(--mestech-danger)",  // critical — red
      <= 0.50 => "var(--mestech-orange)",  // warning — orange
      _ => "#ffc107"         // caution — yellow
    };
  }

