@page "/dashboard"
@attribute [Authorize]
@using MediatR
@using MesTech.Application.Features.Finance.Queries.GetProfitLoss
@using MesTech.Application.DTOs.Finance
@using MesTech.Domain.Interfaces
@using MesTech.Domain.Enums
@inject IMediator Mediator
@inject ICrmLeadRepository LeadRepository
@inject ICurrentUserService CurrentUser

<h3 class="mb-4">
  <i class="fas fa-tachometer-alt me-2" style="color: #2855AC;"></i>Dashboard
</h3>

<!-- Summary Cards -->
<div class="row g-3 g-md-4 mb-4">
  <div class="col-6 col-md-3">
    <div class="card stat-card shadow-sm border-start border-4 border-success">
      <div class="card-body p-2 p-md-3">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-success bg-opacity-10 text-success d-none d-sm-flex">
            <i class="fas fa-coins"></i>
          </div>
          <div class="ms-0 ms-sm-3">
            <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Bu Ay Gelir</small>
            @if (isLoading)
            {
              <div class="placeholder-glow"><span class="placeholder col-8"></span></div>
            }
            else
            {
              <h4 class="mb-0 fw-bold text-success fs-6 fs-md-4">@monthlyRevenue.ToString("N0") TL</h4>
            }
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card shadow-sm border-start border-4" style="border-color: #2855AC !important;">
      <div class="card-body p-2 p-md-3">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-opacity-10 d-none d-sm-flex" style="background-color: rgba(40,85,172,0.1); color: #2855AC;">
            <i class="fas fa-handshake"></i>
          </div>
          <div class="ms-0 ms-sm-3">
            <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Acik Firsatlar</small>
            @if (isLoading)
            {
              <div class="placeholder-glow"><span class="placeholder col-4"></span></div>
            }
            else
            {
              <h4 class="mb-0 fw-bold fs-6 fs-md-4" style="color: #2855AC;">@openOpportunities</h4>
            }
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card shadow-sm border-start border-4 border-info">
      <div class="card-body p-2 p-md-3">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-info bg-opacity-10 text-info d-none d-sm-flex">
            <i class="fas fa-user-plus"></i>
          </div>
          <div class="ms-0 ms-sm-3">
            <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Yeni Leadler</small>
            @if (isLoading)
            {
              <div class="placeholder-glow"><span class="placeholder col-4"></span></div>
            }
            else
            {
              <h4 class="mb-0 fw-bold text-info fs-6 fs-md-4">@newLeads</h4>
            }
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card shadow-sm border-start border-4 border-danger">
      <div class="card-body p-2 p-md-3">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-danger bg-opacity-10 text-danger d-none d-sm-flex">
            <i class="fas fa-file-invoice-dollar"></i>
          </div>
          <div class="ms-0 ms-sm-3">
            <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Bekleyen Gider</small>
            @if (isLoading)
            {
              <div class="placeholder-glow"><span class="placeholder col-8"></span></div>
            }
            else
            {
              <h4 class="mb-0 fw-bold text-danger fs-6 fs-md-4">@pendingExpenses.ToString("N0") TL</h4>
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 g-md-4">
  <!-- Platform Status -->
  <div class="col-12 col-lg-7">
    <div class="card shadow-sm h-100">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0"><i class="fas fa-store me-2" style="color: #2855AC;"></i>Platform Durumu</h6>
        <span class="badge bg-secondary">@platforms.Count Platform</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Platform</th>
                <th class="text-center">Durum</th>
                <th class="text-end d-none d-sm-table-cell">Urun</th>
                <th class="text-end d-none d-sm-table-cell">Siparis/Ay</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var p in platforms)
              {
                <tr>
                  <td>
                    <i class="@p.Icon me-2" style="color: @p.Color; width: 18px; text-align: center;"></i>
                    <span class="fw-semibold">@p.Name</span>
                  </td>
                  <td class="text-center">
                    <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")">
                      @(p.IsActive ? "TAM" : "PASIF")
                    </span>
                  </td>
                  <td class="text-end d-none d-sm-table-cell">@p.ProductCount.ToString("N0")</td>
                  <td class="text-end d-none d-sm-table-cell">@p.MonthlyOrders.ToString("N0")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Links -->
  <div class="col-12 col-lg-5">
    <div class="card shadow-sm h-100">
      <div class="card-header bg-white">
        <h6 class="mb-0"><i class="fas fa-bolt me-2 text-warning"></i>Hizli Erisim</h6>
      </div>
      <div class="card-body">
        <div class="list-group list-group-flush">
          <a href="crm/leads" class="list-group-item list-group-item-action d-flex align-items-center px-0 border-0">
            <div class="stat-icon bg-primary bg-opacity-10 text-primary me-3" style="width: 36px; height: 36px; font-size: 0.9rem;">
              <i class="fas fa-user-plus"></i>
            </div>
            <div>
              <span class="fw-semibold">CRM Leadler</span>
              <br /><small class="text-muted">Lead yonetimi ve takibi</small>
            </div>
          </a>
          <a href="finans/kar-zarar" class="list-group-item list-group-item-action d-flex align-items-center px-0 border-0">
            <div class="stat-icon bg-success bg-opacity-10 text-success me-3" style="width: 36px; height: 36px; font-size: 0.9rem;">
              <i class="fas fa-chart-line"></i>
            </div>
            <div>
              <span class="fw-semibold">Kar / Zarar</span>
              <br /><small class="text-muted">Aylik gelir-gider raporu</small>
            </div>
          </a>
          <a href="stok" class="list-group-item list-group-item-action d-flex align-items-center px-0 border-0">
            <div class="stat-icon bg-warning bg-opacity-10 text-warning me-3" style="width: 36px; height: 36px; font-size: 0.9rem;">
              <i class="fas fa-boxes-stacked"></i>
            </div>
            <div>
              <span class="fw-semibold">Stok Yonetimi</span>
              <br /><small class="text-muted">Urun ve depo takibi</small>
            </div>
          </a>
          <a href="siparisler" class="list-group-item list-group-item-action d-flex align-items-center px-0 border-0">
            <div class="stat-icon bg-info bg-opacity-10 text-info me-3" style="width: 36px; height: 36px; font-size: 0.9rem;">
              <i class="fas fa-shopping-cart"></i>
            </div>
            <div>
              <span class="fw-semibold">Siparisler</span>
              <br /><small class="text-muted">Tum platform siparisleri</small>
            </div>
          </a>
          <a href="pazaryerleri" class="list-group-item list-group-item-action d-flex align-items-center px-0 border-0">
            <div class="stat-icon bg-danger bg-opacity-10 text-danger me-3" style="width: 36px; height: 36px; font-size: 0.9rem;">
              <i class="fas fa-globe"></i>
            </div>
            <div>
              <span class="fw-semibold">Pazaryerleri</span>
              <br /><small class="text-muted">10 platform entegrasyonu</small>
            </div>
          </a>
          <a href="raporlar" class="list-group-item list-group-item-action d-flex align-items-center px-0 border-0">
            <div class="stat-icon bg-secondary bg-opacity-10 text-secondary me-3" style="width: 36px; height: 36px; font-size: 0.9rem;">
              <i class="fas fa-file-alt"></i>
            </div>
            <div>
              <span class="fw-semibold">Raporlar</span>
              <br /><small class="text-muted">Detayli analiz ve raporlama</small>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
  <div class="alert alert-warning mt-4" role="alert">
    <i class="fas fa-exclamation-triangle me-2"></i>@errorMessage
  </div>
}

<div class="alert alert-info mt-4" role="alert">
  <i class="fas fa-info-circle me-2"></i>
  <strong>Dalga 10:</strong> Dashboard verileri Domain + Application katmanindan MediatR ile cekilir.
  WPF ile ayni CQRS pipeline paylasilir.
</div>

@code {
  private bool isLoading = true;
  private string? errorMessage;

  // Summary card values
  private decimal monthlyRevenue;
  private int openOpportunities;
  private int newLeads;
  private decimal pendingExpenses;

  // Platform status list
  private List<PlatformStatus> platforms = [];

  protected override async Task OnInitializedAsync()
  {
    await LoadDashboardData();
    LoadPlatformStatuses();
  }

  private async Task LoadDashboardData()
  {
    isLoading = true;
    try
    {
      // GetProfitLossQuery — same query as ProfitLoss.razor and WPF
      var now = DateTime.Today;
      var plData = await Mediator.Send(
        new GetProfitLossQuery(CurrentUser.TenantId, now.Year, now.Month));

      monthlyRevenue = plData.TotalRevenue;
      pendingExpenses = plData.TotalExpenses;

      // GetLeadsQuery — count new leads this month
      var (leads, totalCount) = await LeadRepository.GetPagedAsync(
        CurrentUser.TenantId, LeadStatus.New, null, 1, 1000);
      newLeads = totalCount;

      // Open opportunities — qualified leads as proxy
      var (qualifiedLeads, qualifiedCount) = await LeadRepository.GetPagedAsync(
        CurrentUser.TenantId, LeadStatus.Qualified, null, 1, 1000);
      openOpportunities = qualifiedCount;
    }
    catch (Exception ex)
    {
      errorMessage = $"Dashboard verileri yuklenirken hata: {ex.Message}";
    }
    finally
    {
      isLoading = false;
    }
  }

  private void LoadPlatformStatuses()
  {
    // 10 TAM platform adapters — static display for PoC, will pull live data in Dalga 11
    platforms =
    [
      new("Trendyol", "fas fa-shopping-bag", "#FF6F00", true, 1_240, 356),
      new("OpenCart", "fas fa-cart-shopping", "#2196F3", true, 890, 124),
      new("N11", "fas fa-store", "#FF5722", true, 670, 98),
      new("Hepsiburada", "fas fa-box", "#FF9800", true, 540, 87),
      new("Amazon TR", "fab fa-amazon", "#FF9900", true, 320, 65),
      new("Pazarama", "fas fa-shop", "#4CAF50", true, 280, 42),
      new("CicekSepeti", "fas fa-seedling", "#E91E63", true, 195, 31),
      new("Bitrix24 CRM", "fas fa-users-cog", "#00BCD4", true, 0, 0),
      new("Google Merchant", "fab fa-google", "#4285F4", true, 1_240, 0),
      new("Facebook Shop", "fab fa-facebook", "#1877F2", true, 890, 0),
    ];
  }

  private record PlatformStatus(
    string Name, string Icon, string Color,
    bool IsActive, int ProductCount, int MonthlyOrders);
}
