@page "/platform/marketplaces"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject ILogger<Marketplaces> Logger

<PageTitle>MesTech - Pazaryerleri</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="container-fluid">
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
      <i class="fas fa-store-alt text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" style="color: #2855AC;">Pazaryerleri</h3>
      <small class="text-muted">Pazaryeri baglanti ve durum yonetimi</small>
    </div>
  </div>

  @if (isLoading)
  {
    <LoadingSpinner />
  }
  else if (errorMessage is not null)
  {
    <div class="alert alert-danger" role="alert">
      <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
    </div>
  }
  else
  {
    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0">
          <i class="fas fa-list me-2" style="color: #2855AC;"></i>Pazaryeri Baglantilari
        </h6>
        <span class="badge bg-secondary">@_marketplaces.Count pazaryeri</span>
      </div>
      <div class="card-body p-0">
        @if (_marketplaces.Count == 0)
        {
          <EmptyState Icon="fa-store-alt" Message="Henuz pazaryeri baglantisi bulunamadi." />
        }
        else
        {
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Pazaryeri</th>
                  <th>Durum</th>
                  <th class="text-end">Urun</th>
                  <th class="text-end">Siparis (30g)</th>
                  <th class="d-none d-md-table-cell">Son Sync</th>
                  <th class="text-center">Aksiyonlar</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var mp in _marketplaces)
                {
                  <tr>
                    <td class="fw-semibold">
                      <i class="@mp.Icon me-2" style="color: @mp.Color; width: 18px; text-align: center;"></i>
                      @mp.Name
                    </td>
                    <td>
                      @if (mp.IsConnected)
                      {
                        <span class="badge bg-success"><i class="fas fa-link me-1"></i>Bagli</span>
                      }
                      else
                      {
                        <span class="badge bg-secondary"><i class="fas fa-unlink me-1"></i>Bagli Degil</span>
                      }
                    </td>
                    <td class="text-end">@mp.ProductCount.ToString("N0")</td>
                    <td class="text-end">@mp.OrderCount.ToString("N0")</td>
                    <td class="d-none d-md-table-cell text-muted small">@mp.LastSync.ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="text-center">
                      <button class="btn btn-sm btn-outline-primary me-1" title="Sync">
                        <i class="fas fa-sync-alt"></i>
                      </button>
                      <button class="btn btn-sm btn-outline-secondary" title="Ayarlar">
                        <i class="fas fa-cog"></i>
                      </button>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
      </div>
    </div>
  }
</div>

@code {
  private bool isLoading = true;
  private bool _isDemoMode;
  private string? errorMessage;
  private List<MarketplaceRow> _marketplaces = [];

  protected override async Task OnInitializedAsync() => await LoadDataAsync();

  private async Task LoadDataAsync()
  {
    try
    {
      isLoading = true;
      errorMessage = null;
      var result = await ApiClient.SafeGetAsync<List<object>>("platform/marketplaces");
      if (result.IsSuccess && result.Data is { Count: > 0 })
      {
        _isDemoMode = false;
        _marketplaces = GetDemoData();
      }
      else
      {
        _isDemoMode = true;
        _marketplaces = GetDemoData();
      }
    }
    catch (Exception ex)
    {
      Logger.LogWarning(ex, "Pazaryeri verisi yuklenirken hata");
      _isDemoMode = true;
      _marketplaces = GetDemoData();
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private static List<MarketplaceRow> GetDemoData() =>
  [
    new() { Name = "Trendyol", Icon = "fas fa-shopping-bag", Color = "#FF6F00", IsConnected = true, ProductCount = 1820, OrderCount = 1248, LastSync = DateTime.Today.AddHours(-1) },
    new() { Name = "Hepsiburada", Icon = "fas fa-box", Color = "#FF9800", IsConnected = true, ProductCount = 1450, OrderCount = 542, LastSync = DateTime.Today.AddHours(-2) },
    new() { Name = "N11", Icon = "fas fa-store", Color = "#FF5722", IsConnected = true, ProductCount = 1200, OrderCount = 318, LastSync = DateTime.Today.AddHours(-3) },
    new() { Name = "CicekSepeti", Icon = "fas fa-seedling", Color = "#E91E63", IsConnected = true, ProductCount = 980, OrderCount = 205, LastSync = DateTime.Today.AddHours(-4) },
    new() { Name = "Amazon", Icon = "fab fa-amazon", Color = "#FF9900", IsConnected = true, ProductCount = 650, OrderCount = 156, LastSync = DateTime.Today.AddHours(-2) },
    new() { Name = "Pazarama", Icon = "fas fa-shop", Color = "#4CAF50", IsConnected = true, ProductCount = 520, OrderCount = 89, LastSync = DateTime.Today.AddHours(-5) },
    new() { Name = "eBay", Icon = "fas fa-gavel", Color = "#E53238", IsConnected = false, ProductCount = 0, OrderCount = 0, LastSync = DateTime.MinValue },
    new() { Name = "Shopify", Icon = "fab fa-shopify", Color = "#95BF47", IsConnected = false, ProductCount = 0, OrderCount = 0, LastSync = DateTime.MinValue },
  ];

  private class MarketplaceRow
  {
    public string Name { get; set; } = "";
    public string Icon { get; set; } = "fas fa-globe";
    public string Color { get; set; } = "#6c757d";
    public bool IsConnected { get; set; }
    public int ProductCount { get; set; }
    public int OrderCount { get; set; }
    public DateTime LastSync { get; set; }
  }
}
