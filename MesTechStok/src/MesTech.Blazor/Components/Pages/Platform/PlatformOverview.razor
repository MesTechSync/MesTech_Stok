@page "/platforms"
@attribute [Authorize]
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject MesTechApiClient ApiClient
@inject ILogger<PlatformOverview> Logger

<PageTitle>MesTech - Platform Genel Bakis</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
        <i class="fas fa-store text-white"></i>
    </div>
    <div>
        <h3 class="mb-0" style="color: #2855AC;">Platform Genel Bakis</h3>
        <small class="text-muted">11 platform entegrasyonunun ozet durumu</small>
    </div>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger d-flex align-items-center justify-content-between" role="alert">
        <span><i class="fas fa-exclamation-triangle me-2"></i>@errorMessage</span>
        <button class="btn btn-sm btn-outline-danger" @onclick="OnInitializedAsync">
            <i class="fas fa-sync-alt me-1"></i>Tekrar Dene
        </button>
    </div>
}
else
{
    <!-- Summary Row -->
    <div class="row g-3 mb-4">
        <KpiCard Icon="fa-store" Value="@platforms.Count.ToString()" Label="Toplam Platform" TextColor="text-primary" />
        <KpiCard Icon="fa-check-circle" Value="@platforms.Count(p => p.BaglantiDurumu).ToString()" Label="Bagli" TextColor="text-success" />
        <KpiCard Icon="fa-box" Value="@platforms.Sum(p => p.UrunSayisi).ToString("N0")" Label="Toplam Urun" TextColor="text-info" />
        <KpiCard Icon="fa-shopping-cart" Value="@platforms.Sum(p => p.SiparisSayisi).ToString("N0")" Label="Toplam Siparis" TextColor="text-warning" />
    </div>

    <!-- Platform Grid -->
    <div class="row g-3">
        @if (platforms.Count == 0 && !isLoading)

        {

            <EmptyState Icon="fa-th-large" Message="Henuz platform verisi bulunamadi." />

        }

        @foreach (var p in platforms)
        {
            <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                <div class="card shadow-sm h-100 @(p.BaglantiDurumu ? "" : "border-danger border-opacity-50")">
                    <div class="card-body">
                        <!-- Header -->
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                                 style="width: 40px; height: 40px; background-color: @(p.Color)20;">
                                <i class="@p.Icon" style="color: @p.Color;"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-0 fw-bold">@p.Name</h6>
                                <small class="text-muted">@p.Tip</small>
                            </div>
                            <div>
                                <span class="rounded-circle d-inline-block" style="width: 10px; height: 10px; background-color: @(p.BaglantiDurumu ? "#198754" : "#dc3545");"></span>
                            </div>
                        </div>

                        <!-- Stats -->
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div class="bg-light rounded p-2 text-center">
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">Urun</small>
                                    <span class="fw-bold">@p.UrunSayisi.ToString("N0")</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="bg-light rounded p-2 text-center">
                                    <small class="text-muted d-block" style="font-size: 0.7rem;">Siparis</small>
                                    <span class="fw-bold">@p.SiparisSayisi.ToString("N0")</span>
                                </div>
                            </div>
                        </div>

                        <!-- Sync Status -->
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small class="text-muted">Stok Sync:</small>
                            <StatusBadge Text="@p.StokSyncDurum" Variant="@GetSyncVariant(p.StokSyncDurum)" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">Son Sync:</small>
                            <small class="text-muted">@p.SonSync.ToString("dd.MM HH:mm")</small>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-top-0 text-center">
                        <a href="/platform-sync" class="btn btn-sm btn-outline-primary w-100">
                            <i class="fas fa-sync-alt me-1"></i>Sync Detay
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private record PlatformInfo(string Name, string Icon, string Color, string Tip,
        int UrunSayisi, int SiparisSayisi, string StokSyncDurum, bool BaglantiDurumu, DateTime SonSync);

    private List<PlatformInfo> platforms = [];
    private bool isLoading = true;
    private bool _isDemoMode;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var apiData = await ApiClient.GetPlatformOverviewAsync();
            if (apiData?.Count > 0)
            {
                _isDemoMode = false;
                try
                {
                    var json = System.Text.Json.JsonSerializer.Serialize(apiData);
                    platforms = System.Text.Json.JsonSerializer.Deserialize<List<PlatformInfo>>(json,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true })
                        ?? GetDemoPlatforms();
                }
                catch { platforms = GetDemoPlatforms(); _isDemoMode = true; }
            }
            else
            {
                _isDemoMode = true;
                platforms = GetDemoPlatforms();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "API fallback, using demo data");
            _isDemoMode = true;
            platforms = GetDemoPlatforms();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private static List<PlatformInfo> GetDemoPlatforms() =>
    [
        new("Trendyol", "fas fa-shopping-bag", "#FF6F00", "Pazaryeri", 1250, 340, "Guncel", true, DateTime.Now.AddMinutes(-15)),
        new("OpenCart", "fas fa-cart-shopping", "#2196F3", "E-Ticaret", 980, 120, "Guncel", true, DateTime.Now.AddMinutes(-30)),
        new("N11", "fas fa-store", "#FF5722", "Pazaryeri", 870, 95, "Guncel", true, DateTime.Now.AddHours(-1)),
        new("Hepsiburada", "fas fa-box", "#FF9800", "Pazaryeri", 1100, 280, "Gecikme", true, DateTime.Now.AddHours(-2)),
        new("Amazon TR", "fab fa-amazon", "#FF9900", "Pazaryeri", 560, 78, "Guncel", true, DateTime.Now.AddMinutes(-45)),
        new("Pazarama", "fas fa-shop", "#4CAF50", "Pazaryeri", 420, 35, "Bekliyor", true, DateTime.Now.AddHours(-3)),
        new("CicekSepeti", "fas fa-seedling", "#E91E63", "Pazaryeri", 310, 45, "Guncel", true, DateTime.Now.AddHours(-1)),
        new("Shopify", "fab fa-shopify", "#96BF48", "E-Ticaret", 750, 190, "Guncel", true, DateTime.Now.AddMinutes(-20)),
        new("WooCommerce", "fab fa-wordpress", "#96588A", "E-Ticaret", 630, 85, "Hata", false, DateTime.Now.AddHours(-4)),
        new("eBay", "fab fa-ebay", "#E53238", "Pazaryeri", 280, 42, "Guncel", true, DateTime.Now.AddMinutes(-50)),
        new("Bitrix24", "fas fa-users-cog", "#00BCD4", "CRM", 0, 0, "Bekliyor", true, DateTime.Now.AddHours(-6)),
    ];

    private static string GetSyncVariant(string durum) => durum switch
    {
        "Guncel" => "success",
        "Hata" => "danger",
        "Gecikme" => "warning",
        "Bekliyor" => "info",
        _ => "secondary"
    };
}
