@page "/crm/deals"
@attribute [Authorize]
@inject MesTechApiClient ApiClient

<PageTitle>MesTech - Firsatlar</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
  <div class="rounded-circle d-flex align-items-center justify-content-center me-3" >
    <i class="fas fa-handshake text-white"></i>
  </div>
  <div>
    <h3 class="mb-0" >Firsatlar (Deals)</h3>
    <small class="text-muted">Kanban gorunumu ile firsat takibi</small>
  </div>
</div>

<!-- Pipeline Summary -->
<div class="row g-2 mb-3">
  <div class="col-auto">
    <span class="badge bg-secondary">Toplam: @deals.Count firsat</span>
  </div>
  <div class="col-auto">
    <span class="badge bg-success">Pipeline: @deals.Sum(d => d.Value).ToString("N0") TL</span>
  </div>
  <div class="col-auto ms-auto">
    <button class="btn btn-sm btn-outline-primary" @onclick="LoadDataAsync">
      <i class="fas fa-sync-alt me-1"></i>Yenile
    </button>
  </div>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger d-flex align-items-center justify-content-between" role="alert">
        <span><i class="fas fa-exclamation-triangle me-2"></i>@errorMessage</span>
        <button class="btn btn-sm btn-outline-danger" @onclick="OnInitializedAsync">
            <i class="fas fa-sync-alt me-1"></i>Tekrar Dene
        </button>
    </div>
}
else if (deals.Count == 0)
{
    <EmptyState Icon="fa-handshake" Message="Henuz firsat bulunamadi." />
}
else
{
    <!-- Kanban Board -->
    <div class="row g-3 mb-4" style="overflow-x: auto; flex-wrap: nowrap;">
      @foreach (var stage in stages)
      {
        var stageDeals = deals.Where(d => d.Stage == stage.Name).ToList();
        <div class="col" style="min-width: 220px;">
          <div class="card shadow-sm h-100" style="border-top: 3px solid @stage.Color;">
            <div class="card-header bg-white py-2">
              <div class="d-flex justify-content-between align-items-center">
                <span class="fw-semibold small">@stage.Name</span>
                <span class="badge rounded-pill" style="background-color: @stage.Color;">@stageDeals.Count</span>
              </div>
              <small class="text-muted" style="font-size: 0.7rem;">
                @stageDeals.Sum(d => d.Value).ToString("N0") TL
              </small>
            </div>
            <div class="card-body p-2" style="max-height: 480px; overflow-y: auto;">
              @if (stageDeals.Count == 0)
              {
                <div class="text-center py-3">
                  <i class="fas fa-inbox text-muted"></i>
                  <br /><small class="text-muted">Firsat yok</small>
                </div>
              }
              else
              {
                @foreach (var deal in stageDeals)
                {
                  <div class="card mb-2 border-0 shadow-sm">
                    <div class="card-body p-2">
                      <div class="fw-semibold small">@deal.Title</div>
                      <div class="text-muted" style="font-size: 0.75rem;">@deal.Company</div>
                      <div class="d-flex justify-content-between align-items-center mt-1">
                        <span class="fw-bold small text-success">@deal.Value.ToString("N0") TL</span>
                        <span class="badge @GetPriorityBadgeClass(deal.Priority)" style="font-size: 0.65rem;">
                          @deal.Priority
                        </span>
                      </div>
                      <div class="text-muted mt-1" style="font-size: 0.7rem;">
                        <i class="fas fa-user me-1"></i>@deal.AssignedTo
                      </div>
                    </div>
                  </div>
                }
              }
            </div>
          </div>
        </div>
      }
    </div>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private bool _isDemoMode;

    private record KanbanStage(string Name, string Color);
    private record DealItem(string Title, string Company, string Stage, decimal Value, string Priority, string AssignedTo);

    private List<KanbanStage> stages =
    [
        new("Yeni", "var(--mestech-info)"),
        new("Iletisim", "var(--mestech-purple)"),
        new("Teklif", "var(--mestech-orange)"),
        new("Muzakere", "#ffc107"),
        new("Kazanildi", "var(--mestech-success)"),
    ];

    private List<DealItem> deals = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var result = await ApiClient.SafeGetAsync<List<DealItem>>("crm/deals");
            if (result.IsSuccess && result.Data is not null)
            {
                deals = result.Data;
            }
            else
            {
                _isDemoMode = true;
                LoadDemoDeals();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Veri yuklenirken hata: {ex.Message}";
            _isDemoMode = true;
            LoadDemoDeals();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void LoadDemoDeals()
    {
        deals =
        [
            new("Web sitesi yenileme", "TechCo A.S.", "Yeni", 45_000m, "Yuksek", "Mert K."),
            new("ERP entegrasyonu", "Mega Ticaret Ltd.", "Yeni", 120_000m, "Orta", "Selin A."),
            new("Stok modulu", "Start Up Hub", "Iletisim", 28_000m, "Dusuk", "Can D."),
            new("E-ticaret paketi", "Global Import A.S.", "Iletisim", 85_000m, "Yuksek", "Mert K."),
            new("API gelistirme", "E-Ticaret Pro", "Teklif", 35_000m, "Orta", "Selin A."),
            new("Marketplace entegrasyonu", "Moda Dunyasi", "Teklif", 65_000m, "Yuksek", "Can D."),
            new("CRM kurulumu", "Teknoloji Evi", "Teklif", 42_000m, "Orta", "Mert K."),
            new("Toplu urun aktarimi", "Perakende Plus", "Muzakere", 18_000m, "Dusuk", "Selin A."),
            new("Muhasebe modulu", "B2B Solutions", "Muzakere", 95_000m, "Yuksek", "Can D."),
            new("Dashboard projesi", "Hizli Kargo Ltd.", "Kazanildi", 55_000m, "Orta", "Mert K."),
            new("Raporlama sistemi", "Mega Ticaret Ltd.", "Kazanildi", 38_000m, "Dusuk", "Selin A."),
        ];
    }

    private static string GetPriorityBadgeClass(string priority) => priority switch
    {
        "Yuksek" => "bg-danger",
        "Orta" => "bg-warning text-dark",
        "Dusuk" => "bg-info",
        _ => "bg-secondary"
    };
}
