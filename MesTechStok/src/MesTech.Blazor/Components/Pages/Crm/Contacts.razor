@page "/crm/contacts"

<div class="d-flex align-items-center mb-4">
  <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
       style="width: 48px; height: 48px; background-color: #2855AC;">
    <i class="fas fa-address-book text-white"></i>
  </div>
  <div>
    <h3 class="mb-0" style="color: #2855AC;">Kisiler (Contacts)</h3>
    <small class="text-muted">Musteri ve tedarikci rehberi</small>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-body text-center py-5">
    <i class="fas fa-address-book fa-3x mb-3 d-block" style="color: #2855AC; opacity: 0.3;"></i>
    <h5 class="text-muted">Kisi Yonetimi</h5>
    <p class="text-muted mb-0">Musteri, tedarikci ve is ortagi kayitlari bu sayfada yonetilecek.</p>
  </div>
</div>

<div class="alert alert-secondary mt-4" role="alert">
  <i class="fas fa-clock me-2"></i>
  <strong>Dalga 11:</strong> Bu sayfa Dalga 11'de tamamlanacak. Kisi listesi, detay goruntuleme,
  iletisim gecmisi ve etiket sistemi eklenecek.
</div>
