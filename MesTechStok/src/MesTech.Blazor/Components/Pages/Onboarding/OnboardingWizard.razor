@page "/onboarding"
@attribute [Authorize]
@inject IStringLocalizer<SharedResource> L
@inject NavigationManager Nav
@inject OnboardingService OnboardingService
@inject ILogger<OnboardingWizard> Logger

<PageTitle>MesTech - Kurulum Sihirbazi</PageTitle>

<div class="container py-4" style="max-width: 720px;">

  <!-- Progress bar: Step X of 7 -->
  <div class="text-center mb-2">
    <small class="text-muted fw-semibold">@L["Onboarding.StepOf", currentStep, TotalSteps]</small>
  </div>
  <div class="progress mb-4" style="height: 8px;">
    <div class="progress-bar bg-primary"role="progressbar"
         style="width: @(currentStep * 100 / TotalSteps)%"
         aria-valuenow="@currentStep" aria-valuemin="0" aria-valuemax="@TotalSteps"></div>
  </div>

  <!-- Step indicator: numbered circles with connecting lines -->
  <div class="d-flex justify-content-between align-items-center mb-4 px-2">
    @for (int i = 1; i <= TotalSteps; i++)
    {
      var step = i;
      <div class="d-flex flex-column align-items-center" style="flex: 0 0 auto;">
        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold
                    @(step < currentStep ? "bg-success text-white" : step == currentStep ? "bg-primary text-white" : "bg-light text-muted border")"
             style="width: 36px; height: 36px; font-size: 0.85rem;">
          @if (step < currentStep)
          {
            <i class="fas fa-check"></i>
          }
          else
          {
            @step
          }
        </div>
      </div>
      @if (i < TotalSteps)
      {
        <div class="flex-grow-1 mx-1" style="height: 2px; background: @(i < currentStep ? "var(--mestech-success)" : "#dee2e6"); align-self: center; margin-top: -18px;"></div>
      }
    }
  </div>

  <!-- Step content -->
  @switch (currentStep)
  {
    case 1:
      <!-- Step 1: Hos Geldiniz — Welcome, platform overview, language selection -->
      <div class="card shadow-sm">
        <div class="card-body text-center p-5">
          <div class="mb-3">
            <i class="fas fa-hand-sparkles fa-3x text-primary"></i>
          </div>
          <h2 class="mb-3">@L["Dashboard.Welcome"]</h2>
          <p class="text-muted mb-4">@L["App.Subtitle"] &mdash; @L["Onboarding.WelcomeDescription"]</p>

          <div class="row g-3 text-start" style="max-width: 400px; margin: auto;">
            <div class="col-12">
              <label class="form-label fw-semibold">@L["Settings.Language"]</label>
              <select @bind="selectedLanguage" class="form-select">
                <option value="tr">@L["Language.Turkish"]</option>
                <option value="en">@L["Language.English"]</option>
                <option value="de">@L["Language.German"]</option>
                <option value="ar">@L["Language.Arabic"]</option>
              </select>
            </div>
          </div>

          <div class="mt-4">
            <div class="d-flex justify-content-center gap-3 flex-wrap">
              <div class="text-center px-3">
                <i class="fas fa-store fa-lg text-info mb-1"></i>
                <div class="small text-muted">@L["Nav.Platforms"]</div>
              </div>
              <div class="text-center px-3">
                <i class="fas fa-boxes-stacked fa-lg text-warning mb-1"></i>
                <div class="small text-muted">@L["Nav.Stock"]</div>
              </div>
              <div class="text-center px-3">
                <i class="fas fa-chart-line fa-lg text-success mb-1"></i>
                <div class="small text-muted">@L["Nav.Analytics"]</div>
              </div>
              <div class="text-center px-3">
                <i class="fas fa-file-invoice fa-lg text-danger mb-1"></i>
                <div class="small text-muted">@L["Nav.Invoices"]</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      break;

    case 2:
      <!-- Step 2: Sirket Bilgileri — Company name, tax number, address -->
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h3 class="mb-1"><i class="fas fa-building text-primary me-2"></i>@L["Settings.Company"]</h3>
          <p class="text-muted mb-3">@L["Onboarding.CompanyDescription"]</p>
          <div class="row g-3" style="max-width: 500px;">
            <div class="col-12">
              <label class="form-label fw-semibold">@L["Form.CompanyName"] <span class="text-danger">*</span></label>
              <input @bind="companyName" class="form-control @(step2Attempted && string.IsNullOrWhiteSpace(companyName) ? "is-invalid" : "")"
                     placeholder="@L["Form.CompanyName"]" />
              @if (step2Attempted && string.IsNullOrWhiteSpace(companyName))
              {
                <div class="invalid-feedback">@L["Error.Required"]</div>
              }
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Form.TaxId"]</label>
              <input @bind="taxId" class="form-control" placeholder="@L["Form.TaxId"]" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Form.TaxOffice"]</label>
              <input @bind="taxOffice" class="form-control" placeholder="@L["Form.TaxOffice"]" />
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">@L["Form.Address"]</label>
              <textarea @bind="companyAddress" class="form-control" rows="2" placeholder="@L["Form.Address"]"></textarea>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Form.City"]</label>
              <input @bind="city" class="form-control" placeholder="@L["Form.City"]" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Form.District"]</label>
              <input @bind="district" class="form-control" placeholder="@L["Form.District"]" />
            </div>
          </div>
        </div>
      </div>
      break;

    case 3:
      <!-- Step 3: Pazaryeri Baglantisi — Connect first marketplace -->
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h3 class="mb-1"><i class="fas fa-store text-primary me-2"></i>@L["Platform.Title"]</h3>
          <p class="text-muted mb-3">@L["Onboarding.MarketplaceDescription"]</p>
          <div class="row g-3">
            @foreach (var p in _platforms)
            {
              <div class="col-md-3 col-6">
                <div class="card text-center p-3 @(selectedPlatform == p.Name ? "border-primary border-2" : "")"
                     style="cursor: pointer;" @onclick="() => selectedPlatform = p.Name">
                  <i class="@p.Icon fa-2x mb-2" style="color: @p.Color;"></i>
                  <small class="fw-semibold">@p.Name</small>
                </div>
              </div>
            }
          </div>
          @if (!string.IsNullOrEmpty(selectedPlatform))
          {
            <div class="mt-3" style="max-width: 500px;">
              <label class="form-label fw-semibold">@L["Platform.ApiKey"]</label>
              <input @bind="apiKey" class="form-control" type="password" placeholder="@L["Platform.ApiKey"]" />
              <label class="form-label fw-semibold mt-2">@L["Platform.ApiSecret"]</label>
              <input @bind="apiSecret" class="form-control" type="password" placeholder="@L["Platform.ApiSecret"]" />
              <label class="form-label fw-semibold mt-2">@L["Platform.SellerId"]</label>
              <input @bind="sellerId" class="form-control" placeholder="@L["Platform.SellerId"]" />
            </div>
          }
        </div>
      </div>
      break;

    case 4:
      <!-- Step 4: Ilk Urun Ekleme — Add first product -->
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h3 class="mb-1"><i class="fas fa-box text-primary me-2"></i>@L["Products.AddNew"]</h3>
          <p class="text-muted mb-3">@L["Onboarding.FirstProductDescription"]</p>
          <div class="row g-3" style="max-width: 500px;">
            <div class="col-12">
              <label class="form-label fw-semibold">@L["Products.Name"]</label>
              <input @bind="productName" class="form-control" placeholder="@L["Products.Name"]" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Products.SKU"]</label>
              <input @bind="productSku" class="form-control" placeholder="@L["Products.SKU"]" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Products.Price"]</label>
              <input @bind="productPrice" class="form-control" type="number" min="0" step="0.01" placeholder="0.00" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Products.Stock"]</label>
              <input @bind="productStock" class="form-control" type="number" min="0" placeholder="0" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Products.Category"]</label>
              <select @bind="productCategory" class="form-select">
                <option value="">@L["Common.Search.All"]</option>
                <option>Elektronik</option>
                <option>Giyim</option>
                <option>Kozmetik</option>
                <option>Ev &amp; Yasam</option>
              </select>
            </div>
          </div>
        </div>
      </div>
      break;

    case 5:
      <!-- Step 5: Stok Ayarlari — Min stock threshold, alert preferences -->
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h3 class="mb-1"><i class="fas fa-boxes-stacked text-primary me-2"></i>@L["Stock.Title"]</h3>
          <p class="text-muted mb-3">@L["Onboarding.StockSettingsDescription"]</p>
          <div class="row g-3" style="max-width: 500px;">
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Stock.Minimum"]</label>
              <input @bind="minStockThreshold" class="form-control" type="number" min="0" placeholder="10" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">@L["Stock.Maximum"]</label>
              <input @bind="maxStockThreshold" class="form-control" type="number" min="0" placeholder="1000" />
            </div>
            <div class="col-12">
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" @bind="lowStockAlertEnabled" id="lowStockAlert" />
                <label class="form-check-label" for="lowStockAlert">
                  <i class="fas fa-bell text-warning me-1"></i>@L["Notification.LowStock"]
                </label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" @bind="autoReorderEnabled" id="autoReorder" />
                <label class="form-check-label" for="autoReorder">
                  <i class="fas fa-redo text-info me-1"></i>@L["Onboarding.AutoReorder"]
                </label>
              </div>
            </div>
          </div>
        </div>
      </div>
      break;

    case 6:
      <!-- Step 6: Bildirim Tercihleri — Email/SMS/Push notification settings -->
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h3 class="mb-1"><i class="fas fa-bell text-primary me-2"></i>@L["Settings.Notifications"]</h3>
          <p class="text-muted mb-3">@L["Onboarding.NotificationDescription"]</p>
          <div class="row g-3" style="max-width: 500px;">
            <div class="col-12">
              <label class="form-label fw-semibold">@L["Form.Email"]</label>
              <input @bind="notificationEmail" class="form-control" type="email" placeholder="@L["Form.Email"]" />
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">@L["Form.Phone"]</label>
              <input @bind="notificationPhone" class="form-control" type="tel" placeholder="@L["Form.Phone"]" />
            </div>
            <div class="col-12">
              <h6 class="fw-semibold mb-2">@L["Onboarding.NotificationChannels"]</h6>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" @bind="emailNotificationsEnabled" id="emailNotif" />
                <label class="form-check-label" for="emailNotif">
                  <i class="fas fa-envelope text-primary me-1"></i>@L["Onboarding.EmailNotifications"]
                </label>
              </div>
              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" @bind="smsNotificationsEnabled" id="smsNotif" />
                <label class="form-check-label" for="smsNotif">
                  <i class="fas fa-sms text-success me-1"></i>@L["Onboarding.SmsNotifications"]
                </label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" @bind="pushNotificationsEnabled" id="pushNotif" />
                <label class="form-check-label" for="pushNotif">
                  <i class="fas fa-mobile-alt text-info me-1"></i>@L["Onboarding.PushNotifications"]
                </label>
              </div>
            </div>
            <div class="col-12">
              <h6 class="fw-semibold mb-2">@L["Onboarding.NotificationTypes"]</h6>
              <div class="form-check mb-1">
                <input class="form-check-input" type="checkbox" @bind="notifyNewOrder" id="notifyOrder" />
                <label class="form-check-label" for="notifyOrder">@L["Notification.NewOrder"]</label>
              </div>
              <div class="form-check mb-1">
                <input class="form-check-input" type="checkbox" @bind="notifyLowStock" id="notifyStock" />
                <label class="form-check-label" for="notifyStock">@L["Notification.LowStock"]</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="checkbox" @bind="notifySyncComplete" id="notifySync" />
                <label class="form-check-label" for="notifySync">@L["Notification.SyncComplete"]</label>
              </div>
            </div>
          </div>
        </div>
      </div>
      break;

    case 7:
      <!-- Step 7: Tamamlandi — Success summary, quick links -->
      <div class="card shadow-sm">
        <div class="card-body text-center p-5">
          <div class="text-success mb-3">
            <i class="fas fa-check-circle fa-4x"></i>
          </div>
          <h2 class="text-success mb-3">@L["Onboarding.Completed"]</h2>
          <p class="text-muted mb-4">@L["Onboarding.CompletedDescription"]</p>

          <!-- Setup summary -->
          <div class="card bg-light mb-4" style="max-width: 500px; margin: auto;">
            <div class="card-body text-start">
              <h6 class="card-title">@L["Onboarding.SetupSummary"]</h6>
              <ul class="list-unstyled mb-0">
                <li class="mb-1">
                  <i class="fas fa-building text-primary me-2"></i>
                  @L["Form.CompanyName"]: <strong>@(string.IsNullOrEmpty(companyName) ? "—" : companyName)</strong>
                </li>
                <li class="mb-1">
                  <i class="fas fa-store text-primary me-2"></i>
                  @L["Nav.Platforms"]: <strong>@(string.IsNullOrEmpty(selectedPlatform) ? "—" : selectedPlatform)</strong>
                </li>
                <li class="mb-1">
                  <i class="fas fa-box text-primary me-2"></i>
                  @L["Products.Name"]: <strong>@(string.IsNullOrEmpty(productName) ? "—" : productName)</strong>
                </li>
                <li class="mb-1">
                  <i class="fas fa-boxes-stacked text-primary me-2"></i>
                  @L["Stock.Minimum"]: <strong>@minStockThreshold</strong>
                </li>
                <li>
                  <i class="fas fa-bell text-primary me-2"></i>
                  @L["Settings.Notifications"]: <strong>@GetNotificationSummary()</strong>
                </li>
              </ul>
            </div>
          </div>

          <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a href="/dashboard" class="btn btn-primary btn-lg">
              <i class="fas fa-tachometer-alt me-2"></i>@L["Nav.Dashboard"]
            </a>
            <a href="/stok" class="btn btn-outline-success btn-lg">
              <i class="fas fa-boxes-stacked me-2"></i>@L["Nav.Stock"]
            </a>
            <a href="/pages/academy/" class="btn btn-outline-secondary btn-lg">
              <i class="fas fa-graduation-cap me-2"></i>@L["Nav.Academy"]
            </a>
          </div>
        </div>
      </div>
      break;
  }

  <!-- Navigation buttons: Back / Skip / Next -->
  <div class="d-flex justify-content-between align-items-center mt-4">
    @if (currentStep > 1)
    {
      <button class="btn btn-outline-secondary" @onclick="PrevStep">
        <i class="fas fa-arrow-left me-1"></i> @L["Common.Button.Back"]
      </button>
    }
    else
    {
      <div></div>
    }

    <div class="d-flex gap-2">
      @if (currentStep > 1 && currentStep < TotalSteps)
      {
        <button class="btn btn-link text-muted" @onclick="SkipStep">
          @L["Onboarding.Skip"] <i class="fas fa-forward ms-1"></i>
        </button>
      }

      @if (currentStep < TotalSteps)
      {
        <button class="btn btn-primary"@onclick="NextStep"
                disabled="@(!IsCurrentStepValid())">
          @L["Common.Button.Next"] <i class="fas fa-arrow-right ms-1"></i>
        </button>
      }
      else
      {
        <button class="btn btn-success btn-lg" @onclick="CompleteOnboarding" disabled="@_isSubmitting">
          @if (_isSubmitting)
          {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
          }
          else
          {
            <i class="fas fa-check me-1"></i>
          }
          @L["Common.Button.Confirm"]
        </button>
      }
    </div>
  </div>

  @if (!string.IsNullOrEmpty(_errorMessage))
  {
    <div class="alert alert-danger mt-3 d-flex align-items-center">
      <i class="fas fa-exclamation-triangle me-2"></i>
      @_errorMessage
    </div>
  }
</div>

@code {
    // --- Wizard state ---
    private int currentStep = 1;
    private const int TotalSteps = 7;
    private bool _onboardingChecked;

    // Step 1: Welcome
    private string selectedLanguage = "tr";

    // Step 2: Company info
    private string companyName = "";
    private string taxId = "";
    private string taxOffice = "";
    private string companyAddress = "";
    private string city = "";
    private string district = "";
    private bool step2Attempted;

    // Step 3: Marketplace
    private string selectedPlatform = "";
    private string apiKey = "";
    private string apiSecret = "";
    private string sellerId = "";

    // Step 4: First product
    private string productName = "";
    private string productSku = "";
    private decimal productPrice;
    private int productStock;
    private string productCategory = "";

    // Step 5: Stock settings
    private int minStockThreshold = 10;
    private int maxStockThreshold = 1000;
    private bool lowStockAlertEnabled = true;
    private bool autoReorderEnabled;

    // Step 6: Notification preferences
    private string notificationEmail = "";
    private string notificationPhone = "";
    private bool emailNotificationsEnabled = true;
    private bool smsNotificationsEnabled;
    private bool pushNotificationsEnabled = true;
    private bool notifyNewOrder = true;
    private bool notifyLowStock = true;
    private bool notifySyncComplete;

    private readonly List<(string Name, string Icon, string Color)> _platforms = new()
    {
        ("Trendyol", "fas fa-shopping-bag", "#F27A1A"),
        ("Hepsiburada", "fas fa-shopping-cart", "var(--mestech-hepsi)"),
        ("N11", "fas fa-store", "#7B2D8E"),
        ("Ciceksepeti", "fas fa-gift", "#6DC24B"),
        ("Amazon", "fab fa-amazon", "var(--mestech-amazon)"),
        ("Pazarama", "fas fa-shopping-basket", "#1A73E8"),
        ("Shopify", "fab fa-shopify", "#96BF48"),
        ("WooCommerce", "fab fa-wordpress", "#96588A")
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Redirect to dashboard if onboarding already completed
            var completed = await OnboardingService.IsOnboardingCompletedAsync(Guid.Empty);
            if (completed)
            {
                Nav.NavigateTo("/dashboard", replace: true);
                return;
            }

            // Resume from last completed step
            var lastStep = await OnboardingService.GetLastCompletedStepAsync(Guid.Empty);
            if (lastStep > 0 && lastStep < TotalSteps)
            {
                currentStep = lastStep + 1;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Onboarding init error");
        }
        finally
        {
            _onboardingChecked = true;
        }
    }

    private bool IsCurrentStepValid()
    {
        return currentStep switch
        {
            1 => true, // Language selection always valid
            2 => !string.IsNullOrWhiteSpace(companyName),
            3 => true, // Marketplace is optional
            4 => true, // First product is optional
            5 => true, // Stock settings have defaults
            6 => true, // Notifications have defaults
            7 => true,
            _ => false
        };
    }

    private async Task NextStep()
    {
        if (currentStep == 2)
            step2Attempted = true;

        if (!IsCurrentStepValid())
            return;

        if (currentStep < TotalSteps)
        {
            await OnboardingService.SaveOnboardingStepAsync(Guid.Empty, currentStep);
            currentStep++;
        }
    }

    private void PrevStep()
    {
        if (currentStep > 1)
            currentStep--;
    }

    private async Task SkipStep()
    {
        if (currentStep < TotalSteps)
        {
            await OnboardingService.SaveOnboardingStepAsync(Guid.Empty, currentStep);
            currentStep++;
        }
    }

    private bool _isSubmitting;
    private string? _errorMessage;

    private async Task CompleteOnboarding()
    {
        if (_isSubmitting) return;
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            // Step 2 data: company info
            await OnboardingService.SaveOnboardingDataAsync(Guid.Empty, 2, new Dictionary<string, string>
            {
                ["CompanyName"] = companyName,
                ["TaxId"] = taxId,
                ["TaxOffice"] = taxOffice,
                ["Address"] = companyAddress,
                ["City"] = city,
                ["District"] = district
            });

            // Step 3 data: marketplace
            if (!string.IsNullOrEmpty(selectedPlatform))
            {
                await OnboardingService.SaveOnboardingDataAsync(Guid.Empty, 3, new Dictionary<string, string>
                {
                    ["Platform"] = selectedPlatform,
                    ["SellerId"] = sellerId
                });
            }

            // Step 5 data: stock settings
            await OnboardingService.SaveOnboardingDataAsync(Guid.Empty, 5, new Dictionary<string, string>
            {
                ["MinStock"] = minStockThreshold.ToString(),
                ["MaxStock"] = maxStockThreshold.ToString(),
                ["LowStockAlert"] = lowStockAlertEnabled.ToString(),
                ["AutoReorder"] = autoReorderEnabled.ToString()
            });

            // Step 6 data: notifications
            await OnboardingService.SaveOnboardingDataAsync(Guid.Empty, 6, new Dictionary<string, string>
            {
                ["Email"] = notificationEmail,
                ["Phone"] = notificationPhone,
                ["EmailEnabled"] = emailNotificationsEnabled.ToString(),
                ["SmsEnabled"] = smsNotificationsEnabled.ToString(),
                ["PushEnabled"] = pushNotificationsEnabled.ToString()
            });

            // Mark complete
            await OnboardingService.MarkOnboardingCompletedAsync(Guid.Empty);
            Nav.NavigateTo("/dashboard", replace: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Onboarding tamamlama hatası");
            _errorMessage = "Kayıt sırasında bir hata oluştu. Lütfen tekrar deneyin.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string GetNotificationSummary()
    {
        var channels = new List<string>();
        if (emailNotificationsEnabled) channels.Add("Email");
        if (smsNotificationsEnabled) channels.Add("SMS");
        if (pushNotificationsEnabled) channels.Add("Push");
        return channels.Count > 0 ? string.Join(", ", channels) : "—";
    }
}
