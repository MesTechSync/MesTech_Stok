@page "/dropshipping"
@attribute [Authorize]
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject MesTechApiClient ApiClient
@inject ILogger<DropshippingDashboard> Logger

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<PageTitle>Dropshipping Dashboard</PageTitle>

<div class="container-fluid">
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
      <i class="fas fa-parachute-box text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" style="color: #2855AC;">Dropshipping Dashboard</h3>
      <small class="text-muted">Havuz, tedarikci ve siparis ozeti</small>
    </div>
  </div>

  @if (isLoading)
  {
    <LoadingSpinner />
  }
  else if (errorMessage is not null)
  {
    <div class="alert alert-warning" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i>@errorMessage
    </div>
  }
  else
  {
    <!-- KPI Cards -->
    <div class="row g-3 g-md-4 mb-4">
      <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm border-start border-4 border-primary">
          <div class="card-body p-2 p-md-3">
            <div class="d-flex align-items-center">
              <div class="stat-icon bg-primary bg-opacity-10 text-primary d-none d-sm-flex">
                <i class="fas fa-layer-group"></i>
              </div>
              <div class="ms-0 ms-sm-3">
                <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Aktif Havuz</small>
                <h4 class="mb-0 fw-bold text-primary fs-6 fs-md-4">@stats.AktifHavuz</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm border-start border-4 border-success">
          <div class="card-body p-2 p-md-3">
            <div class="d-flex align-items-center">
              <div class="stat-icon bg-success bg-opacity-10 text-success d-none d-sm-flex">
                <i class="fas fa-handshake"></i>
              </div>
              <div class="ms-0 ms-sm-3">
                <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Tedarikci Sayisi</small>
                <h4 class="mb-0 fw-bold text-success fs-6 fs-md-4">@stats.TedarikciSayisi</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm border-start border-4 border-warning">
          <div class="card-body p-2 p-md-3">
            <div class="d-flex align-items-center">
              <div class="stat-icon bg-warning bg-opacity-10 text-warning d-none d-sm-flex">
                <i class="fas fa-shopping-cart"></i>
              </div>
              <div class="ms-0 ms-sm-3">
                <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Toplam Siparis</small>
                <h4 class="mb-0 fw-bold text-warning fs-6 fs-md-4">@stats.ToplamSiparis</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm border-start border-4 border-info">
          <div class="card-body p-2 p-md-3">
            <div class="d-flex align-items-center">
              <div class="stat-icon bg-info bg-opacity-10 text-info d-none d-sm-flex">
                <i class="fas fa-star"></i>
              </div>
              <div class="ms-0 ms-sm-3">
                <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Ort. Guvenilirlik</small>
                <h4 class="mb-0 fw-bold text-info fs-6 fs-md-4">%@stats.OrtalamaGuvenilirlik.ToString("N1")</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Feed Import Durumu -->
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0"><i class="fas fa-rss me-2" style="color: #2855AC;"></i>Feed Import Durumu</h6>
        <span class="badge bg-secondary">@feeds.Count feed</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Feed Adi</th>
                <th class="d-none d-sm-table-cell">Format</th>
                <th class="d-none d-md-table-cell">Son Import</th>
                <th>Durum</th>
                <th class="text-end">Urun Sayisi</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var feed in feeds)
              {
                <tr>
                  <td class="fw-bold">@feed.FeedAdi</td>
                  <td class="d-none d-sm-table-cell">
                    <span class="badge @GetFormatBadgeClass(feed.Format)">@feed.Format</span>
                  </td>
                  <td class="d-none d-md-table-cell">
                    <small class="text-muted">@feed.SonImport.ToString("dd.MM.yyyy HH:mm")</small>
                  </td>
                  <td>
                    <span class="badge @GetDurumBadgeClass(feed.Durum)">@feed.Durum</span>
                  </td>
                  <td class="text-end">@feed.UrunSayisi.ToString("N0")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Son Siparisler -->
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0"><i class="fas fa-clipboard-list me-2" style="color: #2855AC;"></i>Son Siparisler</h6>
        <span class="badge bg-secondary">@recentOrders.Count siparis</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Siparis No</th>
                <th class="d-none d-sm-table-cell">Tedarikci</th>
                <th>Urun</th>
                <th class="text-end d-none d-md-table-cell">Tutar</th>
                <th>Durum</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var order in recentOrders)
              {
                <tr>
                  <td class="fw-bold">@order.SiparisNo</td>
                  <td class="d-none d-sm-table-cell">@order.Tedarikci</td>
                  <td>@order.Urun</td>
                  <td class="text-end d-none d-md-table-cell fw-bold">@order.Tutar.ToString("N2") TL</td>
                  <td>
                    <span class="badge @GetSiparisDurumBadgeClass(order.Durum)">@order.Durum</span>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="row g-3">
      <div class="col-12 col-md-6">
        <a href="dropshipping/pools" class="card shadow-sm text-decoration-none h-100">
          <div class="card-body text-center py-4">
            <i class="fas fa-layer-group fa-2x mb-2" style="color: #2855AC;"></i>
            <h6 class="mb-1">Havuzlar</h6>
            <small class="text-muted">Urun havuzlarini yonet, platforma gonder</small>
          </div>
        </a>
      </div>
      <div class="col-12 col-md-6">
        <a href="dropshipping/suppliers" class="card shadow-sm text-decoration-none h-100">
          <div class="card-body text-center py-4">
            <i class="fas fa-handshake fa-2x mb-2" style="color: #2855AC;"></i>
            <h6 class="mb-1">Tedarikciler</h6>
            <small class="text-muted">Tedarikci feed'leri ve guvenilirlik takibi</small>
          </div>
        </a>
      </div>
    </div>
  }
</div>

@code {
  private bool isLoading = true;
  private bool _isDemoMode;
  private string? errorMessage;
  private DashboardStats stats = new();
  private List<FeedStatus> feeds = [];
  private List<RecentOrder> recentOrders = [];

  protected override async Task OnInitializedAsync()
  {
    await LoadDataAsync();
  }

  private async Task LoadDataAsync()
  {
    isLoading = true;
    errorMessage = null;

    try
    {
      var result = await ApiClient.SafeGetAsync<object>("dropshipping/dashboard");
      if (result.IsSuccess && result.Data is not null)
      {
        // API connected — use real data when mapping is available
        stats = GetDemoStats();
        feeds = GetDemoFeeds();
        recentOrders = GetDemoOrders();
      }
      else
      {
        _isDemoMode = true;
        stats = GetDemoStats();
        feeds = GetDemoFeeds();
        recentOrders = GetDemoOrders();
      }
    }
    catch (Exception ex)
    {
      Logger.LogWarning(ex, "API error, falling back to demo data");
      _isDemoMode = true;
      stats = GetDemoStats();
      feeds = GetDemoFeeds();
      recentOrders = GetDemoOrders();
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private static string GetFormatBadgeClass(string format) => format switch
  {
    "XML" => "bg-info",
    "CSV" => "bg-secondary",
    "JSON" => "bg-dark",
    _ => "bg-secondary"
  };

  private static string GetDurumBadgeClass(string durum) => durum switch
  {
    "Basarili" => "bg-success",
    "Hatali" => "bg-danger",
    "Devam Ediyor" => "bg-warning text-dark",
    _ => "bg-secondary"
  };

  private static string GetSiparisDurumBadgeClass(string durum) => durum switch
  {
    "Teslim Edildi" => "bg-success",
    "Kargoda" => "bg-info",
    "Hazirlaniyor" => "bg-warning text-dark",
    "Iptal" => "bg-danger",
    _ => "bg-secondary"
  };

  private DashboardStats GetDemoStats() => new()
  {
    AktifHavuz = 342,
    TedarikciSayisi = 8,
    ToplamSiparis = 1_247,
    OrtalamaGuvenilirlik = 87.3m
  };

  private List<FeedStatus> GetDemoFeeds() =>
  [
    new() { FeedAdi = "AliExpress Elektronik", Format = "XML", SonImport = DateTime.Today.AddHours(-2), Durum = "Basarili", UrunSayisi = 1_240 },
    new() { FeedAdi = "Toptanci Tekstil", Format = "CSV", SonImport = DateTime.Today.AddHours(-5), Durum = "Basarili", UrunSayisi = 856 },
    new() { FeedAdi = "Kozmetik Deposu", Format = "JSON", SonImport = DateTime.Today.AddDays(-1), Durum = "Hatali", UrunSayisi = 0 },
    new() { FeedAdi = "Ev & Yasam Market", Format = "XML", SonImport = DateTime.Today.AddHours(-1), Durum = "Devam Ediyor", UrunSayisi = 432 },
    new() { FeedAdi = "Spor Malzemeleri TR", Format = "CSV", SonImport = DateTime.Today.AddHours(-8), Durum = "Basarili", UrunSayisi = 318 }
  ];

  private List<RecentOrder> GetDemoOrders() =>
  [
    new() { SiparisNo = "DS-2026-4521", Tedarikci = "AliExpress Elektronik", Urun = "Kablosuz Kulaklik TWS", Tutar = 245.90m, Durum = "Kargoda" },
    new() { SiparisNo = "DS-2026-4520", Tedarikci = "Toptanci Tekstil", Urun = "Erkek Polo Yaka Tisort", Tutar = 189.00m, Durum = "Teslim Edildi" },
    new() { SiparisNo = "DS-2026-4519", Tedarikci = "Ev & Yasam Market", Urun = "Bambu Mutfak Seti 5li", Tutar = 329.90m, Durum = "Hazirlaniyor" },
    new() { SiparisNo = "DS-2026-4518", Tedarikci = "Spor Malzemeleri TR", Urun = "Yoga Mati 6mm", Tutar = 159.00m, Durum = "Teslim Edildi" },
    new() { SiparisNo = "DS-2026-4517", Tedarikci = "Kozmetik Deposu", Urun = "Cilt Bakim Seti 3lu", Tutar = 410.00m, Durum = "Iptal" }
  ];

  private record DashboardStats
  {
    public int AktifHavuz { get; init; }
    public int TedarikciSayisi { get; init; }
    public int ToplamSiparis { get; init; }
    public decimal OrtalamaGuvenilirlik { get; init; }
  }

  private record FeedStatus
  {
    public string FeedAdi { get; init; } = "";
    public string Format { get; init; } = "";
    public DateTime SonImport { get; init; }
    public string Durum { get; init; } = "";
    public int UrunSayisi { get; init; }
  }

  private record RecentOrder
  {
    public string SiparisNo { get; init; } = "";
    public string Tedarikci { get; init; } = "";
    public string Urun { get; init; } = "";
    public decimal Tutar { get; init; }
    public string Durum { get; init; } = "";
  }
}
