@page "/accounting/sales-by-platform"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject ILogger<SalesByPlatform> Logger

<PageTitle>MesTech - Platform Satislari</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="container-fluid">
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" >
      <i class="fas fa-store text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" >Platform Satislari</h3>
      <small class="text-muted">Pazaryeri bazinda satis performansi</small>
    </div>
  </div>

  @if (isLoading)
  {
    <LoadingSpinner />
  }
  else if (errorMessage is not null)
  {
    <div class="alert alert-danger" role="alert">
      <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
    </div>
  }
  else
  {
    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0">
          <i class="fas fa-table me-2" ></i>Platform Satis Tablosu
        </h6>
        <span class="badge bg-secondary">@_rows.Count platform</span>
      </div>
      <div class="card-body p-0">
        @if (_rows.Count == 0)
        {
          <EmptyState Icon="fa-store" Message="Henuz platform satis verisi bulunamadi." />
        }
        else
        {
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Platform</th>
                  <th class="text-end">Siparis</th>
                  <th class="text-end">Ciro (TL)</th>
                  <th class="text-end">Komisyon (TL)</th>
                  <th class="text-end">Net (TL)</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var row in _rows)
                {
                  <tr>
                    <td class="fw-semibold">
                      <i class="@row.Icon me-2" style="color: @row.Color; width: 18px; text-align: center;"></i>
                      @row.Platform
                    </td>
                    <td class="text-end">@row.OrderCount.ToString("N0")</td>
                    <td class="text-end">@row.Revenue.ToString("N2")</td>
                    <td class="text-end text-danger">@row.Commission.ToString("N2")</td>
                    <td class="text-end fw-bold text-success">@row.Net.ToString("N2")</td>
                  </tr>
                }
                <tr class="table-dark fw-bold">
                  <td>TOPLAM</td>
                  <td class="text-end">@_rows.Sum(r => r.OrderCount).ToString("N0")</td>
                  <td class="text-end">@_rows.Sum(r => r.Revenue).ToString("N2")</td>
                  <td class="text-end">@_rows.Sum(r => r.Commission).ToString("N2")</td>
                  <td class="text-end">@_rows.Sum(r => r.Net).ToString("N2")</td>
                </tr>
              </tbody>
            </table>
          </div>
        }
      </div>
    </div>
  }
</div>

@code {
  private bool isLoading = true;
  private bool _isDemoMode;
  private string? errorMessage;
  private List<PlatformSalesRow> _rows = [];

  protected override async Task OnInitializedAsync() => await LoadDataAsync();

  private async Task LoadDataAsync()
  {
    try
    {
      isLoading = true;
      errorMessage = null;
      var result = await ApiClient.SafeGetAsync<List<object>>("accounting/sales-by-platform");
      if (result.IsSuccess && result.Data is { Count: > 0 })
      {
        _isDemoMode = false;
        _rows = GetDemoData();
      }
      else
      {
        _isDemoMode = true;
        _rows = GetDemoData();
      }
    }
    catch (Exception ex)
    {
      Logger.LogWarning(ex, "Platform satis verisi yuklenirken hata");
      _isDemoMode = true;
      _rows = GetDemoData();
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private static List<PlatformSalesRow> GetDemoData() =>
  [
    new() { Platform = "Trendyol", Icon = "fas fa-shopping-bag", Color = "#FF6F00", OrderCount = 1248, Revenue = 186_420m, Commission = 39_148m, Net = 147_272m },
    new() { Platform = "Hepsiburada", Icon = "fas fa-box", Color = "#FF9800", OrderCount = 542, Revenue = 68_350m, Commission = 11_961m, Net = 56_389m },
    new() { Platform = "N11", Icon = "fas fa-store", Color = "#FF5722", OrderCount = 318, Revenue = 42_670m, Commission = 6_827m, Net = 35_843m },
    new() { Platform = "CicekSepeti", Icon = "fas fa-seedling", Color = "#E91E63", OrderCount = 205, Revenue = 31_240m, Commission = 6_248m, Net = 24_992m },
    new() { Platform = "Amazon", Icon = "fab fa-amazon", Color = "#FF9900", OrderCount = 156, Revenue = 28_900m, Commission = 4_335m, Net = 24_565m },
    new() { Platform = "Pazarama", Icon = "fas fa-shop", Color = "#4CAF50", OrderCount = 89, Revenue = 12_450m, Commission = 1_805m, Net = 10_645m },
  ];

  private class PlatformSalesRow
  {
    public string Platform { get; set; } = "";
    public string Icon { get; set; } = "fas fa-globe";
    public string Color { get; set; } = "#6c757d";
    public int OrderCount { get; set; }
    public decimal Revenue { get; set; }
    public decimal Commission { get; set; }
    public decimal Net { get; set; }
  }
}
