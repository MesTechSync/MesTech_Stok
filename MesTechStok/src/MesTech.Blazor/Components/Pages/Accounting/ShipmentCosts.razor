@page "/muhasebe/kargo-maliyetleri"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject ILogger<ShipmentCosts> Logger

<PageTitle>MesTech - Kargo Maliyetleri</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center">
        <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
             style="width: 48px; height: 48px; background-color: #fd7e14;">
            <i class="fas fa-shipping-fast text-white"></i>
        </div>
        <div>
            <h3 class="mb-0" style="color: #fd7e14;">Kargo Maliyetleri</h3>
            <small class="text-muted">Platform bazli kargo gider analizi</small>
        </div>
    </div>
    <button class="btn btn-outline-warning btn-sm" @onclick="LoadDataAsync" disabled="@isLoading">
        <i class="fas fa-sync-alt me-1"></i>Yenile
    </button>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger d-flex align-items-center justify-content-between" role="alert">
        <span><i class="fas fa-exclamation-triangle me-2"></i>@errorMessage</span>
        <button class="btn btn-sm btn-outline-danger" @onclick="LoadDataAsync">
            <i class="fas fa-sync-alt me-1"></i>Tekrar Dene
        </button>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-start border-warning border-4">
                <div class="card-body py-2">
                    <div class="text-muted small">Toplam Kargo Gideri</div>
                    <div class="fs-5 fw-bold">@_costs.Sum(c => c.TotalCost).ToString("C2", _trCulture)</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-start border-primary border-4">
                <div class="card-body py-2">
                    <div class="text-muted small">Ortalama Siparis Basi</div>
                    <div class="fs-5 fw-bold">@(_costs.Sum(c => c.Orders) > 0 ? (_costs.Sum(c => c.TotalCost) / _costs.Sum(c => c.Orders)).ToString("C2", _trCulture) : "0")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-start border-success border-4">
                <div class="card-body py-2">
                    <div class="text-muted small">Toplam Siparis</div>
                    <div class="fs-5 fw-bold">@_costs.Sum(c => c.Orders)</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-start border-info border-4">
                <div class="card-body py-2">
                    <div class="text-muted small">Firma Sayisi</div>
                    <div class="fs-5 fw-bold">@_costs.Select(c => c.Carrier).Distinct().Count()</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kargo Firmasi</th>
                        <th>Platform</th>
                        <th class="text-end">Siparis</th>
                        <th class="text-end">Toplam Maliyet</th>
                        <th class="text-end">Ort. Maliyet</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_costs.Count == 0)
                    {
                        <tr><td colspan="5"><EmptyState Icon="fa-shipping-fast" Message="Kargo maliyet verisi bulunamadi." /></td></tr>
                    }
                    @foreach (var c in _costs)
                    {
                        <tr>
                            <td class="fw-semibold">@c.Carrier</td>
                            <td><span class="badge bg-light text-dark">@c.Platform</span></td>
                            <td class="text-end">@c.Orders</td>
                            <td class="text-end fw-semibold">@c.TotalCost.ToString("C2", _trCulture)</td>
                            <td class="text-end text-muted">@(c.Orders > 0 ? (c.TotalCost / c.Orders).ToString("C2", _trCulture) : "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private static readonly System.Globalization.CultureInfo _trCulture = new("tr-TR");
    private bool isLoading = true;
    private bool _isDemoMode;
    private string? errorMessage;
    private List<ShipmentCostRow> _costs = new();

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var result = await ApiClient.SafeGetAsync<List<ShipmentCostRow>>("accounting/shipment-costs");
            if (result.IsSuccess && result.Data is { Count: > 0 })
                _costs = result.Data;
            else { _isDemoMode = true; _costs = GetDemoData(); }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Shipment costs load failed");
            _isDemoMode = true;
            _costs = GetDemoData();
        }
        finally { isLoading = false; StateHasChanged(); }
    }

    private static List<ShipmentCostRow> GetDemoData() => new()
    {
        new("Yurtici Kargo", "Trendyol", 342, 24_640m),
        new("Aras Kargo", "Hepsiburada", 218, 17_440m),
        new("Surat Kargo", "N11", 156, 10_920m),
        new("Yurtici Kargo", "Ciceksepeti", 89, 7_120m),
        new("Aras Kargo", "Trendyol", 67, 4_690m),
        new("MNG Kargo", "Amazon TR", 45, 3_825m),
    };

    private record ShipmentCostRow(string Carrier, string Platform, int Orders, decimal TotalCost);
}
