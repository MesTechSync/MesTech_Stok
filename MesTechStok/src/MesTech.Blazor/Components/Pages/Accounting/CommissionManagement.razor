@page "/accounting/commissions"
@attribute [Authorize]

@inject MesTechApiClient ApiClient
@inject IStringLocalizer<Strings> L

<PageTitle>MesTech - Komisyon Yonetimi</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
  <div class="rounded-circle d-flex align-items-center justify-content-center me-3" >
    <i class="fas fa-percent text-white"></i>
  </div>
  <div>
    <h3 class="mb-0" >@L["PageTitle.Commissions"]</h3>
    <small class="text-muted">Platform komisyon oranlari CRUD</small>
  </div>
</div>

@if (isLoading)
{
  <LoadingSpinner />
}
else
{
  @if (!string.IsNullOrEmpty(successMessage))
  {
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="fas fa-check-circle me-2"></i>@successMessage
      <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
  }

  @if (!string.IsNullOrEmpty(errorMessage))
  {
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
      <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
  }

  <!-- Add / Edit Form -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-white d-flex align-items-center">
      <h6 class="mb-0">
        <i class="fas fa-@(isEditing ? "edit" : "plus-circle") me-2 text-mestech"></i>
        @(isEditing ? L["UI.EditCommission"] : L["UI.AddCommission"])
      </h6>
    </div>
    <div class="card-body">
      <EditForm Model="formModel" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <div class="row g-3 align-items-end">
          <div class="col-12 col-md-3">
            <label class="form-label fw-semibold">@L["Table.Platform"]</label>
            <InputSelect class="form-select" @bind-Value="formModel.Platform" disabled="@isSaving">
              <option value="">-- @L["UI.SelectPlatform"] --</option>
              @foreach (var p in platformOptions)
              {
                <option value="@p">@p</option>
              }
            </InputSelect>
            <ValidationMessage For="() => formModel.Platform" />
          </div>
          <div class="col-12 col-md-3">
            <label class="form-label fw-semibold">Kategori <small class="text-muted">(istege bagli)</small></label>
            <InputText class="form-control" placeholder="Genel" @bind-Value="formModel.Category" disabled="@isSaving" />
          </div>
          <div class="col-12 col-md-2">
            <label class="form-label fw-semibold">@L["UI.CommissionRate"] (%)</label>
            <InputNumber class="form-control" @bind-Value="formModel.Rate" disabled="@isSaving" />
            <ValidationMessage For="() => formModel.Rate" />
          </div>
          <div class="col-12 col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary" disabled="@isSaving">
              @if (isSaving)
              {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
              }
              <i class="fas fa-save me-1"></i>@L["Common.Save"]
            </button>
            @if (isEditing)
            {
              <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit" disabled="@isSaving">
                <i class="fas fa-times me-1"></i>@L["Common.Cancel"]
              </button>
            }
          </div>
        </div>
      </EditForm>
    </div>
  </div>

  <!-- Commission Rates Table -->
  <div class="card shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between">
      <h6 class="mb-0">
        <i class="fas fa-table me-2" ></i>@L["Accounting.CommissionRates"]
      </h6>
      <span class="badge bg-secondary">@rates.Count kayit</span>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>@L["UI.PlatformName"]</th>
              <th>@L["Table.Category"]</th>
              <th class="text-end">@L["UI.CommissionRate"] (%)</th>
              <th class="d-none d-sm-table-cell">@L["UI.LastUpdated"]</th>
              <th class="text-center">@L["UI.Actions"]</th>
            </tr>
          </thead>
          <tbody>
            @if (rates.Count == 0)
            {
              <tr>
                <td colspan="5">
                  <EmptyState Icon="fa-percent" Message="Henuz komisyon orani tanimlanmamis." />
                </td>
              </tr>
            }
            else
            {
              @foreach (var rate in rates)
              {
                <tr>
                  <td>
                    <i class="@GetPlatformIcon(rate.Platform) me-2" style="color: @GetPlatformColor(rate.Platform); width: 18px; text-align: center;"></i>
                    <span class="fw-semibold">@rate.Platform</span>
                  </td>
                  <td>
                    @if (string.IsNullOrWhiteSpace(rate.Category))
                    {
                      <span class="text-muted fst-italic">Genel</span>
                    }
                    else
                    {
                      @rate.Category
                    }
                  </td>
                  <td class="text-end fw-bold">%@rate.Rate.ToString("N2")</td>
                  <td class="d-none d-sm-table-cell text-muted small">@rate.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                  <td class="text-center">
                    <button class="btn btn-sm btn-outline-primary me-1"@onclick="() => StartEdit(rate)"
                            title="Duzenle" disabled="@isSaving">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger"@onclick="() => ConfirmDelete(rate)"
                            title="Sil" disabled="@isSaving">
                      <i class="fas fa-trash-alt"></i>
                    </button>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
}

<ConfirmDialog IsVisible="showDeleteConfirm"
               Title="Komisyon Sil"
               Message="@($"'{_deletingRate?.Platform}' komisyon oranini silmek istediginize emin misiniz?")"
               ConfirmText="Sil"
               ButtonVariant="danger"
               OnConfirmed="ExecuteDelete"
               OnCancelled="CancelDelete" />

@code {
  // --- State ---
  private List<CommissionRateItem> rates = [];
  private CommissionFormModel formModel = new();
  private bool isLoading = true;
  private bool _isDemoMode;
  private bool isSaving;
  private bool isEditing;
  private int? editingId;
  private string? errorMessage;
  private string? successMessage;

  // Delete confirmation
  private bool showDeleteConfirm;
  private CommissionRateItem? _deletingRate;

  // 11 active platform adapters
  private static readonly string[] platformOptions =
  [
    "Trendyol", "OpenCart", "CicekSepeti", "Hepsiburada", "Pazarama",
    "N11", "Amazon", "eBay", "Shopify", "WooCommerce", "Bitrix24"
  ];

  // --- Lifecycle ---
  protected override async Task OnInitializedAsync()
  {
    await LoadRatesAsync();
  }

  // --- API Calls with Demo Fallback ---
  private async Task LoadRatesAsync()
  {
    isLoading = true;
    errorMessage = null;

    try
    {
      var result = await ApiClient.SafeGetAsync<List<CommissionRateItem>>("accounting/commission-rates");
      if (result.IsSuccess && result.Data is { Count: > 0 })
      {
        rates = result.Data;
        _isDemoMode = false;
      }
      else
      {
        _isDemoMode = true;
        rates = GetDemoRates();
      }
    }
    catch
    {
      _isDemoMode = true;
      rates = GetDemoRates();
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private async Task SaveAsync()
  {
    isSaving = true;
    errorMessage = null;
    successMessage = null;

    try
    {
      var payload = new
      {
        platform = formModel.Platform,
        category = string.IsNullOrWhiteSpace(formModel.Category) ? null : formModel.Category,
        rate = formModel.Rate
      };

      if (isEditing && editingId.HasValue)
      {
        var result = await ApiClient.SafePutAsync<object>(
          $"accounting/commission-rates/{editingId.Value}", payload);

        if (result.IsSuccess)
        {
          successMessage = $"{formModel.Platform} komisyon orani guncellendi.";
          await LoadRatesAsync();
          ResetForm();
          return;
        }
      }
      else
      {
        var result = await ApiClient.SafePostAsync<object>(
          "accounting/commission-rates", payload);

        if (result.IsSuccess)
        {
          successMessage = $"{formModel.Platform} komisyon orani eklendi.";
          await LoadRatesAsync();
          ResetForm();
          return;
        }
      }

      // API call did not succeed — apply locally as demo fallback
      ApplyLocalSave();
    }
    catch
    {
      // Demo fallback — save locally
      ApplyLocalSave();
    }
    finally
    {
      isSaving = false;
    }
  }

  private void ApplyLocalSave()
  {
    if (isEditing && editingId.HasValue)
    {
      var existing = rates.FirstOrDefault(r => r.Id == editingId.Value);
      if (existing is not null)
      {
        existing.Platform = formModel.Platform!;
        existing.Category = string.IsNullOrWhiteSpace(formModel.Category) ? null : formModel.Category;
        existing.Rate = formModel.Rate;
        existing.UpdatedAt = DateTime.Now;
      }
      successMessage = $"{formModel.Platform} komisyon orani guncellendi (demo).";
    }
    else
    {
      var newId = rates.Count > 0 ? rates.Max(r => r.Id) + 1 : 1;
      rates.Add(new CommissionRateItem
      {
        Id = newId,
        Platform = formModel.Platform!,
        Category = string.IsNullOrWhiteSpace(formModel.Category) ? null : formModel.Category,
        Rate = formModel.Rate,
        UpdatedAt = DateTime.Now
      });
      successMessage = $"{formModel.Platform} komisyon orani eklendi (demo).";
    }
    ResetForm();
  }

  private void ConfirmDelete(CommissionRateItem rate)
  {
    _deletingRate = rate;
    showDeleteConfirm = true;
  }

  private async Task ExecuteDelete()
  {
    if (_deletingRate is null) return;
    var rate = _deletingRate;
    showDeleteConfirm = false;
    _deletingRate = null;

    isSaving = true;
    errorMessage = null;
    successMessage = null;

    try
    {
      var result = await ApiClient.SafeDeleteAsync(
        $"accounting/commission-rates/{rate.Id}");

      if (result.IsSuccess)
      {
        successMessage = $"{rate.Platform} komisyon orani silindi.";
        await LoadRatesAsync();
        return;
      }
      rates.Remove(rate);
      successMessage = $"{rate.Platform} komisyon orani silindi (demo).";
    }
    catch
    {
      rates.Remove(rate);
      successMessage = $"{rate.Platform} komisyon orani silindi (demo).";
    }
    finally
    {
      isSaving = false;
      if (isEditing && editingId == rate.Id)
      {
        ResetForm();
      }
    }
  }

  private void CancelDelete()
  {
    showDeleteConfirm = false;
    _deletingRate = null;
  }

  // --- Inline Edit ---
  private void StartEdit(CommissionRateItem rate)
  {
    isEditing = true;
    editingId = rate.Id;
    formModel = new CommissionFormModel
    {
      Platform = rate.Platform,
      Category = rate.Category,
      Rate = rate.Rate
    };
    successMessage = null;
    errorMessage = null;
  }

  private void CancelEdit()
  {
    ResetForm();
  }

  private void ResetForm()
  {
    isEditing = false;
    editingId = null;
    formModel = new CommissionFormModel();
  }

  // --- Platform Visuals ---
  private static string GetPlatformIcon(string platform) => platform switch
  {
    "Trendyol" => "fas fa-shopping-bag",
    "OpenCart" => "fas fa-cart-shopping",
    "CicekSepeti" => "fas fa-seedling",
    "Hepsiburada" => "fas fa-box",
    "Pazarama" => "fas fa-shop",
    "N11" => "fas fa-store",
    "Amazon" => "fab fa-amazon",
    "eBay" => "fas fa-gavel",
    "Shopify" => "fab fa-shopify",
    "WooCommerce" => "fab fa-wordpress",
    "Bitrix24" => "fas fa-users-cog",
    _ => "fas fa-globe"
  };

  private static string GetPlatformColor(string platform) => platform switch
  {
    "Trendyol" => "#FF6F00",
    "OpenCart" => "#2196F3",
    "CicekSepeti" => "#E91E63",
    "Hepsiburada" => "#FF9800",
    "Pazarama" => "#4CAF50",
    "N11" => "#FF5722",
    "Amazon" => "#FF9900",
    "eBay" => "#E53238",
    "Shopify" => "#95BF47",
    "WooCommerce" => "#96588A",
    "Bitrix24" => "#00BCD4",
    _ => "#6c757d"
  };

  // --- Demo Data ---
  private static List<CommissionRateItem> GetDemoRates() =>
  [
    new() { Id = 1,  Platform = "Trendyol",    Category = null,          Rate = 21.00m, UpdatedAt = new DateTime(2026, 3, 1) },
    new() { Id = 2,  Platform = "Trendyol",    Category = "Elektronik",  Rate = 12.50m, UpdatedAt = new DateTime(2026, 3, 1) },
    new() { Id = 3,  Platform = "Hepsiburada", Category = null,          Rate = 17.50m, UpdatedAt = new DateTime(2026, 2, 28) },
    new() { Id = 4,  Platform = "CicekSepeti", Category = null,          Rate = 20.00m, UpdatedAt = new DateTime(2026, 2, 25) },
    new() { Id = 5,  Platform = "N11",         Category = null,          Rate = 16.00m, UpdatedAt = new DateTime(2026, 2, 20) },
    new() { Id = 6,  Platform = "Pazarama",    Category = null,          Rate = 14.50m, UpdatedAt = new DateTime(2026, 2, 18) },
    new() { Id = 7,  Platform = "Amazon",      Category = null,          Rate = 15.00m, UpdatedAt = new DateTime(2026, 2, 15) },
    new() { Id = 8,  Platform = "Amazon",      Category = "Kitap",       Rate = 8.00m,  UpdatedAt = new DateTime(2026, 2, 15) },
    new() { Id = 9,  Platform = "eBay",        Category = null,          Rate = 13.25m, UpdatedAt = new DateTime(2026, 2, 10) },
    new() { Id = 10, Platform = "Shopify",     Category = null,          Rate = 2.90m,  UpdatedAt = new DateTime(2026, 2, 8) },
    new() { Id = 11, Platform = "WooCommerce", Category = null,          Rate = 0.00m,  UpdatedAt = new DateTime(2026, 2, 5) },
    new() { Id = 12, Platform = "OpenCart",    Category = null,          Rate = 0.00m,  UpdatedAt = new DateTime(2026, 2, 1) },
    new() { Id = 13, Platform = "Bitrix24",    Category = null,          Rate = 0.00m,  UpdatedAt = new DateTime(2026, 1, 20) },
  ];

  // --- Models ---
  private class CommissionRateItem
  {
    public int Id { get; set; }
    public string Platform { get; set; } = string.Empty;
    public string? Category { get; set; }
    public decimal Rate { get; set; }
    public DateTime UpdatedAt { get; set; }
  }

  private class CommissionFormModel
  {
    [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Platform secimi zorunludur.")]
    public string? Platform { get; set; }
    public string? Category { get; set; }
    [System.ComponentModel.DataAnnotations.Range(0, 100, ErrorMessage = "Komisyon orani 0-100 arasinda olmalidir.")]
    public decimal Rate { get; set; }
  }
}
