@page "/accounting/reports"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject MesTechApiClient ApiClient
@inject NavigationManager Navigation
@inject ILogger<AccountingReports> Logger

<PageTitle>Muhasebe Raporlari</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="container-fluid">
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" >
      <i class="fas fa-chart-bar text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" >Muhasebe Raporlari</h3>
      <small class="text-muted">Mizan, bilanco ve gelir-gider tablosu</small>
    </div>
  </div>

  <!-- Tab Navigation -->
  <ul class="nav nav-tabs mb-4">
    <li class="nav-item">
      <button class="nav-link @(_activeTab == "trial-balance" ? "active" : "")"
              @onclick='() => SetTab("trial-balance")'>
        <i class="fas fa-balance-scale me-1"></i>Mizan
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link @(_activeTab == "balance-sheet" ? "active" : "")"
              @onclick='() => SetTab("balance-sheet")'>
        <i class="fas fa-file-invoice me-1"></i>Bilanco
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link @(_activeTab == "income-statement" ? "active" : "")"
              @onclick='() => SetTab("income-statement")'>
        <i class="fas fa-chart-line me-1"></i>Gelir-Gider Tablosu
      </button>
    </li>
  </ul>

  @if (isLoading)
  {
    <LoadingSpinner />
  }
  else if (errorMessage is not null)
  {
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
      <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
  }
  else
  {
    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0">
          <i class="fas fa-table me-2" ></i>@GetTabTitle()
        </h6>
        <span class="badge bg-secondary">@_reportRows.Count satir</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Hesap Kodu</th>
                <th>Hesap Adi</th>
                <th class="text-end">Borc</th>
                <th class="text-end">Alacak</th>
                <th class="text-end">Bakiye</th>
              </tr>
            </thead>
            <tbody>
              @if (_reportRows.Count == 0)
              {
                <tr>
                  <td colspan="5" class="text-center text-muted py-4">
                    <i class="fas fa-inbox fa-2x d-block mb-2"></i>
                    Bu donem icin rapor verisi bulunamadi.
                  </td>
                </tr>
              }
              @foreach (var row in _reportRows)
              {
                <tr class="@(row.IsHeader ? "table-light fw-bold" : "")">
                  <td>@row.HesapKodu</td>
                  <td>
                    @if (row.IsHeader)
                    {
                      <strong>@row.HesapAdi</strong>
                    }
                    else
                    {
                      @row.HesapAdi
                    }
                  </td>
                  <td class="text-end">@row.Borc.ToString("N2")</td>
                  <td class="text-end">@row.Alacak.ToString("N2")</td>
                  <td class="text-end fw-bold @(row.Bakiye >= 0 ? "text-success" : "text-danger")">
                    @row.Bakiye.ToString("N2")
                  </td>
                </tr>
              }
              @if (_reportRows.Count > 0)
              {
                <tr class="table-dark fw-bold">
                  <td colspan="2">TOPLAM</td>
                  <td class="text-end">@_reportRows.Sum(r => r.Borc).ToString("N2")</td>
                  <td class="text-end">@_reportRows.Sum(r => r.Alacak).ToString("N2")</td>
                  <td class="text-end">@_reportRows.Sum(r => r.Bakiye).ToString("N2")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  }
</div>

@code {
  private bool isLoading = true;
  private bool _isDemoMode;
  private string? errorMessage;
  private string _activeTab = "trial-balance";
  private List<ReportRow> _reportRows = new();

  protected override async Task OnInitializedAsync()
  {
    await LoadReport();
  }

  private async Task SetTab(string tab)
  {
    _activeTab = tab;
    isLoading = true;
    await LoadReport();
  }

  private async Task LoadReport()
  {
    try
    {
      string endpoint = _activeTab switch
      {
        "trial-balance"    => "accounting/trial-balance",
        "balance-sheet"    => "accounting/balance-sheet",
        "income-statement" => "accounting/profit-report",
        _                  => "accounting/trial-balance"
      };

      var probe = await ApiClient.SafeGetAsync<List<System.Text.Json.JsonElement>>(endpoint);
      if (probe.IsSuccess && probe.Data is { Count: > 0 })
      {
        _isDemoMode = false;
        _reportRows = probe.Data.Select(e => new ReportRow
        {
          HesapKodu = e.TryGetProperty("accountCode",  out var ak) ? ak.GetString()  ?? "" : e.TryGetProperty("hesapKodu", out var ak2) ? ak2.GetString() ?? "" : "",
          HesapAdi  = e.TryGetProperty("accountName",  out var an) ? an.GetString()  ?? "" : e.TryGetProperty("hesapAdi",  out var an2) ? an2.GetString() ?? "" : "",
          Borc      = e.TryGetProperty("debit",        out var db) ? db.GetDecimal() : e.TryGetProperty("borc",      out var db2) ? db2.GetDecimal() : 0,
          Alacak    = e.TryGetProperty("credit",       out var cr) ? cr.GetDecimal() : e.TryGetProperty("alacak",    out var cr2) ? cr2.GetDecimal() : 0,
          Bakiye    = e.TryGetProperty("balance",      out var bl) ? bl.GetDecimal() : e.TryGetProperty("bakiye",    out var bl2) ? bl2.GetDecimal() : 0,
          IsHeader  = e.TryGetProperty("isHeader",     out var ih) ? ih.GetBoolean() : false,
        }).ToList();
      }
      else
      {
        _isDemoMode = true;
        _reportRows = GetDemoData(_activeTab);
      }
    }
    catch (Exception ex)
    {
      Logger.LogWarning(ex, "API error, falling back to demo data");
      _isDemoMode = true;
      _reportRows = GetDemoData(_activeTab);
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private string GetTabTitle() => _activeTab switch
  {
    "trial-balance" => "Mizan",
    "balance-sheet" => "Bilanco",
    "income-statement" => "Gelir-Gider Tablosu",
    _ => "Rapor"
  };

  private List<ReportRow> GetDemoData(string type) => type switch
  {
    "trial-balance" => new()
    {
      new() { HesapKodu = "100", HesapAdi = "Kasa", Borc = 45_000m, Alacak = 12_000m, Bakiye = 33_000m },
      new() { HesapKodu = "102", HesapAdi = "Bankalar", Borc = 284_750m, Alacak = 167_320m, Bakiye = 117_430m },
      new() { HesapKodu = "120", HesapAdi = "Alicilar", Borc = 56_200m, Alacak = 38_400m, Bakiye = 17_800m },
      new() { HesapKodu = "153", HesapAdi = "Ticari Mallar", Borc = 120_000m, Alacak = 85_000m, Bakiye = 35_000m },
      new() { HesapKodu = "320", HesapAdi = "Saticilar", Borc = 42_000m, Alacak = 68_500m, Bakiye = -26_500m },
      new() { HesapKodu = "600", HesapAdi = "Yurtici Satislar", Borc = 0m, Alacak = 284_750m, Bakiye = -284_750m },
      new() { HesapKodu = "760", HesapAdi = "Pazarlama Giderleri", Borc = 6_350m, Alacak = 0m, Bakiye = 6_350m },
      new() { HesapKodu = "770", HesapAdi = "Genel Yonetim Giderleri", Borc = 22_390m, Alacak = 0m, Bakiye = 22_390m },
    },
    "balance-sheet" => new()
    {
      new() { HesapKodu = "I", HesapAdi = "DONEN VARLIKLAR", Borc = 0m, Alacak = 0m, Bakiye = 203_230m, IsHeader = true },
      new() { HesapKodu = "100", HesapAdi = "Kasa", Borc = 0m, Alacak = 0m, Bakiye = 33_000m },
      new() { HesapKodu = "102", HesapAdi = "Bankalar", Borc = 0m, Alacak = 0m, Bakiye = 117_430m },
      new() { HesapKodu = "120", HesapAdi = "Alicilar", Borc = 0m, Alacak = 0m, Bakiye = 17_800m },
      new() { HesapKodu = "153", HesapAdi = "Ticari Mallar", Borc = 0m, Alacak = 0m, Bakiye = 35_000m },
      new() { HesapKodu = "II", HesapAdi = "KISA VADELI BORCLAR", Borc = 0m, Alacak = 0m, Bakiye = -26_500m, IsHeader = true },
      new() { HesapKodu = "320", HesapAdi = "Saticilar", Borc = 0m, Alacak = 0m, Bakiye = -26_500m },
      new() { HesapKodu = "III", HesapAdi = "OZKAYNAKLAR", Borc = 0m, Alacak = 0m, Bakiye = -176_730m, IsHeader = true },
    },
    "income-statement" => new()
    {
      new() { HesapKodu = "A", HesapAdi = "BRUT SATISLAR", Borc = 0m, Alacak = 284_750m, Bakiye = 284_750m, IsHeader = true },
      new() { HesapKodu = "600", HesapAdi = "Yurtici Satislar", Borc = 0m, Alacak = 284_750m, Bakiye = 284_750m },
      new() { HesapKodu = "B", HesapAdi = "SATIS MALIYETI", Borc = 138_580m, Alacak = 0m, Bakiye = -138_580m, IsHeader = true },
      new() { HesapKodu = "621", HesapAdi = "Satilan Ticari Mallar Maliyeti", Borc = 138_580m, Alacak = 0m, Bakiye = -138_580m },
      new() { HesapKodu = "C", HesapAdi = "FAALIYET GIDERLERI", Borc = 28_740m, Alacak = 0m, Bakiye = -28_740m, IsHeader = true },
      new() { HesapKodu = "760", HesapAdi = "Pazarlama Giderleri", Borc = 6_350m, Alacak = 0m, Bakiye = -6_350m },
      new() { HesapKodu = "770", HesapAdi = "Genel Yonetim Giderleri", Borc = 22_390m, Alacak = 0m, Bakiye = -22_390m },
    },
    _ => new()
  };

  private class ReportRow
  {
    public string HesapKodu { get; set; } = "";
    public string HesapAdi { get; set; } = "";
    public decimal Borc { get; set; }
    public decimal Alacak { get; set; }
    public decimal Bakiye { get; set; }
    public bool IsHeader { get; set; }
  }
}
