@page "/accounting/salaries"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@inject MesTechApiClient ApiClient
@inject IStringLocalizer<Strings> L
@inject ILogger<Salaries> Logger

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<PageTitle>Maas Yonetimi</PageTitle>

<div class="container-fluid">
  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="dashboard">Dashboard</a></li>
      <li class="breadcrumb-item"><a href="accounting">Muhasebe</a></li>
      <li class="breadcrumb-item active" aria-current="page">Maas Yonetimi</li>
    </ol>
  </nav>

  <!-- Page Header -->
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
      <i class="fas fa-money-check-alt text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" style="color: #2855AC;">Maas Yonetimi</h3>
      <small class="text-muted">Calisan maas bordrolari ve isci maliyeti takibi</small>
    </div>
  </div>

  @if (_isLoading)
  {
    <LoadingSpinner />
  }
  else if (_errorMessage is not null)
  {
    <div class="alert alert-warning" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i>@_errorMessage
    </div>
  }
  else
  {
    <!-- KPI Cards -->
    <div class="row g-3 g-md-4 mb-4">
      <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm border-start border-4 border-primary">
          <div class="card-body p-2 p-md-3">
            <div class="d-flex align-items-center">
              <div class="stat-icon bg-primary bg-opacity-10 text-primary d-none d-sm-flex">
                <i class="fas fa-coins"></i>
              </div>
              <div class="ms-0 ms-sm-3">
                <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Toplam Brut</small>
                <h4 class="mb-0 fw-bold text-primary fs-6 fs-md-4">@_salaries.Sum(s => s.BrutMaas).ToString("N2") TL</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm border-start border-4 border-success">
          <div class="card-body p-2 p-md-3">
            <div class="d-flex align-items-center">
              <div class="stat-icon bg-success bg-opacity-10 text-success d-none d-sm-flex">
                <i class="fas fa-wallet"></i>
              </div>
              <div class="ms-0 ms-sm-3">
                <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Toplam Net</small>
                <h4 class="mb-0 fw-bold text-success fs-6 fs-md-4">@_salaries.Sum(s => s.NetMaas).ToString("N2") TL</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm border-start border-4 border-danger">
          <div class="card-body p-2 p-md-3">
            <div class="d-flex align-items-center">
              <div class="stat-icon bg-danger bg-opacity-10 text-danger d-none d-sm-flex">
                <i class="fas fa-building"></i>
              </div>
              <div class="ms-0 ms-sm-3">
                <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Toplam Isveren Maliyeti</small>
                <h4 class="mb-0 fw-bold text-danger fs-6 fs-md-4">@_salaries.Sum(s => s.IsverenMaliyet).ToString("N2") TL</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm border-start border-4 border-info">
          <div class="card-body p-2 p-md-3">
            <div class="d-flex align-items-center">
              <div class="stat-icon bg-info bg-opacity-10 text-info d-none d-sm-flex">
                <i class="fas fa-users"></i>
              </div>
              <div class="ms-0 ms-sm-3">
                <small class="text-muted text-uppercase" style="font-size: 0.7rem;">Calisan Sayisi</small>
                <h4 class="mb-0 fw-bold text-info fs-6 fs-md-4">@_salaries.Count</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm mb-4">
      <div class="card-body py-2">
        <div class="row g-2 align-items-center">
          <div class="col-12 col-sm-3">
            <label class="form-label small text-muted mb-0">Yil</label>
            <select class="form-select form-select-sm" @bind="_selectedYear">
              <option value="2026">2026</option>
              <option value="2025">2025</option>
            </select>
          </div>
          <div class="col-12 col-sm-3">
            <label class="form-label small text-muted mb-0">Ay</label>
            <select class="form-select form-select-sm" @bind="_selectedMonth">
              <option value="1">Ocak</option>
              <option value="2">Subat</option>
              <option value="3">Mart</option>
              <option value="4">Nisan</option>
              <option value="5">Mayis</option>
              <option value="6">Haziran</option>
              <option value="7">Temmuz</option>
              <option value="8">Agustos</option>
              <option value="9">Eylul</option>
              <option value="10">Ekim</option>
              <option value="11">Kasim</option>
              <option value="12">Aralik</option>
            </select>
          </div>
          <div class="col-12 col-sm-4">
            <label class="form-label small text-muted mb-0">Ara</label>
            <div class="input-group input-group-sm">
              <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
              <input type="text" class="form-control" placeholder="Calisan ara..."
                     @bind="_searchText" @bind:event="oninput" />
            </div>
          </div>
          <div class="col-12 col-sm-2 text-end">
            <label class="form-label small text-muted mb-0 d-none d-sm-block">&nbsp;</label>
            <button class="btn btn-sm btn-outline-primary w-100" @onclick="RefreshData">
              <i class="fas fa-sync me-1"></i>Yenile
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Data Table -->
    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0"><i class="fas fa-table me-2" style="color: #2855AC;"></i>Maas Bordrosu — @GetMonthName(_selectedMonth) @_selectedYear</h6>
        <span class="badge bg-secondary">@FilteredSalaries.Count kayit</span>
      </div>
      <div class="card-body p-0">
        @if (FilteredSalaries.Count == 0)
        {
          <div class="text-center text-muted py-5">
            <i class="fas fa-inbox fa-3x mb-3 d-block opacity-25"></i>
            <p>Bu donem icin maas kaydi bulunamadi.</p>
          </div>
        }
        else
        {
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Calisan</th>
                  <th class="text-end">Brut Maas</th>
                  <th class="text-end d-none d-md-table-cell">SGK Isveren</th>
                  <th class="text-end d-none d-md-table-cell">SGK Isci</th>
                  <th class="text-end d-none d-lg-table-cell">Gelir Vergisi</th>
                  <th class="text-end d-none d-lg-table-cell">Damga</th>
                  <th class="text-end">Net Maas</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var s in FilteredSalaries)
                {
                  <tr>
                    <td class="fw-bold">@s.CalisanAdi</td>
                    <td class="text-end">@s.BrutMaas.ToString("N2") TL</td>
                    <td class="text-end d-none d-md-table-cell text-danger">@s.SgkIsveren.ToString("N2") TL</td>
                    <td class="text-end d-none d-md-table-cell text-danger">@s.SgkIsci.ToString("N2") TL</td>
                    <td class="text-end d-none d-lg-table-cell text-warning">@s.GelirVergisi.ToString("N2") TL</td>
                    <td class="text-end d-none d-lg-table-cell text-warning">@s.DamgaVergisi.ToString("N2") TL</td>
                    <td class="text-end fw-bold text-success">@s.NetMaas.ToString("N2") TL</td>
                  </tr>
                }
              </tbody>
              <tfoot class="table-light fw-bold">
                <tr>
                  <td>TOPLAM</td>
                  <td class="text-end">@FilteredSalaries.Sum(s => s.BrutMaas).ToString("N2") TL</td>
                  <td class="text-end d-none d-md-table-cell text-danger">@FilteredSalaries.Sum(s => s.SgkIsveren).ToString("N2") TL</td>
                  <td class="text-end d-none d-md-table-cell text-danger">@FilteredSalaries.Sum(s => s.SgkIsci).ToString("N2") TL</td>
                  <td class="text-end d-none d-lg-table-cell text-warning">@FilteredSalaries.Sum(s => s.GelirVergisi).ToString("N2") TL</td>
                  <td class="text-end d-none d-lg-table-cell text-warning">@FilteredSalaries.Sum(s => s.DamgaVergisi).ToString("N2") TL</td>
                  <td class="text-end text-success">@FilteredSalaries.Sum(s => s.NetMaas).ToString("N2") TL</td>
                </tr>
              </tfoot>
            </table>
          </div>
        }
      </div>
    </div>
  }
</div>

@code {
  private bool _isLoading = true;
  private bool _isDemoMode;
  private string? _errorMessage;
  private string _searchText = string.Empty;
  private int _selectedYear = 2026;
  private int _selectedMonth = 3;
  private List<SalaryRecord> _salaries = [];

  private List<SalaryRecord> FilteredSalaries => _salaries
    .Where(s => string.IsNullOrWhiteSpace(_searchText) ||
                s.CalisanAdi.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
    .ToList();

  protected override async Task OnInitializedAsync()
  {
    await LoadDataAsync();
  }

  private async Task LoadDataAsync()
  {
    _isLoading = true;
    _errorMessage = null;

    try
    {
      var probe = await ApiClient.SafeGetAsync<List<System.Text.Json.JsonElement>>(
        $"accounting/salaries?year={_selectedYear}&month={_selectedMonth}");
      if (probe.IsSuccess && probe.Data is { Count: > 0 })
      {
        // API is live and returned data — parse into local records
        _isDemoMode = false;
        _salaries = probe.Data.Select(e => new SalaryRecord
        {
          CalisanAdi      = e.TryGetProperty("employeeName",    out var n)  ? n.GetString()  ?? "" : e.TryGetProperty("calisanAdi",      out var n2) ? n2.GetString()  ?? "" : "",
          BrutMaas        = e.TryGetProperty("grossSalary",     out var g)  ? g.GetDecimal() : e.TryGetProperty("brutMaas",          out var g2) ? g2.GetDecimal() : 0,
          SgkIsveren      = e.TryGetProperty("employerSgk",     out var ei) ? ei.GetDecimal(): e.TryGetProperty("sgkIsveren",         out var ei2)? ei2.GetDecimal(): 0,
          SgkIsci         = e.TryGetProperty("employeeSgk",     out var es) ? es.GetDecimal(): e.TryGetProperty("sgkIsci",            out var es2)? es2.GetDecimal(): 0,
          GelirVergisi    = e.TryGetProperty("incomeTax",       out var it) ? it.GetDecimal(): e.TryGetProperty("gelirVergisi",       out var it2)? it2.GetDecimal(): 0,
          DamgaVergisi    = e.TryGetProperty("stampTax",        out var st) ? st.GetDecimal(): e.TryGetProperty("damgaVergisi",       out var st2)? st2.GetDecimal(): 0,
          NetMaas         = e.TryGetProperty("netSalary",       out var ns) ? ns.GetDecimal(): e.TryGetProperty("netMaas",            out var ns2)? ns2.GetDecimal(): 0,
          IsverenMaliyet  = e.TryGetProperty("totalEmployerCost",out var tc)? tc.GetDecimal(): e.TryGetProperty("isverenMaliyet",     out var tc2)? tc2.GetDecimal(): 0,
        }).ToList();
      }
      else
      {
        _isDemoMode = true;
        _salaries = GetDemoSalaries();
      }
    }
    catch (Exception ex)
    {
      Logger.LogWarning(ex, "API error, falling back to demo data");
      _isDemoMode = true;
      _salaries = GetDemoSalaries();
    }
    finally
    {
      _isLoading = false;
      StateHasChanged();
    }
  }

  private async Task RefreshData() => await LoadDataAsync();

  private static string GetMonthName(int month) => month switch
  {
    1 => "Ocak", 2 => "Subat", 3 => "Mart", 4 => "Nisan",
    5 => "Mayis", 6 => "Haziran", 7 => "Temmuz", 8 => "Agustos",
    9 => "Eylul", 10 => "Ekim", 11 => "Kasim", 12 => "Aralik",
    _ => "?"
  };

  /// <summary>
  /// 2026 TR maas hesaplama parametreleri (gercekci):
  /// - Asgari ucret 2026: 22.104,67 TL brut
  /// - SGK isveren %22.5, SGK isci %14, issizlik isveren %2, issizlik isci %1
  /// - Gelir vergisi %15 (ilk 110.000 TL icin)
  /// - Damga vergisi %0.759
  /// </summary>
  private static List<SalaryRecord> GetDemoSalaries() =>
  [
    new() { CalisanAdi = "Ahmet Yilmaz",     BrutMaas = 45_000.00m, SgkIsveren = 11_025.00m, SgkIsci = 6_300.00m, GelirVergisi = 5_805.00m, DamgaVergisi = 341.55m, NetMaas = 32_553.45m, IsverenMaliyet = 56_025.00m },
    new() { CalisanAdi = "Fatma Demir",       BrutMaas = 38_000.00m, SgkIsveren =  9_310.00m, SgkIsci = 5_320.00m, GelirVergisi = 4_902.00m, DamgaVergisi = 288.42m, NetMaas = 27_489.58m, IsverenMaliyet = 47_310.00m },
    new() { CalisanAdi = "Mehmet Kaya",       BrutMaas = 55_000.00m, SgkIsveren = 13_475.00m, SgkIsci = 7_700.00m, GelirVergisi = 7_095.00m, DamgaVergisi = 417.45m, NetMaas = 39_787.55m, IsverenMaliyet = 68_475.00m },
    new() { CalisanAdi = "Zeynep Ozturk",     BrutMaas = 32_000.00m, SgkIsveren =  7_840.00m, SgkIsci = 4_480.00m, GelirVergisi = 4_128.00m, DamgaVergisi = 242.88m, NetMaas = 23_149.12m, IsverenMaliyet = 39_840.00m },
    new() { CalisanAdi = "Ali Celik",         BrutMaas = 22_104.67m, SgkIsveren =  5_415.64m, SgkIsci = 3_094.65m, GelirVergisi = 2_851.50m, DamgaVergisi = 167.77m, NetMaas = 15_990.75m, IsverenMaliyet = 27_520.31m },
    new() { CalisanAdi = "Ayse Sahin",        BrutMaas = 28_500.00m, SgkIsveren =  6_982.50m, SgkIsci = 3_990.00m, GelirVergisi = 3_676.50m, DamgaVergisi = 216.32m, NetMaas = 20_617.18m, IsverenMaliyet = 35_482.50m },
    new() { CalisanAdi = "Hasan Arslan",      BrutMaas = 42_000.00m, SgkIsveren = 10_290.00m, SgkIsci = 5_880.00m, GelirVergisi = 5_418.00m, DamgaVergisi = 318.78m, NetMaas = 30_383.22m, IsverenMaliyet = 52_290.00m },
    new() { CalisanAdi = "Elif Yildiz",       BrutMaas = 35_000.00m, SgkIsveren =  8_575.00m, SgkIsci = 4_900.00m, GelirVergisi = 4_515.00m, DamgaVergisi = 265.65m, NetMaas = 25_319.35m, IsverenMaliyet = 43_575.00m }
  ];

  private record SalaryRecord
  {
    public string CalisanAdi { get; init; } = "";
    public decimal BrutMaas { get; init; }
    public decimal SgkIsveren { get; init; }
    public decimal SgkIsci { get; init; }
    public decimal GelirVergisi { get; init; }
    public decimal DamgaVergisi { get; init; }
    public decimal NetMaas { get; init; }
    public decimal IsverenMaliyet { get; init; }
  }
}
