@page "/accounting/profit-loss"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject ILogger<ProfitLoss> Logger

<PageTitle>MesTech - Kar/Zarar</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="container-fluid">
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
      <i class="fas fa-chart-line text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" style="color: #2855AC;">Kar / Zarar</h3>
      <small class="text-muted">Donemsel kar/zarar analizi</small>
    </div>
  </div>

  @if (isLoading)
  {
    <LoadingSpinner />
  }
  else if (errorMessage is not null)
  {
    <div class="alert alert-danger" role="alert">
      <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
    </div>
  }
  else
  {
    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
      <KpiCard Icon="fa-arrow-up" Value="@_totalRevenue.ToString("N2")" Label="Toplam Gelir" TextColor="text-success" />
      <KpiCard Icon="fa-arrow-down" Value="@_totalExpense.ToString("N2")" Label="Toplam Gider" TextColor="text-danger" />
      <KpiCard Icon="fa-chart-line" Value="@_netProfit.ToString("N2")" Label="Net Kar/Zarar" TextColor="@(_netProfit >= 0 ? "text-success" : "text-danger")" />
      <KpiCard Icon="fa-percent" Value="@($"{(_totalRevenue > 0 ? (_netProfit / _totalRevenue * 100).ToString("N1") : "0")}%")" Label="Kar Marji" TextColor="text-info" />
    </div>

    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0">
          <i class="fas fa-table me-2" style="color: #2855AC;"></i>Kar/Zarar Detay
        </h6>
        <span class="badge bg-secondary">@_rows.Count satir</span>
      </div>
      <div class="card-body p-0">
        @if (_rows.Count == 0)
        {
          <EmptyState Icon="fa-chart-line" Message="Henuz kar/zarar verisi bulunamadi." />
        }
        else
        {
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Kalem</th>
                  <th class="text-end">Tutar</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var row in _rows)
                {
                  <tr class="@(row.IsHeader ? "table-light fw-bold" : "")">
                    <td>@row.Label</td>
                    <td class="text-end fw-bold @(row.Amount >= 0 ? "text-success" : "text-danger")">
                      @row.Amount.ToString("N2") TL
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
      </div>
    </div>
  }
</div>

@code {
  private bool isLoading = true;
  private bool _isDemoMode;
  private string? errorMessage;
  private List<ProfitLossRow> _rows = [];
  private decimal _totalRevenue;
  private decimal _totalExpense;
  private decimal _netProfit;

  protected override async Task OnInitializedAsync() => await LoadDataAsync();

  private async Task LoadDataAsync()
  {
    try
    {
      isLoading = true;
      errorMessage = null;
      var result = await ApiClient.SafeGetAsync<List<object>>("accounting/profit-loss");
      if (result.IsSuccess && result.Data is { Count: > 0 })
      {
        _isDemoMode = false;
        _rows = GetDemoData();
      }
      else
      {
        _isDemoMode = true;
        _rows = GetDemoData();
      }
      _totalRevenue = _rows.Where(r => !r.IsHeader && r.Amount > 0).Sum(r => r.Amount);
      _totalExpense = _rows.Where(r => !r.IsHeader && r.Amount < 0).Sum(r => Math.Abs(r.Amount));
      _netProfit = _totalRevenue - _totalExpense;
    }
    catch (Exception ex)
    {
      Logger.LogWarning(ex, "Kar/zarar verisi yuklenirken hata");
      _isDemoMode = true;
      _rows = GetDemoData();
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private static List<ProfitLossRow> GetDemoData() =>
  [
    new() { Label = "BRUT SATISLAR", Amount = 284_750m, IsHeader = true },
    new() { Label = "Yurtici Satislar", Amount = 284_750m },
    new() { Label = "SATIS MALIYETI", Amount = -138_580m, IsHeader = true },
    new() { Label = "Satilan Ticari Mallar Maliyeti", Amount = -138_580m },
    new() { Label = "FAALIYET GIDERLERI", Amount = -28_740m, IsHeader = true },
    new() { Label = "Pazarlama Giderleri", Amount = -6_350m },
    new() { Label = "Genel Yonetim Giderleri", Amount = -22_390m },
    new() { Label = "NET KAR/ZARAR", Amount = 117_430m, IsHeader = true },
  ];

  private class ProfitLossRow
  {
    public string Label { get; set; } = "";
    public decimal Amount { get; set; }
    public bool IsHeader { get; set; }
  }
}
