@page "/integration/erp-connections"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject ILogger<ErpConnections> Logger

<PageTitle>MesTech - ERP Baglantilari</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="container-fluid">
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
      <i class="fas fa-plug text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" style="color: #2855AC;">ERP Baglantilari</h3>
      <small class="text-muted">ERP entegrasyon yonetimi</small>
    </div>
  </div>

  @if (isLoading)
  {
    <LoadingSpinner />
  }
  else if (errorMessage is not null)
  {
    <div class="alert alert-danger" role="alert">
      <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
    </div>
  }
  else
  {
    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0">
          <i class="fas fa-list me-2" style="color: #2855AC;"></i>ERP Baglanti Listesi
        </h6>
        <span class="badge bg-secondary">@_connections.Count baglanti</span>
      </div>
      <div class="card-body p-0">
        @if (_connections.Count == 0)
        {
          <EmptyState Icon="fa-plug" Message="Henuz ERP baglantisi tanimlanmamis." />
        }
        else
        {
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>ERP Sistemi</th>
                  <th>Baglanti Tipi</th>
                  <th>Durum</th>
                  <th class="d-none d-md-table-cell">Son Sync</th>
                  <th class="text-center">Aksiyonlar</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var conn in _connections)
                {
                  <tr>
                    <td class="fw-semibold">
                      <i class="@conn.Icon me-2" style="color: @conn.Color; width: 18px; text-align: center;"></i>
                      @conn.Name
                    </td>
                    <td><span class="badge bg-info">@conn.ConnectionType</span></td>
                    <td>
                      @if (conn.IsActive)
                      {
                        <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Aktif</span>
                      }
                      else
                      {
                        <span class="badge bg-secondary"><i class="fas fa-pause-circle me-1"></i>Pasif</span>
                      }
                    </td>
                    <td class="d-none d-md-table-cell text-muted small">@conn.LastSync.ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="text-center">
                      <button class="btn btn-sm btn-outline-primary" title="Test Et">
                        <i class="fas fa-vial"></i>
                      </button>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
      </div>
    </div>
  }
</div>

@code {
  private bool isLoading = true;
  private bool _isDemoMode;
  private string? errorMessage;
  private List<ErpConnectionRow> _connections = [];

  protected override async Task OnInitializedAsync() => await LoadDataAsync();

  private async Task LoadDataAsync()
  {
    try
    {
      isLoading = true;
      errorMessage = null;
      var result = await ApiClient.SafeGetAsync<List<object>>("integration/erp-connections");
      if (result.IsSuccess && result.Data is { Count: > 0 })
      {
        _isDemoMode = false;
        _connections = GetDemoData();
      }
      else
      {
        _isDemoMode = true;
        _connections = GetDemoData();
      }
    }
    catch (Exception ex)
    {
      Logger.LogWarning(ex, "ERP baglanti verisi yuklenirken hata");
      _isDemoMode = true;
      _connections = GetDemoData();
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private static List<ErpConnectionRow> GetDemoData() =>
  [
    new() { Name = "Parasut", Icon = "fas fa-cloud", Color = "#00BCD4", ConnectionType = "REST API", IsActive = true, LastSync = DateTime.Today.AddHours(-1) },
    new() { Name = "Logo Tiger", Icon = "fas fa-database", Color = "#FF9800", ConnectionType = "SOAP", IsActive = false, LastSync = DateTime.Today.AddDays(-15) },
  ];

  private class ErpConnectionRow
  {
    public string Name { get; set; } = "";
    public string Icon { get; set; } = "fas fa-plug";
    public string Color { get; set; } = "#6c757d";
    public string ConnectionType { get; set; } = "";
    public bool IsActive { get; set; }
    public DateTime LastSync { get; set; }
  }
}
