@page "/finans/giderler"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject ILogger<Expenses> Logger

<PageTitle>MesTech - Gider Yonetimi</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
  <div class="rounded-circle d-flex align-items-center justify-content-center me-3" >
    <i class="fas fa-file-invoice-dollar text-white"></i>
  </div>
  <div>
    <h3 class="mb-0" >Gider Yonetimi</h3>
    <small class="text-muted">Gider kayitlari ve kategori takibi</small>
  </div>
  <button class="btn btn-outline-primary ms-auto" @onclick="LoadAsync" disabled="@_isLoading">
    <i class="fas @(_isLoading ? "fa-spinner fa-spin" : "fa-sync-alt") me-1"></i>Yenile
  </button>
</div>

@if (_isLoading)
{
  <LoadingSpinner />
}
else if (_errorMessage is not null)
{
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i>@_errorMessage
    <div class="mt-2">
      <button class="btn btn-sm btn-outline-danger" @onclick="LoadAsync">
        <i class="fas fa-redo me-1"></i>Tekrar Dene
      </button>
    </div>
    <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
  </div>
}
else if (_expenses.Count == 0)
{
  <EmptyState Icon="fa-file-invoice-dollar" Message="Henuz gider kaydi bulunamadi. Ilk giderinizi ekleyin." />
}
else
{
  <!-- KPI Cards -->
  <div class="row g-3 mb-4">
    <KpiCard Icon="fa-receipt" Value="@_expenses.Count.ToString()" Label="Toplam Kayit" TextColor="text-primary" />
    <KpiCard Icon="fa-money-bill-wave" Value="@($"{_expenses.Sum(e => e.Tutar):N0} TL")" Label="Toplam Gider" TextColor="text-danger" />
    <KpiCard Icon="fa-calendar-day" Value="@($"{_expenses.Where(e => e.Tarih.Month == DateTime.Today.Month).Sum(e => e.Tutar):N0} TL")" Label="Bu Ay" TextColor="text-warning" />
    <KpiCard Icon="fa-tags" Value="@_expenses.Select(e => e.Kategori).Distinct().Count().ToString()" Label="Kategori" TextColor="text-info" />
  </div>

  <!-- Expenses Table -->
  <div class="card shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between">
      <h6 class="mb-0"><i class="fas fa-list me-2" ></i>Gider Listesi</h6>
      <span class="badge bg-secondary">@_expenses.Count kayit</span>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Tarih</th>
              <th>Aciklama</th>
              <th>Kategori</th>
              <th class="text-end">Tutar</th>
              <th class="d-none d-md-table-cell">Odeme Yontemi</th>
              <th class="text-center">Durum</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var expense in _expenses)
            {
              <tr>
                <td><small>@expense.Tarih.ToString("dd.MM.yyyy")</small></td>
                <td class="fw-semibold">@expense.Aciklama</td>
                <td>
                  <span class="badge bg-light text-dark">
                    <i class="fas @expense.KategoriIcon me-1"></i>@expense.Kategori
                  </span>
                </td>
                <td class="text-end fw-bold text-danger">@expense.Tutar.ToString("N2") TL</td>
                <td class="d-none d-md-table-cell">@expense.OdemeYontemi</td>
                <td class="text-center">
                  <StatusBadge Text="@expense.Durum" Variant="@GetStatusVariant(expense.Durum)" />
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
}

@code {
    private bool _isLoading = true;
    private bool _isDemoMode;
    private string? _errorMessage;
    private List<ExpenseItem> _expenses = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await ApiClient.SafeGetAsync<List<object>>("finance/expenses");
            if (result.IsSuccess && result.Data is { Count: > 0 })
            {
                _isDemoMode = false;
                try
                {
                    var json = System.Text.Json.JsonSerializer.Serialize(result.Data);
                    _expenses = System.Text.Json.JsonSerializer.Deserialize<List<ExpenseItem>>(json,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true })
                        ?? GetDemoData();
                }
                catch { _expenses = GetDemoData(); _isDemoMode = true; }
            }
            else
            {
                _isDemoMode = true;
                _expenses = GetDemoData();
            }
        }
        catch (Exception ex)
        {
            _isDemoMode = true;
            _expenses = GetDemoData();
            Logger.LogWarning(ex, "API error, falling back to demo mode");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private static string GetStatusVariant(string durum) => durum switch
    {
        "Odendi" => "success",
        "Bekliyor" => "warning",
        "Iptal" => "danger",
        _ => "secondary"
    };

    private static List<ExpenseItem> GetDemoData() =>
    [
        new(DateTime.Today.AddDays(-1), "Yurtici Kargo aylik fatura", "Kargo", "fa-truck", 6_780m, "Otomatik Odeme", "Odendi"),
        new(DateTime.Today.AddDays(-3), "Azure hosting + CDN", "Teknoloji", "fa-cloud", 3_200m, "Kredi Karti", "Odendi"),
        new(DateTime.Today.AddDays(-5), "Google Ads kampanya", "Pazarlama", "fa-bullhorn", 4_250m, "Kredi Karti", "Odendi"),
        new(DateTime.Today.AddDays(-7), "Aras Kargo faturasi", "Kargo", "fa-truck", 5_430m, "Havale/EFT", "Bekliyor"),
        new(DateTime.Today.AddDays(-10), "Ofis kirasi", "Genel Gider", "fa-building", 12_500m, "Havale/EFT", "Odendi"),
        new(DateTime.Today.AddDays(-12), "Muhasebeci ucreti", "Hizmet", "fa-calculator", 3_500m, "Havale/EFT", "Odendi"),
        new(DateTime.Today.AddDays(-15), "Ambalaj malzemesi", "Uretim", "fa-box", 2_150m, "Kredi Karti", "Odendi"),
        new(DateTime.Today.AddDays(-20), "Instagram reklam", "Pazarlama", "fa-bullhorn", 1_800m, "Kredi Karti", "Bekliyor"),
    ];

    private record ExpenseItem(DateTime Tarih, string Aciklama, string Kategori, string KategoriIcon,
        decimal Tutar, string OdemeYontemi, string Durum);
}
