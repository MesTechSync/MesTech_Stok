@page "/finans/banka"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject ILogger<BankAccounts> Logger

<PageTitle>MesTech - Banka Hesaplari</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
  <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
       style="width: 48px; height: 48px; background-color: #2855AC;">
    <i class="fas fa-building-columns text-white"></i>
  </div>
  <div>
    <h3 class="mb-0" style="color: #2855AC;">Banka Hesaplari</h3>
    <small class="text-muted">Banka hesap bakiyeleri ve hareketler</small>
  </div>
  <button class="btn btn-outline-primary ms-auto" @onclick="LoadAsync" disabled="@_isLoading">
    <i class="fas @(_isLoading ? "fa-spinner fa-spin" : "fa-sync-alt") me-1"></i>Yenile
  </button>
</div>

@if (_isLoading)
{
  <LoadingSpinner />
}
else if (_errorMessage is not null)
{
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i>@_errorMessage
    <div class="mt-2">
      <button class="btn btn-sm btn-outline-danger" @onclick="LoadAsync">
        <i class="fas fa-redo me-1"></i>Tekrar Dene
      </button>
    </div>
    <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
  </div>
}
else if (_accounts.Count == 0)
{
  <EmptyState Icon="fa-building-columns" Message="Henuz banka hesabi tanimlanmamis. Ilk hesabinizi ekleyin." />
}
else
{
  <!-- KPI Cards -->
  <div class="row g-3 mb-4">
    <KpiCard Icon="fa-building-columns" Value="@_accounts.Count.ToString()" Label="Hesap Sayisi" TextColor="text-primary" />
    <KpiCard Icon="fa-coins" Value="@($"{_accounts.Sum(a => a.Bakiye):N0} TL")" Label="Toplam Bakiye" TextColor="text-success" />
    <KpiCard Icon="fa-check-circle" Value="@_accounts.Count(a => a.Aktif).ToString()" Label="Aktif Hesap" TextColor="text-info" />
    <KpiCard Icon="fa-sync-alt" Value="@_accounts.Count(a => a.OtomatikEkstre).ToString()" Label="Otomatik Ekstre" TextColor="text-warning" />
  </div>

  <!-- Accounts Table -->
  <div class="card shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between">
      <h6 class="mb-0"><i class="fas fa-list me-2" style="color: #2855AC;"></i>Hesap Listesi</h6>
      <span class="badge bg-secondary">@_accounts.Count hesap</span>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Banka</th>
              <th>Hesap Adi</th>
              <th class="d-none d-md-table-cell">IBAN</th>
              <th class="text-end">Bakiye</th>
              <th class="d-none d-sm-table-cell">Para Birimi</th>
              <th class="text-center">Durum</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var account in _accounts)
            {
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <i class="fas fa-university" style="color: @account.Renk;"></i>
                    <span class="fw-semibold">@account.Banka</span>
                  </div>
                </td>
                <td>@account.HesapAdi</td>
                <td class="d-none d-md-table-cell">
                  <code style="font-size: 0.8rem;">@account.IBAN</code>
                </td>
                <td class="text-end fw-bold @(account.Bakiye >= 0 ? "text-success" : "text-danger")">
                  @account.Bakiye.ToString("N2") @account.ParaBirimi
                </td>
                <td class="d-none d-sm-table-cell">
                  <span class="badge bg-light text-dark">@account.ParaBirimi</span>
                </td>
                <td class="text-center">
                  <StatusBadge Text="@(account.Aktif ? "Aktif" : "Pasif")"
                               Variant="@(account.Aktif ? "success" : "secondary")" />
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
}

@code {
    private bool _isLoading = true;
    private bool _isDemoMode;
    private string? _errorMessage;
    private List<BankAccountItem> _accounts = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await ApiClient.SafeGetAsync<List<BankAccountItem>>("api/v1/finance/bank-accounts");
            if (result.IsSuccess && result.Data is { Count: > 0 })
            {
                _isDemoMode = false;
                _accounts = result.Data;
            }
            else
            {
                _isDemoMode = true;
                _accounts = GetDemoData();
            }
        }
        catch (Exception ex)
        {
            _isDemoMode = true;
            _accounts = GetDemoData();
            Logger.LogWarning(ex, "API error, falling back to demo mode");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private static List<BankAccountItem> GetDemoData() =>
    [
        new("Ziraat Bankasi", "#006B3F", "Ana Isletme Hesabi", "TR33 0001 0000 1234 5678 9012 34", 287_450.75m, "TRY", true, true),
        new("Garanti BBVA", "#00854A", "Trendyol Hesaplasma", "TR55 0006 2000 5678 0012 3456 78", 145_320.00m, "TRY", true, true),
        new("Is Bankasi", "#003399", "Doviz Hesabi", "TR77 0006 4000 0012 3456 7890 12", 12_500.00m, "USD", true, false),
        new("Yapi Kredi", "#0066CC", "Tedarikci Odeme", "TR99 0006 7000 0012 3456 7890 12", 68_750.25m, "TRY", true, true),
        new("Halkbank", "#004C99", "Yedek Hesap", "TR11 0001 2000 0012 3456 7890 12", 15_000.00m, "TRY", false, false),
    ];

    private record BankAccountItem(string Banka, string Renk, string HesapAdi, string IBAN,
        decimal Bakiye, string ParaBirimi, bool Aktif, bool OtomatikEkstre);
}
