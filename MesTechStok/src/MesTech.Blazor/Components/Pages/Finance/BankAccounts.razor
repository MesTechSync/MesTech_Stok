@page "/finans/banka"
@attribute [Authorize]
@inject MesTechApiClient ApiClient

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-warning" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@errorMessage
    </div>
}
else
{
    <div class="d-flex align-items-center mb-4">
      <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
           style="width: 48px; height: 48px; background-color: #2855AC;">
        <i class="fas fa-building-columns text-white"></i>
      </div>
      <div>
        <h3 class="mb-0" style="color: #2855AC;">Banka Hesaplari</h3>
        <small class="text-muted">Banka hesap bakiyeleri ve hareketler</small>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body text-center py-5">
        <i class="fas fa-building-columns fa-3x mb-3 d-block" style="color: #2855AC; opacity: 0.3;"></i>
        <h5 class="text-muted">Banka Hesaplari</h5>
        <p class="text-muted mb-0">Banka hesap tanimlari, bakiye sorgulama, ekstre eslestirme ve mutabakat.</p>
      </div>
    </div>

    <div class="alert alert-secondary mt-4" role="alert">
      <i class="fas fa-clock me-2"></i>
      <strong>Dalga 11:</strong> Bu sayfa Dalga 11'de tamamlanacak. Banka hesaplari CRUD,
      otomatik ekstre cekme ve mutabakat motoru eklenecek.
    </div>
}

@code {
    private bool isLoading = true;
    private bool _isDemoMode;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await ApiClient.SafeGetAsync<List<object>>("finance/bank-accounts");
            if (result.IsSuccess) { /* TODO: map result.Data */ }
            else { _isDemoMode = true; }
        }
        catch (Exception ex)
        {
            errorMessage = $"Veri yuklenirken hata: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
