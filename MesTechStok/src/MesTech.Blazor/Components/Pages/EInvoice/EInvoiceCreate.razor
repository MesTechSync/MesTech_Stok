@page "/e-invoices/create"
@attribute [Authorize]
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject MesTechApiClient ApiClient

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
        <i class="fas fa-plus-circle text-white"></i>
    </div>
    <div>
        <h3 class="mb-0" style="color: #2855AC;">Yeni E-Fatura Olustur</h3>
        <small class="text-muted">E-Fatura, e-Arsiv, e-SMM veya e-Ihracat faturasi olusturun</small>
    </div>
</div>

<!-- Back button -->
<div class="mb-3">
    <button class="btn btn-outline-secondary btn-sm" @onclick="GoBack">
        <i class="fas fa-arrow-left me-1"></i>Fatura Listesine Don
    </button>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else
{
    @if (successMessage is not null)
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            <i class="fas fa-check-circle me-2"></i>@successMessage
            <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
        </div>
    }

    @if (errorMessage is not null)
    {
        <div class="alert alert-warning" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@errorMessage
        </div>
    }

    <!-- Senaryo Secimi -->
    <div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h6 class="mb-0"><i class="fas fa-file-alt me-2"></i>Fatura Senaryosu</h6>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Senaryo</label>
                <select class="form-select form-select-sm" @bind="form.Senaryo">
                    <option value="eFatura">e-Fatura</option>
                    <option value="eArsiv">e-Arsiv</option>
                    <option value="eSMM">e-SMM</option>
                    <option value="eIhracat">e-Ihracat</option>
                </select>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Fatura Tarihi</label>
                <input type="date" class="form-control form-control-sm" @bind="form.Tarih" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Fatura No</label>
                <input type="text" class="form-control form-control-sm" @bind="form.FaturaNo"
                       placeholder="Otomatik olusturulacak" readonly />
            </div>
        </div>
    </div>
</div>

<!-- Alici Bilgileri -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h6 class="mb-0"><i class="fas fa-user-tie me-2"></i>Alici Bilgileri</h6>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">VKN / TCKN</label>
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control" @bind="form.AliciVkn"
                           placeholder="Vergi / TC Kimlik No" maxlength="11" />
                    <button class="btn btn-outline-primary" @onclick="CheckVkn" disabled="@isVknChecking">
                        <i class="fas @(isVknChecking ? "fa-spinner fa-spin" : "fa-search") me-1"></i>Sorgula
                    </button>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Unvan</label>
                <input type="text" class="form-control form-control-sm" @bind="form.AliciUnvan"
                       placeholder="Sirket / Kisi adi" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold">Vergi Dairesi</label>
                <input type="text" class="form-control form-control-sm" @bind="form.VergiDairesi"
                       placeholder="Vergi dairesi" />
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold">Adres</label>
                <textarea class="form-control form-control-sm" rows="2" @bind="form.Adres"
                          placeholder="Fatura adresi"></textarea>
            </div>
        </div>
    </div>
</div>

<!-- Fatura Kalemleri -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="fas fa-list me-2"></i>Fatura Kalemleri</h6>
        <button class="btn btn-sm btn-outline-primary" @onclick="AddLine">
            <i class="fas fa-plus me-1"></i>Kalem Ekle
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="min-width: 200px;">Urun / Hizmet Adi</th>
                        <th style="width: 100px;">Miktar</th>
                        <th style="width: 130px;">Birim Fiyat</th>
                        <th style="width: 120px;">KDV Orani</th>
                        <th class="text-end" style="width: 130px;">Tutar</th>
                        <th style="width: 50px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var idx = 0; idx < lines.Count; idx++)
                    {
                        var i = idx;
                        <tr>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                       @bind="lines[i].UrunAdi" placeholder="Urun veya hizmet adi" />
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm"
                                       @bind="lines[i].Miktar" min="1" step="1" />
                            </td>
                            <td>
                                <input type="number" class="form-control form-control-sm"
                                       @bind="lines[i].BirimFiyat" min="0" step="0.01" />
                            </td>
                            <td>
                                <select class="form-select form-select-sm" @bind="lines[i].KdvOrani">
                                    <option value="0">%0</option>
                                    <option value="1">%1</option>
                                    <option value="10">%10</option>
                                    <option value="20">%20</option>
                                </select>
                            </td>
                            <td class="text-end align-middle fw-bold">
                                @lines[i].ToplamTutar.ToString("N2") TL
                            </td>
                            <td class="text-center align-middle">
                                @if (lines.Count > 1)
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveLine(i)">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Tutar Ozeti -->
<div class="row justify-content-end mb-4">
    <div class="col-12 col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Ara Toplam:</span>
                    <span class="fw-bold">@AraToplam.ToString("N2") TL</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">KDV Toplam:</span>
                    <span class="fw-bold">@KdvToplam.ToString("N2") TL</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <span class="fw-bold text-primary">Genel Toplam:</span>
                    <span class="fw-bold text-primary fs-5">@GenelToplam.ToString("N2") TL</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Submit -->
<div class="d-flex gap-2 justify-content-end mb-5">
    <button class="btn btn-outline-secondary" @onclick="GoBack">
        <i class="fas fa-times me-1"></i>Vazgec
    </button>
    <button class="btn btn-primary" @onclick="SubmitInvoice" disabled="@isSubmitting">
        @if (isSubmitting)
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
        }
        <i class="fas fa-check me-1"></i>Fatura Olustur
    </button>
</div>

} @* end isLoading else *@

@code {
    private class InvoiceFormModel
    {
        public string Senaryo { get; set; } = "eFatura";
        public DateTime Tarih { get; set; } = DateTime.Today;
        public string FaturaNo { get; set; } = string.Empty;
        public string AliciVkn { get; set; } = string.Empty;
        public string AliciUnvan { get; set; } = string.Empty;
        public string VergiDairesi { get; set; } = string.Empty;
        public string Adres { get; set; } = string.Empty;
    }

    private class InvoiceLineItem
    {
        public string UrunAdi { get; set; } = string.Empty;
        public int Miktar { get; set; } = 1;
        public decimal BirimFiyat { get; set; }
        public int KdvOrani { get; set; } = 20;
        public decimal AraTutar => Miktar * BirimFiyat;
        public decimal KdvTutar => AraTutar * KdvOrani / 100m;
        public decimal ToplamTutar => AraTutar + KdvTutar;
    }

    private bool isLoading = true;
    private bool _isDemoMode;
    private InvoiceFormModel form = new();
    private List<InvoiceLineItem> lines = [new()];
    private bool isSubmitting;
    private bool isVknChecking;
    private string? errorMessage;
    private string? successMessage;

    private decimal AraToplam => lines.Sum(l => l.AraTutar);
    private decimal KdvToplam => lines.Sum(l => l.KdvTutar);
    private decimal GenelToplam => lines.Sum(l => l.ToplamTutar);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            errorMessage = $"Sayfa yuklenirken hata: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddLine() => lines.Add(new InvoiceLineItem());

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < lines.Count && lines.Count > 1)
            lines.RemoveAt(index);
    }

    private async Task CheckVkn()
    {
        if (string.IsNullOrWhiteSpace(form.AliciVkn)) return;

        isVknChecking = true;
        try
        {
            var result = await ApiClient.CheckVknAsync(form.AliciVkn);
            if (result is not null)
            {
                // TODO: map API result to form fields when typed DTO finalized
                _isDemoMode = false;
            }
            else
            {
                _isDemoMode = true;
            }
            // Use demo values until typed DTO mapping is available
            form.AliciUnvan = "Ornek Sirket A.S.";
            form.VergiDairesi = "Kadikoy";
            form.Adres = "Ornek Mah. Test Cad. No:1 Istanbul";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"API fallback (CheckVkn): {ex.Message}");
            _isDemoMode = true;
            form.AliciUnvan = "Ornek Sirket A.S.";
            form.VergiDairesi = "Kadikoy";
            form.Adres = "Ornek Mah. Test Cad. No:1 Istanbul";
        }
        finally
        {
            isVknChecking = false;
        }
    }

    private async Task SubmitInvoice()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(form.AliciVkn))
        {
            errorMessage = "Alici VKN/TCKN alani zorunludur.";
            return;
        }

        if (lines.All(l => string.IsNullOrWhiteSpace(l.UrunAdi)))
        {
            errorMessage = "En az bir fatura kalemi girilmelidir.";
            return;
        }

        isSubmitting = true;
        try
        {
            try
            {
                await ApiClient.CreateEInvoiceAsync(new { form.Senaryo, form.Tarih, form.AliciVkn, form.AliciUnvan, form.VergiDairesi, form.Adres, Lines = lines.Select(l => new { l.UrunAdi, l.Miktar, l.BirimFiyat, l.KdvOrani }) });
            }
            catch (Exception apiEx)
            {
                Console.WriteLine($"API fallback (EInvoiceCreate): {apiEx.Message}");
                _isDemoMode = true;
                await Task.Delay(800); // simulate when API unavailable
            }
            successMessage = "Fatura basariyla olusturuldu!";
            await Task.Delay(1000);
            Nav.NavigateTo("/e-invoices");
        }
        catch (Exception ex)
        {
            errorMessage = $"Fatura olusturulurken hata olustu: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/e-invoices");
}
