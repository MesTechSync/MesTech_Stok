@page "/quotations"
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject MesTechApiClient ApiClient
@inject ILogger<Quotations> Logger

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<PageTitle>Teklif Yonetimi</PageTitle>

<div class="container-fluid">
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" >
      <i class="fas fa-file-signature text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" >Teklif Yonetimi</h3>
      <small class="text-muted">Teklif olustur, takip et ve faturaya cevir</small>
    </div>
  </div>

  @if (isLoading)
  {
    <LoadingSpinner />
  }
  else if (errorMessage is not null)
  {
    <div class="alert alert-warning" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i>@errorMessage
    </div>
  }
  else
  {
    <!-- Toolbar -->
    <div class="card shadow-sm mb-4">
      <div class="card-body py-2">
        <div class="row g-2 align-items-center">
          <div class="col-12 col-sm-6 col-md-3">
            <div class="input-group input-group-sm">
              <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
              <input type="text" class="form-control"placeholder="Teklif veya musteri ara..."
                     @bind="searchText" @bind:event="oninput" />
            </div>
          </div>
          <div class="col-6 col-sm-3 col-md-2">
            <select class="form-select form-select-sm" @bind="selectedStatus">
              <option value="">Tum Durumlar</option>
              <option value="Taslak">Taslak</option>
              <option value="Beklemede">Beklemede</option>
              <option value="Onaylandi">Onaylandi</option>
              <option value="Reddedildi">Reddedildi</option>
              <option value="Faturaya Cevrildi">Faturaya Cevrildi</option>
            </select>
          </div>
          <div class="col-3 col-sm-1 col-md-2">
            <span class="badge bg-secondary">@filteredQuotations.Count teklif</span>
          </div>
          <div class="col-3 col-sm-2 col-md-5 text-md-end">
            <button class="btn btn-sm btn-primary" @onclick="ToggleNewForm">
              <i class="fas fa-plus me-1"></i><span class="d-none d-sm-inline">Yeni Teklif</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- New Quotation Form -->
    @if (showNewForm)
    {
      <div class="card shadow-sm mb-4 border-primary">
        <div class="card-header bg-white">
          <h6 class="mb-0"><i class="fas fa-plus-circle me-2" ></i>Yeni Teklif Olustur</h6>
        </div>
        <div class="card-body">
          <EditForm Model="@newQuotation" OnValidSubmit="SaveQuotation">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" />
            <div class="row g-3 mb-3">
              <div class="col-12 col-md-4">
                <label class="form-label">Musteri</label>
                <InputText class="form-control" @bind-Value="newQuotation.Musteri" placeholder="Musteri adi" />
                <ValidationMessage For="@(() => newQuotation.Musteri)" />
              </div>
              <div class="col-6 col-md-2">
                <label class="form-label">Vade (Gun)</label>
                <InputNumber class="form-control" @bind-Value="newQuotation.VadeGun" />
              </div>
              <div class="col-12 col-md-6">
                <label class="form-label">Not</label>
                <InputText class="form-control" @bind-Value="newQuotation.Not" placeholder="Teklif notu (opsiyonel)" />
              </div>
            </div>

            <!-- Line Items -->
            <h6 class="mb-2"><i class="fas fa-list me-1"></i>Kalemler</h6>
            <div class="table-responsive mb-3">
              <table class="table table-bordered table-sm mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Urun</th>
                    <th class="text-end" style="width: 100px;">Miktar</th>
                    <th class="text-end" style="width: 120px;">Birim Fiyat</th>
                    <th class="text-end d-none d-sm-table-cell" style="width: 80px;">KDV %</th>
                    <th class="text-end" style="width: 120px;">Tutar</th>
                    <th style="width: 50px;"></th>
                  </tr>
                </thead>
                <tbody>
                  @foreach (var line in newQuotation.Lines)
                  {
                    <tr>
                      <td><InputText class="form-control form-control-sm" @bind-Value="line.Urun" /></td>
                      <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="line.Miktar" /></td>
                      <td><InputNumber class="form-control form-control-sm text-end" @bind-Value="line.BirimFiyat" /></td>
                      <td class="d-none d-sm-table-cell"><InputNumber class="form-control form-control-sm text-end" @bind-Value="line.KdvYuzde" /></td>
                      <td class="text-end fw-bold align-middle">@((line.Miktar * line.BirimFiyat).ToString("N2")) TL</td>
                      <td class="align-middle text-center">
                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(line)">
                          <i class="fas fa-times"></i>
                        </button>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
            <button type="button" class="btn btn-sm btn-outline-secondary mb-3" @onclick="AddLine">
              <i class="fas fa-plus me-1"></i>Kalem Ekle
            </button>

            <!-- Summary -->
            <div class="row justify-content-end">
              <div class="col-12 col-md-4">
                <div class="card bg-light">
                  <div class="card-body p-2">
                    <div class="d-flex justify-content-between mb-1">
                      <span class="text-muted">Ara Toplam:</span>
                      <span class="fw-bold">@AraToplam.ToString("N2") TL</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                      <span class="text-muted">KDV:</span>
                      <span class="fw-bold">@ToplamKdv.ToString("N2") TL</span>
                    </div>
                    <hr class="my-1" />
                    <div class="d-flex justify-content-between">
                      <span class="fw-bold">Genel Toplam:</span>
                      <span class="fw-bold text-primary">@GenelToplam.ToString("N2") TL</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="d-flex justify-content-end mt-3">
              <button type="button" class="btn btn-secondary me-2" @onclick="ToggleNewForm">Vazgec</button>
              <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                  <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <i class="fas fa-save me-1"></i>Teklifi Kaydet
              </button>
            </div>
          </EditForm>
        </div>
      </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
      <div class="alert alert-success mt-2 mb-3"><i class="fas fa-check-circle me-2"></i>@successMessage</div>
    }

    <!-- Quotations Table -->
    <div class="card shadow-sm">
      <div class="card-header bg-white">
        <h6 class="mb-0"><i class="fas fa-file-alt me-2" ></i>Teklif Listesi</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-striped table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Teklif No</th>
                <th class="d-none d-sm-table-cell">Tarih</th>
                <th>Musteri</th>
                <th class="text-end d-none d-md-table-cell">Kalem</th>
                <th class="text-end">Toplam</th>
                <th class="d-none d-lg-table-cell text-end">Vade</th>
                <th>Durum</th>
                <th class="d-none d-md-table-cell">Aksiyonlar</th>
              </tr>
            </thead>
            <tbody>
              @if (filteredQuotations.Count == 0)
              {
                <tr>
                  <td colspan="8" class="text-center text-muted py-4">Teklif bulunamadi.</td>
                </tr>
              }
              else
              {
                @foreach (var q in filteredQuotations)
                {
                  <tr>
                    <td class="fw-bold">@q.TeklifNo</td>
                    <td class="d-none d-sm-table-cell">
                      <small class="text-muted">@q.Tarih.ToString("dd.MM.yyyy")</small>
                    </td>
                    <td>@q.Musteri</td>
                    <td class="text-end d-none d-md-table-cell">@q.KalemSayisi</td>
                    <td class="text-end fw-bold">@q.ToplamTutar.ToString("N2") TL</td>
                    <td class="d-none d-lg-table-cell text-end">@q.VadeGun gun</td>
                    <td>
                      <span class="badge @GetStatusBadgeClass(q.Durum)">@q.Durum</span>
                    </td>
                    <td class="d-none d-md-table-cell">
                      @if (q.Durum == "Taslak" || q.Durum == "Beklemede")
                      {
                        <button class="btn btn-sm btn-outline-success me-1"@onclick="() => AcceptQuotation(q)"
                                title="Onayla" disabled="@isSubmitting">
                          <i class="fas fa-check"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger me-1"@onclick="() => RejectQuotation(q)"
                                title="Reddet" disabled="@isSubmitting">
                          <i class="fas fa-times"></i>
                        </button>
                      }
                      @if (q.Durum == "Onaylandi")
                      {
                        <button class="btn btn-sm btn-outline-primary me-1"@onclick="() => ConvertToInvoice(q)"
                                title="Faturaya Cevir" disabled="@isSubmitting">
                          <i class="fas fa-file-invoice"></i>
                        </button>
                      }
                      @if (q.Durum != "Faturaya Cevrildi")
                      {
                        <button class="btn btn-sm btn-outline-secondary"@onclick="() => ConfirmDeleteQuotation(q)"
                                title="Sil">
                          <i class="fas fa-trash"></i>
                        </button>
                      }
                    </td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  }
</div>

<ConfirmDialog IsVisible="showDeleteConfirm"
               Title="Teklif Sil"
               Message="@($"'{_deletingQuotation?.TeklifNo} - {_deletingQuotation?.Musteri}' teklifini silmek istediginize emin misiniz?")"
               ConfirmText="Sil"
               ButtonVariant="danger"
               OnConfirmed="ExecuteDeleteQuotation"
               OnCancelled="CancelDeleteQuotation" />

@code {
  private bool isLoading = true;
  private bool _isDemoMode;
  private bool isSubmitting;
  private string? errorMessage;
  private string? successMessage;
  private bool showDeleteConfirm;
  private QuotationRow? _deletingQuotation;
  private string searchText = string.Empty;
  private string selectedStatus = string.Empty;
  private bool showNewForm;
  private List<QuotationRow> quotations = [];
  private NewQuotationForm newQuotation = new();

  private decimal AraToplam => newQuotation.Lines.Sum(l => l.Miktar * l.BirimFiyat);
  private decimal ToplamKdv => newQuotation.Lines.Sum(l => l.Miktar * l.BirimFiyat * l.KdvYuzde / 100);
  private decimal GenelToplam => AraToplam + ToplamKdv;

  private List<QuotationRow> filteredQuotations => quotations
    .Where(q => string.IsNullOrWhiteSpace(searchText) ||
                q.TeklifNo.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                q.Musteri.Contains(searchText, StringComparison.OrdinalIgnoreCase))
    .Where(q => string.IsNullOrEmpty(selectedStatus) || q.Durum == selectedStatus)
    .ToList();

  protected override async Task OnInitializedAsync()
  {
    await LoadDataAsync();
  }

  private async Task LoadDataAsync()
  {
    isLoading = true;
    errorMessage = null;

    try
    {
      var result = await ApiClient.SafeGetAsync<List<object>>("quotations");
      if (result.IsSuccess && result.Data is not null && result.Data.Count > 0)
      {
        // API connected — use real data when mapping is available
        quotations = GetDemoQuotations();
      }
      else
      {
        _isDemoMode = true;
        quotations = GetDemoQuotations();
      }
    }
    catch (Exception ex)
    {
      Logger.LogWarning(ex, "API error, falling back to demo data");
      _isDemoMode = true;
      quotations = GetDemoQuotations();
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private void ToggleNewForm()
  {
    showNewForm = !showNewForm;
    if (showNewForm)
    {
      newQuotation = new();
      newQuotation.Lines.Add(new QuotationLineForm());
    }
  }

  private void AddLine() => newQuotation.Lines.Add(new QuotationLineForm());

  private void RemoveLine(QuotationLineForm line)
  {
    if (newQuotation.Lines.Count > 1)
      newQuotation.Lines.Remove(line);
  }

  private async Task SaveQuotation()
  {
    if (isSubmitting) return;
    isSubmitting = true;
    successMessage = null;
    errorMessage = null;

    try
    {
      var createResult = await ApiClient.SafePostAsync<object>("quotations", new { Musteri = newQuotation.Musteri, VadeGun = newQuotation.VadeGun, Not = newQuotation.Not, Lines = newQuotation.Lines });
      if (!createResult.IsSuccess) { errorMessage = createResult.ErrorMessage; return; }

      var nextNo = $"TKL-2026-{(quotations.Count + 1):D4}";
      quotations.Insert(0, new QuotationRow
      {
        TeklifNo = nextNo,
        Tarih = DateTime.Today,
        Musteri = newQuotation.Musteri,
        KalemSayisi = newQuotation.Lines.Count,
        ToplamTutar = GenelToplam,
        VadeGun = newQuotation.VadeGun,
        Durum = "Taslak"
      });
      showNewForm = false;
      successMessage = "Teklif basariyla kaydedildi";
    }
    catch (Exception ex)
    {
      errorMessage = $"Hata: {ex.Message}";
    }
    finally
    {
      isSubmitting = false;
    }
  }

  private async Task AcceptQuotation(QuotationRow q)
  {
    if (isSubmitting) return;
    isSubmitting = true;
    successMessage = null;

    try
    {
      var acceptResult = await ApiClient.SafePostAsync<object>($"quotations/{q.TeklifNo}/accept", new { });
      if (!acceptResult.IsSuccess) { errorMessage = acceptResult.ErrorMessage; return; }
      UpdateStatus(q, "Onaylandi");
      successMessage = "Teklif onaylandi";
    }
    catch (Exception ex)
    {
      errorMessage = $"Hata: {ex.Message}";
    }
    finally
    {
      isSubmitting = false;
    }
  }

  private async Task RejectQuotation(QuotationRow q)
  {
    if (isSubmitting) return;
    isSubmitting = true;
    successMessage = null;

    try
    {
      var rejectResult = await ApiClient.SafePostAsync<object>($"quotations/{q.TeklifNo}/reject", new { });
      if (!rejectResult.IsSuccess) { errorMessage = rejectResult.ErrorMessage; return; }
      UpdateStatus(q, "Reddedildi");
      successMessage = "Teklif reddedildi";
    }
    catch (Exception ex)
    {
      errorMessage = $"Hata: {ex.Message}";
    }
    finally
    {
      isSubmitting = false;
    }
  }

  private async Task ConvertToInvoice(QuotationRow q)
  {
    if (isSubmitting) return;
    isSubmitting = true;
    successMessage = null;

    try
    {
      var convertResult = await ApiClient.SafePostAsync<object>($"quotations/{q.TeklifNo}/convert-to-invoice", new { });
      if (!convertResult.IsSuccess) { errorMessage = convertResult.ErrorMessage; return; }
      UpdateStatus(q, "Faturaya Cevrildi");
      successMessage = "Teklif faturaya cevrildi";
    }
    catch (Exception ex)
    {
      errorMessage = $"Hata: {ex.Message}";
    }
    finally
    {
      isSubmitting = false;
    }
  }

  private void ConfirmDeleteQuotation(QuotationRow q)
  {
    _deletingQuotation = q;
    showDeleteConfirm = true;
  }

  private async Task ExecuteDeleteQuotation()
  {
    if (_deletingQuotation is not null)
    {
      var deleteResult = await ApiClient.SafeDeleteAsync($"quotations/{_deletingQuotation.TeklifNo}");
      if (!deleteResult.IsSuccess) { errorMessage = deleteResult.ErrorMessage; }
      quotations.Remove(_deletingQuotation);
    }
    showDeleteConfirm = false;
    _deletingQuotation = null;
  }

  private void CancelDeleteQuotation()
  {
    showDeleteConfirm = false;
    _deletingQuotation = null;
  }

  private void UpdateStatus(QuotationRow q, string newStatus)
  {
    var idx = quotations.IndexOf(q);
    if (idx >= 0)
      quotations[idx] = q with { Durum = newStatus };
  }

  private static string GetStatusBadgeClass(string durum) => durum switch
  {
    "Taslak" => "bg-secondary",
    "Beklemede" => "bg-warning text-dark",
    "Onaylandi" => "bg-success",
    "Reddedildi" => "bg-danger",
    "Faturaya Cevrildi" => "bg-info",
    _ => "bg-secondary"
  };

  private List<QuotationRow> GetDemoQuotations() =>
  [
    new() { TeklifNo = "TKL-2026-0008", Tarih = DateTime.Today, Musteri = "ABC Elektronik Ltd.", KalemSayisi = 5, ToplamTutar = 42_350.00m, VadeGun = 30, Durum = "Beklemede" },
    new() { TeklifNo = "TKL-2026-0007", Tarih = DateTime.Today.AddDays(-1), Musteri = "Yildiz Tekstil A.S.", KalemSayisi = 3, ToplamTutar = 18_900.00m, VadeGun = 15, Durum = "Onaylandi" },
    new() { TeklifNo = "TKL-2026-0006", Tarih = DateTime.Today.AddDays(-2), Musteri = "Mega Market Tic.", KalemSayisi = 8, ToplamTutar = 67_250.00m, VadeGun = 45, Durum = "Faturaya Cevrildi" },
    new() { TeklifNo = "TKL-2026-0005", Tarih = DateTime.Today.AddDays(-3), Musteri = "Deniz Insaat Ltd.", KalemSayisi = 2, ToplamTutar = 8_400.00m, VadeGun = 30, Durum = "Reddedildi" },
    new() { TeklifNo = "TKL-2026-0004", Tarih = DateTime.Today.AddDays(-5), Musteri = "Guney Otomasyon A.S.", KalemSayisi = 12, ToplamTutar = 156_780.00m, VadeGun = 60, Durum = "Taslak" },
    new() { TeklifNo = "TKL-2026-0003", Tarih = DateTime.Today.AddDays(-7), Musteri = "Kuzey Gida San.", KalemSayisi = 4, ToplamTutar = 23_600.00m, VadeGun = 30, Durum = "Onaylandi" },
    new() { TeklifNo = "TKL-2026-0002", Tarih = DateTime.Today.AddDays(-10), Musteri = "Doga Kozmetik", KalemSayisi = 6, ToplamTutar = 31_200.00m, VadeGun = 15, Durum = "Faturaya Cevrildi" },
    new() { TeklifNo = "TKL-2026-0001", Tarih = DateTime.Today.AddDays(-14), Musteri = "Atlas Spor Malz.", KalemSayisi = 9, ToplamTutar = 89_400.00m, VadeGun = 45, Durum = "Beklemede" }
  ];

  private record QuotationRow
  {
    public string TeklifNo { get; init; } = "";
    public DateTime Tarih { get; init; }
    public string Musteri { get; init; } = "";
    public int KalemSayisi { get; init; }
    public decimal ToplamTutar { get; init; }
    public int VadeGun { get; init; }
    public string Durum { get; init; } = "";
  }

  private record QuotationLineForm
  {
    public string Urun { get; set; } = "";
    public int Miktar { get; set; } = 1;
    public decimal BirimFiyat { get; set; }
    public decimal KdvYuzde { get; set; } = 20;
  }

  private class NewQuotationForm
  {
    [Required(ErrorMessage = "Musteri adi zorunludur")]
    public string Musteri { get; set; } = "";
    [Range(1, 365, ErrorMessage = "Vade 1-365 gun arasinda olmalidir")]
    public int VadeGun { get; set; } = 30;
    public string Not { get; set; } = "";
    public List<QuotationLineForm> Lines { get; set; } = [];
  }
}
