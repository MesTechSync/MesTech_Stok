@page "/belgeler"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject ILogger<Documents> Logger

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
  <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
       style="width: 48px; height: 48px; background-color: #2855AC;">
    <i class="fas fa-folder-open text-white"></i>
  </div>
  <div>
    <h3 class="mb-0" style="color: #2855AC;">Belgeler</h3>
    <small class="text-muted">Dokuman yonetimi ve arsiv</small>
  </div>
  <button class="btn btn-outline-primary ms-auto" @onclick="LoadAsync" disabled="@_isLoading">
    <i class="fas @(_isLoading ? "fa-spinner fa-spin" : "fa-sync-alt") me-1"></i>Yenile
  </button>
</div>

@if (_isLoading)
{
  <LoadingSpinner />
}
else if (_errorMessage is not null)
{
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i>@_errorMessage
    <div class="mt-2">
      <button class="btn btn-sm btn-outline-danger" @onclick="LoadAsync">
        <i class="fas fa-redo me-1"></i>Tekrar Dene
      </button>
    </div>
    <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
  </div>
}
else if (_documents.Count == 0)
{
  <EmptyState Icon="fa-folder-open" Message="Henuz belge yuklenmemis. Ilk belgenizi yukleyin." />
}
else
{
  <!-- KPI Cards -->
  <div class="row g-3 mb-4">
    <KpiCard Icon="fa-file" Value="@_documents.Count.ToString()" Label="Toplam Belge" TextColor="text-primary" />
    <KpiCard Icon="fa-folder" Value="@_documents.Select(d => d.Klasor).Distinct().Count().ToString()" Label="Klasor" TextColor="text-info" />
    <KpiCard Icon="fa-hdd" Value="@($"{_documents.Sum(d => d.BoyutMB):N1} MB")" Label="Toplam Boyut" TextColor="text-warning" />
    <KpiCard Icon="fa-calendar-day" Value="@_documents.Count(d => d.YuklemeTarihi >= DateTime.Today.AddDays(-7)).ToString()" Label="Bu Hafta" TextColor="text-success" />
  </div>

  <!-- Documents Table -->
  <div class="card shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between">
      <h6 class="mb-0"><i class="fas fa-list me-2" style="color: #2855AC;"></i>Belge Listesi</h6>
      <span class="badge bg-secondary">@_documents.Count belge</span>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Belge Adi</th>
              <th>Klasor</th>
              <th class="d-none d-md-table-cell">Tur</th>
              <th class="text-end d-none d-sm-table-cell">Boyut</th>
              <th class="d-none d-md-table-cell">Yukleyen</th>
              <th>Tarih</th>
              <th class="text-end">Islem</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var doc in _documents)
            {
              <tr>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <i class="fas @GetFileIcon(doc.Tur)" style="color: @GetFileColor(doc.Tur);"></i>
                    <span class="fw-semibold">@doc.Ad</span>
                  </div>
                </td>
                <td>
                  <span class="badge bg-light text-dark">
                    <i class="fas fa-folder me-1"></i>@doc.Klasor
                  </span>
                </td>
                <td class="d-none d-md-table-cell text-uppercase">
                  <small class="text-muted">@doc.Tur</small>
                </td>
                <td class="text-end d-none d-sm-table-cell">@doc.BoyutMB.ToString("N1") MB</td>
                <td class="d-none d-md-table-cell">@doc.Yukleyen</td>
                <td><small>@doc.YuklemeTarihi.ToString("dd.MM.yyyy")</small></td>
                <td class="text-end">
                  <button class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-download"></i>
                  </button>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
}

@code {
    private bool _isLoading = true;
    private bool _isDemoMode;
    private string? _errorMessage;
    private List<DocumentItem> _documents = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await ApiClient.SafeGetAsync<List<object>>("documents");
            if (result.IsSuccess && result.Data is { Count: > 0 })
            {
                _isDemoMode = false;
                try
                {
                    var json = System.Text.Json.JsonSerializer.Serialize(result.Data);
                    _documents = System.Text.Json.JsonSerializer.Deserialize<List<DocumentItem>>(json,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true })
                        ?? GetDemoData();
                }
                catch { _documents = GetDemoData(); _isDemoMode = true; }
            }
            else
            {
                _isDemoMode = true;
                _documents = GetDemoData();
            }
        }
        catch (Exception ex)
        {
            _isDemoMode = true;
            _documents = GetDemoData();
            Logger.LogWarning(ex, "API error, falling back to demo mode");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetFileIcon(string tur) => tur switch
    {
        "pdf" => "fa-file-pdf",
        "xlsx" => "fa-file-excel",
        "docx" => "fa-file-word",
        "png" or "jpg" => "fa-file-image",
        "zip" => "fa-file-archive",
        _ => "fa-file"
    };

    private static string GetFileColor(string tur) => tur switch
    {
        "pdf" => "#dc3545",
        "xlsx" => "#198754",
        "docx" => "#0d6efd",
        "png" or "jpg" => "#6f42c1",
        "zip" => "#fd7e14",
        _ => "#6c757d"
    };

    private static List<DocumentItem> GetDemoData() =>
    [
        new("Mart_2026_Faturalar.zip", "Faturalar", "zip", 24.5m, "Ayse Celik", DateTime.Today.AddDays(-1)),
        new("Yillik_Gelir_Raporu_2025.xlsx", "Raporlar", "xlsx", 3.2m, "Ahmet Yilmaz", DateTime.Today.AddDays(-3)),
        new("Tedarikci_Sozlesmesi_ABC.pdf", "Sozlesmeler", "pdf", 1.8m, "Ali Ozturk", DateTime.Today.AddDays(-5)),
        new("Urun_Katalog_2026.pdf", "Kataloglar", "pdf", 15.7m, "Fatma Demir", DateTime.Today.AddDays(-7)),
        new("Depo_Sayim_Raporu.xlsx", "Raporlar", "xlsx", 2.1m, "Mehmet Kaya", DateTime.Today.AddDays(-10)),
        new("Logo_Tasarim.png", "Medya", "png", 0.8m, "Fatma Demir", DateTime.Today.AddDays(-14)),
        new("Kargo_Anlasma_2026.docx", "Sozlesmeler", "docx", 0.5m, "Ali Ozturk", DateTime.Today.AddDays(-20)),
        new("Stok_Hareket_Raporu.xlsx", "Raporlar", "xlsx", 4.3m, "Ahmet Yilmaz", DateTime.Today.AddDays(-25)),
    ];

    private record DocumentItem(string Ad, string Klasor, string Tur, decimal BoyutMB,
        string Yukleyen, DateTime YuklemeTarihi);
}
