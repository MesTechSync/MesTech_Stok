@page "/siparisler"
@attribute [Authorize]

<div class="d-flex align-items-center mb-4">
  <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
       style="width: 48px; height: 48px; background-color: #2855AC;">
    <i class="fas fa-shopping-cart text-white"></i>
  </div>
  <div>
    <h3 class="mb-0" style="color: #2855AC;">Siparisler</h3>
    <small class="text-muted">Tum platform siparisleri tek ekranda</small>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-body text-center py-5">
    <i class="fas fa-shopping-cart fa-3x mb-3 d-block" style="color: #2855AC; opacity: 0.3;"></i>
    <h5 class="text-muted">Siparis Yonetimi</h5>
    <p class="text-muted mb-0">10 platformdan gelen siparisler, durum takibi, kargo entegrasyonu ve fatura eslestirme.</p>
  </div>
</div>

<div class="alert alert-secondary mt-4" role="alert">
  <i class="fas fa-clock me-2"></i>
  <strong>Dalga 11:</strong> Bu sayfa Dalga 11'de tamamlanacak. Siparis listesi, platform filtresi,
  toplu islem ve kargo takip entegrasyonu eklenecek.
</div>
