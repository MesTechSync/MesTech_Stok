@page "/stok"
@attribute [Authorize]
@inject MesTechApiClient ApiClient

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-warning d-flex align-items-center justify-content-between" role="alert">
        <span><i class="fas fa-exclamation-triangle me-2"></i>@errorMessage</span>
        <button class="btn btn-sm btn-outline-warning" @onclick="LoadDataAsync">
            <i class="fas fa-sync-alt me-1"></i>Tekrar Dene
        </button>
    </div>
}
else
{
    <div class="d-flex align-items-center mb-4">
      <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
           style="width: 48px; height: 48px; background-color: #2855AC;">
        <i class="fas fa-boxes-stacked text-white"></i>
      </div>
      <div>
        <h3 class="mb-0" style="color: #2855AC;">Stok Yonetimi</h3>
        <small class="text-muted">Urun ve depo stok takibi</small>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body text-center py-5">
        <i class="fas fa-boxes-stacked fa-3x mb-3 d-block" style="color: #2855AC; opacity: 0.3;"></i>
        <h5 class="text-muted">Stok Yonetimi</h5>
        <p class="text-muted mb-0">Urun listeleme, stok hareketleri, depo yonetimi ve kritik stok uyarilari.</p>
      </div>
    </div>

    <div class="alert alert-secondary mt-4" role="alert">
      <i class="fas fa-clock me-2"></i>
      <strong>Dalga 11:</strong> Bu sayfa Dalga 11'de tamamlanacak. Urun CRUD, stok hareketleri,
      barkod tarama ve multi-depo stok bolme eklenecek.
    </div>
}

@code {
    private bool isLoading = true;
    private bool _isDemoMode;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var result = await ApiClient.SafeGetAsync<List<object>>("products");
            if (result.IsSuccess) { }
            else { _isDemoMode = true; }
        }
        catch (Exception ex)
        {
            errorMessage = $"Veri yuklenirken hata: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
