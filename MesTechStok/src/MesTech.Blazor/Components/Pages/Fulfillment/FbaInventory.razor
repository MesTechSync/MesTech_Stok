@page "/fulfillment/fba-inventory"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject ILogger<FbaInventory> Logger

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center">
        <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
             style="width: 48px; height: 48px; background-color: #FF9900;">
            <i class="fas fa-warehouse text-white"></i>
        </div>
        <div>
            <h3 class="mb-0" style="color: #FF9900;">FBA Envanter</h3>
            <small class="text-muted">Amazon FBA depolarindaki stok durumu</small>
        </div>
    </div>
    <button class="btn btn-sm btn-outline-primary" @onclick="LoadDataAsync" disabled="@isLoading">
        <i class="fas fa-sync-alt me-1"></i>Yenile
    </button>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger d-flex align-items-center justify-content-between" role="alert">
        <span><i class="fas fa-exclamation-triangle me-2"></i>@errorMessage</span>
        <button class="btn btn-sm btn-outline-danger" @onclick="LoadDataAsync">
            <i class="fas fa-sync-alt me-1"></i>Tekrar Dene
        </button>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <KpiCard Icon="fa-cubes" Value="@_totalSku.ToString()" Label="Toplam SKU" TextColor="text-primary" />
        <KpiCard Icon="fa-box-open" Value="@_totalUnits.ToString("N0")" Label="Toplam Birim" TextColor="text-info" />
        <KpiCard Icon="fa-exclamation-triangle" Value="@_lowStock.ToString()" Label="Dusuk Stok" TextColor="text-warning" />
        <KpiCard Icon="fa-ban" Value="@_outOfStock.ToString()" Label="Stokta Yok" TextColor="text-danger" />
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-th-list me-2"></i>FBA Envanter Listesi</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>SKU</th>
                            <th>Urun Adi</th>
                            <th>ASIN</th>
                            <th class="text-end">FBA Stok</th>
                            <th class="text-end">Yoldaki</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_items?.Count > 0)
                        {
                            @foreach (var item in _items)
                            {
                                <tr>
                                    <td><code>@item.Sku</code></td>
                                    <td>@item.ProductName</td>
                                    <td><code>@item.Asin</code></td>
                                    <td class="text-end fw-bold">@item.FbaQuantity</td>
                                    <td class="text-end">@item.InboundQuantity</td>
                                    <td>
                                        @if (item.FbaQuantity == 0)
                                        {
                                            <span class="badge bg-danger">Stokta Yok</span>
                                        }
                                        else if (item.FbaQuantity < 10)
                                        {
                                            <span class="badge bg-warning">Dusuk Stok</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Yeterli</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="6" class="text-center text-muted py-4">FBA envanterinde urun bulunmuyor.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool _isDemoMode;
    private string? errorMessage;

    private int _totalSku, _totalUnits, _lowStock, _outOfStock;
    private List<FbaInventoryItem>? _items;

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var result = await ApiClient.SafeGetAsync<List<FbaInventoryItem>>("api/v1/fulfillment/fba/inventory");
            if (result.IsSuccess && result.Data != null)
            {
                _items = result.Data;
            }
            else
            {
                _isDemoMode = true;
                _items = GetDemoData();
            }
            _totalSku = _items.Count;
            _totalUnits = _items.Sum(i => i.FbaQuantity);
            _lowStock = _items.Count(i => i.FbaQuantity is > 0 and < 10);
            _outOfStock = _items.Count(i => i.FbaQuantity == 0);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "FBA envanter yuklenirken hata");
            errorMessage = "FBA envanter verileri yuklenirken bir hata olustu.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static List<FbaInventoryItem> GetDemoData() => new()
    {
        new("MT-001", "Kablosuz Mouse", "B0C1D2E3F4", 45, 20),
        new("MT-002", "USB-C Hub 7in1", "B0C1D2E3F5", 8, 50),
        new("MT-003", "Mekanik Klavye", "B0C1D2E3F6", 0, 30),
        new("MT-004", "Monitor Standı", "B0C1D2E3F7", 120, 0),
    };

    private record FbaInventoryItem(string Sku, string ProductName, string Asin, int FbaQuantity, int InboundQuantity);
}
