@page "/shipments/tracking"
@attribute [Authorize]
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject MesTechApiClient ApiClient

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
        <i class="fas fa-truck text-white"></i>
    </div>
    <div>
        <h3 class="mb-0" style="color: #2855AC;">Kargo Takip</h3>
        <small class="text-muted">Gonderi takibi ve kargo firma karsilastirmasi</small>
    </div>
</div>

<!-- Back button -->
<div class="mb-3">
    <button class="btn btn-outline-secondary btn-sm" @onclick="GoToShipments">
        <i class="fas fa-arrow-left me-1"></i>Gonderim Kuyrugune Don
    </button>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}
else
{

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <KpiCard Icon="fa-shipping-fast" Value="@aktifGonderi.ToString()" Label="Aktif Gonderi" TextColor="text-primary" />
    <KpiCard Icon="fa-clock" Value="@ortalamaGun" Label="Ort. Teslimat" TextColor="text-info" />
    <KpiCard Icon="fa-undo" Value="@iadeOrani" Label="Iade Orani" TextColor="text-danger" />
    <KpiCard Icon="fa-check-circle" Value="@teslimOrani" Label="Teslim Orani" TextColor="text-success" />
</div>

<!-- Tracking Input -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h6 class="mb-0"><i class="fas fa-barcode me-2"></i>Gonderi Sorgula</h6>
    </div>
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-6">
                <label class="form-label fw-semibold">Barkod / Takip Numarasi</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" class="form-control" @bind="trackingNumber"
                           placeholder="Takip numarasi veya barkod girin..." />
                    <button class="btn btn-primary" @onclick="SearchTracking" disabled="@isSearching">
                        @if (isSearching)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="fas fa-search me-1"></i>Sorgula
                    </button>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="QuickSearchYurtici">
                        <i class="fas fa-bolt me-1"></i>Yurtici Ornek
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="QuickSearchAras">
                        <i class="fas fa-bolt me-1"></i>Aras Ornek
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success mt-2 mb-3"><i class="fas fa-check-circle me-2"></i>@successMessage</div>
}

<!-- Tracking Result -->
@if (trackingResult is not null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="fas fa-route me-2"></i>Takip Sonucu — @trackingResult.TakipNo</h6>
            <StatusBadge Text="@trackingResult.Durum" Variant="@GetTrackingVariant(trackingResult.Durum)" />
        </div>
        <div class="card-body">
            <!-- Shipment Info -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <small class="text-muted d-block">Kargo Firma</small>
                    <span class="fw-bold">@trackingResult.KargoFirma</span>
                </div>
                <div class="col-6 col-md-3">
                    <small class="text-muted d-block">Alici</small>
                    <span class="fw-bold">@trackingResult.Alici</span>
                </div>
                <div class="col-6 col-md-3">
                    <small class="text-muted d-block">Gonderim Tarihi</small>
                    <span>@trackingResult.GonderimTarihi.ToString("dd.MM.yyyy")</span>
                </div>
                <div class="col-6 col-md-3">
                    <small class="text-muted d-block">Tahmini Teslim</small>
                    <span>@trackingResult.TahminiTeslim.ToString("dd.MM.yyyy")</span>
                </div>
            </div>

            <!-- Timeline Steps -->
            <div class="position-relative">
                @for (var i = 0; i < trackingSteps.Count; i++)
                {
                    var step = trackingSteps[i];
                    var isActive = i <= activeStepIndex;
                    var isCurrent = i == activeStepIndex;
                    <div class="d-flex align-items-start mb-3">
                        <div class="d-flex flex-column align-items-center me-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 36px; height: 36px; min-width: 36px;
                                        background-color: @(isActive ? "#2855AC" : "#e9ecef");
                                        border: @(isCurrent ? "3px solid #0d6efd" : "none");">
                                <i class="fas @step.Icon @(isActive ? "text-white" : "text-muted")"
                                   style="font-size: 0.8rem;"></i>
                            </div>
                            @if (i < trackingSteps.Count - 1)
                            {
                                <div style="width: 2px; height: 30px; background-color: @(isActive ? "#2855AC" : "#e9ecef");"></div>
                            }
                        </div>
                        <div class="pt-1">
                            <span class="fw-semibold @(isCurrent ? "text-primary" : "")">@step.Baslik</span>
                            @if (step.Tarih.HasValue)
                            {
                                <small class="text-muted d-block">@step.Tarih.Value.ToString("dd.MM.yyyy HH:mm")</small>
                            }
                            @if (!string.IsNullOrEmpty(step.Aciklama))
                            {
                                <small class="text-muted d-block">@step.Aciklama</small>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else if (trackingSearched && trackingResult is null)
{
    <EmptyState Icon="fa-search" Message="Bu takip numarasi ile gonderi bulunamadi." />
}

<!-- Kargo Firma Karsilastirma -->
<div class="card shadow-sm mb-5">
    <div class="card-header bg-white">
        <h6 class="mb-0"><i class="fas fa-balance-scale me-2"></i>Kargo Firma Karsilastirmasi</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kargo Firma</th>
                        <th class="text-end">Ort. Sure (gun)</th>
                        <th class="text-end d-none d-sm-table-cell">Ort. Fiyat (TL)</th>
                        <th class="text-end d-none d-md-table-cell">Teslim Orani (%)</th>
                        <th class="text-end d-none d-lg-table-cell">Gonderi Sayisi</th>
                        <th>Performans</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cargo in cargoComparisons)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fas fa-truck" style="color: @cargo.Color;"></i>
                                    <span class="fw-semibold">@cargo.Firma</span>
                                </div>
                            </td>
                            <td class="text-end">@cargo.OrtalamaSure.ToString("N1")</td>
                            <td class="text-end d-none d-sm-table-cell">@cargo.OrtalamaFiyat.ToString("N2")</td>
                            <td class="text-end d-none d-md-table-cell">%@cargo.TeslimOrani.ToString("N1")</td>
                            <td class="text-end d-none d-lg-table-cell">@cargo.GonderiSayisi</td>
                            <td>
                                <div class="progress" style="height: 20px; min-width: 80px;">
                                    <div class="progress-bar @GetProgressClass(cargo.TeslimOrani)"
                                         role="progressbar"
                                         style="width: @cargo.TeslimOrani%;">
                                        %@cargo.TeslimOrani.ToString("N0")
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

} @* end isLoading else *@

@code {
    private record TrackingResult(string TakipNo, string KargoFirma, string Alici, string Durum,
        DateTime GonderimTarihi, DateTime TahminiTeslim);

    private record TrackingStep(string Baslik, string Icon, DateTime? Tarih, string? Aciklama);

    private record CargoCompare(string Firma, string Color, decimal OrtalamaSure, decimal OrtalamaFiyat,
        decimal TeslimOrani, int GonderiSayisi);

    private bool isLoading = true;
    private bool isSubmitting;
    private bool _isDemoMode;
    private string? errorMessage;
    private string? successMessage;

    private TrackingResult? trackingResult;
    private List<TrackingStep> trackingSteps = [];
    private int activeStepIndex = -1;
    private List<CargoCompare> cargoComparisons = [];

    private string trackingNumber = string.Empty;
    private bool isSearching;
    private bool trackingSearched;

    // KPI values
    private int aktifGonderi = 47;
    private string ortalamaGun = "2.3 gun";
    private string iadeOrani = "%4.2";
    private string teslimOrani = "%96.8";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadComparisonData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Sayfa yuklenirken hata: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadComparisonData()
    {
        try
        {
            var result = await ApiClient.GetCargoComparisonAsync();
            if (result is { Count: > 0 })
            {
                _isDemoMode = false;
                // TODO: map API response to CargoCompare when DTO finalized
            }
            else
            {
                _isDemoMode = true;
            }
        }
        catch (Exception apiEx)
        {
            Console.WriteLine($"API error, using demo data: {apiEx.Message}");
            _isDemoMode = true;
        }

        if (_isDemoMode)
        {
            cargoComparisons = GetDemoComparisons();
        }
    }

    private static List<CargoCompare> GetDemoComparisons() =>
    [
        new("Yurtici Kargo", "#E30613", 2.1m, 42.50m, 97.5m, 1850),
        new("Aras Kargo", "#FF6F00", 2.4m, 38.00m, 95.8m, 1240),
        new("Surat Kargo", "#00897B", 2.8m, 35.00m, 93.2m, 680),
    ];

    private async Task SearchTracking()
    {
        if (string.IsNullOrWhiteSpace(trackingNumber)) return;
        if (isSubmitting) return;
        isSubmitting = true;
        isSearching = true;
        trackingSearched = false;
        successMessage = null;
        errorMessage = null;

        try
        {
            try
            {
                var apiResult = await ApiClient.GetShipmentTrackingAsync(trackingNumber);
                if (apiResult is not null)
                {
                    _isDemoMode = false;
                    // TODO: map API response to TrackingResult when DTO finalized
                }
                else
                {
                    _isDemoMode = true;
                }
            }
            catch (Exception apiEx)
            {
                Console.WriteLine($"API error, using demo data: {apiEx.Message}");
                _isDemoMode = true;
            }

            trackingResult = new TrackingResult(
                trackingNumber,
                trackingNumber.StartsWith("YK") ? "Yurtici Kargo" : trackingNumber.StartsWith("AR") ? "Aras Kargo" : "Surat Kargo",
                "Ahmet Yilmaz",
                "Dagitimda",
                DateTime.Today.AddDays(-2),
                DateTime.Today.AddDays(1));

            trackingSteps =
            [
                new("Hazirlaniyor", "fa-box", DateTime.Today.AddDays(-2).AddHours(10), "Paket hazirlik asamasinda"),
                new("Kargoya Verildi", "fa-warehouse", DateTime.Today.AddDays(-2).AddHours(14), "Transfer merkezine teslim edildi"),
                new("Aktarma Merkezinde", "fa-exchange-alt", DateTime.Today.AddDays(-1).AddHours(8), "Istanbul Anadolu aktarma merkezi"),
                new("Dagitimda", "fa-truck", DateTime.Today.AddHours(9), "Dagitim aracina yuklendi"),
                new("Teslim Edildi", "fa-check-circle", null, null),
            ];
            activeStepIndex = 3; // Dagitimda
            successMessage = "Gonderi bilgileri basariyla getirildi";
        }
        catch
        {
            trackingResult = null;
        }
        finally
        {
            isSearching = false;
            isSubmitting = false;
            trackingSearched = true;
        }
    }

    private async Task QuickSearch(string number)
    {
        trackingNumber = number;
        await SearchTracking();
    }

    private async Task QuickSearchYurtici() => await QuickSearch("YK-12345678");
    private async Task QuickSearchAras() => await QuickSearch("AR-87654321");
    private void GoToShipments() => Nav.NavigateTo("/shipments");

    private static string GetTrackingVariant(string durum) => durum switch
    {
        "Hazirlaniyor" => "info",
        "Kargoya Verildi" => "primary",
        "Dagitimda" => "warning",
        "Teslim Edildi" => "success",
        _ => "secondary"
    };

    private static string GetProgressClass(decimal oran) => oran switch
    {
        >= 96 => "bg-success",
        >= 93 => "bg-warning",
        _ => "bg-danger"
    };
}
