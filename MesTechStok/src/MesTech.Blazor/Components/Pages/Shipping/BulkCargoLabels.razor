@page "/shipping/bulk-labels"
@attribute [Authorize]
@inject NavigationManager Nav
@inject MesTechApiClient ApiClient

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
        <i class="fas fa-tags text-white"></i>
    </div>
    <div>
        <h3 class="mb-0" style="color: #2855AC;">Toplu Kargo Etiketi</h3>
        <small class="text-muted">Siparis secimi ve toplu etiket yazdirma</small>
    </div>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}
else
{

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="fas fa-cog me-2"></i>Etiket Ayarlari</h6>
        <span class="badge bg-primary">@orders.Count(o => o.Selected) siparis secili</span>
    </div>
    <div class="card-body">
        <EditForm Model="@_labelSettings" OnValidSubmit="GenerateLabels">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" />
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold">Kargo Firmasi</label>
                    <InputSelect class="form-select" @bind-Value="_labelSettings.Carrier">
                        <option value="">Secin...</option>
                        <option value="yurtici">Yurtici Kargo</option>
                        <option value="aras">Aras Kargo</option>
                        <option value="surat">Surat Kargo</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => _labelSettings.Carrier)" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold">Etiket Formati</label>
                    <InputSelect class="form-select" @bind-Value="_labelSettings.Format">
                        <option value="">Secin...</option>
                        <option value="A4">A4 Kagit</option>
                        <option value="thermal">Termal (100x150mm)</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => _labelSettings.Format)" />
                </div>
                <div class="col-12 col-md-4">
                    <button type="submit" class="btn btn-primary w-100"
                            disabled="@(!orders.Any(o => o.Selected))">
                        <i class="fas fa-print me-1"></i>Etiket Olustur
                    </button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

<div class="card shadow-sm mb-5">
    <div class="card-header bg-white">
        <h6 class="mb-0"><i class="fas fa-list me-2"></i>Siparisler</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th><input type="checkbox" class="form-check-input" @onchange="ToggleAll" /></th>
                        <th>Siparis No</th>
                        <th>Musteri</th>
                        <th>Sehir</th>
                        <th>Urun Adedi</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in orders)
                    {
                        <tr>
                            <td><input type="checkbox" class="form-check-input" @bind="order.Selected" /></td>
                            <td class="fw-semibold">@order.OrderNo</td>
                            <td>@order.Customer</td>
                            <td>@order.City</td>
                            <td>@order.ItemCount</td>
                            <td><span class="badge bg-warning text-dark">Hazir</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

} @* end isLoading else *@

@code {
    private record OrderRow(string OrderNo, string Customer, string City, int ItemCount)
    {
        public bool Selected { get; set; }
    }

    private bool isLoading = true;
    private bool _isDemoMode;
    private string? errorMessage;
    private LabelSettingsForm _labelSettings = new();
    private List<OrderRow> orders = [];

    private class LabelSettingsForm
    {
        [Required(ErrorMessage = "Kargo firmasi secimi zorunludur")]
        public string Carrier { get; set; } = "yurtici";
        [Required(ErrorMessage = "Etiket formati secimi zorunludur")]
        public string Format { get; set; } = "A4";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            try
            {
                var result = await ApiClient.GetShipmentsAsync();
                if (result is { Count: > 0 })
                {
                    _isDemoMode = false;
                }
                else
                {
                    _isDemoMode = true;
                }
            }
            catch (Exception apiEx)
            {
                Console.WriteLine($"API error, using demo data: {apiEx.Message}");
                _isDemoMode = true;
            }

            if (_isDemoMode)
            {
                orders = GetDemoOrders();
            }
        }
        catch (Exception ex) { errorMessage = $"Sayfa yuklenirken hata: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private static List<OrderRow> GetDemoOrders() =>
    [
        new("SIP-20260301", "Ahmet Yilmaz", "Istanbul", 3),
        new("SIP-20260302", "Fatma Demir", "Ankara", 1),
        new("SIP-20260303", "Mehmet Kaya", "Izmir", 2),
        new("SIP-20260304", "Ayse Celik", "Bursa", 5),
        new("SIP-20260305", "Ali Ozturk", "Antalya", 1),
    ];

    private void ToggleAll(ChangeEventArgs e)
    {
        var val = (bool)(e.Value ?? false);
        foreach (var o in orders) o.Selected = val;
    }

    private void GenerateLabels()
    {
        Nav.NavigateTo($"/shipments/labels?carrier={_labelSettings.Carrier}&format={_labelSettings.Format}");
    }
}
