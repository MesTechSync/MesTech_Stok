@page "/shipments/create"
@attribute [Authorize]
@inject MesTechApiClient ApiClient
@inject NavigationManager Nav

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
  <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
       style="width: 48px; height: 48px; background-color: #2855AC;">
    <i class="fas fa-plus-circle text-white"></i>
  </div>
  <div>
    <h3 class="mb-0" style="color: #2855AC;">Yeni Gonderi Olustur</h3>
    <small class="text-muted">Siparis icin kargo gonderimi olusturun</small>
  </div>
</div>

<div class="mb-3">
  <button class="btn btn-outline-secondary btn-sm" @onclick="GoBack">
    <i class="fas fa-arrow-left me-1"></i>Gonderim Kuyrugune Don
  </button>
</div>

@if (_isLoading)
{
  <LoadingSpinner />
}
else
{
  @if (_successMessage is not null)
  {
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="fas fa-check-circle me-2"></i>@_successMessage
      <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
  }

  @if (_errorMessage is not null)
  {
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="fas fa-exclamation-circle me-2"></i>@_errorMessage
      <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
  }

  <!-- Siparis Bilgileri -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
      <h6 class="mb-0"><i class="fas fa-shopping-cart me-2" style="color: #2855AC;"></i>Siparis Bilgileri</h6>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold">Siparis No</label>
          <input type="text" class="form-control" @bind="_form.SiparisNo" placeholder="TY-2026-0001" />
        </div>
        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold">Musteri Adi</label>
          <input type="text" class="form-control" @bind="_form.MusteriAdi" placeholder="Musteri adi" />
        </div>
        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold">Platform</label>
          <select class="form-select" @bind="_form.Platform">
            <option value="Trendyol">Trendyol</option>
            <option value="Hepsiburada">Hepsiburada</option>
            <option value="N11">N11</option>
            <option value="Amazon TR">Amazon TR</option>
            <option value="Shopify">Shopify</option>
            <option value="WooCommerce">WooCommerce</option>
          </select>
        </div>
      </div>
    </div>
  </div>

  <!-- Kargo Bilgileri -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
      <h6 class="mb-0"><i class="fas fa-truck me-2" style="color: #2855AC;"></i>Kargo Bilgileri</h6>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold">Kargo Firma</label>
          <select class="form-select" @bind="_form.KargoFirma">
            <option value="Yurtici">Yurtici Kargo</option>
            <option value="Aras">Aras Kargo</option>
            <option value="Surat">Surat Kargo</option>
          </select>
        </div>
        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold">Paket Agirligi (kg)</label>
          <input type="number" class="form-control" @bind="_form.Agirlik" min="0.1" step="0.1" />
        </div>
        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold">Desi</label>
          <input type="number" class="form-control" @bind="_form.Desi" min="1" step="1" />
        </div>
        <div class="col-12">
          <label class="form-label fw-semibold">Teslimat Adresi</label>
          <textarea class="form-control" rows="2" @bind="_form.Adres" placeholder="Teslimat adresi"></textarea>
        </div>
      </div>
    </div>
  </div>

  <!-- Urun Listesi -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
      <h6 class="mb-0"><i class="fas fa-box me-2" style="color: #2855AC;"></i>Urunler</h6>
      <button class="btn btn-sm btn-outline-primary" @onclick="AddProduct">
        <i class="fas fa-plus me-1"></i>Urun Ekle
      </button>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Urun Adi</th>
              <th style="width: 100px;">Miktar</th>
              <th style="width: 50px;"></th>
            </tr>
          </thead>
          <tbody>
            @for (var i = 0; i < _products.Count; i++)
            {
              var idx = i;
              <tr>
                <td>
                  <input type="text" class="form-control form-control-sm"
                         @bind="_products[idx].UrunAdi" placeholder="Urun adi" />
                </td>
                <td>
                  <input type="number" class="form-control form-control-sm"
                         @bind="_products[idx].Miktar" min="1" />
                </td>
                <td class="text-center">
                  @if (_products.Count > 1)
                  {
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveProduct(idx)">
                      <i class="fas fa-trash-alt"></i>
                    </button>
                  }
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Submit -->
  <div class="d-flex gap-2 justify-content-end mb-5">
    <button class="btn btn-outline-secondary" @onclick="GoBack">
      <i class="fas fa-times me-1"></i>Vazgec
    </button>
    <button class="btn btn-primary" @onclick="SubmitShipment" disabled="@_isSubmitting">
      @if (_isSubmitting)
      {
        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
      }
      <i class="fas fa-paper-plane me-1"></i>Gonderi Olustur
    </button>
  </div>
}

@code {
  private bool _isLoading = true;
  private bool _isDemoMode;
  private bool _isSubmitting;
  private string? _errorMessage;
  private string? _successMessage;

  private ShipmentForm _form = new();
  private List<ProductLine> _products = [new()];

  protected override async Task OnInitializedAsync()
  {
    try
    {
      try { await ApiClient.GetCargoProvidersAsync(); }
      catch { _isDemoMode = true; }
    }
    catch (Exception ex)
    {
      _errorMessage = $"Sayfa yuklenirken hata: {ex.Message}";
    }
    finally
    {
      _isLoading = false;
    }
  }

  private void AddProduct() => _products.Add(new ProductLine());

  private void RemoveProduct(int idx)
  {
    if (idx >= 0 && idx < _products.Count && _products.Count > 1)
      _products.RemoveAt(idx);
  }

  private async Task SubmitShipment()
  {
    _errorMessage = null;
    _successMessage = null;

    if (string.IsNullOrWhiteSpace(_form.SiparisNo))
    {
      _errorMessage = "Siparis numarasi zorunludur.";
      return;
    }

    _isSubmitting = true;
    try
    {
      var payload = new
      {
        _form.SiparisNo,
        _form.MusteriAdi,
        _form.Platform,
        _form.KargoFirma,
        _form.Agirlik,
        _form.Desi,
        _form.Adres,
        Products = _products.Select(p => new { p.UrunAdi, p.Miktar })
      };

      try
      {
        await ApiClient.CreateShipmentAsync(payload);
        _successMessage = "Gonderi basariyla olusturuldu!";
      }
      catch
      {
        _isDemoMode = true;
        _successMessage = "Gonderi olusturuldu (demo mod).";
      }

      await Task.Delay(1000);
      Nav.NavigateTo("/shipments");
    }
    catch (Exception ex)
    {
      _errorMessage = $"Gonderi olusturulurken hata: {ex.Message}";
    }
    finally
    {
      _isSubmitting = false;
    }
  }

  private void GoBack() => Nav.NavigateTo("/shipments");

  private class ShipmentForm
  {
    public string SiparisNo { get; set; } = "";
    public string MusteriAdi { get; set; } = "";
    public string Platform { get; set; } = "Trendyol";
    public string KargoFirma { get; set; } = "Yurtici";
    public decimal Agirlik { get; set; } = 1.0m;
    public int Desi { get; set; } = 1;
    public string Adres { get; set; } = "";
  }

  private class ProductLine
  {
    public string UrunAdi { get; set; } = "";
    public int Miktar { get; set; } = 1;
  }
}
