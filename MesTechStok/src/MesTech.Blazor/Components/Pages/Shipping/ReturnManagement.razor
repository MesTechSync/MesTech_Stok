@page "/shipping/returns"
@attribute [Authorize]
@inject MesTechApiClient ApiClient

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
         style="width: 48px; height: 48px; background-color: #2855AC;">
        <i class="fas fa-undo-alt text-white"></i>
    </div>
    <div>
        <h3 class="mb-0" style="color: #2855AC;">Iade Yonetimi</h3>
        <small class="text-muted">Siparis iadeleri, onay ve red islemleri</small>
    </div>
</div>

@if (isLoading)
{
    <LoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}
else
{

<div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <label class="form-label fw-semibold">Durum Filtresi</label>
        <select class="form-select" @bind="filterStatus" @bind:after="ApplyFilter">
            <option value="">Tumu</option>
            <option value="Beklemede">Beklemede</option>
            <option value="Onaylandi">Onaylandi</option>
            <option value="Reddedildi">Reddedildi</option>
        </select>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="fas fa-exchange-alt me-2"></i>Iade Talepleri</h6>
        <span class="badge bg-primary">@filteredReturns.Count kayit</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Iade No</th>
                        <th>Siparis No</th>
                        <th class="d-none d-md-table-cell">Musteri</th>
                        <th>Sebep</th>
                        <th>Durum</th>
                        <th class="d-none d-sm-table-cell">Tarih</th>
                        <th>Islem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in filteredReturns)
                    {
                        <tr class="@(selectedReturn?.ReturnNo == r.ReturnNo ? "table-active" : "")">
                            <td class="fw-semibold">@r.ReturnNo</td>
                            <td>@r.OrderNo</td>
                            <td class="d-none d-md-table-cell">@r.Customer</td>
                            <td>@r.Reason</td>
                            <td><span class="badge @GetStatusBadge(r.Status)">@r.Status</span></td>
                            <td class="d-none d-sm-table-cell">@r.Date.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (r.Status == "Beklemede")
                                {
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-success" @onclick='() => UpdateStatus(r, "Onaylandi")'>
                                            <i class="fas fa-check"></i>
                                        </button>
                                        <button class="btn btn-outline-danger" @onclick='() => UpdateStatus(r, "Reddedildi")'>
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                }
                                <button class="btn btn-outline-primary btn-sm ms-1" @onclick="() => SelectReturn(r)">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (selectedReturn is not null)
{
    <div class="card shadow-sm mb-5 border-primary">
        <div class="card-header bg-white">
            <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Iade Detayi — @selectedReturn.ReturnNo</h6>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <small class="text-muted d-block">Siparis No</small>
                    <span class="fw-bold">@selectedReturn.OrderNo</span>
                </div>
                <div class="col-6 col-md-3">
                    <small class="text-muted d-block">Musteri</small>
                    <span class="fw-bold">@selectedReturn.Customer</span>
                </div>
                <div class="col-6 col-md-3">
                    <small class="text-muted d-block">Iade Sebebi</small>
                    <span>@selectedReturn.Reason</span>
                </div>
                <div class="col-6 col-md-3">
                    <small class="text-muted d-block">Durum</small>
                    <span class="badge @GetStatusBadge(selectedReturn.Status)">@selectedReturn.Status</span>
                </div>
            </div>
        </div>
    </div>
}

} @* end isLoading else *@

@code {
    private class ReturnItem
    {
        public string ReturnNo { get; set; } = "";
        public string OrderNo { get; set; } = "";
        public string Customer { get; set; } = "";
        public string Reason { get; set; } = "";
        public string Status { get; set; } = "Beklemede";
        public DateTime Date { get; set; }
    }

    private bool isLoading = true;
    private bool _isDemoMode;
    private string? errorMessage;
    private string filterStatus = "";
    private ReturnItem? selectedReturn;
    private List<ReturnItem> allReturns = [];
    private List<ReturnItem> filteredReturns = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            try
            {
                var result = await ApiClient.SafeGetAsync<List<object>>("shipping/returns");
                if (result.IsSuccess && result.Data is { Count: > 0 })
                {
                    _isDemoMode = false;
                    // TODO: map API response to ReturnItem when DTO finalized
                }
                else
                {
                    _isDemoMode = true;
                }
            }
            catch (Exception apiEx)
            {
                Console.WriteLine($"API error, using demo data: {apiEx.Message}");
                _isDemoMode = true;
            }

            if (_isDemoMode)
            {
                allReturns = GetDemoReturns();
            }
            filteredReturns = [.. allReturns];
        }
        catch (Exception ex) { errorMessage = $"Sayfa yuklenirken hata: {ex.Message}"; }
        finally { isLoading = false; }
    }

    private static List<ReturnItem> GetDemoReturns() =>
    [
        new() { ReturnNo = "IAD-001", OrderNo = "SIP-20260280", Customer = "Zeynep Arslan", Reason = "Urun hasarli", Status = "Beklemede", Date = DateTime.Today.AddDays(-1) },
        new() { ReturnNo = "IAD-002", OrderNo = "SIP-20260275", Customer = "Burak Sahin", Reason = "Yanlis urun", Status = "Onaylandi", Date = DateTime.Today.AddDays(-3) },
        new() { ReturnNo = "IAD-003", OrderNo = "SIP-20260268", Customer = "Selin Yildiz", Reason = "Beden uyumsuz", Status = "Beklemede", Date = DateTime.Today.AddDays(-2) },
        new() { ReturnNo = "IAD-004", OrderNo = "SIP-20260260", Customer = "Emre Koc", Reason = "Vazgecme", Status = "Reddedildi", Date = DateTime.Today.AddDays(-5) },
        new() { ReturnNo = "IAD-005", OrderNo = "SIP-20260255", Customer = "Deniz Acar", Reason = "Urun hasarli", Status = "Beklemede", Date = DateTime.Today },
    ];

    private void ApplyFilter()
    {
        filteredReturns = allReturns
            .Where(r => string.IsNullOrEmpty(filterStatus) || r.Status == filterStatus)
            .ToList();
    }

    private void UpdateStatus(ReturnItem item, string newStatus)
    {
        item.Status = newStatus;
        ApplyFilter();
    }

    private void SelectReturn(ReturnItem item) => selectedReturn = item;

    private static string GetStatusBadge(string status) => status switch
    {
        "Onaylandi" => "bg-success",
        "Reddedildi" => "bg-danger",
        "Beklemede" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}
