@page "/admin/stock-placement"
@attribute [Authorize]
@inject MesTechApiClient ApiClient

<PageTitle>MesTech - Stok Yerlestirme</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

@if (isLoading)
{
  <LoadingSpinner />
}
else if (errorMessage is not null)
{
  <div class="alert alert-danger d-flex align-items-center justify-content-between" role="alert">
    <span><i class="fas fa-exclamation-triangle me-2"></i>@errorMessage</span>
    <button class="btn btn-sm btn-outline-danger" @onclick="OnInitializedAsync">
      <i class="fas fa-sync-alt me-1"></i>Tekrar Dene
    </button>
  </div>
}
else
{
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" >
      <i class="fas fa-warehouse text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" >Stok Yerlestirme</h3>
      <small class="text-muted">Depo, zon, raf ve urun yerlesim yonetimi</small>
    </div>
  </div>

  <!-- Warehouse Selector -->
  <div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
      <label class="form-label fw-semibold">Depo Secimi</label>
      <select class="form-select" @bind="selectedWarehouse">
        @foreach (var wh in warehouses)
        {
          <option value="@wh.Id">@wh.Name</option>
        }
      </select>
    </div>
    <div class="col-12 col-md-8">
      <div class="alert alert-info mb-0 h-100 d-flex align-items-center">
        <i class="fas fa-info-circle me-2"></i>
        <span><strong>@warehouses.First(w => w.Id == selectedWarehouse).Name:</strong>
        @warehouses.First(w => w.Id == selectedWarehouse).ZoneCount zon, @warehouses.First(w => w.Id == selectedWarehouse).RackCount raf, %@warehouses.First(w => w.Id == selectedWarehouse).Occupancy doluluk</span>
      </div>
    </div>
  </div>

  <!-- Zone/Rack/Shelf Visual Grid -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
      <h6 class="mb-0"><i class="fas fa-th me-2" ></i>Zon / Raf Haritasi</h6>
    </div>
    <div class="card-body">
      @if (!zones.Any(z => z.WarehouseId == selectedWarehouse))
      {
        <EmptyState Icon="fa-warehouse" Message="Henuz yerlesim kaydi bulunamadi." />
      }
      else
      {
      <div class="row g-2">
        @foreach (var zone in zones.Where(z => z.WarehouseId == selectedWarehouse))
        {
          <div class="col-6 col-md-3">
            <div class="card h-100 @(zone.Id == selectedZone ? "border-primary border-2" : "")"
                 style="cursor: pointer;" @onclick="() => selectedZone = zone.Id">
              <div class="card-body text-center py-3">
                <i class="fas fa-th-large fa-2x mb-2 @(zone.Occupancy > 80 ? "text-danger" : zone.Occupancy > 50 ? "text-warning" : "text-success")"></i>
                <h6 class="mb-1">@zone.Name</h6>
                <div class="progress" style="height: 6px;">
                  <div class="progress-bar @(zone.Occupancy > 80 ? "bg-danger" : zone.Occupancy > 50 ? "bg-warning" : "bg-success")"
                       style="width: @zone.Occupancy%"></div>
                </div>
                <small class="text-muted">@zone.RackCount raf — %@zone.Occupancy dolu</small>
              </div>
            </div>
          </div>
        }
      </div>
      }
    </div>
  </div>

  <!-- Product Placement Form -->
  <div class="card shadow-sm">
    <div class="card-header bg-white">
      <h6 class="mb-0"><i class="fas fa-plus-circle me-2" ></i>Urun Yerlestir</h6>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-12 col-md-4">
          <label class="form-label fw-semibold">Urun</label>
          <input type="text" class="form-control" @bind="placementProduct" placeholder="Urun adi veya SKU..." />
        </div>
        <div class="col-6 col-md-2">
          <label class="form-label fw-semibold">Zon</label>
          <select class="form-select" @bind="placementZone">
            @foreach (var z in zones.Where(z => z.WarehouseId == selectedWarehouse))
            {
              <option value="@z.Name">@z.Name</option>
            }
          </select>
        </div>
        <div class="col-6 col-md-2">
          <label class="form-label fw-semibold">Raf</label>
          <select class="form-select" @bind="placementRack">
            @for (int i = 1; i <= 10; i++)
            {
              <option value="R@i">R@i</option>
            }
          </select>
        </div>
        <div class="col-6 col-md-2">
          <label class="form-label fw-semibold">Raf Kati</label>
          <select class="form-select" @bind="placementShelf">
            @for (int i = 1; i <= 5; i++)
            {
              <option value="K@i">Kat @i</option>
            }
          </select>
        </div>
        <div class="col-6 col-md-2">
          <label class="form-label fw-semibold">Adet</label>
          <input type="number" class="form-control" @bind="placementQty" min="1" />
        </div>
      </div>
      <div class="mt-3 text-end">
        <button class="btn btn-primary" @onclick="PlaceProduct">
          <i class="fas fa-check me-1"></i>Yerlestir
        </button>
      </div>
    </div>
  </div>
}

@code {
  private bool isLoading = true;
  private bool _isDemoMode;
  private string? errorMessage;
  private int selectedWarehouse = 1;
  private int selectedZone;
  private List<Warehouse> warehouses = [];
  private List<Zone> zones = [];

  // Placement form
  private string placementProduct = string.Empty;
  private string placementZone = string.Empty;
  private string placementRack = "R1";
  private string placementShelf = "K1";
  private int placementQty = 1;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      var result = await ApiClient.SafeGetAsync<object>("warehouses");
      if (!result.IsSuccess) { _isDemoMode = true; }

      warehouses =
      [
        new(1, "Ana Depo - Istanbul", 4, 40, 72),
        new(2, "Yedek Depo - Ankara", 2, 16, 45),
        new(3, "Dagitim Merkezi - Izmir", 3, 24, 58),
      ];

      zones =
      [
        new(1, 1, "A Zon", 10, 85),
        new(2, 1, "B Zon", 10, 62),
        new(3, 1, "C Zon", 10, 78),
        new(4, 1, "D Zon", 10, 43),
        new(5, 2, "A Zon", 8, 50),
        new(6, 2, "B Zon", 8, 40),
        new(7, 3, "A Zon", 8, 65),
        new(8, 3, "B Zon", 8, 55),
        new(9, 3, "C Zon", 8, 48),
      ];

      selectedZone = zones.First().Id;
      placementZone = zones.First().Name;
    }
    catch (Exception ex)
    {
      errorMessage = $"Yerlestirme verileri yuklenirken hata: {ex.Message}";
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private async Task PlaceProduct()
  {
    var payload = new { ProductName = placementProduct, Zone = placementZone, Rack = placementRack, Shelf = placementShelf, Quantity = placementQty, WarehouseId = selectedWarehouse };
    var result = await ApiClient.SafePostAsync<object>("warehouses/placement", payload);
    if (!result.IsSuccess)
    {
      errorMessage = result.ErrorMessage;
    }
  }

  private record Warehouse(int Id, string Name, int ZoneCount, int RackCount, int Occupancy);
  private record Zone(int Id, int WarehouseId, string Name, int RackCount, int Occupancy);
}
