@page "/admin/api-health"
@attribute [Authorize(Roles = "Admin")]
@inject MesTechApiClient ApiClient
@inject ILogger<ApiHealth> Logger

<PageTitle>MesTech - API Saglik Durumu</PageTitle>

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

@if (isLoading)
{
  <LoadingSpinner />
}
else if (errorMessage is not null)
{
  <div class="alert alert-danger d-flex align-items-center justify-content-between" role="alert">
    <span><i class="fas fa-exclamation-triangle me-2"></i>@errorMessage</span>
    <button class="btn btn-sm btn-outline-danger" @onclick="OnInitializedAsync">
      <i class="fas fa-sync-alt me-1"></i>Tekrar Dene
    </button>
  </div>
}
else
{
  <div class="d-flex align-items-center mb-4">
    <div class="rounded-circle d-flex align-items-center justify-content-center me-3" >
      <i class="fas fa-heartbeat text-white"></i>
    </div>
    <div>
      <h3 class="mb-0" >API Saglik Durumu</h3>
      <small class="text-muted">Platform adapter'larinin canli durum izleme paneli</small>
    </div>
    <button class="btn btn-outline-primary ms-auto" @onclick="RefreshAll" disabled="@isRefreshing">
      <i class="fas @(isRefreshing ? "fa-spinner fa-spin" : "fa-sync-alt") me-1"></i>Tumu Yenile
    </button>
  </div>

  <!-- Summary Bar -->
  <div class="row g-3 mb-4">
    <div class="col-4">
      <div class="card shadow-sm border-start border-4 border-success">
        <div class="card-body text-center py-2">
          <h4 class="fw-bold text-success mb-0">@adapters.Count(a => a.Status == "UP")</h4>
          <small class="text-muted">Aktif</small>
        </div>
      </div>
    </div>
    <div class="col-4">
      <div class="card shadow-sm border-start border-4 border-warning">
        <div class="card-body text-center py-2">
          <h4 class="fw-bold text-warning mb-0">@adapters.Count(a => a.Status == "DEGRADED")</h4>
          <small class="text-muted">Yavaslamis</small>
        </div>
      </div>
    </div>
    <div class="col-4">
      <div class="card shadow-sm border-start border-4 border-danger">
        <div class="card-body text-center py-2">
          <h4 class="fw-bold text-danger mb-0">@adapters.Count(a => a.Status == "DOWN")</h4>
          <small class="text-muted">Cevrimdisi</small>
        </div>
      </div>
    </div>
  </div>

  <!-- Adapter Health Cards -->
  <div class="row g-3">
    @if (adapters.Count == 0 && !isLoading)

    {

        <EmptyState Icon="fa-heartbeat" Message="Henuz API sagligi verisi bulunamadi." />

    }

    @foreach (var adapter in adapters)
    {
      <div class="col-12 col-sm-6 col-lg-3">
        <div class="card shadow-sm h-100 @GetCardBorder(adapter.Status)">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h6 class="fw-bold mb-0">@adapter.Name</h6>
              <span class="badge @GetBadgeClass(adapter.Status)">@adapter.Status</span>
            </div>
            <div class="mb-2">
              <small class="text-muted d-block">Yanit Suresi</small>
              <span class="fw-semibold @(adapter.ResponseMs > 1000 ? "text-danger" : adapter.ResponseMs > 500 ? "text-warning" : "text-success")">
                @adapter.ResponseMs ms
              </span>
            </div>
            <div class="row g-1">
              <div class="col-6">
                <small class="text-muted d-block">Son Kontrol</small>
                <small>@adapter.LastCheck.ToString("HH:mm:ss")</small>
              </div>
              <div class="col-6">
                <small class="text-muted d-block">Hata Sayisi</small>
                <small class="@(adapter.ErrorCount > 0 ? "text-danger fw-bold" : "text-success")">@adapter.ErrorCount</small>
              </div>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}

@code {
  private bool isLoading = true;
  private bool _isDemoMode;
  private bool isRefreshing;
  private string? errorMessage;
  private List<AdapterHealth> adapters = [];

  protected override async Task OnInitializedAsync()
  {
    try
    {
      var result = await ApiClient.SafeGetAsync<object>("health");
      if (!result.IsSuccess) { _isDemoMode = true; }

      var now = DateTime.Now;
      adapters =
      [
        new("Trendyol", "UP", 124, now.AddMinutes(-1), 0),
        new("Hepsiburada", "UP", 198, now.AddMinutes(-1), 0),
        new("N11", "UP", 231, now.AddMinutes(-2), 0),
        new("CicekSepeti", "DEGRADED", 876, now.AddMinutes(-1), 3),
        new("Amazon TR", "UP", 156, now.AddMinutes(-3), 0),
        new("eBay", "UP", 342, now.AddMinutes(-2), 1),
        new("Shopify", "UP", 189, now.AddMinutes(-1), 0),
        new("WooCommerce", "UP", 267, now.AddMinutes(-4), 0),
        new("OpenCart", "UP", 145, now.AddMinutes(-1), 0),
        new("Pttavm", "DOWN", 0, now.AddMinutes(-5), 12),
        new("GittiGidiyor", "DOWN", 0, now.AddMinutes(-5), 8),
        new("Ozon", "DEGRADED", 1240, now.AddMinutes(-2), 5),
        new("Etsy", "UP", 312, now.AddMinutes(-3), 0),
        new("Zalando", "UP", 287, now.AddMinutes(-2), 0),
        new("Google Merchant", "UP", 198, now.AddMinutes(-1), 0),
        new("Facebook Shop", "UP", 156, now.AddMinutes(-4), 0),
      ];
    }
    catch (Exception ex)
    {
      _isDemoMode = true;
      Logger.LogWarning(ex, "Health API error, using demo data");
    }
    finally
    {
      isLoading = false;
      StateHasChanged();
    }
  }

  private async Task RefreshAll()
  {
    isRefreshing = true;
    await Task.Delay(1500); // simulate refresh
    var now = DateTime.Now;
    foreach (var a in adapters)
      adapters[adapters.IndexOf(a)] = a with { LastCheck = now };
    isRefreshing = false;
  }

  private static string GetBadgeClass(string status) => status switch
  {
    "UP" => "bg-success",
    "DEGRADED" => "bg-warning text-dark",
    "DOWN" => "bg-danger",
    _ => "bg-secondary"
  };

  private static string GetCardBorder(string status) => status switch
  {
    "UP" => "",
    "DEGRADED" => "border-start border-4 border-warning",
    "DOWN" => "border-start border-4 border-danger",
    _ => ""
  };

  private record AdapterHealth(string Name, string Status, int ResponseMs, DateTime LastCheck, int ErrorCount);
}
