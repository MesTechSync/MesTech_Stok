@page "/admin/tenants/{Id:guid}"
@attribute [Authorize(Roles = "Admin")]
@inject IMediator Mediator
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject MesTechApiClient ApiClient

<DemoFallbackBanner IsDemoMode="@_isDemoMode" />

<!-- Back button -->
<div class="mb-3">
  <button class="btn btn-sm btn-outline-secondary" @onclick="GoBack">
    <i class="fas fa-arrow-left me-1"></i>Tenant Listesine Don
  </button>
</div>

@if (isLoading)
{
  <LoadingSpinner />
}
else
{
  @if (!string.IsNullOrEmpty(errorMessage))
  {
    <div class="alert alert-warning" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i>@errorMessage
    </div>
  }

  <!-- Tenant Header Card -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex align-items-center justify-content-between flex-wrap">
        <div class="d-flex align-items-center">
          <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
               style="width: 56px; height: 56px; background-color: #2855AC;">
            <i class="fas fa-building text-white fa-lg"></i>
          </div>
          <div>
            <h4 class="mb-0" style="color: #2855AC;">@tenant.FirmaAdi</h4>
            <small class="text-muted">Vergi No: @tenant.VergiNo</small>
          </div>
        </div>
        <div class="d-flex align-items-center gap-3 mt-2 mt-md-0">
          <StatusBadge Text="@tenant.Durum" Variant="@(tenant.Durum == "Aktif" ? "success" : "secondary")" />
          <small class="text-muted">
            <i class="fas fa-calendar me-1"></i>@tenant.OlusturmaTarihi.ToString("dd.MM.yyyy")
          </small>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab Navigation -->
  <ul class="nav nav-tabs mb-3">
    <li class="nav-item">
      <button class="nav-link @(activeTab == "stores" ? "active" : "")" @onclick='() => activeTab = "stores"'>
        <i class="fas fa-store me-1"></i>Store'lar
        <span class="badge bg-secondary ms-1">@stores.Count</span>
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link @(activeTab == "users" ? "active" : "")" @onclick='() => activeTab = "users"'>
        <i class="fas fa-users me-1"></i>Kullanicilar
        <span class="badge bg-secondary ms-1">@users.Count</span>
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link @(activeTab == "credentials" ? "active" : "")" @onclick='() => activeTab = "credentials"'>
        <i class="fas fa-key me-1"></i>Credential'lar
        <span class="badge bg-secondary ms-1">@credentials.Count</span>
      </button>
    </li>
  </ul>

  <!-- Tab Content -->
  @if (activeTab == "stores")
  {
    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0"><i class="fas fa-store me-2" style="color: #2855AC;"></i>Bagli Store'lar</h6>
        <button class="btn btn-sm" style="background-color: #2855AC; color: white;" @onclick="ShowAddStore">
          <i class="fas fa-plus me-1"></i>Store Ekle
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Magaza Adi</th>
                <th>Platform</th>
                <th class="text-center">Durum</th>
                <th class="d-none d-md-table-cell">Son Sync</th>
                <th class="text-end d-none d-md-table-cell">Urun Sayisi</th>
              </tr>
            </thead>
            <tbody>
              @if (stores.Count == 0)
              {
                <tr><td colspan="5" class="text-center text-muted py-4">Henuz store eklenmemis.</td></tr>
              }
              else
              {
                @foreach (var s in stores)
                {
                  <tr>
                    <td><span class="fw-semibold">@s.MagazaAdi</span></td>
                    <td>
                      <span class="badge bg-primary bg-opacity-10 text-primary">@s.Platform</span>
                    </td>
                    <td class="text-center">
                      <StatusBadge Text="@s.Durum" Variant="@(s.Durum == "Aktif" ? "success" : "danger")" />
                    </td>
                    <td class="d-none d-md-table-cell">@s.SonSync.ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="text-end d-none d-md-table-cell">@s.UrunSayisi.ToString("N0")</td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  }

  @if (activeTab == "users")
  {
    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0"><i class="fas fa-users me-2" style="color: #2855AC;"></i>Kullanicilar</h6>
        <button class="btn btn-sm" style="background-color: #2855AC; color: white;" @onclick="ShowAddUser">
          <i class="fas fa-plus me-1"></i>Kullanici Ekle
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Ad Soyad</th>
                <th>Email</th>
                <th class="text-center">Rol</th>
                <th class="d-none d-md-table-cell">Son Giris</th>
              </tr>
            </thead>
            <tbody>
              @if (users.Count == 0)
              {
                <tr><td colspan="4" class="text-center text-muted py-4">Henuz kullanici eklenmemis.</td></tr>
              }
              else
              {
                @foreach (var u in users)
                {
                  <tr>
                    <td>
                      <i class="fas fa-user-circle me-2 text-muted"></i>
                      <span class="fw-semibold">@u.AdSoyad</span>
                    </td>
                    <td>@u.Email</td>
                    <td class="text-center">
                      <StatusBadge Text="@u.Rol" Variant="@(u.Rol == "Admin" ? "danger" : u.Rol == "Manager" ? "warning" : "info")" />
                    </td>
                    <td class="d-none d-md-table-cell">@u.SonGiris.ToString("dd.MM.yyyy HH:mm")</td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  }

  @if (activeTab == "credentials")
  {
    <div class="card shadow-sm">
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0"><i class="fas fa-key me-2" style="color: #2855AC;"></i>API Credential'lari</h6>
        <button class="btn btn-sm" style="background-color: #2855AC; color: white;">
          <i class="fas fa-plus me-1"></i>Credential Ekle
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Platform</th>
                <th>API Key</th>
                <th class="d-none d-md-table-cell">Olusturma Tarihi</th>
                <th class="text-center">Durum</th>
              </tr>
            </thead>
            <tbody>
              @if (credentials.Count == 0)
              {
                <tr><td colspan="4" class="text-center text-muted py-4">Henuz credential eklenmemis.</td></tr>
              }
              else
              {
                @foreach (var c in credentials)
                {
                  <tr>
                    <td>
                      <i class="fas fa-plug me-2 text-muted"></i>
                      <span class="fw-semibold">@c.Platform</span>
                    </td>
                    <td><code>@c.MaskedKey</code></td>
                    <td class="d-none d-md-table-cell">@c.OlusturmaTarihi.ToString("dd.MM.yyyy")</td>
                    <td class="text-center">
                      <StatusBadge Text="@c.Durum" Variant="@(c.Durum == "Aktif" ? "success" : "secondary")" />
                    </td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  }
}

@code {
  [Parameter] public Guid Id { get; set; }

  private bool isLoading = true;
  private bool _isDemoMode;
  private string? errorMessage;
  private string activeTab = "stores";

  private TenantInfo tenant = new("", "", "", DateTime.Today);
  private List<StoreInfo> stores = [];
  private List<UserInfo> users = [];
  private List<CredentialInfo> credentials = [];

  protected override async Task OnInitializedAsync()
  {
    await LoadDataAsync();
  }

  private async Task LoadDataAsync()
  {
    isLoading = true;
    try
    {
      var apiData = await ApiClient.GetTenantByIdAsync(Id);
      if (apiData is not null)
      {
        _isDemoMode = false;
        // Keep demo data for now — typed DTOs not yet available
        // When API returns real data, map apiData to tenant/stores/users/credentials
        tenant = GetDemoTenant();
      }
      else
      {
        _isDemoMode = true;
        tenant = GetDemoTenant();
      }

      // TODO(v2): wire to GetStoresByTenantQuery
      stores = GetDemoStores();
      users = GetDemoUsers();
      credentials = GetDemoCredentials();
    }
    catch (Exception ex)
    {
      Console.WriteLine($"API fallback (TenantDetail): {ex.Message}");
      _isDemoMode = true;
      tenant = GetDemoTenant();
      stores = GetDemoStores();
      users = GetDemoUsers();
      credentials = GetDemoCredentials();
    }
    finally
    {
      isLoading = false;
    }
  }

  private static TenantInfo GetDemoTenant() =>
    new("Anadolu Ticaret A.S.", "1234567890", "Aktif", new DateTime(2025, 6, 15));

  private static List<StoreInfo> GetDemoStores() =>
  [
    new("Anadolu Trendyol", "Trendyol", "Aktif", new DateTime(2026, 3, 16, 9, 30, 0), 1240),
    new("Anadolu HB", "Hepsiburada", "Aktif", new DateTime(2026, 3, 16, 8, 45, 0), 890),
    new("Anadolu N11", "N11", "Baglanti Hatasi", new DateTime(2026, 3, 15, 22, 10, 0), 670),
  ];

  private static List<UserInfo> GetDemoUsers() =>
  [
    new("Ahmet Yilmaz", "ahmet@anadoluticaret.com", "Admin", new DateTime(2026, 3, 16, 10, 15, 0)),
    new("Fatma Demir", "fatma@anadoluticaret.com", "Manager", new DateTime(2026, 3, 16, 9, 0, 0)),
    new("Mehmet Kaya", "mehmet@anadoluticaret.com", "Operator", new DateTime(2026, 3, 15, 17, 30, 0)),
    new("Ayse Celik", "ayse@anadoluticaret.com", "Operator", new DateTime(2026, 3, 14, 11, 20, 0)),
  ];

  private static List<CredentialInfo> GetDemoCredentials() =>
  [
    new("Trendyol", "trn_****7890", new DateTime(2025, 8, 10), "Aktif"),
    new("Hepsiburada", "hb_****3456", new DateTime(2025, 9, 5), "Aktif"),
    new("N11", "n11_****1234", new DateTime(2025, 10, 20), "Pasif"),
  ];

  private void GoBack() => Nav.NavigateTo("/admin/tenants");

  private void ShowAddStore()
  {
    // Awaiting CreateStoreCommand integration (Panel A)
    errorMessage = "Store ekleme henuz aktif degil — Panel A entegrasyonu bekleniyor.";
  }

  private void ShowAddUser()
  {
    // Awaiting CreateTenantUserCommand integration (Panel A)
    errorMessage = "Kullanici ekleme henuz aktif degil — Panel A entegrasyonu bekleniyor.";
  }

  private record TenantInfo(string FirmaAdi, string VergiNo, string Durum, DateTime OlusturmaTarihi);
  private record StoreInfo(string MagazaAdi, string Platform, string Durum, DateTime SonSync, int UrunSayisi);
  private record UserInfo(string AdSoyad, string Email, string Rol, DateTime SonGiris);
  private record CredentialInfo(string Platform, string MaskedKey, DateTime OlusturmaTarihi, string Durum);
}
