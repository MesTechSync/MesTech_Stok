<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:MesTech.Avalonia.Converters"
             xmlns:sty="using:FluentAvalonia.Styling"
             x:Class="MesTech.Avalonia.App"
             RequestedThemeVariant="Light">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://MesTech.Avalonia/Styles/MesTechTheme.axaml"/>
                <ResourceInclude Source="avares://MesTech.Avalonia/Themes/MesTechDesignTokens.axaml"/>
                <ResourceInclude Source="avares://MesTech.Avalonia/Themes/MesTechSpotlightTokens.axaml"/>
                <!-- MesTechComponentStyles is a Styles resource, included via Application.Styles -->
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <ResourceDictionary.MergedDictionaries>
                        <ResourceInclude Source="avares://MesTech.Avalonia/Themes/MesTechDarkTokens.axaml"/>
                    </ResourceDictionary.MergedDictionaries>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <!-- G041: Converters for OnboardingWizard and conditional views -->
            <converters:EqualConverter x:Key="EqualConverter" />
            <converters:GreaterThanConverter x:Key="GreaterThanConverter" />
            <converters:BetweenConverter x:Key="BetweenConverter" />
            <!-- G136: Status → theme-aware color converter (replaces hardcoded hex) -->
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
            <!-- WPF014: Stock level row color converter -->
            <converters:StockLevelToBrushConverter x:Key="StockLevelToBrushConverter" />
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <sty:FluentAvaloniaTheme PreferSystemTheme="False" CustomAccentColor="#2855AC" />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://DialogHost.Avalonia/Styles.xaml" />
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/Controls/ButtonStyles.axaml"/>
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/Controls/CardStyles.axaml"/>
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/Controls/DataGridStyles.axaml"/>
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/Controls/InputStyles.axaml"/>
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/Controls/SidebarStyles.axaml"/>
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/Controls/DialogStyles.axaml"/>
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/MesTechComponentStyles.axaml"/>
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/Controls/TypographyStyles.axaml"/>
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/Controls/AccessibilityStyles.axaml"/>
        <StyleInclude Source="avares://MesTech.Avalonia/Themes/MesTechIcons.axaml"/>
    </Application.Styles>
</Application>
