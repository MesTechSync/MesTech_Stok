<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.ColumnSelectDialog"
        x:DataType="local:ColumnSelectDialog"
        xmlns:local="using:MesTech.Avalonia.Dialogs"
        Title="Kolon Secimi"
        Width="400" Height="400"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

  <Border Padding="24">
    <Grid RowDefinitions="Auto,*,Auto">

      <TextBlock Grid.Row="0"
                 Classes="dialog-title"
                 Text="Goruntulenecek Kolonlar" />

      <Border Grid.Row="1"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource CornerRadiusMedium}"
              Margin="0,8,0,0"
              Padding="8">
        <ScrollViewer>
          <StackPanel x:Name="ColumnsPanel" Spacing="8">
            <!-- CheckBox items added programmatically -->
          </StackPanel>
        </ScrollViewer>
      </Border>

      <StackPanel Grid.Row="2" Classes="dialog-actions">
        <Button Classes="mestech-outline"
                Content="Iptal"
                Click="OnCancel" />
        <Button Classes="mestech-raised"
                Content="Uygula"
                Click="OnApply" />
      </StackPanel>

    </Grid>
  </Border>

</Window>
