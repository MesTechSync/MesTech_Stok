<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.ImageDialog"
        Title="Resim Galerisi"
        Width="600" Height="450"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

  <Border Padding="24">
    <Grid RowDefinitions="Auto,*,Auto">

      <TextBlock x:Name="TitleText"
                 Grid.Row="0"
                 Classes="dialog-title"
                 Text="Resim Galerisi" />

      <Border Grid.Row="1"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="{StaticResource CornerRadiusMedium}"
              Margin="0,8,0,0"
              Padding="8">
        <ScrollViewer>
          <WrapPanel x:Name="ImagePanel"
                     Orientation="Horizontal">
            <!-- Images added programmatically -->
            <Border Width="100" Height="100"
                    Background="{DynamicResource MesBgTertiary}"
                    CornerRadius="{StaticResource CornerRadiusMedium}"
                    Margin="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
              <TextBlock Text="Resim Yok"
                         FontSize="{StaticResource FontSizeSmall}"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
          </WrapPanel>
        </ScrollViewer>
      </Border>

      <StackPanel Grid.Row="2" Classes="dialog-actions">
        <Button Classes="mestech-accent"
                Content="Resim Ekle"
                Click="OnAddImage" />
        <Button Classes="mestech-outline"
                Content="Kapat"
                Click="OnClose" />
      </StackPanel>

    </Grid>
  </Border>

</Window>
