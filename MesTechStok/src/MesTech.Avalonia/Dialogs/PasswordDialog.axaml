<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.PasswordDialog"
        Title="Sifre Degistir"
        Width="420" Height="320"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">

  <Border Padding="24">
    <StackPanel Spacing="16">

      <TextBlock x:Name="TitleText"
                 Classes="dialog-title"
                 Text="Sifre Degistir" />

      <StackPanel Spacing="8">
        <TextBlock Text="Mevcut Sifre"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{StaticResource TextSecondaryBrush}" />
        <TextBox x:Name="OldPasswordBox"
                 Classes="mestech"
                 PasswordChar="&#x25CF;"
                 Watermark="Mevcut sifrenizi giriniz" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Text="Yeni Sifre"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{StaticResource TextSecondaryBrush}" />
        <TextBox x:Name="NewPasswordBox"
                 Classes="mestech"
                 PasswordChar="&#x25CF;"
                 Watermark="Yeni sifrenizi giriniz" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock Text="Yeni Sifre (Tekrar)"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{StaticResource TextSecondaryBrush}" />
        <TextBox x:Name="ConfirmPasswordBox"
                 Classes="mestech"
                 PasswordChar="&#x25CF;"
                 Watermark="Yeni sifrenizi tekrar giriniz" />
      </StackPanel>

      <TextBlock x:Name="ErrorText"
                 Foreground="{StaticResource ErrorRedBrush}"
                 FontSize="{StaticResource FontSizeSmall}"
                 IsVisible="False" />

      <StackPanel Classes="dialog-actions">
        <Button Classes="mestech-outline"
                Content="Iptal"
                Click="OnCancel" />
        <Button Classes="mestech-raised"
                Content="Degistir"
                Click="OnConfirm" />
      </StackPanel>

    </StackPanel>
  </Border>

</Window>
