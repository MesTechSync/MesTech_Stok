<Window xmlns="https://github.com/avaloniaui"
        xmlns:vm="clr-namespace:MesTech.Avalonia.Dialogs"
        x:DataType="vm:ReplyDialogViewModel"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.ReplyDialog"
        Title="Yanit"
        Width="500" Height="350"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

  <Border Padding="24">
    <StackPanel Spacing="16">

      <TextBlock Classes="dialog-title"
                 Text="Yanit Yaz" />

      <!-- Original Message -->
      <Border Background="{DynamicResource MesBgPage}"
              CornerRadius="{StaticResource CornerRadiusMedium}"
              Padding="12"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1">
        <StackPanel Spacing="4">
          <TextBlock Text="Orijinal Mesaj:"
                     FontSize="{StaticResource FontSizeSmall}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock x:Name="OriginalMessageText"
                     FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     MaxHeight="60" />
        </StackPanel>
      </Border>

      <StackPanel Spacing="4">
        <TextBlock Text="Yanitiniz"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBox x:Name="ReplyBox"
                 Classes="mestech"
                 AcceptsReturn="True"
                 Height="100"
                 TextWrapping="Wrap"
                 Watermark="Yanitinizi yazin..." />
      </StackPanel>

      <StackPanel Classes="dialog-actions">
        <Button Classes="mestech-outline"
                Content="Iptal"
                Click="OnCancel" />
        <Button Classes="mestech-raised"
                Content="Gonder"
                Click="OnSend" />
      </StackPanel>

    </StackPanel>
  </Border>

</Window>
