<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.TreeSelectDialog"
        Title="Kategori Secimi"
        Width="500" Height="450"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">

  <Border Padding="24">
    <Grid RowDefinitions="Auto,*,Auto">

      <TextBlock x:Name="TitleText"
                 Grid.Row="0"
                 Classes="dialog-title"
                 Text="Kategori Secimi" />

      <TreeView x:Name="TreeItems"
                Grid.Row="1"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Margin="0,8,0,0">
        <TreeView.ItemTemplate>
          <TreeDataTemplate x:CompileBindings="False" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}"
                       FontSize="{StaticResource FontSizeBody}"
                       Foreground="{StaticResource TextPrimaryBrush}" />
          </TreeDataTemplate>
        </TreeView.ItemTemplate>
      </TreeView>

      <StackPanel Grid.Row="2" Classes="dialog-actions">
        <Button Classes="mestech-outline"
                Content="Iptal"
                Click="OnCancel" />
        <Button Classes="mestech-raised"
                Content="Sec"
                Click="OnConfirm" />
      </StackPanel>

    </Grid>
  </Border>

</Window>
