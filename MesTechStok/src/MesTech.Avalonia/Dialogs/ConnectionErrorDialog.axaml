<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.ConnectionErrorDialog"
             AutomationProperties.Name="Connection Error Dialog"
        Title="Baglanti Hatasi"
        Width="480" Height="320"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

  <Border Padding="24">
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <StackPanel Grid.Row="0" Spacing="8">
        <TextBlock Classes="dialog-title" Text="Baglanti Hatasi" />
        <Border Background="{DynamicResource StatusDangerBrush}" CornerRadius="{StaticResource MesRadiusBase}"
                Padding="12,8" Opacity="0.15">
          <TextBlock x:Name="ErrorIcon" Text="Sunucuya baglanilamiyor"
                     FontSize="{StaticResource FontSizeBody}"
                     Foreground="{DynamicResource StatusDangerBrush}"
                     FontWeight="SemiBold" HorizontalAlignment="Center" />
        </Border>
      </StackPanel>

      <!-- Content -->
      <StackPanel Grid.Row="1" Spacing="12" Margin="0,16,0,0">
        <StackPanel Spacing="4">
          <TextBlock Text="Hata Detayi" FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBox x:Name="ErrorDetailBox" Classes="mestech"
                   IsReadOnly="True" AcceptsReturn="True"
                   Height="80" TextWrapping="Wrap"
                   Foreground="{DynamicResource StatusDangerBrush}" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="Sunucu" FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBox x:Name="ServerBox" Classes="mestech" IsReadOnly="True" />
        </StackPanel>
      </StackPanel>

      <!-- Actions -->
      <StackPanel Grid.Row="2" Classes="dialog-actions" Margin="0,12,0,0">
        <Button Classes="mestech-outline" Content="Kapat" Click="OnClose"
                ToolTip.Tip="Pencereyi kapat" />
        <Button Classes="mestech-raised" Content="Tekrar Dene" Click="OnRetry"
                ToolTip.Tip="Baglantiyi tekrar dene" />
      </StackPanel>

    </Grid>
  </Border>

</Window>
