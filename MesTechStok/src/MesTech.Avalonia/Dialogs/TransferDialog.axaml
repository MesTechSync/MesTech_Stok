<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.TransferDialog"
        Title="Stok Transfer"
        Width="500" Height="400"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

  <Border Padding="24">
    <StackPanel Spacing="16">

      <TextBlock Classes="dialog-title"
                 Text="Stok Transfer" />

      <Grid ColumnDefinitions="*,16,*">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Kaynak Depo"
                     FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <ComboBox x:Name="SourceWarehouse"
                    HorizontalAlignment="Stretch" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="4">
          <TextBlock Text="Hedef Depo"
                     FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <ComboBox x:Name="TargetWarehouse"
                    HorizontalAlignment="Stretch" />
        </StackPanel>
      </Grid>

      <StackPanel Spacing="4">
        <TextBlock Text="Urun"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBox x:Name="ProductBox"
                 Classes="mestech"
                 Watermark="Urun adi veya SKU" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Miktar"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <NumericUpDown x:Name="QuantityInput"
                       Minimum="1" Maximum="99999" Value="1"
                       HorizontalAlignment="Stretch" />
      </StackPanel>

      <TextBlock x:Name="ErrorText"
                 Foreground="{DynamicResource ErrorRedBrush}"
                 FontSize="{StaticResource FontSizeSmall}"
                 IsVisible="False" />

      <StackPanel Classes="dialog-actions">
        <Button Classes="mestech-outline"
                Content="Iptal"
                Click="OnCancel" />
        <Button Classes="mestech-raised"
                Content="Transfer Et"
                Click="OnTransfer" />
      </StackPanel>

    </StackPanel>
  </Border>

</Window>
