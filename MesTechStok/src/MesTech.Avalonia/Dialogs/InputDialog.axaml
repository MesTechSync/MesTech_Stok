<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.InputDialog"
             AutomationProperties.Name="Input Dialog"
        xmlns:vm="clr-namespace:MesTech.Avalonia.Dialogs"
        x:DataType="vm:InputDialog"
        Title="Girdi"
        Width="420" Height="240"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

  <Border Padding="24">
    <StackPanel Spacing="16">

      <TextBlock x:Name="TitleText"
                 Classes="dialog-title"
                 Text="Girdi" />

      <TextBlock x:Name="LabelText"
                 Classes="dialog-body"
                 Text="Deger giriniz:" />

      <TextBox x:Name="InputBox"
               Classes="mestech"
               Watermark="Giriniz..." />

      <StackPanel Classes="dialog-actions">
        <Button Classes="mestech-outline"
                Content="Iptal"
                Click="OnCancel" />
        <Button Classes="mestech-raised"
                Content="Tamam"
                Click="OnConfirm" />
      </StackPanel>

    </StackPanel>
  </Border>

</Window>
