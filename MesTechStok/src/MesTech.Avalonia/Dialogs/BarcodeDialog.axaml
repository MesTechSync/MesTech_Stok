<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.BarcodeDialog"
        Title="Barkod"
        Width="400" Height="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">

  <Border Padding="24">
    <StackPanel Spacing="16">

      <TextBlock Classes="dialog-title"
                 Text="Barkod Islemleri" />

      <StackPanel Spacing="4">
        <TextBlock Text="Barkod Numarasi"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{StaticResource TextSecondaryBrush}" />
        <Grid ColumnDefinitions="*,Auto">
          <TextBox x:Name="BarcodeInput"
                   Grid.Column="0"
                   Classes="mestech"
                   Watermark="Barkod numarasi giriniz" />
          <Button Grid.Column="1"
                  Classes="mestech-raised"
                  Content="Olustur"
                  Margin="8,0,0,0"
                  Click="OnGenerate" />
        </Grid>
      </StackPanel>

      <!-- Barcode Display Area -->
      <Border x:Name="BarcodeDisplay"
              Height="80"
              Background="{DynamicResource MesBgPage}"
              CornerRadius="{StaticResource CornerRadiusMedium}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              HorizontalAlignment="Stretch">
        <TextBlock x:Name="BarcodePreview"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
      </Border>

      <StackPanel Classes="dialog-actions">
        <Button Classes="mestech-outline"
                Content="Kapat"
                Click="OnClose" />
      </StackPanel>

    </StackPanel>
  </Border>

</Window>
