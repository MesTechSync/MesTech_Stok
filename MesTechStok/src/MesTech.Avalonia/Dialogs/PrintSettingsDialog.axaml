<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.PrintSettingsDialog"
             AutomationProperties.Name="Print Settings Dialog"
        Title="Yazdir Ayarlari"
        Width="450" Height="350"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

  <Border Padding="24">
    <StackPanel Spacing="16">

      <TextBlock Classes="dialog-title"
                 Text="Yazdirma Ayarlari" />

      <StackPanel Spacing="4">
        <TextBlock Text="Etiket Boyutu"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <ComboBox x:Name="LabelSizeCombo"
                  HorizontalAlignment="Stretch"
                  SelectedIndex="0">
          <ComboBoxItem Content="40x20 mm" />
          <ComboBoxItem Content="50x25 mm" />
          <ComboBoxItem Content="60x40 mm" />
          <ComboBoxItem Content="100x50 mm" />
        </ComboBox>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Kopya Sayisi"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <NumericUpDown x:Name="CopyCount"
                       Minimum="1" Maximum="100" Value="1"
                       HorizontalAlignment="Stretch" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Yazici"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{DynamicResource TextSecondaryBrush}" />
        <ComboBox x:Name="PrinterCombo"
                  HorizontalAlignment="Stretch">
          <ComboBoxItem Content="Varsayilan Yazici" />
        </ComboBox>
      </StackPanel>

      <StackPanel Classes="dialog-actions">
        <Button Classes="mestech-outline"
                Content="Iptal"
                Click="OnCancel" />
        <Button Classes="mestech-raised"
                Content="Yazdir"
                Click="OnPrint" />
      </StackPanel>

    </StackPanel>
  </Border>

</Window>
