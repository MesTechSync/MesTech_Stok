<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.InvoicePreviewDialog"
        Title="Fatura Onizleme"
        Width="600" Height="700"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

  <Border Padding="24">
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

      <TextBlock Grid.Row="0"
                 Classes="dialog-title"
                 Text="Fatura Onizleme" />

      <!-- Seller / Buyer Info -->
      <Grid Grid.Row="1" ColumnDefinitions="*,16,*" Margin="0,8,0,12">
        <Border Grid.Column="0"
                Background="{DynamicResource MesBgPage}"
                CornerRadius="{StaticResource CornerRadiusMedium}"
                Padding="12">
          <StackPanel Spacing="4">
            <TextBlock Text="Satici"
                       FontSize="{StaticResource FontSizeSmall}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock x:Name="SellerName"
                       FontSize="{StaticResource FontSizeBody}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock x:Name="SellerAddress"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="SellerTaxInfo"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Grid.Column="2"
                Background="{DynamicResource MesBgPage}"
                CornerRadius="{StaticResource CornerRadiusMedium}"
                Padding="12">
          <StackPanel Spacing="4">
            <TextBlock Text="Alici"
                       FontSize="{StaticResource FontSizeSmall}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock x:Name="BuyerName"
                       FontSize="{StaticResource FontSizeBody}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock x:Name="BuyerAddress"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="BuyerTaxInfo"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Invoice Info -->
      <Grid Grid.Row="2" ColumnDefinitions="*,*,*" Margin="0,0,0,8">
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="Fatura No"
                     FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock x:Name="InvoiceNoText"
                     FontSize="{StaticResource FontSizeBody}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock Text="Tarih"
                     FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock x:Name="InvoiceDateText"
                     FontSize="{StaticResource FontSizeBody}"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="2" Spacing="2">
          <TextBlock Text="Tur"
                     FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock x:Name="InvoiceTypeText"
                     FontSize="{StaticResource FontSizeBody}"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
        </StackPanel>
      </Grid>

      <!-- Items -->
      <DataGrid x:Name="ItemsGrid"
                Grid.Row="3"
                x:CompileBindings="False"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserReorderColumns="False"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Urun" Binding="{Binding ProductName}" Width="*" />
          <DataGridTextColumn Header="Adet" Binding="{Binding Quantity}" Width="60" />
          <DataGridTextColumn Header="Birim" Binding="{Binding UnitPrice}" Width="80" />
          <DataGridTextColumn Header="KDV %" Binding="{Binding VatRate}" Width="60" />
          <DataGridTextColumn Header="Toplam" Binding="{Binding Total}" Width="90" />
        </DataGrid.Columns>
      </DataGrid>

      <!-- Totals -->
      <Border Grid.Row="4"
              Background="{DynamicResource MesBgPage}"
              CornerRadius="{StaticResource CornerRadiusMedium}"
              Padding="12"
              Margin="0,8,0,0">
        <StackPanel HorizontalAlignment="Right" Spacing="4">
          <StackPanel Orientation="Horizontal" Spacing="24">
            <TextBlock Text="Ara Toplam:" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock x:Name="SubtotalText" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="24">
            <TextBlock Text="KDV:" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBlock x:Name="VatText" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
          </StackPanel>
          <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4" />
          <StackPanel Orientation="Horizontal" Spacing="24">
            <TextBlock Text="Genel Toplam:" FontWeight="Bold" FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock x:Name="GrandTotalText" FontWeight="Bold" FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource PrimaryBlueBrush}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel Grid.Row="5" Classes="dialog-actions">
        <Button Classes="mestech-outline"
                Content="Kapat"
                Click="OnClose" />
      </StackPanel>

    </Grid>
  </Border>

</Window>
