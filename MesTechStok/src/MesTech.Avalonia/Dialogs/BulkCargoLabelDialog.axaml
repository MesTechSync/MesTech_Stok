<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MesTech.Avalonia.Dialogs.BulkCargoLabelDialog"
             x:CompileBindings="False"
             AutomationProperties.Name="Bulk Cargo Label Dialog"
        Title="Toplu Kargo Etiketi"
        Width="720" Height="560"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceBrush}">

  <Border Padding="24">
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

      <!-- Row 0: Title -->
      <TextBlock Grid.Row="0" Classes="dialog-title" Text="Toplu Kargo Etiketi Yazdir" />

      <!-- Row 1: Format + Provider -->
      <Grid Grid.Row="1" ColumnDefinitions="*,20,*" Margin="0,12,0,0">
        <!-- Format Selection -->
        <Border Grid.Column="0" Background="{DynamicResource MesBgSecondary}"
                CornerRadius="{StaticResource MesRadiusBase}" Padding="14,10">
          <StackPanel Spacing="8">
            <TextBlock Text="Etiket Formati" FontSize="{StaticResource FontSizeSmall}"
                       FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="16">
              <RadioButton x:Name="FormatZpl" Content="ZPL (Termal)" IsChecked="True"
                           GroupName="Format" ToolTip.Tip="Termal yazici icin ZPL format" />
              <RadioButton x:Name="FormatPdf" Content="PDF"
                           GroupName="Format" ToolTip.Tip="PDF etiket formati" />
              <RadioButton x:Name="FormatPng" Content="PNG"
                           GroupName="Format" ToolTip.Tip="PNG gorsel etiket" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Provider Selection -->
        <Border Grid.Column="2" Background="{DynamicResource MesBgSecondary}"
                CornerRadius="{StaticResource MesRadiusBase}" Padding="14,10">
          <StackPanel Spacing="8">
            <TextBlock Text="Kargo Firmasi" FontSize="{StaticResource FontSizeSmall}"
                       FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" />
            <ComboBox x:Name="CargoProviderCombo" Classes="mestech" SelectedIndex="0"
                      ToolTip.Tip="Kargo firmasini secin">
              <ComboBoxItem Content="Yurtici Kargo" Tag="YURTICI" />
              <ComboBoxItem Content="Aras Kargo" Tag="ARAS" />
              <ComboBoxItem Content="Surat Kargo" Tag="SURAT" />
            </ComboBox>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Row 2: Label -->
      <TextBlock Grid.Row="2" Text="Kargo Bekleyen Siparisler:"
                 FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                 Foreground="{DynamicResource MesTextPrimary}" Margin="0,12,0,4" />

      <!-- Row 3: DataGrid -->
      <DataGrid x:Name="ShipmentsGrid" Grid.Row="3"
                AutoGenerateColumns="False" IsReadOnly="False"
                GridLinesVisibility="Horizontal"
                Background="{DynamicResource MesBgPrimary}"
                BorderBrush="{DynamicResource MesBorderDefault}" BorderThickness="1">
        <DataGrid.Columns>
          <DataGridCheckBoxColumn Header="Sec" Width="50" />
          <DataGridTextColumn Header="Siparis No" Width="130" IsReadOnly="True" />
          <DataGridTextColumn Header="Musteri" Width="*" IsReadOnly="True" />
          <DataGridTextColumn Header="Platform" Width="110" IsReadOnly="True" />
          <DataGridTextColumn Header="Kargo Takip" Width="140" IsReadOnly="True" />
        </DataGrid.Columns>
      </DataGrid>

      <!-- Row 4: Summary -->
      <Border Grid.Row="4" Background="{DynamicResource MesBgSecondary}"
              CornerRadius="{StaticResource MesRadiusBase}" Padding="12,8" Margin="0,8,0,0"
              BorderBrush="{DynamicResource MesBorderDefault}" BorderThickness="1">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock x:Name="SelectionSummary" Grid.Column="0"
                     Text="0 siparis secildi"
                     FontSize="{StaticResource FontSizeSmall}"
                     Foreground="{DynamicResource MesTextPrimary}" VerticalAlignment="Center" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Classes="mestech-outline" Content="Tumunu Sec" Click="OnSelectAll"
                    ToolTip.Tip="Tum siparisleri sec" />
            <Button Classes="mestech-outline" Content="Secimi Kaldir" Click="OnDeselectAll"
                    ToolTip.Tip="Secimi temizle" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Row 5: Actions -->
      <StackPanel Grid.Row="5" Classes="dialog-actions" Margin="0,12,0,0">
        <Button Classes="mestech-outline" Content="Iptal" Click="OnCancel"
                ToolTip.Tip="Islemi iptal et" />
        <Button Classes="mestech-raised" Content="Secilenleri Yazdir" Click="OnPrint"
                ToolTip.Tip="Secilen siparislerin kargo etiketlerini yazdir" />
      </StackPanel>

    </Grid>
  </Border>

</Window>
