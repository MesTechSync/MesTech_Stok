<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Controls.CargoProviderCard"
             x:DataType="controls:CargoProviderCardViewModel">

  <Border Classes="card" Padding="16" MinWidth="280" CornerRadius="8"
          Background="{DynamicResource CardBackgroundBrush}"
          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
      <!-- Row 0: Logo + Name + Status dot -->
      <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="10">
        <Border Width="40" Height="40" CornerRadius="8"
                Background="{Binding ProviderColor}">
          <TextBlock Text="&#x1F4E6;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="{Binding ProviderName}" FontWeight="SemiBold" FontSize="14"/>
          <TextBlock Text="{Binding ApiTypeText}" FontSize="11" Opacity="0.6"/>
        </StackPanel>
      </StackPanel>
      <Ellipse Grid.Row="0" Grid.Column="1" Width="10" Height="10"
               Fill="{Binding ConnectionStatusColor}"
               VerticalAlignment="Top" Margin="0,4,0,0"
               ToolTip.Tip="{Binding ConnectionStatusTooltip}"/>

      <!-- Row 1: Divider -->
      <Border Grid.Row="1" Grid.ColumnSpan="2" Height="1"
              Background="{DynamicResource BorderBrush}" Margin="0,12"/>

      <!-- Row 2: Stats -->
      <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="6">
        <DockPanel>
          <TextBlock Text="Son gönderim:" FontSize="12" Opacity="0.7"/>
          <TextBlock DockPanel.Dock="Right" Text="{Binding LastShipmentText}" FontWeight="Medium" FontSize="12"/>
        </DockPanel>
        <DockPanel>
          <TextBlock Text="Bugün:" FontSize="12" Opacity="0.7"/>
          <TextBlock DockPanel.Dock="Right" Text="{Binding TodayStats}" FontWeight="Medium" FontSize="12"/>
        </DockPanel>
        <DockPanel>
          <TextBlock Text="Ort. teslim:" FontSize="12" Opacity="0.7"/>
          <TextBlock DockPanel.Dock="Right" Text="{Binding AvgDeliveryDays, StringFormat={}{0:N1} gün}" FontWeight="Medium" FontSize="12"/>
        </DockPanel>
      </StackPanel>

      <!-- Row 3: Divider -->
      <Border Grid.Row="3" Grid.ColumnSpan="2" Height="1"
              Background="{DynamicResource BorderBrush}" Margin="0,12"/>

      <!-- Row 4: Action buttons -->
      <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button Content="Takip Et" Padding="12,6" FontSize="12" Command="{Binding TrackCommand}"/>
        <Button Content="Gönderi Oluştur" Padding="12,6" FontSize="12" Classes="accent" Command="{Binding CreateShipmentCommand}"/>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
