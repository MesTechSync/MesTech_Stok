<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Controls.OrderTimelineControl"
             x:CompileBindings="False">

  <ItemsControl ItemsSource="{Binding TimelineSteps}">
    <ItemsControl.ItemsPanel>
      <ItemsPanelTemplate>
        <StackPanel Orientation="Horizontal" Spacing="0"/>
      </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
    <ItemsControl.ItemTemplate>
      <DataTemplate x:DataType="controls:TimelineStepViewModel">
        <StackPanel Width="120" Spacing="4">
          <Grid ColumnDefinitions="Auto,*">
            <Ellipse Grid.Column="0" Width="20" Height="20"
                     Fill="{Binding StepColor}"
                     Stroke="{Binding StepBorderColor}"
                     StrokeThickness="2"/>
            <Border Grid.Column="1" Height="2"
                    Background="{Binding LineColor}"
                    VerticalAlignment="Center" Margin="4,0"
                    IsVisible="{Binding !IsLastStep}"/>
          </Grid>
          <TextBlock Text="{Binding StepTitle}"
                     FontSize="11" FontWeight="{Binding TitleWeight}"
                     Foreground="{Binding TitleColor}"
                     HorizontalAlignment="Left"/>
          <TextBlock Text="{Binding DateTimeText}"
                     FontSize="10" Opacity="0.5"
                     HorizontalAlignment="Left"/>
        </StackPanel>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
