<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.MesaAvaloniaView"
             x:DataType="vm:MesaAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="MESA OS — AI Dashboard" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#10B98144" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding AiStatus}" Foreground="White"
                                   FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22" Spacing="16">

                <!-- Loading -->
                <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                           Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" Margin="0,20" />

                <!-- Error -->
                <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}"
                        CornerRadius="8" Padding="16" BorderBrush="#FECACA" BorderThickness="1">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" TextWrapping="Wrap" />
                </Border>

                <!-- KPI Cards -->
                <UniformGrid Columns="4" IsVisible="{Binding !IsLoading}">
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Model" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding ModelVersion}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Tahmin Sayisi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding PredictionCount}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Dogruluk" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding Accuracy}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource MesEmerald}" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Durum" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding AiStatus}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource MesEmerald}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- AI Tools + Recent Predictions -->
                <Grid ColumnDefinitions="*,*" IsVisible="{Binding !IsLoading}">
                    <!-- AI Tools -->
                    <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="AI Araclari" FontWeight="SemiBold" FontSize="15" />
                            <ItemsControl ItemsSource="{Binding AiTools}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MesaToolVm">
                                        <Border Margin="0,0,0,8" Padding="12" Background="{DynamicResource MesBgPage}"
                                                CornerRadius="6" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Background="{DynamicResource MesPrimaryBlue}" CornerRadius="6"
                                                        Width="36" Height="36" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Icon}" Foreground="White"
                                                               FontSize="16" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                               Foreground="{DynamicResource MesSlateGray}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                        VerticalAlignment="Top">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#10B981" Opacity="0.15" />
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{DynamicResource MesEmerald}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Recent Predictions -->
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Son Tahminler" FontWeight="SemiBold" FontSize="15" />
                            <ItemsControl ItemsSource="{Binding RecentPredictions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MesaPredictionVm">
                                        <Border Margin="0,0,0,8" Padding="12" Background="{DynamicResource MesBgPage}"
                                                CornerRadius="6" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding Tool}"
                                                               FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource MesPrimaryBlue}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Confidence}"
                                                               FontSize="11" Foreground="{DynamicResource MesEmerald}" FontWeight="Bold" />
                                                </Grid>
                                                <TextBlock Text="{Binding Result}" FontSize="12"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TimeDisplay}" FontSize="10"
                                                           Foreground="{DynamicResource MesMutedGray}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Last Updated -->
                <TextBlock Text="{Binding LastUpdated, StringFormat='Son guncelleme: {0}'}"
                           FontSize="11" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Right"
                           IsVisible="{Binding !IsLoading}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
