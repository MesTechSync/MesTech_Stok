<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.MesaAvaloniaView"
             x:DataType="vm:MesaAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="MESA OS — AI Dashboard" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesMesaGlow}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding AiStatus}" Foreground="{DynamicResource MesBgPrimary}"
                                   FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22" Spacing="16">

                <!-- Loading -->
                <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                           Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" Margin="0,20" />

                <!-- Error -->
                <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}"
                        CornerRadius="{StaticResource MesRadiusMd}" Padding="16" BorderBrush="{DynamicResource MesBorderDanger}" BorderThickness="1">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" TextWrapping="Wrap" />
                </Border>

                <!-- KPI Cards -->
                <UniformGrid Columns="4" IsVisible="{Binding !IsLoading}">
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Model" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding ModelVersion}" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Tahmin Sayisi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding PredictionCount}" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Dogruluk" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding Accuracy}" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold" Foreground="{DynamicResource MesEmerald}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Durum" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding AiStatus}" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold" Foreground="{DynamicResource MesEmerald}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- AI Tools + Recent Predictions -->
                <Grid ColumnDefinitions="*,*" IsVisible="{Binding !IsLoading}">
                    <!-- AI Tools -->
                    <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="AI Araclari" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBodyLg}" />
                            <ItemsControl ItemsSource="{Binding AiTools}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MesaToolVm">
                                        <Border Margin="0,0,0,8" Padding="12" Background="{DynamicResource MesBgPage}"
                                                CornerRadius="{StaticResource MesRadiusBase}" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Background="{DynamicResource MesPrimaryBlue}" CornerRadius="{StaticResource MesRadiusBase}"
                                                        Width="36" Height="36" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Icon}" Foreground="{DynamicResource MesBgPrimary}"
                                                               FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeCallout}" />
                                                    <TextBlock Text="{Binding Description}" FontSize="{StaticResource FontSizeCaption}"
                                                               Foreground="{DynamicResource MesSlateGray}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Border Grid.Column="2" CornerRadius="{StaticResource MesRadiusSm}" Padding="6,2"
                                                        VerticalAlignment="Top">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{DynamicResource MesEmerald}" Opacity="0.15" />
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Status}" FontSize="{StaticResource FontSizeCaption1}" Foreground="{DynamicResource MesEmerald}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Recent Predictions -->
                    <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Son Tahminler" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBodyLg}" />
                            <ItemsControl ItemsSource="{Binding RecentPredictions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MesaPredictionVm">
                                        <Border Margin="0,0,0,8" Padding="12" Background="{DynamicResource MesBgPage}"
                                                CornerRadius="{StaticResource MesRadiusBase}" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding Tool}"
                                                               FontWeight="SemiBold" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesPrimaryBlue}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Confidence}"
                                                               FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesEmerald}" FontWeight="Bold" />
                                                </Grid>
                                                <TextBlock Text="{Binding Result}" FontSize="{StaticResource FontSizeSmall}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TimeDisplay}" FontSize="{StaticResource FontSizeCaption1}"
                                                           Foreground="{DynamicResource MesMutedGray}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Last Updated -->
                <TextBlock Text="{Binding LastUpdated, StringFormat='Son guncelleme: {0}'}"
                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Right"
                           IsVisible="{Binding !IsLoading}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
