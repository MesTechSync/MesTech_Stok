<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ReportsAvaloniaView"
             x:DataType="vm:ReportsAvaloniaViewModel">

    <!-- Stub view for Reports — Dalga 11 -->

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="#475569" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Raporlar"
                           Foreground="White" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#475569" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Placeholder Content -->
        <Border Grid.Row="1" Background="#F8FAFC" Margin="24"
                CornerRadius="12" BorderBrush="#E0E6ED" BorderThickness="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <Border Background="#F1F5F9" CornerRadius="50" Width="80" Height="80"
                        HorizontalAlignment="Center">
                    <TextBlock Text="&#x1F4CA;" FontSize="36"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Raporlar" FontSize="22" FontWeight="Bold"
                           Foreground="#1E293B" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Summary}" FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"
                           TextAlignment="Center" />
                <TextBlock Text="Satis analizi | Stok raporu | Platform karsilastirmasi | Ozel sablonlar"
                           FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
