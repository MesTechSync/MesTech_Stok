<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ReportsAvaloniaView"
             x:DataType="vm:ReportsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Raporlar — Dalga 14/15 -->

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Raporlar"
                           Foreground="White" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Background="{DynamicResource MesBgPage}">
            <StackPanel Margin="24" Spacing="20">

                <!-- Date Range Picker -->
                <Border Background="White" CornerRadius="12" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Tarih Araligi" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Baslangic" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <DatePicker SelectedDate="{Binding StartDate}" Width="180" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Bitis" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <DatePicker SelectedDate="{Binding EndDate}" Width="180" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Status Message -->
                <TextBlock Text="{Binding Summary}" FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           TextWrapping="Wrap" Margin="0,0,0,4" />

                <!-- Generating Overlay Message -->
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="8" Padding="16"
                        BorderBrush="#FDBA74" BorderThickness="1"
                        IsVisible="{Binding IsGenerating}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                     VerticalAlignment="Center" />
                        <TextBlock Text="{Binding GeneratingMessage}" FontSize="14"
                                   Foreground="{DynamicResource MesAmber}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Summary Number Cards -->
                <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,8">

                    <!-- Satis Ozeti -->
                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="0,0,6,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Toplam Satis" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TotalSales}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" />
                            <TextBlock Text="{Binding TotalOrders, StringFormat='{}{0} siparis'}" FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>
                    </Border>

                    <!-- Stok Ozeti -->
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="3,0,3,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Toplam Urun" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TotalProducts}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MesGreen}" />
                            <TextBlock Text="{Binding LowStockCount, StringFormat='{}{0} dusuk stok'}" FontSize="12" Foreground="{DynamicResource MesAmber}" />
                        </StackPanel>
                    </Border>

                    <!-- Gelir Ozeti -->
                    <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="6,0,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Net Kar" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding NetProfit}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MesTeal}" />
                            <TextBlock Text="{Binding TotalExpenses, StringFormat='Gider: {0}'}" FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Report Cards -->
                <Grid ColumnDefinitions="*,*,*">

                    <!-- Satis Raporu Card -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="0,0,10,0">
                        <StackPanel Spacing="12">
                            <Border Background="{DynamicResource MesBgSurface}" CornerRadius="8" Width="48" Height="48"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="S" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource MesPrimaryBlue}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Satis Raporu" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Secili tarih araligindaki satis performansi, siparis sayilari ve ortalama sepet tutari analizi."
                                       FontSize="13" Foreground="{DynamicResource MesSlateGray}" TextWrapping="Wrap"
                                       MinHeight="48" />
                            <Button Content="Rapor Olustur" ToolTip.Tip="Rapor olustur ve indir"
                                    Command="{Binding GenerateReportCommand}"
                                    CommandParameter="Satis Raporu"
                                    Background="{DynamicResource MesPrimaryBlue}" Foreground="White"
                                    FontWeight="SemiBold" Padding="16,10"
                                    CornerRadius="6" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Stok Raporu Card -->
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="24"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="5,0,5,0">
                        <StackPanel Spacing="12">
                            <Border Background="{DynamicResource MesBgSurface}" CornerRadius="8" Width="48" Height="48"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="D" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource MesGreen}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Stok Raporu" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Depo bazli stok durumu, dusuk stoklu urunler ve stok hareket gecmisi detaylari."
                                       FontSize="13" Foreground="{DynamicResource MesSlateGray}" TextWrapping="Wrap"
                                       MinHeight="48" />
                            <Button Content="Rapor Olustur" ToolTip.Tip="Rapor olustur ve indir"
                                    Command="{Binding GenerateReportCommand}"
                                    CommandParameter="Stok Raporu"
                                    Background="{DynamicResource MesGreen}" Foreground="White"
                                    FontWeight="SemiBold" Padding="16,10"
                                    CornerRadius="6" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Finansal Rapor Card -->
                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="10,0,0,0">
                        <StackPanel Spacing="12">
                            <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="8" Width="48" Height="48"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="F" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource MesRedAlert}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Finansal Rapor" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Gelir-gider analizi, kar-zarar tablosu ve donem bazli finansal performans ozeti."
                                       FontSize="13" Foreground="{DynamicResource MesSlateGray}" TextWrapping="Wrap"
                                       MinHeight="48" />
                            <Button Content="Rapor Olustur" ToolTip.Tip="Rapor olustur ve indir"
                                    Command="{Binding GenerateReportCommand}"
                                    CommandParameter="Finansal Rapor"
                                    Background="{DynamicResource MesRedAlert}" Foreground="White"
                                    FontWeight="SemiBold" Padding="16,10"
                                    CornerRadius="6" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Raporlar yukleniyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
