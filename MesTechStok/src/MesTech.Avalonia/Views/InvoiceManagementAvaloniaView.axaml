<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MesTech.Avalonia.Views.InvoiceManagementAvaloniaView">

    <!-- Avalonia port — Fatura Yonetimi -->

    <Grid RowDefinitions="Auto,*" Background="#F8FAFC">
        <Border Grid.Row="0" Background="#DC2626" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Fatura Yonetimi" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" x:Name="RetryButton"
                        Background="White" Foreground="#DC2626" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border x:Name="ContentArea" Grid.Row="1" Background="White" CornerRadius="12"
                Margin="22" Padding="24"
                BorderBrush="#E0E6ED" BorderThickness="1">
            <TextBlock Text="Avalonia port — Fatura Yonetimi" FontSize="14" Foreground="#64748B"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="2"
                Background="#80000000"
                IsVisible="False"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Faturalar yukleniyor..."
                           FontSize="14" Foreground="White"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="0" Grid.RowSpan="2"
                Background="White"
                IsVisible="False"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Fatura bulunamadi" FontSize="48"
                           HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8" />
                <TextBlock Text="Henuz fatura kaydedilmemis"
                           FontSize="16" Foreground="#64748B"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.Row="0" Grid.RowSpan="2"
                Background="White"
                IsVisible="False"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#E53935"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="ErrorText"
                           Text="Faturalar yuklenemedi"
                           FontSize="14" Foreground="#E53935"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" x:Name="RetryErrorButton"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
