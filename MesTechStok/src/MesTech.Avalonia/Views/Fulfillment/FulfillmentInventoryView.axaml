<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.Fulfillment.FulfillmentInventoryView"
             x:Name="FulfillmentInventoryView"
             x:DataType="vm:FulfillmentInventoryViewModel">
<UserControl.KeyBindings>
    <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
</UserControl.KeyBindings>

    <!-- F-03: Fulfillment Cross-Inventory Comparison -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Fulfillment Envanter" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} urun'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Envanter verilerini yenile (F5)"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Tab Filter + Search -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button Content="Tumu" ToolTip.Tip="Tum merkezleri goster"
                            Command="{Binding SelectTabCommand}" CommandParameter="Tumu"
                            Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}"
                            FontWeight="{Binding TabAllWeight}" />
                    <Button Content="Amazon FBA" ToolTip.Tip="Amazon FBA envanteri"
                            Command="{Binding SelectTabCommand}" CommandParameter="AmazonFBA"
                            Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}"
                            FontWeight="{Binding TabFbaWeight}" />
                    <Button Content="Hepsilojistik" ToolTip.Tip="Hepsilojistik envanteri"
                            Command="{Binding SelectTabCommand}" CommandParameter="Hepsilojistik"
                            Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}"
                            FontWeight="{Binding TabHepsiWeight}" />
                    <Button Content="Yerel Depo" ToolTip.Tip="Kendi depo envanteri"
                            Command="{Binding SelectTabCommand}" CommandParameter="OwnWarehouse"
                            Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}"
                            FontWeight="{Binding TabLocalWeight}" />
                </StackPanel>
                <TextBox Grid.Column="1" Width="260" Watermark="SKU veya urun adi ara..."
                         AutomationProperties.Name="SKU veya urun adi ara..."
                         Text="{Binding SearchText}" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Inventory DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding InventoryItems}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="160" />
                <DataGridTextColumn Header="Urun Adi" Binding="{Binding ProductName}" Width="220" />
                <DataGridTextColumn Header="FBA Adet" Binding="{Binding FbaQty}" Width="90" />
                <DataGridTextColumn Header="HepsiL Adet" Binding="{Binding HepsiQty}" Width="100" />
                <DataGridTextColumn Header="Yerel Adet" Binding="{Binding LocalQty}" Width="100" />
                <DataGridTextColumn Header="Toplam" Binding="{Binding TotalQty}" Width="90" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Envanter verileri yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Envanter kaydi bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Secilen merkez icin envanter verisi yok"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
