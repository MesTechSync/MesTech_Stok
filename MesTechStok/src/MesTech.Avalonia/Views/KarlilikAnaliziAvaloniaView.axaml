<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.KarlilikAnaliziAvaloniaView"
             x:DataType="vm:KarlilikAnaliziAvaloniaViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#059669" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Karlilik Analizi" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} urun'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#059669" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- KPI Row -->
        <Border Grid.Row="1" Background="#F8FAFC" Padding="16,12">
            <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" Margin="4"
                        BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Toplam Ciro" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding TotalRevenue}" FontSize="20" FontWeight="Bold"
                                   Foreground="#2563EB" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16" Margin="4"
                        BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Toplam Kar" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding TotalProfit}" FontSize="20" FontWeight="Bold"
                                   Foreground="#10B981" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16" Margin="4"
                        BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Ortalama Marj" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding AverageMargin}" FontSize="20" FontWeight="Bold"
                                   Foreground="#8B5CF6" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="2" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox ItemsSource="{Binding Platforms}" SelectedItem="{Binding SelectedPlatform}"
                          Width="160" />
                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                          Width="160" />
                <TextBox Width="220" Watermark="Urun adi ara..."
                         Text="{Binding SearchText}" />
                <DatePicker SelectedDate="{Binding StartDate}" Width="140" />
                <DatePicker SelectedDate="{Binding EndDate}" Width="140" />
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Background="White" Margin="16" CornerRadius="12"
                BorderBrush="#E0E6ED" BorderThickness="1">
                <Grid>
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Urun" Binding="{Binding ProductName}" Width="*" />
                    <DataGridTextColumn Header="Satis" Binding="{Binding SalesFormatted}" Width="120" />
                    <DataGridTextColumn Header="Maliyet" Binding="{Binding CostFormatted}" Width="120" />
                    <DataGridTextColumn Header="Komisyon" Binding="{Binding CommissionFormatted}" Width="110" />
                    <DataGridTextColumn Header="Kargo" Binding="{Binding ShippingFormatted}" Width="100" />
                    <DataGridTextColumn Header="Net Kar" Binding="{Binding NetProfitFormatted}" Width="120" />
                    <DataGridTextColumn Header="Marj (%)" Binding="{Binding MarginFormatted}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="16"
                               IsVisible="{Binding !Items.Count}" />
                </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Karlilik verileri yukleniyor..." FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="3"
                Background="#F7F9FC"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Kayit bulunamadi" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#1E293B" Margin="0,0,0,8" />
                <TextBlock Text="Secilen filtreler icin karlilik verisi bulunamadi"
                           FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#F7F9FC"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#E53935" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="#E53935"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
