<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.InvoiceReportAvaloniaView"
             x:DataType="vm:InvoiceReportAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Fatura Raporlari — Donem secimi, KPI kartlari, platform dagilimi -->

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource BackgroundBrush}">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBlueBrush}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <PathIcon Data="{StaticResource IconChart}" Width="22" Height="22" Foreground="{DynamicResource MesBgPrimary}"/>
                    <TextBlock Text="Fatura Raporlari" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeHeader}" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Excel" Command="{Binding ExportExcelCommand}"
                            ToolTip.Tip="Excel"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="{StaticResource CornerRadiusMedium}">
                    </Button>
                    <Button Content="PDF" Command="{Binding ExportPdfCommand}"
                            ToolTip.Tip="PDF"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource ErrorRedBrush}" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="{StaticResource CornerRadiusMedium}">
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Period Filter -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Padding="16,10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Baslangic:" VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DatePicker SelectedDate="{Binding FromDate}" Width="160"/>
                <TextBlock Text="Bitis:" VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <DatePicker SelectedDate="{Binding ToDate}" Width="160"/>
                <ComboBox Width="150" ItemsSource="{Binding PlatformList}"
                          SelectedItem="{Binding SelectedPlatform}"/>
                <Button Command="{Binding RefreshCommand}" Background="Transparent"
                        BorderThickness="0" Padding="8"
                        CornerRadius="{StaticResource CornerRadiusMedium}">
                    <PathIcon Data="{StaticResource IconRefresh}" Width="18" Height="18"
                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Row 2: KPI Cards -->
        <Border Grid.Row="2" Background="{DynamicResource BackgroundBrush}" Padding="16">
            <UniformGrid Columns="4" Rows="1">
                <!-- Total Invoices -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20,16" Margin="8,0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Toplam Fatura"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalCount}"
                                   FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <!-- Total Amount -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20,16" Margin="8,0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Toplam Tutar"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2} TL'}"
                                   FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBlueBrush}"/>
                    </StackPanel>
                </Border>
                <!-- e-Fatura Count -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20,16" Margin="8,0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="e-Fatura"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding EFaturaCount}"
                                   FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPrimaryBlue}"/>
                    </StackPanel>
                </Border>
                <!-- e-Arsiv Count -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20,16" Margin="8,0"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="e-Arsiv"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding EArsivCount}"
                                   FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPurple}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <!-- Row 3: Platform Breakdown Table -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding PlatformBreakdown}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True" CanUserResizeColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource SurfaceBrush}"
                  Margin="16,0,16,16"
                  CornerRadius="{StaticResource CornerRadiusLarge}"
                  IsVisible="{Binding !IsLoading}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="200"/>
                <DataGridTextColumn Header="Fatura Sayisi" Binding="{Binding InvoiceCount}" Width="140"/>
                <DataGridTextColumn Header="Toplam Tutar (TL)" Binding="{Binding TotalAmount, StringFormat='{}{0:N2}'}" Width="180"/>
                <DataGridTextColumn Header="e-Fatura" Binding="{Binding EFaturaCount}" Width="120"/>
                <DataGridTextColumn Header="e-Arsiv" Binding="{Binding EArsivCount}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
<!-- Empty State -->        <TextBlock Grid.Row="3" Text="Fatura bulunamadi"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !PlatformBreakdown.Count}" />

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12"/>
                <TextBlock Text="Rapor yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Fatura bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz fatura bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
