<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.InvoiceReportAvaloniaView"
             x:DataType="vm:InvoiceReportAvaloniaViewModel">

    <!-- Fatura Raporlari — Donem secimi, KPI kartlari, platform dagilimi -->

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{StaticResource BackgroundBrush}">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <PathIcon Data="{StaticResource IconChart}" Width="22" Height="22" Foreground="White"/>
                    <TextBlock Text="Fatura Raporlari" Foreground="White"
                               FontSize="{StaticResource FontSizeHeader}" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Excel" Command="{Binding ExportExcelCommand}"
                            Background="White" Foreground="#16A34A" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="{StaticResource CornerRadiusMedium}">
                    </Button>
                    <Button Content="PDF" Command="{Binding ExportPdfCommand}"
                            Background="White" Foreground="{StaticResource ErrorRedBrush}" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="{StaticResource CornerRadiusMedium}">
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Period Filter -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Padding="16,10"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Baslangic:" VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <DatePicker SelectedDate="{Binding FromDate}" Width="160"/>
                <TextBlock Text="Bitis:" VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <DatePicker SelectedDate="{Binding ToDate}" Width="160"/>
                <ComboBox Width="150" ItemsSource="{Binding PlatformList}"
                          SelectedItem="{Binding SelectedPlatform}"/>
                <Button Command="{Binding RefreshCommand}" Background="Transparent"
                        BorderThickness="0" Padding="8"
                        CornerRadius="{StaticResource CornerRadiusMedium}">
                    <PathIcon Data="{StaticResource IconRefresh}" Width="18" Height="18"
                              Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Row 2: KPI Cards -->
        <Border Grid.Row="2" Background="{StaticResource BackgroundBrush}" Padding="16">
            <UniformGrid Columns="4" Rows="1">
                <!-- Total Invoices -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20,16" Margin="8,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Toplam Fatura"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalCount}"
                                   FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <!-- Total Amount -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20,16" Margin="8,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Toplam Tutar"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2} TL'}"
                                   FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBlueBrush}"/>
                    </StackPanel>
                </Border>
                <!-- e-Fatura Count -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20,16" Margin="8,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="e-Fatura"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding EFaturaCount}"
                                   FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPrimaryBlue}"/>
                    </StackPanel>
                </Border>
                <!-- e-Arsiv Count -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20,16" Margin="8,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="e-Arsiv"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding EArsivCount}"
                                   FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                                   Foreground="#7B1FA2"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <!-- Row 3: Platform Breakdown Table -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding PlatformBreakdown}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{StaticResource SurfaceBrush}"
                  Margin="16,0,16,16"
                  CornerRadius="{StaticResource CornerRadiusLarge}"
                  IsVisible="{Binding !IsLoading}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="200"/>
                <DataGridTextColumn Header="Fatura Sayisi" Binding="{Binding InvoiceCount}" Width="140"/>
                <DataGridTextColumn Header="Toplam Tutar (TL)" Binding="{Binding TotalAmount, StringFormat='{}{0:N2}'}" Width="180"/>
                <DataGridTextColumn Header="e-Fatura" Binding="{Binding EFaturaCount}" Width="120"/>
                <DataGridTextColumn Header="e-Arsiv" Binding="{Binding EArsivCount}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
<!-- Empty State -->        <TextBlock Grid.Row="3" Text="Kayıt bulunamadı"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="16"                   IsVisible="{Binding !PlatformBreakdown.Count}" />

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12"/>
                <TextBlock Text="Rapor yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
