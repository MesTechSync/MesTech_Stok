<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.StockAvaloniaView"
             x:DataType="vm:StockAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />        <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesTeal}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Stok Yonetimi"
                           Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox x:Name="SearchBox" Grid.Column="0" Watermark="Urun veya SKU ara..." AutomationProperties.Name="Urun veya SKU ara..." Width="280" HorizontalAlignment="Left" />
                <ComboBox Grid.Column="1" PlaceholderText="Depo" Width="140" Margin="8,0"  AutomationProperties.Name="Depo" />
                <Button Grid.Column="2" Content="+ Stok Hareketi" Command="{Binding AddMovementCommand}"
                        Background="{DynamicResource MesTeal}" Foreground="{DynamicResource MesBgPrimary}"
                        ToolTip.Tip="Yeni stok hareketi olustur"
                        FontWeight="SemiBold" Padding="12,6" CornerRadius="{StaticResource MesRadiusSm}" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Stock Summary -->
            <StackPanel VerticalAlignment="Top" Margin="20" Spacing="12"
                        IsVisible="{Binding !IsLoading}">
                <TextBlock Text="{Binding Summary}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" Opacity="0.7" />
                <TextBlock Text="{Binding TotalCount, StringFormat='Toplam: {0} stok kalemi'}" FontSize="{StaticResource FontSizeCallout}" Opacity="0.5" />
            </StackPanel>

            <!-- Loading Skeleton -->
            <Border Grid.Row="0"
                    Background="{DynamicResource MesBgPage}"
                    IsVisible="{Binding IsLoading}"
                    ZIndex="100">
                <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
            </Border>
        </Grid>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Stok verisi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz urun bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Grid.Row="0"
                    Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

</Grid>
</UserControl>
