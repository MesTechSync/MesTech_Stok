<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StockAvaloniaView"
             x:DataType="vm:StockAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesTeal}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Stok Yonetimi"
                           Foreground="{DynamicResource MesBgPrimary}" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Watermark="Urun veya SKU ara..." AutomationProperties.Name="Urun veya SKU ara..." Width="280" HorizontalAlignment="Left" />
                <ComboBox Grid.Column="1" PlaceholderText="Depo" Width="140" Margin="8,0" />
                <Button Grid.Column="2" Content="+ Stok Hareketi" Background="{DynamicResource MesTeal}" Foreground="{DynamicResource MesBgPrimary}"
                        FontWeight="SemiBold" Padding="12,6" CornerRadius="4" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Stock DataGrid -->
            <DataGrid ItemsSource="{Binding StockItems}"
                      SelectedItem="{Binding SelectedStockItem}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource MesBgPrimary}"
                      IsVisible="{Binding !IsLoading}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="140" />
                    <DataGridTextColumn Header="Urun Adi" Binding="{Binding ProductName}" Width="250" />
                    <DataGridTextColumn Header="Depo" Binding="{Binding Warehouse}" Width="120" />
                    <DataGridTextColumn Header="Mevcut Stok" Binding="{Binding CurrentStock}" Width="110" />
                    <DataGridTextColumn Header="Min Stok" Binding="{Binding MinStock}" Width="90" />
                    <DataGridTextColumn Header="Durum" Binding="{Binding StockStatus}" Width="100" />
                    <DataGridTextColumn Header="Son Hareket" Binding="{Binding LastMovementDisplay}" Width="160" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty State -->
            <TextBlock Text="Stok verisi bulunamadi"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,40" Opacity="0.5" FontSize="16"
                       IsVisible="{Binding !StockItems.Count}" />

            <!-- Loading Overlay -->
            <Border Background="{DynamicResource MesOverlayLight}"
                    IsVisible="{Binding IsLoading}" ZIndex="100">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                    <TextBlock Text="Stok verileri yukleniyor..."
                               FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
