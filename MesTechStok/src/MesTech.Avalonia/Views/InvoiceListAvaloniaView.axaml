<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.InvoiceListAvaloniaView"
             x:DataType="vm:InvoiceListAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />        <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />    </UserControl.KeyBindings>

    <!-- Fatura Listesi — Arama, Filtre, DataGrid, Sayfalama -->

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource BackgroundBrush}">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBlueBrush}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <PathIcon Data="{StaticResource IconReceipt}" Width="22" Height="22" Foreground="{DynamicResource MesBgPrimary}"/>
                    <TextBlock Text="Faturalar" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeHeader}" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Yeni Fatura" ToolTip.Tip="Yeni fatura olustur"
                            Command="{Binding CreateInvoiceCommand}"
                            Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource CornerRadiusMedium}"/>
                    <!-- KD-DEV2-006: Export Excel button -->
                    <Button Content="Excel Aktar" ToolTip.Tip="Fatura listesini Excel olarak disari aktar"
                            Command="{Binding ExportExcelCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource CornerRadiusMedium}"/>
                    <Button Content="Iptal Et" ToolTip.Tip="Secili faturayi iptal et"
                            Command="{Binding CancelInvoiceCommand}"
                            Background="{DynamicResource StatusDangerBrush}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource CornerRadiusMedium}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Filters -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Padding="16,10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox x:Name="SearchBox" Width="260" Watermark="Fatura no veya alici ara..." AutomationProperties.Name="Fatura no veya alici ara..."
                         Text="{Binding SearchText}" FontSize="{StaticResource FontSizeBody}"/>
                <ComboBox Width="140" ItemsSource="{Binding InvoiceTypes}"
                          SelectedItem="{Binding SelectedType}" AutomationProperties.Name="Type seciniz"/>
                <ComboBox Width="140" ItemsSource="{Binding StatusList}"
                          SelectedItem="{Binding SelectedStatus}" AutomationProperties.Name="Status seciniz"/>
                <ComboBox Width="150" ItemsSource="{Binding PlatformList}"
                          SelectedItem="{Binding SelectedPlatform}" AutomationProperties.Name="Platform seciniz"/>
                <Button Command="{Binding RefreshCommand}" Background="Transparent"
                        ToolTip.Tip="Verileri yenile"
                        BorderThickness="0" Padding="8"
                        CornerRadius="{StaticResource CornerRadiusMedium}">
                    <PathIcon Data="{StaticResource IconRefresh}" Width="18" Height="18"
                              Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Row 2: DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Invoices}"
                  SelectedItem="{Binding SelectedInvoice}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource SurfaceBrush}"
                 >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fatura No" Binding="{Binding InvoiceNumber}" Width="170"/>
                <DataGridTextColumn Header="Alici" Binding="{Binding RecipientName}" Width="240"/>
                <DataGridTemplateColumn Header="Tip" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:InvoiceListItemDto">
                            <Border Padding="6,2" CornerRadius="{StaticResource MesRadiusSm}" HorizontalAlignment="Left"
                                    Margin="4,0">
                                <Border.Background>
                                    <MultiBinding Converter="{x:Null}">
                                        <Binding Path="Type"/>
                                    </MultiBinding>
                                </Border.Background>
                                <TextBlock Text="{Binding Type}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesBgPrimary}"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Durum" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:InvoiceListItemDto">
                            <Border Padding="6,2" CornerRadius="{StaticResource MesRadiusSm}" HorizontalAlignment="Left"
                                    Margin="4,0" Background="{Binding StatusColor}">
                                <TextBlock Text="{Binding Status}" FontSize="{StaticResource FontSizeCaption}"
                                           FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Tutar (TL)" Binding="{Binding Amount, StringFormat='{}{0:N2}'}" Width="140"/>
                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="120"/>
                <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State: Invoices -->
        <TextBlock Grid.Row="2"
                   Text="Kayıt bulunamadı"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,40"
                   Opacity="0.5"
                   FontSize="{StaticResource FontSizeSubtitle}"
                   IsVisible="{Binding !Invoices.Count}" />

        <!-- Row 3: Footer — pagination -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" Padding="16,10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding TotalCount, StringFormat='Toplam: {0} fatura'}"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Onceki" Command="{Binding PreviousPageCommand}"
                            ToolTip.Tip="Onceki"
                            Padding="12,6" CornerRadius="{StaticResource CornerRadiusMedium}"
                            FontSize="{StaticResource FontSizeSmall}"/>
                    <TextBlock Text="{Binding CurrentPage, StringFormat='Sayfa {0}'}"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalPages, StringFormat='/ {0}'}"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button Content="Sonraki" Command="{Binding NextPageCommand}"
                            ToolTip.Tip="Sonraki"
                            Padding="12,6" CornerRadius="{StaticResource CornerRadiusMedium}"
                            FontSize="{StaticResource FontSizeSmall}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2"
                Background="{DynamicResource BackgroundBrush}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <PathIcon Data="{StaticResource IconReceipt}" Width="48" Height="48"
                          Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.4"/>
                <TextBlock Text="Kayit bulunamadi" FontSize="{StaticResource FontSizeTitle}"
                           HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,12,0,4"/>
                <TextBlock Text="Arama kriterlerine uygun fatura bulunamadi"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Opacity="0.7"/>
            </StackPanel>
        </Border>
    
        <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Grid.Row="0"
                    Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

</Grid>
</UserControl>
