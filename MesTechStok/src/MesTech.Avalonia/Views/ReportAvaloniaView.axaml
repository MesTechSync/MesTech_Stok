<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ReportAvaloniaView"
             x:DataType="vm:ReportAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Raporlar" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" ColumnDefinitions="320,*" Margin="16">

            <!-- Left Panel: Report Types -->
            <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="0,0,8,0" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Rapor Tipi" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding ReportTypes}"
                             SelectedItem="{Binding SelectedReportType}"
                             Padding="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ReportTypeDto">
                                <Border Padding="12,10" CornerRadius="{StaticResource MesRadiusBase}" Margin="2">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Name}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MesDarkSlate}" />
                                        <TextBlock Text="{Binding Description}" FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{DynamicResource MesSlateGray}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Right Panel: Report Config + Result -->
            <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="8,0,0,0" Padding="0">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- Config Bar -->
                    <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding SelectedReportType.Name, FallbackValue='Rapor Secin'}"
                                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Baslangic" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                                    <DatePicker SelectedDate="{Binding StartDate}" Width="140"  AutomationProperties.Name="Baslangic" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Bitis" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                                    <DatePicker SelectedDate="{Binding EndDate}" Width="140"  AutomationProperties.Name="Bitis" />
                                </StackPanel>
                                <Button Content="Rapor Olustur" ToolTip.Tip="Rapor olustur ve indir"
                                        Command="{Binding GenerateReportCommand}"
                                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}"
                                        VerticalAlignment="Bottom" />
                                <Button Content="Excel'e Aktar"
                                        ToolTip.Tip="Excel'e Aktar"
                                        Command="{Binding ExportExcelCommand}"
                                        Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}"
                                        VerticalAlignment="Bottom" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Summary -->
                    <Border Grid.Row="1" Padding="16,10" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1"
                            IsVisible="{Binding HasReportResult}">
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <StackPanel>
                                <TextBlock Text="Toplam Satir" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" />
                                <TextBlock Text="{Binding TotalCount}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Toplam Tutar" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" />
                                <TextBlock Text="{Binding TotalAmount}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesPrimaryBlue}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Report Result DataGrid -->
                <Grid>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding ReportItems}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True" CanUserReorderColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="110" />
                            <DataGridTextColumn Header="Referans" Binding="{Binding Reference}" Width="120" />
                            <DataGridTextColumn Header="Aciklama" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="140" />
                            <DataGridTextColumn Header="Tutar" Binding="{Binding AmountFormatted}" Width="130" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               IsVisible="{Binding !ReportItems.Count}" />
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Rapor olusturuluyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="1"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Rapor sonucu bos" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Secilen rapor tipi ve tarih araligi icin veri bulunamadi"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
