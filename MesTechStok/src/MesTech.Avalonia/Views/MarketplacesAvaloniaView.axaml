<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.MarketplacesAvaloniaView"
             x:DataType="vm:MarketplacesAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesBrandAccent}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Pazaryerleri" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding PlatformCount, StringFormat='{}{0} platform'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesAmber}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Watermark="Platform ara..." AutomationProperties.Name="Platform ara..." Width="250" HorizontalAlignment="Left" />
                <ComboBox Grid.Column="1" PlaceholderText="Durum" Width="120" Margin="8,0" />
                <Button Grid.Column="2" Content="+ Platform Ekle" Background="{DynamicResource MesBrandAccent}" Foreground="White"
                        FontWeight="SemiBold" Padding="12,6" CornerRadius="4" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Platform DataGrid -->
            <DataGrid ItemsSource="{Binding Platforms}"
                      SelectedItem="{Binding SelectedPlatform}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource MesBgPrimary}"
                      IsVisible="{Binding !IsLoading}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Platform" Binding="{Binding Name}" Width="180" />
                    <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="100" />
                    <DataGridTextColumn Header="Urun Sayisi" Binding="{Binding ProductCount}" Width="110" />
                    <DataGridTextColumn Header="Siparis" Binding="{Binding OrderCount}" Width="100" />
                    <DataGridTextColumn Header="Son Senkronizasyon" Binding="{Binding LastSyncDisplay}" Width="180" />
                    <DataGridTextColumn Header="API Durumu" Binding="{Binding ApiStatus}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty State -->
            <TextBlock Text="Platform bulunamadi"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,40" Opacity="0.5" FontSize="16"
                       IsVisible="{Binding !Platforms.Count}" />

            <!-- Loading Overlay -->
            <Border Background="{DynamicResource MesOverlayLight}"
                    IsVisible="{Binding IsLoading}" ZIndex="100">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                    <TextBlock Text="Platformlar yukleniyor..."
                               FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
