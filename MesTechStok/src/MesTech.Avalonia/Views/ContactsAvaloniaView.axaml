<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ContactsAvaloniaView"
             x:DataType="vm:ContactsAvaloniaViewModel">

    <!-- Stub view for CRM Contacts — Dalga 11 -->

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="#2855AC" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="CRM Kisiler" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#2855AC" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Placeholder Content -->
        <Border Grid.Row="1" Background="#F8FAFC" Margin="24"
                CornerRadius="12" BorderBrush="#E0E6ED" BorderThickness="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <Border Background="#EFF6FF" CornerRadius="50" Width="80" Height="80"
                        HorizontalAlignment="Center">
                    <TextBlock Text="&#x1F4D6;" FontSize="36"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="CRM Kisiler" FontSize="22" FontWeight="Bold"
                           Foreground="#1E293B" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Summary}" FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"
                           TextAlignment="Center" />
                <TextBlock Text="Kisi yonetimi | Firma eslestirme | Iletisim gecmisi | Notlar"
                           FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
