<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ProductFetchAvaloniaView"
             x:Name="RootProductFetchAvaloniaView"
             x:DataType="vm:ProductFetchAvaloniaViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
    </UserControl.KeyBindings>

    <!-- Urun Cekme — URL'den urun bilgisi cekme ve kaydetme -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <TextBlock Text="Ürün Çekme" Foreground="{DynamicResource MesBgPrimary}"
                       FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Border>

        <!-- URL Input -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="600" Watermark="Ürün URL'si giriniz..." AutomationProperties.Name="Ürün URL'si giriniz..."
                         Text="{Binding ProductUrl}" Padding="10,8" />
                <Button Content="Çek" Command="{Binding FetchProductCommand}"
                        ToolTip.Tip="Cek"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                <Button Content="Temizle" Command="{Binding ResetCommand}"
                        ToolTip.Tip="Temizle"
                        Background="{DynamicResource MesMutedGray}" Foreground="{DynamicResource MesBgPrimary}"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </StackPanel>
        </Border>

        <!-- Product Info -->
        <ScrollViewer Grid.Row="2" Padding="24">
            <StackPanel MaxWidth="700" Spacing="16">

                <!-- Product Card (visible after fetch) -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                        IsVisible="{Binding ProductLoaded}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Çekilen Ürün Bilgileri" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />

                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ürün Adı:" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FetchedName}" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fiyat:" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FetchedPrice, StringFormat='₺{0:N2}'}"
                                       FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" Foreground="{DynamicResource MesPrimaryBlue}" Margin="0,6,0,0" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="SKU:" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FetchedSKU}" FontSize="{StaticResource FontSizeCallout}" Margin="0,6,0,0" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Stok:" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FetchedStock}" FontSize="{StaticResource FontSizeCallout}" Margin="0,6,0,0" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Kategori:" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FetchedCategory}" FontSize="{StaticResource FontSizeCallout}" Margin="0,6,0,0" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Platform:" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding FetchedPlatform}" FontSize="{StaticResource FontSizeCallout}" Margin="0,6,0,0" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Açıklama:" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding FetchedDescription}" FontSize="{StaticResource FontSizeCallout}"
                                       TextWrapping="Wrap" Margin="0,6,0,0" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
                            <Button Content="Ürün Olarak Kaydet" Command="{Binding SaveProductCommand}"
                                    ToolTip.Tip="Urun Olarak Kaydet"
                                    Background="{DynamicResource MesGreenMaterial}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                    Padding="20,10" CornerRadius="{StaticResource MesRadiusBase}"
                                    IsEnabled="{Binding !IsSaving}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Save Success -->
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                        IsVisible="{Binding SaveCompleted}">
                    <TextBlock Text="Ürün başarıyla kaydedildi!" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesGreen}" />
                </Border>

                <!-- Empty state -->
                <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
                  <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="Urun bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Henuz urun bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>

                <!-- Error -->
                <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="{StaticResource MesRadiusMd}" Padding="12"
                        IsVisible="{Binding HasError}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" />
                </Border>

                <!-- Empty state before fetch -->
                <StackPanel IsVisible="{Binding !ProductLoaded}" HorizontalAlignment="Center" Margin="0,48,0,0">
                    <TextBlock Text="Ürün URL'si girin ve 'Çek' butonuna tıklayın"
                               FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesOverlayLight}" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Ürün bilgileri çekiliyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
