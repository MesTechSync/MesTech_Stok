<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.DropshipDashboardAvaloniaView"
             x:DataType="vm:DropshipDashboardAvaloniaViewModel">

    <!-- Dropshipping Dashboard — KPI kartlari + tedarikci performans tablosu -->

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Dropshipping Paneli" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- KPI Cards -->
        <Border Grid.Row="1" Padding="16,16,16,0">
            <Grid ColumnDefinitions="*,*,*,*" Margin="0,0,0,8">
                <!-- Total Orders -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="16" Margin="4"
                        BorderBrush="#E5E9F2" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Toplam Sipariş" FontSize="12" Foreground="#64748B" />
                        <TextBlock Text="{Binding TotalOrders, StringFormat='{}{0:N0}'}"
                                   FontSize="24" FontWeight="Bold" Foreground="#1E293B" />
                    </StackPanel>
                </Border>
                <!-- Revenue -->
                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="16" Margin="4"
                        BorderBrush="#E5E9F2" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Toplam Ciro" FontSize="12" Foreground="#64748B" />
                        <TextBlock Text="{Binding TotalRevenue, StringFormat='₺{0:N0}'}"
                                   FontSize="24" FontWeight="Bold" Foreground="#0078D4" />
                    </StackPanel>
                </Border>
                <!-- Profit -->
                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="16" Margin="4"
                        BorderBrush="#E5E9F2" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Net Kâr" FontSize="12" Foreground="#64748B" />
                        <TextBlock Text="{Binding TotalProfit, StringFormat='₺{0:N0}'}"
                                   FontSize="24" FontWeight="Bold" Foreground="#4CAF50" />
                    </StackPanel>
                </Border>
                <!-- Margin -->
                <Border Grid.Column="3" Background="White" CornerRadius="8" Padding="16" Margin="4"
                        BorderBrush="#E5E9F2" BorderThickness="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Ort. Marj" FontSize="12" Foreground="#64748B" />
                        <TextBlock Text="{Binding AverageMargin, StringFormat='%{0:N1}'}"
                                   FontSize="24" FontWeight="Bold" Foreground="#FF6F00" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Supplier Performance Table -->
        <Border Grid.Row="2" Background="White" Margin="16" CornerRadius="8"
                BorderBrush="#E5E9F2" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Tedarikçi Performansı" FontSize="15" FontWeight="SemiBold"
                           Foreground="#1E293B" Padding="16,12" />
                <DataGrid ItemsSource="{Binding Suppliers}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" BorderThickness="0" Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tedarikçi" Binding="{Binding SupplierName}" Width="200" />
                        <DataGridTextColumn Header="Sipariş" Binding="{Binding OrderCount}" Width="100" />
                        <DataGridTextColumn Header="Ciro" Binding="{Binding Revenue, StringFormat='₺{0:N0}'}" Width="140" />
                        <DataGridTextColumn Header="Karşılama %" Binding="{Binding FulfillRate, StringFormat='{}{0:N1}%'}" Width="120" />
                        <DataGridTextColumn Header="Ort. Teslimat (Gün)" Binding="{Binding AvgDeliveryDays, StringFormat='{}{0:N1}'}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Dropshipping verileri yukleniyor..." FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
