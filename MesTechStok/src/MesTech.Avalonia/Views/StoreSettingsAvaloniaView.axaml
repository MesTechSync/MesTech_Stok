<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.StoreSettingsAvaloniaView"
             x:Name="RootStoreSettingsAvaloniaView"
             x:DataType="vm:StoreSettingsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Magaza Ayarlari — kimlik + sync araligi + webhook + oto-sync -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Mağaza Ayarları" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Settings Form -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel MaxWidth="600" Spacing="16">

                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Mağaza Bilgileri" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Mağaza Adı" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding StoreName}" AutomationProperties.Name="Magaza adi" Padding="10,8" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Platform" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding PlatformName}" AutomationProperties.Name="Platform adi" IsReadOnly="True" Padding="10,8" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="API Key" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding ApiKey}" AutomationProperties.Name="API anahtari" PasswordChar="*" Padding="10,8" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="API Secret" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding ApiSecret}" AutomationProperties.Name="API sifresi" PasswordChar="*" Padding="10,8" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Seller ID" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding SellerId}" AutomationProperties.Name="Satici kimlik numarasi" Padding="10,8" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Senkronizasyon Ayarları" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding SyncIntervalMinutes, StringFormat='Sync Aralığı: {0} dakika'}"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <Slider Minimum="5" Maximum="120" Value="{Binding SyncIntervalMinutes}"
                                    TickFrequency="5" IsSnapToTickEnabled="True" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Webhook URL" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding WebhookUrl}" Padding="10,8"
                                     Watermark="https://api.mestech.com/webhooks/..." AutomationProperties.Name="https://api.mestech.com/webhooks/..." />
                        </StackPanel>

                        <CheckBox Content="Otomatik Senkronizasyon" IsChecked="{Binding AutoSyncEnabled}"
                                  FontSize="{StaticResource FontSizeCallout}" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet" Command="{Binding SaveCommand}"
                            Background="{DynamicResource MesGreenMaterial}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="20,10" CornerRadius="{StaticResource MesRadiusBase}"
                            IsEnabled="{Binding !IsSaving}" />
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsSaving}" Width="120" Height="4"
                                 VerticalAlignment="Center" />
                </StackPanel>

                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="12"
                        IsVisible="{Binding SaveSuccess}">
                    <TextBlock Text="Ayarlar başarıyla kaydedildi!" Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold" />
                </Border>

                <!-- Empty State -->
                <Border IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center" Padding="0,20">
                    <TextBlock Text="Magaza ayari bulunamadi" FontSize="{StaticResource FontSizeSubtitle}"
                               HorizontalAlignment="Center" Opacity="0.6" />
                </Border>

                <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="{StaticResource MesRadiusMd}" Padding="12"
                        IsVisible="{Binding HasError}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>
    </Grid>
</UserControl>
