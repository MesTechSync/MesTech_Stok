<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.CargoProvidersAvaloniaView"
             x:DataType="vm:CargoProvidersAvaloniaViewModel">

    <!-- Kargo Firmalari — I-05 -->

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Kargo Firmalari" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding ConnectedProviders, StringFormat='{}{0} bagli'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalProviders, StringFormat='{}{0} toplam'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Provider Cards Grid -->
        <ScrollViewer Grid.Row="1" Background="#F1F5F9">
            <ItemsControl ItemsSource="{Binding Providers}" Margin="20,16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="controls:CargoProviderCardViewModel">
                        <Border Background="White" CornerRadius="10" Margin="8" Padding="20"
                                Width="280" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <!-- Provider Name + Status -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding ProviderName}"
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" />
                                    <Ellipse Grid.Column="1" Width="10" Height="10"
                                             Fill="{Binding ConnectionStatusColor}"
                                             ToolTip.Tip="{Binding ConnectionStatusTooltip}" />
                                </Grid>

                                <!-- API Type -->
                                <Border Background="#F1F5F9" CornerRadius="4" Padding="8,4"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding ApiTypeText}" FontSize="11"
                                               Foreground="#64748B" FontFamily="Consolas" />
                                </Border>

                                <!-- Stats -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding TodayStats, StringFormat='Bugun: {0}'}"
                                               FontSize="13" Foreground="#475569" />
                                    <TextBlock Text="{Binding LastShipmentText, StringFormat='Son gonderim: {0}'}"
                                               FontSize="12" Foreground="#94A3B8" />
                                    <TextBlock Text="{Binding AvgDeliveryDays, StringFormat='Ort. teslim: {0:N1} gun'}"
                                               FontSize="12" Foreground="#94A3B8" />
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Gonderim Olustur"
                                            Command="{Binding CreateShipmentCommand}"
                                            Padding="10,6" FontSize="12" CornerRadius="4"
                                            Background="#0078D4" Foreground="White" />
                                    <Button Content="Takip"
                                            Command="{Binding TrackCommand}"
                                            Padding="10,6" FontSize="12" CornerRadius="4" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Kargo firmalari yukleniyor..."
                           FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#F7F9FC"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#E53935"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="#E53935"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
