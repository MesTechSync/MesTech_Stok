<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.BulkShipmentAvaloniaView"
             x:DataType="vm:BulkShipmentAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Toplu Kargo Gonderim — I-05 -->

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Toplu Kargo Gonderim" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} secili'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} toplam'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <ComboBox Grid.Column="1" Width="180" Margin="0,0,12,0"
                          ItemsSource="{Binding Providers}"
                          SelectedItem="{Binding SelectedProvider}" />
                <Button Grid.Column="2" Content="Gonder"
                        ToolTip.Tip="Gonder"
                        Command="{Binding SendBulkCommand}"
                        IsEnabled="{Binding !IsSending}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <CheckBox Content="Tumunu Sec" IsChecked="{Binding SelectAll}" VerticalAlignment="Center" />
                <Button Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}" Padding="12,6" />
            </StackPanel>
        </Border>

        <!-- Orders DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Orders}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="False"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}">

            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Sec" Binding="{Binding IsSelected}" Width="60" />
                <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderNumber}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="Musteri" Binding="{Binding CustomerName}" Width="180" IsReadOnly="True" />
                <DataGridTextColumn Header="Sehir" Binding="{Binding City}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="Agirlik (kg)" Binding="{Binding Weight}" Width="100" IsReadOnly="True" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="150" IsReadOnly="True" />
                <DataGridTextColumn Header="Takip No" Binding="{Binding TrackingNumber}" Width="180" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>
<!-- Empty State -->        <TextBlock Grid.Row="2" Text="Siparis bulunamadi"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !Orders.Count}" />

        <!-- Progress + Summary Footer -->
        <Border Grid.Row="3" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,1,0,0">
            <StackPanel Spacing="8">
                <!-- Progress Bar -->
                <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                             Height="6" IsVisible="{Binding IsSending}" />
                <TextBlock IsVisible="{Binding IsSending}"
                           Text="{Binding ProgressCurrent, StringFormat='Gonderiliyor: {0}'}"
                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />

                <!-- Summary -->
                <StackPanel Orientation="Horizontal" Spacing="20"
                            IsVisible="{Binding !IsSending}">
                    <TextBlock FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesGreenMaterial}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Basarili: {0}">
                                <Binding Path="SuccessCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesRedClassic}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Hata: {0}">
                                <Binding Path="FailCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesWarning}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Uyari: {0}">
                                <Binding Path="WarningCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Siparisler yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
