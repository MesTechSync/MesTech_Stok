<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.Bitrix24AvaloniaView"
             x:DataType="vm:Bitrix24AvaloniaViewModel"
             AutomationProperties.Name="Bitrix24 CRM Pipeline Yonetimi">
<UserControl.KeyBindings>
    <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
</UserControl.KeyBindings>

    <!-- G096: Bitrix24 CRM Kanban Pipeline -->
    <Panel>
    <!-- Loading -->
    <Border IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="12" HorizontalAlignment="Center">
            <ProgressBar IsIndeterminate="True" Width="200" />
            <TextBlock Text="Pipeline yukleniyor..." Foreground="{DynamicResource MesTextSecondary}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Border>

    <!-- Error -->
    <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}"
            CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="20"
            VerticalAlignment="Top" HorizontalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="⚠" FontSize="18" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" />
            <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}" Padding="8,4"
                    CornerRadius="{StaticResource MesRadiusMd}" />
        </StackPanel>
    </Border>

    <!-- Main Content -->
    <ScrollViewer IsVisible="{Binding !IsLoading}" VerticalScrollBarVisibility="Auto">
    <Grid RowDefinitions="Auto,Auto,*" Margin="24,16">

        <!-- Row 0: Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Bitrix24 CRM Pipeline" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource MesDarkSlate}" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Foreground="{DynamicResource MesTextSecondary}" FontSize="{StaticResource FontSizeSmall}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}Toplam: {0} anlaşma">
                                <Binding Path="TotalDeals" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource MesGreenSuccess}" FontSize="{StaticResource FontSizeSmall}"
                               FontWeight="SemiBold">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}₺{0:N0} değer">
                                <Binding Path="TotalValue" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Content="↻ Yenile" Command="{Binding RefreshCommand}"
                    Padding="12,8" Background="{DynamicResource MesPrimaryBlue}"
                    Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                    CornerRadius="{StaticResource MesRadiusMd}"
                    ToolTip.Tip="Pipeline verilerini yenile (F5)"
                    AutomationProperties.Name="Pipeline yenile butonu" />
        </Grid>

        <!-- Row 1: Stage filter chips -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
            <Button Content="Tumu" Command="{Binding FilterByStageCommand}" CommandParameter="{x:Null}"
                    Padding="12,6" CornerRadius="14" FontSize="{StaticResource FontSizeSmall}"
                    Background="{DynamicResource MesBgMist}" />
            <Button Content="Yeni" Command="{Binding FilterByStageCommand}" CommandParameter="new"
                    Padding="12,6" CornerRadius="14" FontSize="{StaticResource FontSizeSmall}"
                    Background="#DBEAFE" Foreground="#1D4ED8" />
            <Button Content="Temas" Command="{Binding FilterByStageCommand}" CommandParameter="contact"
                    Padding="12,6" CornerRadius="14" FontSize="{StaticResource FontSizeSmall}"
                    Background="#FEF3C7" Foreground="#92400E" />
            <Button Content="Teklif" Command="{Binding FilterByStageCommand}" CommandParameter="proposal"
                    Padding="12,6" CornerRadius="14" FontSize="{StaticResource FontSizeSmall}"
                    Background="#E0E7FF" Foreground="#3730A3" />
            <Button Content="Kazanildi" Command="{Binding FilterByStageCommand}" CommandParameter="won"
                    Padding="12,6" CornerRadius="14" FontSize="{StaticResource FontSizeSmall}"
                    Background="#D1FAE5" Foreground="#065F46" />
        </StackPanel>

        <!-- Row 2: Kanban Columns -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Stages}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PipelineStageItem">
                    <Border Width="240" MinHeight="300" Background="{DynamicResource MesBgPrimary}"
                            CornerRadius="{StaticResource MesRadiusLg}" Padding="12"
                            BoxShadow="{DynamicResource MesElevation1}">
                        <StackPanel Spacing="12">
                            <!-- Stage Header -->
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding StageName}" FontWeight="Bold"
                                           FontSize="{StaticResource FontSizeSubtitle}"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <Border Grid.Column="1" Background="{DynamicResource MesBgMist}"
                                        CornerRadius="10" Padding="8,2" MinWidth="28"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding DealCount}" FontSize="{StaticResource FontSizeSmall}"
                                               FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{DynamicResource MesTextSecondary}" />
                                </Border>
                            </Grid>

                            <!-- Stage Value -->
                            <TextBlock FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource MesGreenSuccess}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}₺{0:N0}">
                                        <Binding Path="TotalValue" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- Divider -->
                            <Border Height="1" Background="{DynamicResource MesBgMist}" />

                            <!-- Empty state -->
                            <Border IsVisible="{Binding !DealCount}" Padding="0,24"
                                    HorizontalAlignment="Center">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <TextBlock Text="📋" FontSize="24" HorizontalAlignment="Center" />
                                    <TextBlock Text="Anlasma yok" FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource MesTextTertiary}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Deal count indicator when has deals -->
                            <Border IsVisible="{Binding DealCount}" Padding="8"
                                    Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusMd}">
                                <TextBlock FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesTextSecondary}"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} anlasma bu asamada">
                                            <Binding Path="DealCount" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
    </ScrollViewer>
    </Panel>
</UserControl>
