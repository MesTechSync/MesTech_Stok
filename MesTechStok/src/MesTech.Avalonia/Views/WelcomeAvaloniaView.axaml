<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.WelcomeAvaloniaView"
             x:DataType="vm:WelcomeAvaloniaViewModel">

    <!-- EMR-12: Karsilama Ekrani — logo + hosgeldin mesaji + son aktiviteler -->

    <Grid Background="{DynamicResource MesBgPage}">

        <ScrollViewer Padding="40">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24" MaxWidth="600">

                <!-- Logo Area -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Background="{DynamicResource MesBgMist}" CornerRadius="50" Width="96" Height="96"
                            HorizontalAlignment="Center">
                        <TextBlock Text="M" FontSize="44" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPrimaryBlue}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="MesTech Stok" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                               Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding WelcomeText}" FontSize="15"
                               Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Quick Stats -->
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="6"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="150">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalProducts}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesPrimaryBlue}" HorizontalAlignment="Center" />
                            <TextBlock Text="Urun" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="6"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="150">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalOrders}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesTeal}" HorizontalAlignment="Center" />
                            <TextBlock Text="Siparis" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="6"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="150">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding ActivePlatforms}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesAmber}" HorizontalAlignment="Center" />
                            <TextBlock Text="Platform" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Recent Activity -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Son Aktiviteler" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding RecentActivities}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,10" BorderBrush="{DynamicResource MesBgMist}" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Description}"
                                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesDarkSlate}" />
                                            <TextBlock Grid.Column="1" Text="{Binding TimeAgo}"
                                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Version -->
                <TextBlock Text="MesTech Stok v10.0 — Avalonia"
                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}"
                           HorizontalAlignment="Center" />

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Veriler yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
