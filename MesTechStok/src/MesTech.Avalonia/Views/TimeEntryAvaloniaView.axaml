<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.TimeEntryAvaloniaView"
             x:Name="RootTimeEntryAvaloniaView"
             x:DataType="vm:TimeEntryAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-12: Zaman Kaydi — tarih, saat, proje, aciklama girisi -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Zaman Kaydi" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="16">

                <!-- New Entry Form -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Yeni Zaman Kaydi" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4" Margin="0,0,12,12">
                                <TextBlock Text="Tarih" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <DatePicker SelectedDate="{Binding SelectedDate}" HorizontalAlignment="Stretch"  AutomationProperties.Name="Tarih" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4" Margin="0,0,12,12">
                                <TextBlock Text="Baslangic Saati" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding StartTime}" Watermark="09:00" AutomationProperties.Name="09:00" Padding="10,8" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                                <TextBlock Text="Bitis Saati" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding EndTime}" Watermark="18:00" AutomationProperties.Name="18:00" Padding="10,8" />
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4" Margin="0,0,12,0">
                                <TextBlock Text="Proje" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding ProjectName}" Watermark="Proje adi" AutomationProperties.Name="Proje adi" Padding="10,8" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="2" Spacing="4">
                                <TextBlock Text="Aciklama" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding Description}" Watermark="Yapilan is aciklamasi" AutomationProperties.Name="Yapilan is aciklamasi" Padding="10,8" />
                            </StackPanel>
                        </Grid>
                        <Button Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet" Command="{Binding SaveEntryCommand}"
                                Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- Time Entry List -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Zaman Kayitlari" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                <Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding TimeEntries}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource MesBgPrimary}"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="120" />
                                <DataGridTextColumn Header="Baslangic" Binding="{Binding StartTime}" Width="100" />
                                <DataGridTextColumn Header="Bitis" Binding="{Binding EndTime}" Width="100" />
                                <DataGridTextColumn Header="Sure" Binding="{Binding Duration}" Width="80" />
                                <DataGridTextColumn Header="Proje" Binding="{Binding Project}" Width="160" />
                                <DataGridTextColumn Header="Aciklama" Binding="{Binding Description}" Width="250" />
                            </DataGrid.Columns>
                        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayit bulunamadi" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,40" Opacity="0.5" FontSize="{StaticResource FontSizeTitle}"
                               Foreground="{DynamicResource MesMutedGray}"
                               IsVisible="{Binding !TimeEntries.Count}" />
                </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Personel kaydi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz personel kaydi bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
