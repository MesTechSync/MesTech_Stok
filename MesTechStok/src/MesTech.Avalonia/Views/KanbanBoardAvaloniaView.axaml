<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.KanbanBoardAvaloniaView"
             x:Name="RootKanbanBoardAvaloniaView"
             x:DataType="vm:KanbanBoardAvaloniaViewModel"
             AutomationProperties.Name="Kanban Panosu">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Kanban Panosu" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center"
                           Grid.Column="0" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Background="{DynamicResource MesBgSecondary}">
            <!-- Loading -->
            <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Gorev bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz gorev bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

                    <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

            <!-- Empty State -->
            <TextBlock Text="Kayit bulunamadi"
                       FontSize="{StaticResource FontSizeTitle}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource MesMutedGray}"
                       IsVisible="{Binding !Columns.Count}"
                       Opacity="0.5" />

            <!-- Kanban Columns -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                         >
                <ItemsControl ItemsSource="{Binding Columns}" Margin="16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskColumnVm">
                            <Border Width="280" VerticalAlignment="Top"
                                    Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                                    BoxShadow="{DynamicResource MesElevationCard}">
                                <DockPanel>
                                    <!-- Column Header -->
                                    <Border DockPanel.Dock="Top" CornerRadius="8,8,0,0" Padding="14,10">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Color}" />
                                        </Border.Background>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource MesBgPrimary}"
                                                       FontWeight="SemiBold" FontSize="{StaticResource FontSizeCallout}" Grid.Column="0" />
                                            <Border Grid.Column="1" Background="{DynamicResource MesBadgeOverlay}"
                                                    CornerRadius="{StaticResource MesRadiusMdLg}" Padding="6,2">
                                                <TextBlock Text="{Binding TaskCount}" Foreground="{DynamicResource MesBgPrimary}"
                                                           FontSize="{StaticResource FontSizeCaption}" FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Task Cards -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                                        <ItemsControl ItemsSource="{Binding Tasks}" Margin="8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:TaskCardVm">
                                                    <Border Margin="0,0,0,8" Padding="12"
                                                            Background="{DynamicResource MesBgPage}" CornerRadius="{StaticResource MesRadiusBase}"
                                                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1"
                                                            Cursor="Hand">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontWeight="SemiBold" FontSize="{StaticResource FontSizeCallout}"
                                                                       TextWrapping="Wrap" />
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="{Binding Assignee}"
                                                                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                                                                <TextBlock Text="{Binding DueDateDisplay}"
                                                                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" />
                                                            </StackPanel>
                                                            <Border CornerRadius="{StaticResource MesRadiusSm}" Padding="6,2"
                                                                    HorizontalAlignment="Left">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding PriorityColor}" Opacity="0.15" />
                                                                </Border.Background>
                                                                <TextBlock Text="{Binding Priority}" FontSize="{StaticResource FontSizeCaption1}">
                                                                    <TextBlock.Foreground>
                                                                        <SolidColorBrush Color="{Binding PriorityColor}" />
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
${skeleton}
<!-- Loading Skeleton -->        <Border Grid.Row="0" Grid.RowSpan="2"                Background="{DynamicResource MesBgPage}"                IsVisible="{Binding IsLoading}"                ZIndex="100">            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />        </Border>
    </Grid>
</UserControl>
