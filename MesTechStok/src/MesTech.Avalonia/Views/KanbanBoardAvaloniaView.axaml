<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.KanbanBoardAvaloniaView"
             x:DataType="vm:KanbanBoardAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Kanban Panosu" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"
                           Grid.Column="0" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Background="#F4F6F9">
            <!-- Loading -->
            <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Error -->
            <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}" Margin="22"
                    CornerRadius="8" Padding="16" BorderBrush="{DynamicResource MesBorderDanger}" BorderThickness="1"
                    VerticalAlignment="Top">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" TextWrapping="Wrap" />
            </Border>

            <!-- Kanban Columns -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          IsVisible="{Binding !IsLoading}">
                <ItemsControl ItemsSource="{Binding Columns}" Margin="16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskColumnVm">
                            <Border Width="280" VerticalAlignment="Top"
                                    Background="White" CornerRadius="8"
                                    BoxShadow="0 1 6 0 #1F000000">
                                <DockPanel>
                                    <!-- Column Header -->
                                    <Border DockPanel.Dock="Top" CornerRadius="8,8,0,0" Padding="14,10">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Color}" />
                                        </Border.Background>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding Name}" Foreground="White"
                                                       FontWeight="SemiBold" FontSize="13" Grid.Column="0" />
                                            <Border Grid.Column="1" Background="#FFFFFF33"
                                                    CornerRadius="10" Padding="6,2">
                                                <TextBlock Text="{Binding TaskCount}" Foreground="White"
                                                           FontSize="11" FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Task Cards -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                                        <ItemsControl ItemsSource="{Binding Tasks}" Margin="8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:TaskCardVm">
                                                    <Border Margin="0,0,0,8" Padding="12"
                                                            Background="#F8F9FB" CornerRadius="6"
                                                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1"
                                                            Cursor="Hand">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontWeight="SemiBold" FontSize="13"
                                                                       TextWrapping="Wrap" />
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="{Binding Assignee}"
                                                                           FontSize="11" Foreground="{DynamicResource MesSlateGray}" />
                                                                <TextBlock Text="{Binding DueDateDisplay}"
                                                                           FontSize="11" Foreground="{DynamicResource MesMutedGray}" />
                                                            </StackPanel>
                                                            <Border CornerRadius="4" Padding="6,2"
                                                                    HorizontalAlignment="Left">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding PriorityColor}" Opacity="0.15" />
                                                                </Border.Background>
                                                                <TextBlock Text="{Binding Priority}" FontSize="10">
                                                                    <TextBlock.Foreground>
                                                                        <SolidColorBrush Color="{Binding PriorityColor}" />
                                                                    </TextBlock.Foreground>
                                                                </TextBlock>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
