<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.AboutAvaloniaView"
             x:Name="RootAboutAvaloniaView"
             x:DataType="vm:AboutAvaloniaViewModel"
             AutomationProperties.Name="Hakkinda Sayfasi">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <TextBlock Text="Hakkinda" Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" />
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="24" MaxWidth="600" HorizontalAlignment="Center" Margin="0,16">

                <!-- Logo / App Name -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Background="{DynamicResource MesPrimaryBlue}" CornerRadius="{StaticResource MesRadiusXl}" Width="80" Height="80"
                            HorizontalAlignment="Center">
                        <TextBlock Text="MT" Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="MesTech Stok Yonetimi" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                               Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding VersionText}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Info Card -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Uygulama:" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesSlateGray}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="MesTech Stok" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Versiyon:" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesSlateGray}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding VersionText}" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Platform:" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesSlateGray}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding PlatformText}" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Framework:" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesSlateGray}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text=".NET 9.0 / Avalonia UI" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Lisans:" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesSlateGray}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding LicenseText}" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Grid>
                        <Grid ColumnDefinitions="140,*">
                            <TextBlock Grid.Column="0" Text="Gelistirici:" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesSlateGray}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="MesTech Yazilim" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Copyright -->
                <TextBlock Text="{Binding CopyrightText}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}"
                           HorizontalAlignment="Center" />

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <TextBlock Text="Uygulama bilgisi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}"
                           HorizontalAlignment="Center" Opacity="0.6" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
