<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MesTech.Avalonia.ViewModels"
        x:Class="MesTech.Avalonia.Views.WelcomeWindow"
        x:DataType="vm:SpotlightWelcomeViewModel"
        Title="MesTech — Hos Geldiniz"
        WindowState="Maximized"
        SystemDecorations="None"
        Background="{DynamicResource MesSpotDarkBase}"
        Topmost="True"
        CanResize="False"
        AutomationProperties.Name="Giris Ekrani">

  <!-- ╔═══════════════════════════════════════════════════════════════════╗ -->
  <!-- ║ KORUMALI TASARIM — SPOTLIGHT WELCOME SCREEN                     ║ -->
  <!-- ║ Sahip: DEV2 (Frontend & UI/UX)                                  ║ -->
  <!-- ║ Versiyon: v1.2.0 — 2026-04-04 (renk token migrasyonu)          ║ -->
  <!-- ╠═══════════════════════════════════════════════════════════════════╣ -->
  <!-- ║ KURALLAR:                                                       ║ -->
  <!-- ║ 1. Katman yapisi (Layer 0-5) DEGISTIRILEMEZ — sadece ICERIK    ║ -->
  <!-- ║ 2. Renk/font/spacing degisiklikleri → DesignTokens uzerinden   ║ -->
  <!-- ║ 3. Yeni ozellik → mevcut yapiya UYUMLU ekleme, kirma YASAK    ║ -->
  <!-- ║ 4. Koklu layout degisikligi → ONCE tasarim onayi al           ║ -->
  <!-- ║ 5. Iyilestirme = zariflestirme. Basitlestirme = kalite kaybi  ║ -->
  <!-- ║ 6. macOS/Bitrix24 kalite hedefi — kolaya kacma YASAK           ║ -->
  <!-- ��═══════════════════════════════════════════════════════════════════╝ -->
  <!--                                                                     -->
  <!-- BING SPOTLIGHT / WINDOWS LOCK SCREEN INSPIRED WELCOME + LOGIN       -->
  <!-- Layered Panel: Solid BG → Current Image → Next Image → Overlays → Content -->
  <!-- v1.1: Seamless crossfade fix — current stays at 1.0, next fades IN on top -->
  <!-- v1.2: 40+ hardcoded renk → MesTechSpotlightTokens.axaml token'lari -->
  <!-- ═══════════════════════════════════════════════ -->

  <Panel>

    <!-- ═══ LAYER 0: Solid dark fallback — ALWAYS visible, prevents flash ═══ -->
    <Border Background="{DynamicResource MesSpotDarkBase}"/>

    <!-- ═══ LAYER 0b: Gradient fallback (when no images) ═══ -->
    <Border IsVisible="{Binding !HasSpotlightImages}">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="{DynamicResource MesGradientDark}" Offset="0"/>
          <GradientStop Color="{DynamicResource MesGradientMid}" Offset="0.4"/>
          <GradientStop Color="{DynamicResource MesSpotGradientDeep}" Offset="0.7"/>
          <GradientStop Color="{DynamicResource MesPrimaryBlue}" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- ═══ LAYER 1: Current background image (always opacity=1, stable base) ═══ -->
    <Image x:Name="CurrentBgImage"
           Source="{Binding CurrentBackgroundImage}"
           Stretch="UniformToFill"/>

    <!-- ═══ LAYER 2: Next background image — fades IN on top of current ═══ -->
    <Image x:Name="NextBgImage"
           Source="{Binding NextBackgroundImage}"
           Stretch="UniformToFill"
           Opacity="{Binding NextImageOpacity}">
      <Image.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:1.2" Easing="CubicEaseInOut"/>
        </Transitions>
      </Image.Transitions>
    </Image>

    <!-- ═══ LAYER 3: Top gradient overlay ═══ -->
    <Border VerticalAlignment="Top" Height="180" IsHitTestVisible="False">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="{DynamicResource MesSpotOverlayHeavy}" Offset="0"/>
          <GradientStop Color="{DynamicResource MesSpotOverlayLight}" Offset="0.6"/>
          <GradientStop Color="{DynamicResource MesSpotOverlayNone}" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- ═══ LAYER 4: Bottom gradient overlay (taller, smoother) ═══ -->
    <Border VerticalAlignment="Bottom" Height="480" IsHitTestVisible="False">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="{DynamicResource MesSpotOverlayNone}" Offset="0"/>
          <GradientStop Color="{DynamicResource MesSpotOverlayMedium}" Offset="0.2"/>
          <GradientStop Color="{DynamicResource MesSpotOverlayHeavy}" Offset="0.5"/>
          <GradientStop Color="{DynamicResource MesSpotOverlayDense}" Offset="0.75"/>
          <GradientStop Color="{DynamicResource MesSpotOverlayMax}" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- ═══ LAYER 5: Content grid ═══ -->
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- ═════════════════════════════════════════ -->
      <!-- ROW 0: Top thumbnail bar                 -->
      <!-- ═════════════════════════════════════════ -->
      <Border Grid.Row="0" Margin="32,24,32,0">
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Thumbnails}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SpotlightThumbnailItem">
                <Button Command="{Binding $parent[Window].((vm:SpotlightWelcomeViewModel)DataContext).SelectThumbnailCommand}"
                        CommandParameter="{Binding}"
                        Padding="0" BorderThickness="0" Background="Transparent"
                        Cursor="Hand"
                        CornerRadius="12">
                  <Border Width="110" Height="72" CornerRadius="12"
                          ClipToBounds="True"
                          Background="{DynamicResource MesSpotThumbBg}"
                          BorderBrush="{DynamicResource MesSpotThumbBorder}" BorderThickness="1">
                    <Border.Transitions>
                      <Transitions>
                        <BrushTransition Property="Background" Duration="0:0:0.25"/>
                        <BrushTransition Property="BorderBrush" Duration="0:0:0.25"/>
                      </Transitions>
                    </Border.Transitions>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center" Spacing="6">
                      <TextBlock Text="{Binding Icon}" FontSize="{StaticResource FontSizeHeader}"
                                 HorizontalAlignment="Center"
                                 Opacity="0.95"/>
                      <TextBlock Text="{Binding Name}" FontSize="{StaticResource FontSizeCaption1}"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource MesSpotTextPrimary}"
                                 HorizontalAlignment="Center"
                                 Opacity="0.85"
                                 LetterSpacing="0.3"/>
                    </StackPanel>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <!-- ═════════════════════════════════════════ -->
      <!-- ROW 2: Bottom area                       -->
      <!-- ═════════════════════════════════════════ -->
      <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="48,0,48,40">

        <!-- ─── BOTTOM-LEFT: Clock + Branding + Info ─── -->
        <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Spacing="4"
                    MaxWidth="600">

          <!-- Clock + Date (Windows lock screen style — large clock on top) -->
          <StackPanel Spacing="-4" Margin="0,0,0,16">
            <TextBlock x:Name="ClockDisplay" Text="{Binding ClockText}"
                       FontSize="{StaticResource FontSizeSpotlightClock}" FontWeight="ExtraLight"
                       Foreground="{DynamicResource MesSpotTextPrimary}" Opacity="0.95"
                       LetterSpacing="2">
              <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" OffsetX="0" OffsetY="3" Opacity="0.35"/>
              </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="DateDisplay" Text="{Binding DateText}"
                       FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesSpotTextDate}" Margin="3,0,0,0"
                       LetterSpacing="0.5">
              <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" OffsetX="0" OffsetY="1" Opacity="0.3"/>
              </TextBlock.Effect>
            </TextBlock>
          </StackPanel>

          <!-- Brand name -->
          <TextBlock Text="MesTech" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                     Foreground="{DynamicResource MesSpotTextPrimary}" Opacity="0.9"
                     LetterSpacing="1.5">
            <TextBlock.Effect>
              <DropShadowEffect Color="Black" BlurRadius="10" OffsetX="0" OffsetY="1" Opacity="0.4"/>
            </TextBlock.Effect>
          </TextBlock>

          <!-- Subtitle -->
          <TextBlock Text="Entegrator  |  Coklu Pazaryeri Yonetim Platformu"
                     FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSpotTextSubtitle}" Margin="1,0,0,0"
                     LetterSpacing="0.3">
            <TextBlock.Effect>
              <DropShadowEffect Color="Black" BlurRadius="8" OffsetX="0" OffsetY="1" Opacity="0.3"/>
            </TextBlock.Effect>
          </TextBlock>

          <!-- Quick stats row -->
          <StackPanel Orientation="Horizontal" Spacing="16" Margin="1,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="{Binding ModuleCount}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                         Foreground="{DynamicResource MesSpotAccentBlue}"/>
              <TextBlock Text="Modul" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSpotTextLabel}"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="|" Foreground="{DynamicResource MesSpotTextSeparator}" VerticalAlignment="Center" FontSize="{StaticResource FontSizeSmall}"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="{Binding PlatformCount}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                         Foreground="{DynamicResource MesSpotAccentGreen}"/>
              <TextBlock Text="Platform" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSpotTextLabel}"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="|" Foreground="{DynamicResource MesSpotTextSeparator}" VerticalAlignment="Center" FontSize="{StaticResource FontSizeSmall}"/>
            <TextBlock Text="{Binding VersionText}" FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{DynamicResource MesSpotTextMuted}" VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Image name (like Bing "Kesfet: Zhangjiajie") -->
          <TextBlock Text="{Binding CurrentImageName, StringFormat='Kesfet: {0}'}"
                     FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSpotTextImageName}" Margin="1,10,0,0"
                     IsVisible="{Binding HasSpotlightImages}"
                     FontStyle="Italic"
                     LetterSpacing="0.3"/>

          <!-- Action links -->
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
            <Button Content="Giris Yap"
                    ToolTip.Tip="Kullanici adi ve sifre ile giris yap"
                    Command="{Binding ToggleLoginModeCommand}"
                    Background="{DynamicResource MesSpotBtnBg}" Foreground="{DynamicResource MesSpotTextPrimary}"
                    FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                    Padding="14,6" CornerRadius="16"
                    BorderThickness="1" BorderBrush="{DynamicResource MesSpotBtnBorder}"
                    Cursor="Hand" Opacity="0.9">
              <Button.Transitions>
                <Transitions>
                  <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
              </Button.Transitions>
            </Button>
            <Button Content="Demo ile Kesfet"
                    ToolTip.Tip="Demo hesabiyla uygulamayi kesfet"
                    Command="{Binding DemoLoginCommand}"
                    Background="Transparent" Foreground="{DynamicResource MesSpotTextDemoBtnLabel}"
                    FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                    Padding="14,6" CornerRadius="16"
                    BorderThickness="1" BorderBrush="{DynamicResource MesSpotBtnDemoBorder}"
                    Cursor="Hand" Opacity="0.85">
              <Button.Transitions>
                <Transitions>
                  <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
              </Button.Transitions>
            </Button>
            <Button Content="Esc"
                    ToolTip.Tip="Pencereyi kapat (Esc)"
                    Command="{Binding CloseCommand}"
                    Background="Transparent" Foreground="{DynamicResource MesSpotTextMuted}"
                    FontSize="{StaticResource FontSizeCaption}" Padding="10,6" CornerRadius="16"
                    BorderThickness="0" Cursor="Hand"/>
          </StackPanel>
        </StackPanel>

        <!-- ─── BOTTOM-RIGHT: Login card ─── -->
        <Border Grid.Column="1" VerticalAlignment="Bottom"
                Width="370" CornerRadius="16"
                IsVisible="{Binding IsLoginMode}"
                BoxShadow="0 12 40 0 #60000000"
                ClipToBounds="True"
                Background="{DynamicResource MesSpotCardBg}">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
            </Transitions>
          </Border.Transitions>

          <!-- Glass overlay -->
          <Border CornerRadius="16"
                  BorderBrush="{DynamicResource MesSpotGlassBorder}" BorderThickness="1"
                  Background="{DynamicResource MesSpotGlassBg}">
            <StackPanel Margin="30,28" Spacing="16">

              <!-- Card header -->
              <StackPanel Spacing="4" Margin="0,0,0,4">
                <TextBlock Text="Giris Yap" FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesSpotTextPrimary}" HorizontalAlignment="Center"
                           LetterSpacing="0.5"/>
                <TextBlock Text="MesTech hesabinizla devam edin"
                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSpotTextImageName}"
                           HorizontalAlignment="Center"/>
              </StackPanel>

              <!-- Username -->
              <StackPanel Spacing="6">
                <TextBlock Text="Kullanici Adi" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSpotTextLabel}"
                           LetterSpacing="0.5"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, Mode=TwoWay}"
                         Watermark="Kullanici adinizi girin"
                         FontSize="{StaticResource FontSizeBody}"
                         Padding="14,11"
                         CornerRadius="10"
                         Background="{DynamicResource MesSpotInputBg}"
                         Foreground="{DynamicResource MesSpotTextPrimary}"
                         BorderBrush="{DynamicResource MesSpotInputBorder}"
                         BorderThickness="1"/>
              </StackPanel>

              <!-- Password -->
              <StackPanel Spacing="6">
                <TextBlock Text="Sifre" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSpotTextLabel}"
                           LetterSpacing="0.5"/>
                <Grid>
                  <TextBox x:Name="PasswordBox"
                           Text="{Binding Password, Mode=TwoWay}"
                           PasswordChar="●"
                           Watermark="Sifrenizi girin"
                           FontSize="{StaticResource FontSizeBody}"
                           Padding="14,11"
                           CornerRadius="10"
                           Background="{DynamicResource MesSpotInputBg}"
                           Foreground="{DynamicResource MesSpotTextPrimary}"
                           BorderBrush="{DynamicResource MesSpotInputBorder}"
                           BorderThickness="1"/>
                  <Button HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Background="Transparent"
                          Padding="6"
                          Cursor="Hand"
                          Command="{Binding TogglePasswordVisibilityCommand}">
                    <TextBlock x:Name="PasswordToggleIcon" Text="*"
                               FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesSpotTextMuted}"/>
                  </Button>
                </Grid>
              </StackPanel>

              <!-- Remember me -->
              <CheckBox x:Name="RememberMeCheck"
                        Content="Beni Hatirla"
                        IsChecked="{Binding RememberMe}"
                        Foreground="{DynamicResource MesSpotTextRememberMe}" FontSize="{StaticResource FontSizeSmall}"/>

              <!-- Login button -->
              <Button x:Name="LoginButton"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      Height="46" CornerRadius="12"
                      FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                      Background="{DynamicResource MesSpotLoginBtnBg}"
                      Foreground="{DynamicResource MesSpotTextPrimary}"
                      Command="{Binding LoginCommand}"
                      IsEnabled="{Binding !IsLoginLoading}"
                      Cursor="Hand">
                <Button.Transitions>
                  <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                  </Transitions>
                </Button.Transitions>
                <Panel>
                  <TextBlock Text="GIRIS YAP" HorizontalAlignment="Center"
                             IsVisible="{Binding !IsLoginLoading}"
                             LetterSpacing="1"/>
                  <TextBlock Text="Dogrulaniyor..." HorizontalAlignment="Center"
                             IsVisible="{Binding IsLoginLoading}" Opacity="0.7"/>
                </Panel>
              </Button>

              <!-- Error panel -->
              <Border IsVisible="{Binding ShowLoginError}"
                      Background="{DynamicResource MesSpotErrorBg}" CornerRadius="10"
                      Padding="14,10">
                <TextBlock Text="{Binding LoginErrorMessage}"
                           Foreground="{DynamicResource MesSpotErrorText}" FontSize="{StaticResource FontSizeSmall}"
                           TextWrapping="Wrap"/>
              </Border>

              <!-- Lockout panel -->
              <Border IsVisible="{Binding ShowLockout}"
                      Background="{DynamicResource MesSpotLockoutBg}" CornerRadius="10"
                      Padding="14,10">
                <TextBlock Text="{Binding LockoutMessage}"
                           Foreground="{DynamicResource MesSpotLockoutText}" FontSize="{StaticResource FontSizeSmall}"/>
              </Border>

              <!-- Demo hint -->
              <TextBlock Text="Demo: admin / Admin123!"
                         FontSize="{StaticResource FontSizeCaption1}" Foreground="{DynamicResource MesSpotTextHint}"
                         HorizontalAlignment="Center" Margin="0,2,0,0"
                         LetterSpacing="0.5"/>
            </StackPanel>
          </Border>
        </Border>

      </Grid>
    </Grid>

  </Panel>
</Window>
