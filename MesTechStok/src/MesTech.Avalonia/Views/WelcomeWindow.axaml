<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MesTech.Avalonia.ViewModels"
        x:Class="MesTech.Avalonia.Views.WelcomeWindow"
        x:DataType="vm:SpotlightWelcomeViewModel"
        Title="MesTech — Hoş Geldiniz"
        WindowState="Maximized"
        SystemDecorations="None"
        Background="Transparent"
        Topmost="True"
        CanResize="False">

  <!-- ═══════════════════════════════════════════════ -->
  <!-- BING SPOTLIGHT INSPIRED WELCOME + LOGIN SCREEN -->
  <!-- Layered Panel: BG Image → Overlays → Content   -->
  <!-- ═══════════════════════════════════════════════ -->

  <Panel>

    <!-- ═══ LAYER 0: Gradient fallback (no images) ═══ -->
    <Border IsVisible="{Binding !HasSpotlightImages}">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#0D1B2A" Offset="0"/>
          <GradientStop Color="#1B2838" Offset="0.4"/>
          <GradientStop Color="#0F2847" Offset="0.7"/>
          <GradientStop Color="#0078D4" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- ═══ LAYER 1: Current background image ═══ -->
    <Image x:Name="CurrentBgImage"
           Source="{Binding CurrentBackgroundImage}"
           Stretch="UniformToFill"
           Opacity="{Binding CurrentImageOpacity}">
      <Image.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.8" Easing="CubicEaseInOut"/>
        </Transitions>
      </Image.Transitions>
    </Image>

    <!-- ═══ LAYER 2: Next background image (crossfade) ═══ -->
    <Image x:Name="NextBgImage"
           Source="{Binding NextBackgroundImage}"
           Stretch="UniformToFill"
           Opacity="{Binding NextImageOpacity}">
      <Image.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.8" Easing="CubicEaseInOut"/>
        </Transitions>
      </Image.Transitions>
    </Image>

    <!-- ═══ LAYER 3: Top gradient overlay ═══ -->
    <Border VerticalAlignment="Top" Height="160" IsHitTestVisible="False">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#99000000" Offset="0"/>
          <GradientStop Color="#33000000" Offset="0.5"/>
          <GradientStop Color="#00000000" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- ═══ LAYER 4: Bottom gradient overlay ═══ -->
    <Border VerticalAlignment="Bottom" Height="420" IsHitTestVisible="False">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
          <GradientStop Color="#00000000" Offset="0"/>
          <GradientStop Color="#55000000" Offset="0.25"/>
          <GradientStop Color="#AA000000" Offset="0.6"/>
          <GradientStop Color="#DD000000" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- ═══ LAYER 5: Content grid ═══ -->
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- ═════════════════════════════════════════ -->
      <!-- ROW 0: Top thumbnail bar                 -->
      <!-- ═════════════════════════════════════════ -->
      <Border Grid.Row="0" Margin="24,20,24,0">
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding Thumbnails}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="10"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SpotlightThumbnailItem">
                <Button Command="{Binding $parent[Window].((vm:SpotlightWelcomeViewModel)DataContext).SelectThumbnailCommand}"
                        CommandParameter="{Binding}"
                        Padding="0" BorderThickness="0" Background="Transparent"
                        Cursor="Hand"
                        CornerRadius="10">
                  <Border Width="130" Height="80" CornerRadius="10"
                          ClipToBounds="True"
                          Background="#55000000"
                          BorderBrush="#33FFFFFF" BorderThickness="1">
                    <Border.Transitions>
                      <Transitions>
                        <BrushTransition Property="Background" Duration="0:0:0.2"/>
                        <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                      </Transitions>
                    </Border.Transitions>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center" Spacing="4">
                      <TextBlock Text="{Binding Icon}" FontSize="22"
                                 HorizontalAlignment="Center"/>
                      <TextBlock Text="{Binding Name}" FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 Opacity="0.9"/>
                    </StackPanel>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <!-- ═════════════════════════════════════════ -->
      <!-- ROW 2: Bottom area                       -->
      <!-- ═════════════════════════════════════════ -->
      <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="40,0,40,36">

        <!-- ─── BOTTOM-LEFT: Branding + Info + Actions + Clock ─── -->
        <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Spacing="8"
                    MaxWidth="600">

          <!-- Brand name -->
          <TextBlock Text="MesTech" FontSize="46" FontWeight="Bold"
                     Foreground="White" Opacity="0.95">
            <TextBlock.Effect>
              <DropShadowEffect Color="Black" BlurRadius="12" OffsetX="0" OffsetY="2" Opacity="0.5"/>
            </TextBlock.Effect>
          </TextBlock>

          <!-- Subtitle -->
          <TextBlock Text="Entegratör  |  Çoklu Pazaryeri Yönetim Platformu"
                     FontSize="15" Foreground="#CCFFFFFF" Margin="2,0,0,0">
            <TextBlock.Effect>
              <DropShadowEffect Color="Black" BlurRadius="8" OffsetX="0" OffsetY="1" Opacity="0.4"/>
            </TextBlock.Effect>
          </TextBlock>

          <!-- Quick stats row -->
          <StackPanel Orientation="Horizontal" Spacing="20" Margin="2,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="{Binding ModuleCount}" FontSize="18" FontWeight="Bold"
                         Foreground="#64B5F6"/>
              <TextBlock Text="Modül" FontSize="13" Foreground="#AAFFFFFF"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="{Binding PlatformCount}" FontSize="18" FontWeight="Bold"
                         Foreground="#81C784"/>
              <TextBlock Text="Platform" FontSize="13" Foreground="#AAFFFFFF"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{Binding VersionText}" FontSize="13"
                       Foreground="#77FFFFFF" VerticalAlignment="Center"/>
          </StackPanel>

          <!-- Action links -->
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="2,6,0,0">
            <Button Content="🔐  Giriş Yap"
                    Command="{Binding ToggleLoginModeCommand}"
                    Background="Transparent" Foreground="White"
                    FontSize="13" FontWeight="SemiBold"
                    Padding="8,4" BorderThickness="0" Cursor="Hand"
                    Opacity="0.9"/>
            <TextBlock Text="│" Foreground="#44FFFFFF" VerticalAlignment="Center" FontSize="14"/>
            <Button Content="🎮  Demo ile Keşfet"
                    Command="{Binding DemoLoginCommand}"
                    Background="Transparent" Foreground="White"
                    FontSize="13" FontWeight="SemiBold"
                    Padding="8,4" BorderThickness="0" Cursor="Hand"
                    Opacity="0.9"/>
            <TextBlock Text="│" Foreground="#44FFFFFF" VerticalAlignment="Center" FontSize="14"/>
            <Button Content="Esc ile Çıkış"
                    Command="{Binding CloseCommand}"
                    Background="Transparent" Foreground="#88FFFFFF"
                    FontSize="12" Padding="8,4" BorderThickness="0" Cursor="Hand"/>
          </StackPanel>

          <!-- Image name (like Bing "Keşfedin: Zhangjiajie") -->
          <TextBlock Text="{Binding CurrentImageName, StringFormat='Keşfedin: {0}'}"
                     FontSize="13" Foreground="#99FFFFFF" Margin="2,4,0,0"
                     IsVisible="{Binding HasSpotlightImages}"
                     FontStyle="Italic"/>

          <!-- Clock + Date -->
          <StackPanel Spacing="0" Margin="0,12,0,0">
            <TextBlock x:Name="ClockDisplay" Text="{Binding ClockText}"
                       FontSize="52" FontWeight="Light"
                       Foreground="White" Opacity="0.92">
              <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="16" OffsetX="0" OffsetY="2" Opacity="0.4"/>
              </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="DateDisplay" Text="{Binding DateText}"
                       FontSize="15" Foreground="#BBFFFFFF" Margin="2,-2,0,0">
              <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="8" OffsetX="0" OffsetY="1" Opacity="0.3"/>
              </TextBlock.Effect>
            </TextBlock>
          </StackPanel>
        </StackPanel>

        <!-- ─── BOTTOM-RIGHT: Login card ─── -->
        <Border Grid.Column="1" VerticalAlignment="Bottom"
                Width="360" CornerRadius="16"
                IsVisible="{Binding IsLoginMode}"
                BoxShadow="0 8 32 0 #50000000"
                ClipToBounds="True"
                Background="#CC0D1B2A">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
            </Transitions>
          </Border.Transitions>

          <!-- Glass overlay -->
          <Border CornerRadius="16"
                  BorderBrush="#22FFFFFF" BorderThickness="1"
                  Background="#18FFFFFF">
            <StackPanel Margin="28,24" Spacing="14">

              <!-- Card header -->
              <StackPanel Spacing="2" Margin="0,0,0,4">
                <TextBlock Text="Giriş Yap" FontSize="22" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="MesTech hesabınızla devam edin"
                           FontSize="12" Foreground="#88FFFFFF"
                           HorizontalAlignment="Center"/>
              </StackPanel>

              <!-- Username -->
              <StackPanel Spacing="4">
                <TextBlock Text="Kullanıcı Adı" FontSize="12" Foreground="#AAFFFFFF"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, Mode=TwoWay}"
                         Watermark="Kullanıcı adınızı girin"
                         FontSize="14"
                         Padding="12,10"
                         CornerRadius="8"
                         Background="#22FFFFFF"
                         Foreground="White"
                         BorderBrush="#33FFFFFF"
                         BorderThickness="1"/>
              </StackPanel>

              <!-- Password -->
              <StackPanel Spacing="4">
                <TextBlock Text="Şifre" FontSize="12" Foreground="#AAFFFFFF"/>
                <Grid>
                  <TextBox x:Name="PasswordBox"
                           Text="{Binding Password, Mode=TwoWay}"
                           PasswordChar="●"
                           Watermark="Şifrenizi girin"
                           FontSize="14"
                           Padding="12,10"
                           CornerRadius="8"
                           Background="#22FFFFFF"
                           Foreground="White"
                           BorderBrush="#33FFFFFF"
                           BorderThickness="1"/>
                  <Button HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Background="Transparent"
                          Padding="6"
                          Cursor="Hand"
                          Command="{Binding TogglePasswordVisibilityCommand}">
                    <TextBlock x:Name="PasswordToggleIcon" Text="👁"
                               FontSize="14" Foreground="#88FFFFFF"/>
                  </Button>
                </Grid>
              </StackPanel>

              <!-- Remember me -->
              <CheckBox x:Name="RememberMeCheck"
                        Content="Beni Hatırla"
                        IsChecked="{Binding RememberMe}"
                        Foreground="#BBFFFFFF" FontSize="12"/>

              <!-- Login button -->
              <Button x:Name="LoginButton"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      Height="44" CornerRadius="10"
                      FontSize="14" FontWeight="SemiBold"
                      Background="#2563EB"
                      Foreground="White"
                      Command="{Binding LoginCommand}"
                      IsEnabled="{Binding !IsLoginLoading}"
                      Cursor="Hand">
                <Button.Transitions>
                  <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                  </Transitions>
                </Button.Transitions>
                <Panel>
                  <TextBlock Text="GİRİŞ YAP" HorizontalAlignment="Center"
                             IsVisible="{Binding !IsLoginLoading}"/>
                  <TextBlock Text="Doğrulanıyor..." HorizontalAlignment="Center"
                             IsVisible="{Binding IsLoginLoading}" Opacity="0.7"/>
                </Panel>
              </Button>

              <!-- Error panel -->
              <Border IsVisible="{Binding ShowLoginError}"
                      Background="#33FF3B30" CornerRadius="8"
                      Padding="12,8">
                <TextBlock Text="{Binding LoginErrorMessage}"
                           Foreground="#FF6B6B" FontSize="12"
                           TextWrapping="Wrap"/>
              </Border>

              <!-- Lockout panel -->
              <Border IsVisible="{Binding ShowLockout}"
                      Background="#33F59E0B" CornerRadius="8"
                      Padding="12,8">
                <TextBlock Text="{Binding LockoutMessage}"
                           Foreground="#FFBE4D" FontSize="12"/>
              </Border>

              <!-- Demo hint -->
              <TextBlock Text="Demo Giriş: admin / Admin123!"
                         FontSize="11" Foreground="#55FFFFFF"
                         HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
          </Border>
        </Border>

      </Grid>
    </Grid>

  </Panel>
</Window>
