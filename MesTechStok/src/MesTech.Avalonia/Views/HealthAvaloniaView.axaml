<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.HealthAvaloniaView"
             x:Name="RootHealthAvaloniaView"
             x:DataType="vm:HealthAvaloniaViewModel"
             AutomationProperties.Name="Sistem Sagligi">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- WPF008: Sistem Sagligi — servis kartlari, 30s oto-yenileme, hata log paneli -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Sistem Sağlığı" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding LastUpdated, StringFormat='Son: {0}'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="30s oto-yenileme" Foreground="{DynamicResource MesBgPrimary}"
                                   FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" Opacity="0.8" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="CSV Dışa Aktar" ToolTip.Tip="Sağlık verilerini CSV olarak dışa aktar"
                            Command="{Binding ExportCsvCommand}"
                            Background="Transparent" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}"
                            BorderBrush="{DynamicResource MesBgPrimary}" BorderThickness="1" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Skeleton (inline) -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <controls:SkeletonLoader ShowKpi="True" ShowChart="True" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Servis bulunamadi" FontSize="{StaticResource FontSizeTitle}"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesMutedGray}" Margin="0,0,0,8" />
                <TextBlock Text="Izlenen servis tanimlanmamis veya baglanti kurulamadi"
                           FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="20">

                <!-- KPI Cards Row -->
                <WrapPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="CPU Kullanımı" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0}%'}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding CpuUsage}"
                                         Height="6" Margin="0,4,0,0" Foreground="{DynamicResource MesPrimaryBlue}"
                                         Background="{DynamicResource MesBorderMedium}" />
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="RAM Kullanımı" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding RamUsage, StringFormat='{}{0}%'}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding RamUsage}"
                                         Height="6" Margin="0,4,0,0" Foreground="{DynamicResource MesTeal}"
                                         Background="{DynamicResource MesBorderMedium}" />
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Disk Kullanımı" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding DiskUsage, StringFormat='{}{0}%'}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding DiskUsage}"
                                         Height="6" Margin="0,4,0,0" Foreground="{DynamicResource MesWarning}"
                                         Background="{DynamicResource MesBorderMedium}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- MesTech Process + System Metrics -->
                <WrapPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="MesTech Bellek" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding MestechMemoryMb}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="MB" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Bottom" Margin="0,0,0,4" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="MesTech Thread" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding MestechThreadCount}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Sistem Uptime" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding SystemUptime}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Aktif Proses" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding ProcessCount}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- CSV Export Status -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource MesTeal}" Margin="0,-12,0,0"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <!-- Service Cards Grid — 3-column WrapPanel -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel>
                        <Border Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Servis Durumu" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>

                        <ItemsControl ItemsSource="{Binding ServiceCards}" Margin="16,16,16,12">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ServiceHealthItem">
                                    <!-- Service Card -->
                                    <Border Background="{DynamicResource MesBgSurface}"
                                            CornerRadius="8"
                                            BorderBrush="{DynamicResource MesBorderLight}"
                                            BorderThickness="1"
                                            Padding="14,12"
                                            Margin="0,0,10,10"
                                            MinWidth="200" MaxWidth="240">
                                        <Grid RowDefinitions="Auto,Auto,Auto">
                                            <!-- Service Name + Status Badge -->
                                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding ServiceName}"
                                                           FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MesDarkSlate}"
                                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                                <Border Grid.Column="1" Background="{Binding StatusColor}"
                                                        CornerRadius="12" Padding="6,2" Margin="4,0,0,0">
                                                    <TextBlock Text="{Binding StatusLabel}"
                                                               Foreground="White" FontSize="{StaticResource FontSizeCaption1}" FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>

                                            <!-- Category -->
                                            <TextBlock Grid.Row="1" Text="{Binding Category}"
                                                       FontSize="{StaticResource FontSizeCaption1}" Foreground="{DynamicResource MesSlateGray}"
                                                       Margin="0,4,0,0" Opacity="0.8" />

                                            <!-- Response Time + Last Check -->
                                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="Yanıt Süresi" FontSize="{StaticResource FontSizeCaption1}"
                                                               Foreground="{DynamicResource MesSlateGray}" Opacity="0.7" />
                                                    <TextBlock Text="{Binding ResponseTime}"
                                                               FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource MesDarkSlate}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="Son Kontrol" FontSize="{StaticResource FontSizeCaption1}"
                                                               Foreground="{DynamicResource MesSlateGray}" Opacity="0.7" />
                                                    <TextBlock Text="{Binding LastCheck}"
                                                               FontSize="{StaticResource FontSizeSmall}"
                                                               Foreground="{DynamicResource MesDarkSlate}" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state for service cards -->
                        <TextBlock Text="Servis durumu bulunamadı"
                                   HorizontalAlignment="Center"
                                   Margin="0,24,0,24"
                                   Opacity="0.5"
                                   FontSize="{StaticResource FontSizeSubtitle}"
                                   IsVisible="{Binding !ServiceCards.Count}" />
                    </StackPanel>
                </Border>

                <!-- Service Status Detail Table -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Servis Detay Tablosu" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                        <Grid Grid.Row="1">
                            <DataGrid ItemsSource="{Binding ServiceStatuses}"
                                      AutoGenerateColumns="False"
                                      CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                                      IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      Background="{DynamicResource MesBgPrimary}"
                                      MaxHeight="260">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Servis"       Binding="{Binding ServiceName}" Width="200" />
                                    <DataGridTextColumn Header="Durum"        Binding="{Binding Status}"      Width="120" />
                                    <DataGridTextColumn Header="Yanıt Süresi" Binding="{Binding ResponseTime}" Width="120" />
                                    <DataGridTextColumn Header="Son Kontrol"  Binding="{Binding LastCheck}"   Width="160" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="Servis durumu bulunamadı"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,40"
                                       Opacity="0.5"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       IsVisible="{Binding !ServiceStatuses.Count}" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Error Log Section — last 10 errors -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel>
                        <Border Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Hata Günlüğü (Son 10)"
                                           FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <Border Grid.Column="1" Background="{DynamicResource MesDanger}"
                                        CornerRadius="10" Padding="8,2"
                                        IsVisible="{Binding ErrorLogs.Count}">
                                    <TextBlock Text="{Binding ErrorLogs.Count}"
                                               Foreground="White" FontSize="{StaticResource FontSizeCaption}" FontWeight="Bold" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- No errors state -->
                        <Border Padding="0,24" IsVisible="{Binding !ErrorLogs.Count}">
                            <TextBlock Text="Hata bulunamadı — tüm servisler sağlıklı"
                                       HorizontalAlignment="Center"
                                       Opacity="0.5"
                                       FontSize="{StaticResource FontSizeSubtitle}" />
                        </Border>

                        <!-- Error list -->
                        <ItemsControl ItemsSource="{Binding ErrorLogs}"
                                      IsVisible="{Binding ErrorLogs.Count}"
                                      Margin="0,4,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:HealthErrorLogItem">
                                    <Border Padding="16,10"
                                            BorderBrush="{DynamicResource MesBorderLight}"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                            <!-- Level Badge -->
                                            <Border Grid.Column="0" Background="{Binding LevelColor}"
                                                    CornerRadius="4" Padding="6,2" Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Level}"
                                                           Foreground="White" FontSize="{StaticResource FontSizeCaption1}" FontWeight="Bold" />
                                            </Border>
                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="1" Text="{Binding Timestamp}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{DynamicResource MesSlateGray}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0" />
                                            <!-- Message -->
                                            <TextBlock Grid.Column="2" Text="{Binding Message}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{DynamicResource MesDarkSlate}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                            <!-- Service Name -->
                                            <TextBlock Grid.Column="3" Text="{Binding ServiceName}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{DynamicResource MesDanger}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,0,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="True" ShowChart="True" />
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>
    </Grid>
</UserControl>
