<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.HealthAvaloniaView"
             x:DataType="vm:HealthAvaloniaViewModel">

    <!-- EMR-12: Sistem Sagligi — CPU, RAM, Disk, DB baglanti durumu -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Sistem Sagligi" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding LastUpdated, StringFormat='Son: {0}'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="16">

                <!-- KPI Cards Row -->
                <WrapPanel Orientation="Horizontal">
                    <Border Background="White" CornerRadius="8" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="CPU Kullanimi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0}%'}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <Border CornerRadius="4" Height="6" Background="#E5E9F2" Margin="0,4,0,0">
                                <Border CornerRadius="4" Height="6" Background="{DynamicResource MesPrimaryBlue}"
                                        HorizontalAlignment="Left" Width="120" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="RAM Kullanimi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding RamUsage, StringFormat='{}{0}%'}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <Border CornerRadius="4" Height="6" Background="#E5E9F2" Margin="0,4,0,0">
                                <Border CornerRadius="4" Height="6" Background="#059669"
                                        HorizontalAlignment="Left" Width="140" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="8" Padding="20,16" Margin="0,0,12,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="200">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Disk Kullanimi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding DiskUsage, StringFormat='{}{0}%'}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <Border CornerRadius="4" Height="6" Background="#E5E9F2" Margin="0,4,0,0">
                                <Border CornerRadius="4" Height="6" Background="#EA580C"
                                        HorizontalAlignment="Left" Width="100" />
                            </Border>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Service Status Table -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Servis Durumu" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                <Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ServiceStatuses}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="White"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Servis" Binding="{Binding ServiceName}" Width="200" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120" />
                                <DataGridTextColumn Header="Yanit Suresi" Binding="{Binding ResponseTime}" Width="120" />
                                <DataGridTextColumn Header="Son Kontrol" Binding="{Binding LastCheck}" Width="160" />
                            </DataGrid.Columns>
                        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="16"
                               IsVisible="{Binding !ServiceStatuses.Count}" />
                </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Sistem durumu kontrol ediliyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
