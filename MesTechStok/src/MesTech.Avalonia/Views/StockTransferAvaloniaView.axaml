<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StockTransferAvaloniaView"
             x:DataType="vm:StockTransferAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-06 Gorev 4A: Depolar Arasi Transfer — kaynak/hedef depo urun transferi -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Depolar Arasi Transfer" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content: Transfer Form + History -->
        <Grid Grid.Row="1" ColumnDefinitions="420,*" Margin="16">

            <!-- Left: Transfer Form -->
            <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="0,0,8,0">
                <StackPanel Spacing="14">
                    <TextBlock Text="Yeni Transfer" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,4" />

                    <!-- Kaynak Depo -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Kaynak Depo" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                        <ComboBox ItemsSource="{Binding Warehouses}"
                                  SelectedItem="{Binding SelectedSourceWarehouse}"
                                  PlaceholderText="Kaynak depo secin..."
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Hedef Depo -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Hedef Depo" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                        <ComboBox ItemsSource="{Binding Warehouses}"
                                  SelectedItem="{Binding SelectedTargetWarehouse}"
                                  PlaceholderText="Hedef depo secin..."
                                  HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- Urun Secimi -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Urun Ara" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                        <TextBox Watermark="SKU veya urun adi..." AutomationProperties.Name="SKU veya urun adi..."
                                 Text="{Binding ProductSearchText}" />
                        <ListBox ItemsSource="{Binding SourceProducts}"
                                 SelectedItem="{Binding SelectedProduct}"
                                 MaxHeight="150">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:TransferProductDto">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Ad}" FontSize="13"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Miktar, StringFormat='Stok: {0}'}"
                                                   FontSize="12" Foreground="{DynamicResource MesSlateGray}"
                                                   VerticalAlignment="Center" Margin="8,0" />
                                        <Border Grid.Column="2" CornerRadius="{StaticResource MesRadiusSm}" Padding="6,2"
                                                Background="{Binding StokDurumRenk}">
                                            <TextBlock Text="{Binding StokDurum}" FontSize="10"
                                                       Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- Transfer Miktari -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Transfer Miktari" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                        <NumericUpDown Value="{Binding TransferQuantity}" Minimum="0"
                                       FormatString="N0" />
                    </StackPanel>

                    <!-- Stok Bilgisi -->
                    <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusBase}" Padding="12,8">
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Kaynak Stok" FontSize="11" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBlock Text="{Binding SourceStock}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="Kalan Stok" FontSize="11" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBlock Text="{Binding RemainingStock}" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Transfer Butonu -->
                    <Button Content="Transfer Et" Command="{Binding TransferCommand}"
                            Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Margin="0,4,0,0" />

                    <!-- Status -->
                    <TextBlock Text="{Binding TransferStatus}" FontSize="13"
                               Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Right: Transfer History -->
            <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="8,0,0,0">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Transfer Gecmisi" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                    </Border>
                <Grid>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding TransferHistory}"
                              AutoGenerateColumns="False"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="{DynamicResource MesBgPrimary}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" />
                            <DataGridTextColumn Header="Urun" Binding="{Binding ProductName}" Width="200" />
                            <DataGridTextColumn Header="Kaynak" Binding="{Binding Source}" Width="110" />
                            <DataGridTextColumn Header="Hedef" Binding="{Binding Target}" Width="110" />
                            <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity}" Width="80" />
                            <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Empty State -->
                    <!-- Empty State -->
                    <TextBlock Text="Stok verisi bulunamadi" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,40" Opacity="0.5" FontSize="14"
                               IsVisible="{Binding !IsLoading}" />
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Transfer verileri yukleniyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
