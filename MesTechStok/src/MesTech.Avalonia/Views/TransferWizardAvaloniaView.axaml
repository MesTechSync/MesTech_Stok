<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.TransferWizardAvaloniaView"
             x:DataType="vm:TransferWizardAvaloniaViewModel">

    <!-- I-06 Gorev 4: Depo Arasi Transfer Wizard — barkod/SKU arama + coklu urun + validasyon -->

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Depo Arasi Transfer Wizard" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Sifirla"
                        ToolTip.Tip="Sifirla"
                        Command="{Binding ResetCommand}"
                        Background="{DynamicResource MesBadgeOverlay}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="12,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="16">
            <StackPanel Spacing="16">

                <!-- Step 1: Warehouse Selection -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="1. Depo Secimi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="*,40,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Kaynak Depo" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <ComboBox ItemsSource="{Binding Warehouses}"
                                          SelectedItem="{Binding SelectedSourceWarehouse}"
                                          PlaceholderText="Kaynak depo secin..."
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="{StaticResource FontSizeHeader}" Foreground="{DynamicResource MesMutedGray}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Hedef Depo" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <ComboBox ItemsSource="{Binding Warehouses}"
                                          SelectedItem="{Binding SelectedTargetWarehouse}"
                                          PlaceholderText="Hedef depo secin..."
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>
                        <!-- Same warehouse warning -->
                        <TextBlock Text="Kaynak ve hedef depo ayni olamaz!"
                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesRedAlert}" FontWeight="SemiBold"
                                   IsVisible="{Binding IsSameWarehouse}" />
                    </StackPanel>
                </Border>

                <!-- Step 2: Product Search -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="2. Urun Ekle" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Watermark="Barkod / SKU / Urun adi..." AutomationProperties.Name="Barkod / SKU / Urun adi..."
                                     Text="{Binding ProductSearchText}" />
                            <Button Grid.Column="1" Content="Ekle" Command="{Binding AddProductCommand}"
                                    ToolTip.Tip="Ekle"
                                    Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                    Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="8,0,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Step 3: Transfer List -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="3. Transfer Listesi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding TransferSummary}"
                                           FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                <Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding TransferItems}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="False"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource MesBgPrimary}"
                                  MinHeight="150"
                                  MaxHeight="320">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Urun" Binding="{Binding ProductName}" Width="200" IsReadOnly="True" />
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" IsReadOnly="True" />
                                <DataGridTextColumn Header="Kaynak Stok" Binding="{Binding SourceStock}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="Hedef Stok" Binding="{Binding TargetStock}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="Transfer Adet" Binding="{Binding TransferQuantity}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayit bulunamadi"
                               FontSize="{StaticResource FontSizeTitle}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource MesMutedGray}"
                               IsVisible="{Binding !TransferItems.Count}"
                               Opacity="0.5" />
                </Grid>
                    </Grid>
                </Border>

                <!-- Warnings -->
                <Border Background="{DynamicResource MesBgAmberLight}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                        BorderBrush="{DynamicResource MesBorderAmber}" BorderThickness="1"
                        IsVisible="{Binding HasWarnings}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Uyarilar" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" Foreground="{DynamicResource MesAmber}" />
                        <ItemsControl ItemsSource="{Binding Warnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesAmberDark}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer: Action Buttons -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding TransferStatus}"
                           FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Iptal"
                        ToolTip.Tip="Iptal"
                        Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesTextSlate}"
                        Padding="20,10" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Transferi Baslat"
                        ToolTip.Tip="Transferi Baslat"
                        Command="{Binding ExecuteTransferCommand}"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="24,10" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Transfer isleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
