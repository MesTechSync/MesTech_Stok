<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.TransferWizardAvaloniaView"
             x:DataType="vm:TransferWizardAvaloniaViewModel">

    <!-- I-06 Gorev 4: Depo Arasi Transfer Wizard — barkod/SKU arama + coklu urun + validasyon -->

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Depo Arasi Transfer Wizard" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Sifirla"
                        Command="{Binding ResetCommand}"
                        Background="#FFFFFF33" Foreground="White" FontWeight="SemiBold"
                        Padding="12,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="16">
            <StackPanel Spacing="16">

                <!-- Step 1: Warehouse Selection -->
                <Border Background="White" CornerRadius="8" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="1. Depo Secimi" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="*,40,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Kaynak Depo" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <ComboBox ItemsSource="{Binding Warehouses}"
                                          SelectedItem="{Binding SelectedSourceWarehouse}"
                                          PlaceholderText="Kaynak depo secin..."
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="24" Foreground="{DynamicResource MesMutedGray}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Hedef Depo" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <ComboBox ItemsSource="{Binding Warehouses}"
                                          SelectedItem="{Binding SelectedTargetWarehouse}"
                                          PlaceholderText="Hedef depo secin..."
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>
                        <!-- Same warehouse warning -->
                        <TextBlock Text="Kaynak ve hedef depo ayni olamaz!"
                                   FontSize="12" Foreground="{DynamicResource MesRedAlert}" FontWeight="SemiBold"
                                   IsVisible="{Binding IsSameWarehouse}" />
                    </StackPanel>
                </Border>

                <!-- Step 2: Product Search -->
                <Border Background="White" CornerRadius="8" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="2. Urun Ekle" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Watermark="Barkod / SKU / Urun adi..." AutomationProperties.Name="Barkod / SKU / Urun adi..."
                                     Text="{Binding ProductSearchText}" />
                            <Button Grid.Column="1" Content="Ekle" Command="{Binding AddProductCommand}"
                                    Background="{DynamicResource MesPrimaryBlue}" Foreground="White" FontWeight="SemiBold"
                                    Padding="16,8" CornerRadius="6" Margin="8,0,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Step 3: Transfer List -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="3. Transfer Listesi" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding TransferSummary}"
                                           FontSize="13" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                <Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding TransferItems}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="False"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="White"
                                  MinHeight="150"
                                  MaxHeight="320">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Urun" Binding="{Binding ProductName}" Width="200" IsReadOnly="True" />
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" IsReadOnly="True" />
                                <DataGridTextColumn Header="Kaynak Stok" Binding="{Binding SourceStock}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="Hedef Stok" Binding="{Binding TargetStock}" Width="100" IsReadOnly="True" />
                                <DataGridTextColumn Header="Transfer Adet" Binding="{Binding TransferQuantity}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="16"
                               IsVisible="{Binding !TransferItems.Count}" />
                </Grid>
                    </Grid>
                </Border>

                <!-- Warnings -->
                <Border Background="#FFFBEB" CornerRadius="8" Padding="16"
                        BorderBrush="#FDE68A" BorderThickness="1"
                        IsVisible="{Binding HasWarnings}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Uyarilar" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MesAmber}" />
                        <ItemsControl ItemsSource="{Binding Warnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#92400E" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer: Action Buttons -->
        <Border Grid.Row="2" Background="White" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding TransferStatus}"
                           FontSize="13" Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Iptal"
                        Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesTextSlate}"
                        Padding="20,10" CornerRadius="6" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Transferi Baslat"
                        Command="{Binding ExecuteTransferCommand}"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="White" FontWeight="SemiBold"
                        Padding="24,10" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Transfer isleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
