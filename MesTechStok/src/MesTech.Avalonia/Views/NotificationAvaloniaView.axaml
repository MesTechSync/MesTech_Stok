<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.NotificationAvaloniaView"
             x:Name="NotificationAvaloniaView"
             x:DataType="vm:NotificationAvaloniaViewModel"
             AutomationProperties.Name="Bildirimler">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-12: Bildirimler — bildirim zaman cizelgesi -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Bildirimler" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} bildirim'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Tumunu Okundu Isaretle"
                            ToolTip.Tip="Tumunu Okundu Isaretle"
                            Command="{Binding MarkAllReadCommand}"
                            Background="Transparent" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="12,8" CornerRadius="{StaticResource MesRadiusBase}" BorderBrush="{DynamicResource MesBadgeOverlay}" BorderThickness="1" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Notification List -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <ItemsControl ItemsSource="{Binding Notifications}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16,14" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="{StaticResource MesRadiusSm}"
                                        Background="{Binding StatusColor}" VerticalAlignment="Top" Margin="0,6,12,0" />
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding Title}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MesDarkSlate}" />
                                    <TextBlock Text="{Binding Message}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding TimeAgo}" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesMutedGray}" VerticalAlignment="Top" Margin="12,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <Border Grid.Row="1"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Bildirim Yok" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Henuz bildiriminiz bulunmuyor"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Bildirimler yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    
        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
