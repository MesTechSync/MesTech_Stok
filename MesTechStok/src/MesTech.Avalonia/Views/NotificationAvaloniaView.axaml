<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.NotificationAvaloniaView"
             x:DataType="vm:NotificationAvaloniaViewModel">

    <!-- EMR-12: Bildirimler — bildirim zaman cizelgesi -->

    <Grid RowDefinitions="Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Bildirimler" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} bildirim'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Tumunu Okundu Isaretle"
                            Command="{Binding MarkAllReadCommand}"
                            Background="Transparent" Foreground="White" FontWeight="SemiBold"
                            Padding="12,8" CornerRadius="6" BorderBrush="#FFFFFF55" BorderThickness="1" />
                    <Button Content="Yenile"
                            Command="{Binding RefreshCommand}"
                            Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="6" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Notification List -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <ItemsControl ItemsSource="{Binding Notifications}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="8" Padding="16,14" Margin="0,0,0,8"
                                BorderBrush="#E0E6ED" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                        Background="{Binding StatusColor}" VerticalAlignment="Top" Margin="0,6,12,0" />
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#1E293B" />
                                    <TextBlock Text="{Binding Message}" FontSize="13" Foreground="#64748B"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding TimeAgo}" FontSize="12"
                                           Foreground="#94A3B8" VerticalAlignment="Top" Margin="12,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <Border Grid.Row="1"
                Background="#F7F9FC"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Bildirim Yok" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#1E293B" Margin="0,0,0,8" />
                <TextBlock Text="Henuz bildiriminiz bulunmuyor"
                           FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Bildirimler yukleniyor..."
                           FontSize="14" Foreground="#555555" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
