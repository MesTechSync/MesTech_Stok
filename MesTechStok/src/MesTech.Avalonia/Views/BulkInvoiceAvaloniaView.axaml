<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.BulkInvoiceAvaloniaView"
             x:Name="RootBulkInvoiceAvaloniaView"
             x:DataType="vm:BulkInvoiceAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding LoadDataCommand}" />    </UserControl.KeyBindings>

    <!-- Toplu Fatura Olustur -->

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource BackgroundBrush}">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBlueBrush}" Padding="20,14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconReceipt}" Width="22" Height="22" Foreground="{DynamicResource MesBgPrimary}"/>
                <TextBlock Text="Toplu Fatura Olustur" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeHeader}" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Row 1: Controls -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Padding="16,10"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                <CheckBox Grid.Column="0" Content="Tumunu Sec" IsChecked="{Binding SelectAll}"
                          VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBox Grid.Column="1" Width="220" Watermark="Ara: siparis no, musteri..."
                         AutomationProperties.Name="Ara: siparis no, musteri..."
                         Text="{Binding SearchText}"
                         FontSize="{StaticResource FontSizeSmall}" Padding="8,6"
                         CornerRadius="{StaticResource MesRadiusBase}" VerticalAlignment="Center"
                         Margin="0,0,12,0" />
                <TextBlock Grid.Column="2"
                           Text="{Binding SelectedCount, StringFormat='{}{0} siparis secili'}"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="Provider:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="4" Width="160"
                          ItemsSource="{Binding Providers}"
                          SelectedItem="{Binding SelectedProvider}" AutomationProperties.Name="Provider:"/>
                <Button Grid.Column="5" Content="Toplu Fatura Olustur"
                        ToolTip.Tip="Toplu Fatura Olustur"
                        Command="{Binding ProcessBulkCommand}"
                        Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource CornerRadiusMedium}"
                        Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- Row 2: Content area -->
        <Grid Grid.Row="2">

            <!-- Orders DataGrid -->
            <DataGrid ItemsSource="{Binding Orders}"
                      AutomationProperties.Name="Toplu fatura siparis listesi"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                      IsReadOnly="False"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource SurfaceBrush}"
                      IsVisible="{Binding !IsProcessing}">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Sec" Binding="{Binding IsSelected}" Width="60"/>
                    <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderId}" Width="160"/>
                    <DataGridTextColumn Header="Musteri" Binding="{Binding CustomerName}" Width="250"/>
                    <DataGridTextColumn Header="Tutar (TL)" Binding="{Binding Amount, StringFormat='{}{0:N2}'}" Width="140"/>
                    <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="130"/>
                    <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty State: BulkInvoice -->
            <TextBlock Grid.Row="2"
                       Text="Siparis bulunamadi"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,40"
                       Opacity="0.5"
                       FontSize="{StaticResource FontSizeSubtitle}"
                       IsVisible="{Binding !Orders.Count}" />

            <!-- Processing Progress -->
            <Border IsVisible="{Binding IsProcessing}"
                    Background="{DynamicResource SurfaceBrush}"
                    ZIndex="100">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                            Width="400">
                    <TextBlock Text="Faturalar olusturuluyor..."
                               FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100"
                                 Height="8" CornerRadius="{StaticResource MesRadiusSm}"/>
                    <TextBlock Text="{Binding Progress, StringFormat='%{0:F0}'}"
                               HorizontalAlignment="Center"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 3: Results -->
        <Border Grid.Row="3" IsVisible="{Binding ShowResults}"
                Background="{DynamicResource SurfaceBrush}" Padding="16,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource IconCheck}" Width="16" Height="16"
                                  Foreground="{DynamicResource SuccessBrush}"/>
                        <TextBlock Text="{Binding SuccessCount, StringFormat='Basarili: {0}'}"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource IconError}" Width="16" Height="16"
                                  Foreground="{DynamicResource ErrorRedBrush}"/>
                        <TextBlock Text="{Binding FailCount, StringFormat='Basarisiz: {0}'}"
                                   Foreground="{DynamicResource ErrorRedBrush}"
                                   FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Error details -->
                <ItemsControl ItemsSource="{Binding ErrorDetails}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource ErrorRedBrush}" Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Fatura bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz fatura bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

</Grid>
</UserControl>
