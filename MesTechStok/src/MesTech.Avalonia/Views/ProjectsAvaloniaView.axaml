<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ProjectsAvaloniaView"
             x:Name="RootProjectsAvaloniaView"
             x:DataType="vm:ProjectsAvaloniaViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Projeler" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} proje'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Proje" Command="{Binding AddCommand}"
                        ToolTip.Tip="Yeni proje olustur"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="220" Watermark="Proje ara..." AutomationProperties.Name="Proje ara..."
                         Text="{Binding SearchText}" />
                <ComboBox Width="160" PlaceholderText="Durum"
                          ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}"  AutomationProperties.Name="Durum"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Loading -->
            <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Error -->
            <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}" Margin="22"
                    CornerRadius="{StaticResource MesRadiusMd}" Padding="16" BorderBrush="{DynamicResource MesBorderDanger}" BorderThickness="1"
                    VerticalAlignment="Top">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" TextWrapping="Wrap" />
            </Border>

            <!-- Empty -->
            <TextBlock Text="Henuz proje bulunmuyor."
                       IsVisible="{Binding IsEmpty}" Foreground="{DynamicResource MesMutedGray}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}" />

            <!-- Data Grid -->
                <Grid>
            <DataGrid ItemsSource="{Binding Projects}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource MesBgPrimary}"
                     >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Proje Adi" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120" />
                    <DataGridTextColumn Header="Yonetici" Binding="{Binding Manager}" Width="130" />
                    <DataGridTextColumn Header="Tarih Araligi" Binding="{Binding DateRange}" Width="200" />
                    <DataGridTextColumn Header="Ilerleme" Binding="{Binding ProgressDisplay}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
                    <!-- Empty State -->
                    <!-- Empty State -->
                    <TextBlock Text="Veri bulunamadi" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,40" Opacity="0.5" FontSize="{StaticResource FontSizeBody}"
                               />
                </Grid>
        </Grid>
    </Grid>
</UserControl>
