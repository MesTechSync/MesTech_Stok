<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.UserManagementAvaloniaView"
             x:Name="RootUserManagementAvaloniaView"
             x:DataType="vm:UserManagementAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-12: Kullanici Yonetimi — kullanici listesi + rol yonetimi -->

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Kullanici Yonetimi" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kullanici'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <!-- HH-DEV2-038: User CRUD buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="+ Kullanici Ekle" ToolTip.Tip="Yeni kullanici ekle"
                            Command="{Binding AddUserCommand}"
                            Background="{DynamicResource MesSuccessGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Duzenle" ToolTip.Tip="Secili kullaniciyi duzenle"
                            Command="{Binding EditUserCommand}"
                            Background="{DynamicResource MesAmber}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Sil" ToolTip.Tip="Secili kullaniciyi sil"
                            Command="{Binding DeleteUserCommand}"
                            Background="{DynamicResource MesRedAlert}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <TextBox Width="360" Watermark="Kullanici adi, e-posta ile arama..." AutomationProperties.Name="Kullanici adi, e-posta ile arama..."
                     Text="{Binding SearchText}"
                     FontSize="{StaticResource FontSizeBody}" Padding="10,8" HorizontalAlignment="Left" />
        </Border>

        <!-- HH-DEV2-038: Inline Edit Form -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgSurface}" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1"
                IsVisible="{Binding IsEditing}">
            <StackPanel Spacing="10">
                <TextBlock Text="Kullanici Bilgileri" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesPrimaryBlue}" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBox Width="160" Watermark="Kullanici Adi" AutomationProperties.Name="Kullanici Adi"
                             Text="{Binding EditUsername}" />
                    <TextBox Width="180" Watermark="Ad Soyad" AutomationProperties.Name="Ad Soyad"
                             Text="{Binding EditFullName}" />
                    <TextBox Width="200" Watermark="E-posta" AutomationProperties.Name="E-posta"
                             Text="{Binding EditEmail}" />
                    <ComboBox Width="120" ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding EditRole}"
                              AutomationProperties.Name="Rol seciniz" />
                    <Button Content="Kaydet" Command="{Binding SaveUserCommand}"
                            Background="{DynamicResource MesSuccessGreen}" Foreground="{DynamicResource MesBgPrimary}"
                            FontWeight="SemiBold" Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Iptal" Command="{Binding CancelEditCommand}"
                            Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesSlateGray}"
                            Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
                <TextBlock Text="{Binding EditStatus}" FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource MesAmber}"
                           IsVisible="{Binding EditStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
        </Border>

        <!-- Users DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}"
                  Margin="16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Kullanici Adi" Binding="{Binding Username}" Width="160" />
                <DataGridTextColumn Header="Ad Soyad" Binding="{Binding FullName}" Width="200" />
                <DataGridTextColumn Header="E-posta" Binding="{Binding Email}" Width="220" />
                <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="120" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="100" />
                <DataGridTextColumn Header="Son Giris" Binding="{Binding LastLogin}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State -->
        <Border Grid.Row="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Kullanici Bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Arama kriterlerinize uygun kullanici bulunamadi"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>
    
                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

</Grid>
</UserControl>
