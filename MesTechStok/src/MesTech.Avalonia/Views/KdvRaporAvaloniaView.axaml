<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.KdvRaporAvaloniaView"
             x:DataType="vm:KdvRaporAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="#B45309" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="KDV Raporu" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} fatura'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesAmber}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- KPI Row -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPage}" Padding="16,12">
            <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" Margin="4"
                        BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Satis KDV" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding SalesVat}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource MesEmerald}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16" Margin="4"
                        BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Alis KDV" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding PurchaseVat}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource MesRedBright}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16" Margin="4"
                        BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Odenecek / Devreden KDV" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding NetVat}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPrimaryBlue}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="2" Background="White" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox ItemsSource="{Binding PeriodTypes}" SelectedItem="{Binding SelectedPeriodType}"
                          Width="140" />
                <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}"
                          Width="140" />
                <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"
                          Width="100" />
                <ComboBox ItemsSource="{Binding InvoiceTypes}" SelectedItem="{Binding SelectedInvoiceType}"
                          Width="140" />
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Background="White" Margin="16" CornerRadius="12"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
            <Grid>
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fatura" Binding="{Binding InvoiceNumber}" Width="140" />
                    <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="110" />
                    <DataGridTextColumn Header="Tutar" Binding="{Binding AmountFormatted}" Width="130" />
                    <DataGridTextColumn Header="KDV Orani" Binding="{Binding VatRateFormatted}" Width="100" />
                    <DataGridTextColumn Header="KDV Tutari" Binding="{Binding VatAmountFormatted}" Width="130" />
                    <DataGridTextColumn Header="Tip" Binding="{Binding InvoiceType}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
                <!-- Empty State -->
                <TextBlock Text="Kayıt bulunamadı"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,40"
                           Opacity="0.5"
                           FontSize="16"
                           IsVisible="{Binding !Items.Count}" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="KDV raporu yukleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Kayit bulunamadi" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Secilen donem icin KDV kaydi bulunamadi"
                           FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
