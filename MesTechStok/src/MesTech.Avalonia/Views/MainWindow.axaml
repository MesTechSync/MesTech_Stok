<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MesTech.Avalonia.ViewModels"
        xmlns:views="using:MesTech.Avalonia.Views"
        xmlns:wpfvm="using:MesTechStok.Desktop.ViewModels.Finance"
        xmlns:acctvm="using:MesTech.Avalonia.ViewModels.Accounting"
        xmlns:monvm="using:MesTech.Avalonia.ViewModels.Monitoring"
        xmlns:ordvm="using:MesTech.Avalonia.ViewModels.Orders"
        xmlns:acctviews="using:MesTech.Avalonia.Views.Accounting"
        xmlns:monviews="using:MesTech.Avalonia.Views.Monitoring"
        xmlns:ordviews="using:MesTech.Avalonia.Views.Orders"
        x:Class="MesTech.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MesTech Entegratör"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Styles>
        <!-- Sidebar button style -->
        <Style Selector="Button.sidebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Button.sidebar-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextActiveBrush}" />
        </Style>
        <!-- Icon button style (toolbar) -->
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverOverlayBrush}" />
        </Style>
        <!-- Sidebar section header -->
        <Style Selector="TextBlock.sidebar-section">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource MesSlateGray}" />
            <Setter Property="Margin" Value="16,14,0,6" />
        </Style>
        <!-- Disabled sidebar item -->
        <Style Selector="Button.sidebar-disabled">
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Opacity" Value="0.4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- ═══ TOOLBAR (UST) ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                Height="52"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Sol: Sidebar toggle + Baslik -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <Button x:Name="SidebarToggleBtn" Classes="icon-btn"
                            ToolTip.Tip="MesTech Entegrator"
                            Click="OnSidebarToggle">
                        <PathIcon Data="{StaticResource IconMenu}" Width="20" Height="20"/>
                    </Button>
                    <TextBlock Text="MesTech Entegratör"
                               FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Orta: Arama -->
                <TextBox Grid.Column="1"
                         Watermark="Ara..." AutomationProperties.Name="Ara..."
                         MaxWidth="400" Margin="24,0"
                         VerticalAlignment="Center"
                         FontSize="{StaticResource FontSizeBody}"/>

                <!-- Sag: Saat + Bildirim + Profil -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0" Spacing="4">
                    <TextBlock x:Name="ToolbarClock" Text="00:00"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Classes="icon-btn">
                            ToolTip.Tip="Admin"
                        <PathIcon Data="{StaticResource IconNotification}" Width="18" Height="18"/>
                    </Button>
                    <Button Classes="icon-btn">
                            ToolTip.Tip="Admin"
                        <PathIcon Data="{StaticResource IconPerson}" Width="18" Height="18"/>
                    </Button>
                    <TextBlock Text="Admin"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ STATUSBAR (ALT) ═══ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                Height="30"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="Bağlı" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="PostgreSQL 17" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="v1.0.0" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="StatusUser" Text="admin"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SIDEBAR (SOL) + CONTENT (ORTA) ═══ -->
        <Grid ColumnDefinitions="Auto,*">

            <!-- SIDEBAR -->
            <Border x:Name="SidebarPanel" Grid.Column="0" Width="240"
                    Background="{DynamicResource SidebarBackgroundBrush}">
                <DockPanel>

                    <!-- Sidebar ust: MesTech mini logo -->
                    <Border DockPanel.Dock="Top" Height="48" Padding="16,0"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <PathIcon Data="{StaticResource IconMenu}"
                                      Foreground="{DynamicResource SidebarTextActiveBrush}"
                                      Width="16" Height="16"/>
                            <TextBlock x:Name="SidebarTitle" Text="MesTech"
                                       Foreground="{DynamicResource SidebarTextActiveBrush}"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Sidebar alt: Footer -->
                    <Border DockPanel.Dock="Bottom" Padding="16,10"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <TextBlock Text="Dalga 14+15 — Avalonia Shell" FontSize="{StaticResource FontSizeCaption1}"
                                   Foreground="{DynamicResource MesTextSlate}"/>
                    </Border>

                    <!-- Sidebar menu — ScrollViewer icinde -->
                    <ScrollViewer>
                        <StackPanel Margin="0,4" Spacing="1">

                            <!-- 1. DASHBOARD -->
                            <TextBlock Classes="sidebar-section" Text="DASHBOARD"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kontrol Paneli"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Dashboard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Kontrol Paneli"/>
                                </StackPanel>
                            </Button>

                            <!-- 2. URUNLER -->
                            <TextBlock Classes="sidebar-section" Text="ÜRÜNLER"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Urun Listesi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Products">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16"/>
                                    <TextBlock Text="Ürün Listesi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Toplu Ice Aktarma"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ImportProducts">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconUpload}" Width="16" Height="16"/>
                                    <TextBlock Text="Toplu İçe Aktarma"/>
                                </StackPanel>
                            </Button>

                            <!-- 3. SIPARISLER -->
                            <TextBlock Classes="sidebar-section" Text="SİPARİŞLER"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Siparisler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Orders">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconShoppingCart}" Width="16" Height="16"/>
                                    <TextBlock Text="Siparişler"/>
                                </StackPanel>
                            </Button>

                            <!-- 4. STOK -->
                            <TextBlock Classes="sidebar-section" Text="STOK"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Stok Takibi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Stock">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Takibi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Envanter"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Inventory">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarcode}" Width="16" Height="16"/>
                                    <TextBlock Text="Envanter"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Stok Guncelleme"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="StockMovement">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Güncelleme"/>
                                </StackPanel>
                            </Button>

                            <!-- 5. KATEGORILER -->
                            <TextBlock Classes="sidebar-section" Text="KATEGORİLER"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kategoriler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Category">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconCategory}" Width="16" Height="16"/>
                                    <TextBlock Text="Kategoriler"/>
                                </StackPanel>
                            </Button>

                            <!-- 6. KARGO -->
                            <TextBlock Classes="sidebar-section" Text="KARGO"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kargo Takip"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CargoTracking">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconTruck}" Width="16" Height="16"/>
                                    <TextBlock Text="Kargo Takip"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kargo Firmalari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CargoProviders">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconTruck}" Width="16" Height="16"/>
                                    <TextBlock Text="Kargo Firmalari"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Toplu Gonderim"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="BulkShipment">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconTruck}" Width="16" Height="16"/>
                                    <TextBlock Text="Toplu Gonderim"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Etiket Yazdir"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="LabelPreview">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPrint}" Width="16" Height="16"/>
                                    <TextBlock Text="Etiket Yazdir"/>
                                </StackPanel>
                            </Button>

                            <!-- IADELER -->
                            <TextBlock Classes="sidebar-section" Text="IADELER"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Iade Listesi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ReturnList">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                                    <TextBlock Text="Iade Listesi"/>
                                </StackPanel>
                            </Button>

                            <!-- 7. E-FATURA -->
                            <TextBlock Classes="sidebar-section" Text="E-FATURA"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fatura Yonetimi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceManagement">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Yönetimi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fatura Listesi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceList">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Listesi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fatura Olustur"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceCreate">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconAdd}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Oluştur"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Toplu Fatura"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="BulkInvoice">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Toplu Fatura"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Provider Ayarlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceProviders">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="Provider Ayarları"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fatura Raporlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceReport">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Raporları"/>
                                </StackPanel>
                            </Button>

                            <!-- 8. FINANS -->
                            <TextBlock Classes="sidebar-section" Text="FİNANS"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kar / Zarar Raporu"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ProfitLoss">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Kâr / Zarar Raporu"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Giderler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Expenses">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Giderler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Banka Hesaplari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="BankAccounts">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSave}" Width="16" Height="16"/>
                                    <TextBlock Text="Banka Hesapları"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Cari Hesaplar"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CariHesaplar">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Cari Hesaplar"/>
                                </StackPanel>
                            </Button>

                            <!-- 8b. MUHASEBE (V4 — Zincir 2/3/6/14) -->
                            <TextBlock Classes="sidebar-section" Text="MUHASEBE"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Yevmiye Defteri"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="JournalEntries">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDocument}" Width="16" Height="16"/>
                                    <TextBlock Text="Yevmiye Defteri"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Mizan"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="TrialBalance">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Mizan"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Komisyon Oranlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CommissionRates">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconStar}" Width="16" Height="16"/>
                                    <TextBlock Text="Komisyon Oranları"/>
                                </StackPanel>
                            </Button>

                            <!-- 8c. İZLEME (V4 — Zincir 10/11) -->
                            <TextBlock Classes="sidebar-section" Text="İZLEME"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Gecikmis Siparisler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="StaleOrders">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconNotification}" Width="16" Height="16"/>
                                    <TextBlock Text="Gecikmiş Siparişler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Siparis Kanban"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="OrderKanban">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Sipariş Kanban"/>
                                </StackPanel>
                            </Button>

                            <!-- 9. CRM -->
                            <TextBlock Classes="sidebar-section" Text="CRM"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Potansiyel Musteriler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Leads">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Potansiyel Müşteriler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kisiler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Contacts">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Kişiler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Firsatlar — Kanban"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Kanban">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Fırsatlar — Kanban"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Musteriler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Customers">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Müşteriler"/>
                                </StackPanel>
                            </Button>

                            <!-- 10. PLATFORM -->
                            <TextBlock Classes="sidebar-section" Text="PLATFORM"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Platformlar"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="PlatformList">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Platformlar"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Magaza Ekle"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="StoreWizard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconAdd}" Width="16" Height="16"/>
                                    <TextBlock Text="Mağaza Ekle"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Magaza Ayarlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="StoreSettings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="Mağaza Ayarları"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kategori Eslestirme"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CategoryMapping">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconCategory}" Width="16" Height="16"/>
                                    <TextBlock Text="Kategori Eşleştirme"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Sync Durumu"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="PlatformSyncStatus">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                                    <TextBlock Text="Sync Durumu"/>
                                </StackPanel>
                            </Button>

                            <!-- 10b. DROPSHIPPING -->
                            <TextBlock Classes="sidebar-section" Text="DROPSHİPPİNG"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Dropship Paneli"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="DropshipDashboard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Dropship Paneli"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Dropship Siparisler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="DropshipOrders">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconShoppingCart}" Width="16" Height="16"/>
                                    <TextBlock Text="Dropship Siparişler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Karlilik Analizi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="DropshipProfit">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Kârlılık Analizi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Tedarikci Feed'leri"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="SupplierFeeds">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconUpload}" Width="16" Height="16"/>
                                    <TextBlock Text="Tedarikçi Feed'leri"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Yeni Feed"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="FeedCreate">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconAdd}" Width="16" Height="16"/>
                                    <TextBlock Text="Yeni Feed"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Ice Aktarma Ayarlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ImportSettings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="İçe Aktarma Ayarları"/>
                                </StackPanel>
                            </Button>

                            <!-- MARKETPLACE -->
                            <TextBlock Classes="sidebar-section" Text="MARKETPLACE"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Buybox Analizi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Buybox">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Buybox Analizi"/>
                                </StackPanel>
                            </Button>

                            <!-- 11. FULFILLMENT -->
                            <TextBlock Classes="sidebar-section" Text="FULFILLMENT"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fulfillment Dashboard"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="FulfillmentDashboard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Inbound Gonderimler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="FulfillmentInbound">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconUpload}" Width="16" Height="16"/>
                                    <TextBlock Text="Inbound Gonderimler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fulfillment Envanter"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="FulfillmentInventory">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16"/>
                                    <TextBlock Text="Envanter"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fulfillment Ayarlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="FulfillmentSettings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="Ayarlar"/>
                                </StackPanel>
                            </Button>

                            <!-- 12. ERP & MUHASEBE -->
                            <TextBlock Classes="sidebar-section" Text="ERP &amp; MUHASEBE"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="ERP Dashboard"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ErpDashboard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="ERP Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Cari Esleme"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ErpAccountMapping">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconCopy}" Width="16" Height="16"/>
                                    <TextBlock Text="Cari Esleme"/>
                                </StackPanel>
                            </Button>

                            <!-- 13. GELIR / GIDER -->
                            <TextBlock Classes="sidebar-section" Text="GEL&#x0130;R / G&#x0130;DER"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Gelir Gider Dashboard"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="IncomeExpenseDashboard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Dashboard"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Gelir Gider Kayitlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="IncomeExpenseList">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Kayitlar"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Karlilik Raporu"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ProfitabilityReport">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Karlilik Raporu"/>
                                </StackPanel>
                            </Button>

                            <!-- 14. RAPORLAR -->
                            <TextBlock Classes="sidebar-section" Text="RAPORLAR"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Belgeler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Documents">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconCopy}" Width="16" Height="16"/>
                                    <TextBlock Text="Belgeler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Raporlar"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Reports">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Raporlar"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Nakit Akis Raporu"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CashFlowReport">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Nakit Akis"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Satis Analizi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="SalesAnalytics">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Satis Analizi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Stok Deger Raporu"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="StockValueReport">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Deger"/>
                                </StackPanel>
                            </Button>

                            <!-- 12. AYARLAR -->
                            <TextBlock Classes="sidebar-section" Text="AYARLAR"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Ayarlar"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Settings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="Ayarlar"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="ERP Ayarlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ErpSettings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="ERP Ayarlari"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Pazaryerleri"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Marketplaces">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconShoppingCart}" Width="16" Height="16"/>
                                    <TextBlock Text="Pazaryerleri"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Platform Senkronizasyon"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="SyncStatus">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                                    <TextBlock Text="Platform Senkronizasyon"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Calisanlar"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Employees">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Çalışanlar"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Izin Talepleri"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="LeaveRequests">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconHome}" Width="16" Height="16"/>
                                    <TextBlock Text="İzin Talepleri"/>
                                </StackPanel>
                            </Button>

                            <!-- Cikis -->
                            <Border Height="1" Background="{DynamicResource SidebarBorderBrush}" Margin="16,8"/>
                            <Button Classes="sidebar-btn" x:Name="LogoutBtn" Click="OnLogout">
                                    ToolTip.Tip="Cikis"
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconLogout}" Width="16" Height="16"/>
                                    <TextBlock Text="Çıkış"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>

                </DockPanel>
            </Border>

            <!-- CONTENT AREA -->
            <DockPanel Grid.Column="1">
                <!-- Content Header -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                        Padding="24,14"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding CurrentViewTitle}"
                               FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>

                <!-- Dynamic Content -->
                <ContentControl Content="{Binding CurrentView}" Margin="0">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:DashboardAvaloniaViewModel">
                            <views:DashboardAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LeadsAvaloniaViewModel">
                            <views:LeadsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:KanbanAvaloniaViewModel">
                            <views:KanbanAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ProductsAvaloniaViewModel">
                            <views:ProductsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="wpfvm:ProfitLossViewModel">
                            <views:ProfitLossAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:StockAvaloniaViewModel">
                            <views:StockAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:OrdersAvaloniaViewModel">
                            <views:OrdersAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsAvaloniaViewModel">
                            <views:SettingsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LoginAvaloniaViewModel">
                            <views:LoginAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:CategoryAvaloniaViewModel">
                            <views:CategoryAvaloniaView />
                        </DataTemplate>
                        <!-- Dalga 11 batch expansion -->
                        <DataTemplate DataType="vm:ContactsAvaloniaViewModel">
                            <views:ContactsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:EmployeesAvaloniaViewModel">
                            <views:EmployeesAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LeaveRequestsAvaloniaViewModel">
                            <views:LeaveRequestsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:DocumentsAvaloniaViewModel">
                            <views:DocumentsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ReportsAvaloniaViewModel">
                            <views:ReportsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:MarketplacesAvaloniaViewModel">
                            <views:MarketplacesAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ExpensesAvaloniaViewModel">
                            <views:ExpensesAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:BankAccountsAvaloniaViewModel">
                            <views:BankAccountsAvaloniaView />
                        </DataTemplate>
                        <!-- Dalga 14+15 functional views -->
                        <DataTemplate DataType="vm:InventoryAvaloniaViewModel">
                            <views:InventoryAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:InvoiceManagementAvaloniaViewModel">
                            <views:InvoiceManagementAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:CustomerAvaloniaViewModel">
                            <views:CustomerAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:CariHesaplarAvaloniaViewModel">
                            <views:CariHesaplarAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SyncStatusAvaloniaViewModel">
                            <views:SyncStatusAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:StockMovementAvaloniaViewModel">
                            <views:StockMovementAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:CargoTrackingAvaloniaViewModel">
                            <views:CargoTrackingAvaloniaView />
                        </DataTemplate>
                        <!-- Invoice views (e-Fatura batch) -->
                        <DataTemplate DataType="vm:InvoiceListAvaloniaViewModel">
                            <views:InvoiceListAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:InvoiceCreateAvaloniaViewModel">
                            <views:InvoiceCreateAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:BulkInvoiceAvaloniaViewModel">
                            <views:BulkInvoiceAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:InvoicePdfAvaloniaViewModel">
                            <views:InvoicePdfAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:InvoiceProviderSettingsAvaloniaViewModel">
                            <views:InvoiceProviderSettingsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:InvoiceReportAvaloniaViewModel">
                            <views:InvoiceReportAvaloniaView />
                        </DataTemplate>
                        <!-- ERP Settings -->
                        <DataTemplate DataType="vm:ErpSettingsAvaloniaViewModel">
                            <views:ErpSettingsAvaloniaView />
                        </DataTemplate>
                        <!-- EMR-10 Platform + Dropshipping views -->
                        <DataTemplate DataType="vm:PlatformListAvaloniaViewModel">
                            <views:PlatformListAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:StoreWizardAvaloniaViewModel">
                            <views:StoreWizardAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:CategoryMappingAvaloniaViewModel">
                            <views:CategoryMappingAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:DropshipDashboardAvaloniaViewModel">
                            <views:DropshipDashboardAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:FeedPreviewAvaloniaViewModel">
                            <views:FeedPreviewAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:StoreSettingsAvaloniaViewModel">
                            <views:StoreSettingsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:StoreDetailAvaloniaViewModel">
                            <views:StoreDetailAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ProductFetchAvaloniaViewModel">
                            <views:ProductFetchAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SupplierFeedListAvaloniaViewModel">
                            <views:SupplierFeedListAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:FeedCreateAvaloniaViewModel">
                            <views:FeedCreateAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:DropshipOrdersAvaloniaViewModel">
                            <views:DropshipOrdersAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:DropshipProfitAvaloniaViewModel">
                            <views:DropshipProfitAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ImportSettingsAvaloniaViewModel">
                            <views:ImportSettingsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:PlatformSyncStatusAvaloniaViewModel">
                            <views:PlatformSyncStatusAvaloniaView />
                        </DataTemplate>
                        <!-- İ-05 Siparis/Kargo Celiklestirme views -->
                        <DataTemplate DataType="vm:BulkShipmentAvaloniaViewModel">
                            <views:BulkShipmentAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ReturnListAvaloniaViewModel">
                            <views:ReturnListAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ReturnDetailAvaloniaViewModel">
                            <views:ReturnDetailAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LabelPreviewAvaloniaViewModel">
                            <views:LabelPreviewAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:CargoProvidersAvaloniaViewModel">
                            <views:CargoProvidersAvaloniaView />
                        </DataTemplate>
                        <!-- FIX-18 Gorev #13: Buybox Analizi -->
                        <DataTemplate DataType="vm:BuyboxAvaloniaViewModel">
                            <views:BuyboxAvaloniaView />
                        </DataTemplate>
                        <!-- V4 — Muhasebe + İzleme + Kanban -->
                        <DataTemplate DataType="acctvm:JournalEntryListViewModel">
                            <acctviews:JournalEntryListView />
                        </DataTemplate>
                        <DataTemplate DataType="acctvm:TrialBalanceViewModel">
                            <acctviews:TrialBalanceView />
                        </DataTemplate>
                        <DataTemplate DataType="acctvm:CommissionRatesViewModel">
                            <acctviews:CommissionRatesView />
                        </DataTemplate>
                        <DataTemplate DataType="monvm:StaleOrdersAvaloniaViewModel">
                            <monviews:StaleOrdersAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="ordvm:OrderKanbanViewModel">
                            <ordviews:OrderKanbanView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </DockPanel>

        </Grid>

    </DockPanel>
</Window>
