<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MesTech.Avalonia.ViewModels"
        xmlns:views="using:MesTech.Avalonia.Views"
        xmlns:wpfvm="using:MesTechStok.Desktop.ViewModels.Finance"
        x:Class="MesTech.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MesTech Entegratör"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Styles>
        <!-- Sidebar button style -->
        <Style Selector="Button.sidebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Button.sidebar-btn:pointerover">
            <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}" />
            <Setter Property="Foreground" Value="{StaticResource SidebarTextActiveBrush}" />
        </Style>
        <!-- Icon button style (toolbar) -->
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="{StaticResource HoverOverlayBrush}" />
        </Style>
        <!-- Sidebar section header -->
        <Style Selector="TextBlock.sidebar-section">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="Margin" Value="16,14,0,6" />
        </Style>
        <!-- Disabled sidebar item -->
        <Style Selector="Button.sidebar-disabled">
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Opacity" Value="0.4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- ═══ TOOLBAR (UST) ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceBrush}"
                Height="52"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Sol: Sidebar toggle + Baslik -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <Button x:Name="SidebarToggleBtn" Classes="icon-btn"
                            Click="OnSidebarToggle">
                        <PathIcon Data="{StaticResource IconMenu}" Width="20" Height="20"/>
                    </Button>
                    <TextBlock Text="MesTech Entegratör"
                               FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Orta: Arama -->
                <TextBox Grid.Column="1"
                         Watermark="Ara..."
                         MaxWidth="400" Margin="24,0"
                         VerticalAlignment="Center"
                         FontSize="{StaticResource FontSizeBody}"/>

                <!-- Sag: Saat + Bildirim + Profil -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0" Spacing="4">
                    <TextBlock x:Name="ToolbarClock" Text="00:00"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Classes="icon-btn">
                        <PathIcon Data="{StaticResource IconNotification}" Width="18" Height="18"/>
                    </Button>
                    <Button Classes="icon-btn">
                        <PathIcon Data="{StaticResource IconPerson}" Width="18" Height="18"/>
                    </Button>
                    <TextBlock Text="Admin"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ STATUSBAR (ALT) ═══ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                Height="30"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}"/>
                    <TextBlock Text="Bağlı" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource SuccessBrush}"/>
                    <TextBlock Text="|" Foreground="{StaticResource BorderBrush}"/>
                    <TextBlock Text="PostgreSQL 17" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="v1.0.0" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="|" Foreground="{StaticResource BorderBrush}"/>
                    <TextBlock x:Name="StatusUser" Text="admin"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SIDEBAR (SOL) + CONTENT (ORTA) ═══ -->
        <Grid ColumnDefinitions="Auto,*">

            <!-- SIDEBAR -->
            <Border x:Name="SidebarPanel" Grid.Column="0" Width="240"
                    Background="{StaticResource SidebarBackgroundBrush}">
                <DockPanel>

                    <!-- Sidebar ust: MesTech mini logo -->
                    <Border DockPanel.Dock="Top" Height="48" Padding="16,0"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <PathIcon Data="{StaticResource IconMenu}"
                                      Foreground="{StaticResource SidebarTextActiveBrush}"
                                      Width="16" Height="16"/>
                            <TextBlock x:Name="SidebarTitle" Text="MesTech"
                                       Foreground="{StaticResource SidebarTextActiveBrush}"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Sidebar alt: Footer -->
                    <Border DockPanel.Dock="Bottom" Padding="16,10"
                            BorderBrush="{StaticResource SidebarBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <TextBlock Text="Dalga 14+15 — Avalonia Shell" FontSize="10"
                                   Foreground="#475569"/>
                    </Border>

                    <!-- Sidebar menu — ScrollViewer icinde -->
                    <ScrollViewer>
                        <StackPanel Margin="0,4" Spacing="1">

                            <!-- 1. DASHBOARD -->
                            <TextBlock Classes="sidebar-section" Text="DASHBOARD"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Dashboard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Kontrol Paneli"/>
                                </StackPanel>
                            </Button>

                            <!-- 2. URUNLER -->
                            <TextBlock Classes="sidebar-section" Text="ÜRÜNLER"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Products">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16"/>
                                    <TextBlock Text="Ürün Listesi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-disabled">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconUpload}" Width="16" Height="16"/>
                                    <TextBlock Text="Toplu İçe Aktarma (Yakında)"/>
                                </StackPanel>
                            </Button>

                            <!-- 3. SIPARISLER -->
                            <TextBlock Classes="sidebar-section" Text="SİPARİŞLER"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Orders">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconShoppingCart}" Width="16" Height="16"/>
                                    <TextBlock Text="Siparişler"/>
                                </StackPanel>
                            </Button>

                            <!-- 4. STOK -->
                            <TextBlock Classes="sidebar-section" Text="STOK"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Stock">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Takibi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Inventory">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarcode}" Width="16" Height="16"/>
                                    <TextBlock Text="Envanter"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="StockMovement">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Güncelleme"/>
                                </StackPanel>
                            </Button>

                            <!-- 5. KATEGORILER -->
                            <TextBlock Classes="sidebar-section" Text="KATEGORİLER"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Category">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconCategory}" Width="16" Height="16"/>
                                    <TextBlock Text="Kategoriler"/>
                                </StackPanel>
                            </Button>

                            <!-- 6. KARGO -->
                            <TextBlock Classes="sidebar-section" Text="KARGO"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CargoTracking">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconTruck}" Width="16" Height="16"/>
                                    <TextBlock Text="Kargo Takip"/>
                                </StackPanel>
                            </Button>

                            <!-- 7. E-FATURA -->
                            <TextBlock Classes="sidebar-section" Text="E-FATURA"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceManagement">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Yönetimi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceList">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Listesi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceCreate">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconAdd}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Oluştur"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="BulkInvoice">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Toplu Fatura"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceProviders">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="Provider Ayarları"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceReport">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Raporları"/>
                                </StackPanel>
                            </Button>

                            <!-- 8. FINANS -->
                            <TextBlock Classes="sidebar-section" Text="FİNANS"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ProfitLoss">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Kâr / Zarar Raporu"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Expenses">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Giderler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="BankAccounts">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSave}" Width="16" Height="16"/>
                                    <TextBlock Text="Banka Hesapları"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CariHesaplar">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Cari Hesaplar"/>
                                </StackPanel>
                            </Button>

                            <!-- 9. CRM -->
                            <TextBlock Classes="sidebar-section" Text="CRM"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Leads">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Potansiyel Müşteriler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Contacts">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Kişiler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Kanban">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Fırsatlar — Kanban"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Customers">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Müşteriler"/>
                                </StackPanel>
                            </Button>

                            <!-- 10. PLATFORM -->
                            <TextBlock Classes="sidebar-section" Text="PLATFORM"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="PlatformList">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Platformlar"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="StoreWizard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconAdd}" Width="16" Height="16"/>
                                    <TextBlock Text="Mağaza Ekle"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="StoreSettings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="Mağaza Ayarları"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CategoryMapping">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconCategory}" Width="16" Height="16"/>
                                    <TextBlock Text="Kategori Eşleştirme"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="PlatformSyncStatus">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                                    <TextBlock Text="Sync Durumu"/>
                                </StackPanel>
                            </Button>

                            <!-- 10b. DROPSHIPPING -->
                            <TextBlock Classes="sidebar-section" Text="DROPSHİPPİNG"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="DropshipDashboard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Dropship Paneli"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="DropshipOrders">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconShoppingCart}" Width="16" Height="16"/>
                                    <TextBlock Text="Dropship Siparişler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="DropshipProfit">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Kârlılık Analizi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="SupplierFeeds">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconUpload}" Width="16" Height="16"/>
                                    <TextBlock Text="Tedarikçi Feed'leri"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="FeedCreate">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconAdd}" Width="16" Height="16"/>
                                    <TextBlock Text="Yeni Feed"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ImportSettings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="İçe Aktarma Ayarları"/>
                                </StackPanel>
                            </Button>

                            <!-- 11. RAPORLAR -->
                            <TextBlock Classes="sidebar-section" Text="RAPORLAR"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Documents">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconCopy}" Width="16" Height="16"/>
                                    <TextBlock Text="Belgeler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Reports">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Raporlar"/>
                                </StackPanel>
                            </Button>

                            <!-- 12. AYARLAR -->
                            <TextBlock Classes="sidebar-section" Text="AYARLAR"/>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Settings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="Ayarlar"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ErpSettings">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="ERP Ayarlari"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Marketplaces">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconShoppingCart}" Width="16" Height="16"/>
                                    <TextBlock Text="Pazaryerleri"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="SyncStatus">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                                    <TextBlock Text="Platform Senkronizasyon"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Employees">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Çalışanlar"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="LeaveRequests">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconHome}" Width="16" Height="16"/>
                                    <TextBlock Text="İzin Talepleri"/>
                                </StackPanel>
                            </Button>

                            <!-- Cikis -->
                            <Border Height="1" Background="{StaticResource SidebarBorderBrush}" Margin="16,8"/>
                            <Button Classes="sidebar-btn" x:Name="LogoutBtn" Click="OnLogout">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconLogout}" Width="16" Height="16"/>
                                    <TextBlock Text="Çıkış"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>

                </DockPanel>
            </Border>

            <!-- CONTENT AREA -->
            <DockPanel Grid.Column="1">
                <!-- Content Header -->
                <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                        Padding="24,14"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding CurrentViewTitle}"
                               FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>

                <!-- Dynamic Content -->
                <ContentControl Content="{Binding CurrentView}" Margin="0">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:DashboardAvaloniaViewModel">
                            <views:DashboardAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LeadsAvaloniaViewModel">
                            <views:LeadsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:KanbanAvaloniaViewModel">
                            <views:KanbanAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ProductsAvaloniaViewModel">
                            <views:ProductsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="wpfvm:ProfitLossViewModel">
                            <views:ProfitLossAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:StockAvaloniaViewModel">
                            <views:StockAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:OrdersAvaloniaViewModel">
                            <views:OrdersAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsAvaloniaViewModel">
                            <views:SettingsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LoginAvaloniaViewModel">
                            <views:LoginAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:CategoryAvaloniaViewModel">
                            <views:CategoryAvaloniaView />
                        </DataTemplate>
                        <!-- Dalga 11 batch expansion -->
                        <DataTemplate DataType="vm:ContactsAvaloniaViewModel">
                            <views:ContactsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:EmployeesAvaloniaViewModel">
                            <views:EmployeesAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LeaveRequestsAvaloniaViewModel">
                            <views:LeaveRequestsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:DocumentsAvaloniaViewModel">
                            <views:DocumentsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ReportsAvaloniaViewModel">
                            <views:ReportsAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:MarketplacesAvaloniaViewModel">
                            <views:MarketplacesAvaloniaView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:ExpensesAvaloniaViewModel">
                            <views:ExpensesAvaloniaView />
                        </DataTemplate>
