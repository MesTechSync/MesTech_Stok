<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MesTech.Avalonia.ViewModels"
        xmlns:views="using:MesTech.Avalonia.Views"
        xmlns:wpfvm="using:MesTechStok.Desktop.ViewModels.Finance"
        x:Class="MesTech.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MesTech Stok — Avalonia PoC"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <!-- Sidebar button style -->
        <Style Selector="Button.sidebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CBD5E1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Button.sidebar-btn:pointerover">
            <Setter Property="Background" Value="#334155" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="240,*">

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1E293B">
            <DockPanel>
                <!-- Logo / App Title -->
                <Border DockPanel.Dock="Top" Padding="20,20,20,16"
                        BorderBrush="#334155" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="MesTech Stok" FontSize="20" FontWeight="Bold"
                                   Foreground="White" />
                        <TextBlock Text="Avalonia PoC" FontSize="12"
                                   Foreground="#64748B" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Navigation Buttons — 12 Standard Groups -->
                <ScrollViewer DockPanel.Dock="Top">
                <StackPanel Margin="0,8">

                    <!-- 1. DASHBOARD -->
                    <TextBlock Text="DASHBOARD" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,8,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Kontrol Paneli"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Dashboard" />

                    <!-- 2. URUNLER -->
                    <TextBlock Text="URUNLER" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Urunler"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Products" />

                    <Button IsEnabled="False" Opacity="0.5"
                            Padding="20,12" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Background="Transparent"
                            Foreground="#CBD5E1" FontSize="14">
                        <TextBlock Text="Toplu Urun Guncelleme (Yakinda)"/>
                    </Button>

                    <Button IsEnabled="False" Opacity="0.5"
                            Padding="20,12" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Background="Transparent"
                            Foreground="#CBD5E1" FontSize="14">
                        <TextBlock Text="Urun Varyantlari (Yakinda)"/>
                    </Button>

                    <!-- 3. SIPARISLER -->
                    <TextBlock Text="SIPARISLER" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Siparisler"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Orders" />

                    <!-- 4. STOK -->
                    <TextBlock Text="STOK" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Stok Yonetimi"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Stock" />

                    <Button Classes="sidebar-btn"
                            Content="Stok Guncelleme"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="StockMovement" />

                    <Button Classes="sidebar-btn"
                            Content="Envanter"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Inventory" />

                    <!-- 5. KATEGORILER -->
                    <TextBlock Text="KATEGORILER" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Kategoriler"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Category" />

                    <Button IsEnabled="False" Opacity="0.5"
                            Padding="20,12" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Background="Transparent"
                            Foreground="#CBD5E1" FontSize="14">
                        <TextBlock Text="Kategori Eslestirme (Yakinda)"/>
                    </Button>

                    <!-- 6. KARGO -->
                    <TextBlock Text="KARGO" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Kargo Takip"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="CargoTracking" />

                    <Button IsEnabled="False" Opacity="0.5"
                            Padding="20,12" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Background="Transparent"
                            Foreground="#CBD5E1" FontSize="14">
                        <TextBlock Text="Kargo Entegrasyonu (Yakinda)"/>
                    </Button>

                    <!-- 7. E-FATURA -->
                    <TextBlock Text="E-FATURA" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="e-Fatura Yonetimi"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="InvoiceManagement" />

                    <Button IsEnabled="False" Opacity="0.5"
                            Padding="20,12" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Background="Transparent"
                            Foreground="#CBD5E1" FontSize="14">
                        <TextBlock Text="e-Arsiv (Yakinda)"/>
                    </Button>

                    <!-- 8. FINANS -->
                    <TextBlock Text="FINANS" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Kar / Zarar Raporu"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="ProfitLoss" />

                    <Button Classes="sidebar-btn"
                            Content="Giderler"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Expenses" />

                    <Button Classes="sidebar-btn"
                            Content="Banka Hesaplari"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="BankAccounts" />

                    <Button Classes="sidebar-btn"
                            Content="Cari Hesaplar"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="CariHesaplar" />

                    <!-- 9. CRM -->
                    <TextBlock Text="CRM" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Potansiyel Musteriler"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Leads" />

                    <Button Classes="sidebar-btn"
                            Content="Kisiler"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Contacts" />

                    <Button Classes="sidebar-btn"
                            Content="Firsatlar — Kanban"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Kanban" />

                    <Button Classes="sidebar-btn"
                            Content="Musteriler"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Customers" />

                    <!-- 10. DROPSHIPPING -->
                    <TextBlock Text="DROPSHIPPING" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button IsEnabled="False" Opacity="0.5"
                            Padding="20,12" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" Background="Transparent"
                            Foreground="#CBD5E1" FontSize="14">
                        <TextBlock Text="Dropshipping (Yakinda)"/>
                    </Button>

                    <!-- 11. RAPORLAR -->
                    <TextBlock Text="RAPORLAR" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Belgeler"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Documents" />

                    <Button Classes="sidebar-btn"
                            Content="Raporlar"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Reports" />

                    <!-- 12. AYARLAR -->
                    <TextBlock Text="AYARLAR" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="20,16,0,8" />

                    <Button Classes="sidebar-btn"
                            Content="Ayarlar"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Settings" />

                    <Button Classes="sidebar-btn"
                            Content="Pazaryerleri"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Marketplaces" />

                    <Button Classes="sidebar-btn"
                            Content="Platform Senkronizasyon"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="SyncStatus" />

                    <Button Classes="sidebar-btn"
                            Content="Calisanlar"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Employees" />

                    <Button Classes="sidebar-btn"
                            Content="Izin Talepleri"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="LeaveRequests" />

                    <Button Classes="sidebar-btn"
                            Content="Giris"
                            Command="{Binding NavigateToCommand}"
                            CommandParameter="Login" />

                </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom" Padding="20,12"
                        BorderBrush="#334155" BorderThickness="0,1,0,0">
                    <TextBlock Text="Dalga 11 — Avalonia Expansion" FontSize="11"
                               Foreground="#475569" />
                </Border>

                <!-- Spacer -->
                <Panel />
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <DockPanel Grid.Column="1" Background="#F8FAFC">
            <!-- Content Header -->
            <Border DockPanel.Dock="Top" Background="White" Padding="24,16"
                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding CurrentViewTitle}"
                           FontSize="20" FontWeight="SemiBold" Foreground="#1E293B" />
            </Border>

            <!-- Dynamic Content -->
            <ContentControl Content="{Binding CurrentView}" Margin="0">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vm:DashboardAvaloniaViewModel">
                        <views:DashboardAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:LeadsAvaloniaViewModel">
                        <views:LeadsAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:KanbanAvaloniaViewModel">
                        <views:KanbanAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:ProductsAvaloniaViewModel">
                        <views:ProductsAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="wpfvm:ProfitLossViewModel">
                        <views:ProfitLossAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:StockAvaloniaViewModel">
                        <views:StockAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:OrdersAvaloniaViewModel">
                        <views:OrdersAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:SettingsAvaloniaViewModel">
                        <views:SettingsAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:LoginAvaloniaViewModel">
                        <views:LoginAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:CategoryAvaloniaViewModel">
                        <views:CategoryAvaloniaView />
                    </DataTemplate>
                    <!-- Dalga 11 batch expansion -->
                    <DataTemplate DataType="vm:ContactsAvaloniaViewModel">
                        <views:ContactsAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:EmployeesAvaloniaViewModel">
                        <views:EmployeesAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:LeaveRequestsAvaloniaViewModel">
                        <views:LeaveRequestsAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:DocumentsAvaloniaViewModel">
                        <views:DocumentsAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:ReportsAvaloniaViewModel">
                        <views:ReportsAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:MarketplacesAvaloniaViewModel">
                        <views:MarketplacesAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:ExpensesAvaloniaViewModel">
                        <views:ExpensesAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:BankAccountsAvaloniaViewModel">
                        <views:BankAccountsAvaloniaView />
                    </DataTemplate>
                    <!-- Dalga 14+15 functional views -->
                    <DataTemplate DataType="vm:InventoryAvaloniaViewModel">
                        <views:InventoryAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:InvoiceManagementAvaloniaViewModel">
                        <views:InvoiceManagementAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:CustomerAvaloniaViewModel">
                        <views:CustomerAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:CariHesaplarAvaloniaViewModel">
                        <views:CariHesaplarAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:SyncStatusAvaloniaViewModel">
                        <views:SyncStatusAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:StockMovementAvaloniaViewModel">
                        <views:StockMovementAvaloniaView />
                    </DataTemplate>
                    <DataTemplate DataType="vm:CargoTrackingAvaloniaViewModel">
                        <views:CargoTrackingAvaloniaView />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </DockPanel>
    </Grid>
</Window>
