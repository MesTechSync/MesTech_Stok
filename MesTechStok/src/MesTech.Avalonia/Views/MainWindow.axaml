<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MesTech.Avalonia.ViewModels"
        xmlns:views="using:MesTech.Avalonia.Views"
        xmlns:acctvm="using:MesTech.Avalonia.ViewModels.Accounting"
        xmlns:monvm="using:MesTech.Avalonia.ViewModels.Monitoring"
        xmlns:ordvm="using:MesTech.Avalonia.ViewModels.Orders"
        xmlns:acctviews="using:MesTech.Avalonia.Views.Accounting"
        xmlns:monviews="using:MesTech.Avalonia.Views.Monitoring"
        xmlns:ordviews="using:MesTech.Avalonia.Views.Orders"
        xmlns:erpvm="using:MesTech.Avalonia.ViewModels.Erp"
        xmlns:erpviews="using:MesTech.Avalonia.Views.Erp"
        xmlns:fulfillviews="using:MesTech.Avalonia.Views.Fulfillment"
        xmlns:rptviews="using:MesTech.Avalonia.Views.Reports"
        xmlns:controls="using:MesTech.Avalonia.Controls"
        x:Class="MesTech.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="MesTech Entegratör"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="700"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Styles>
        <!-- Sidebar button style -->
        <Style Selector="Button.sidebar-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Button.sidebar-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextActiveBrush}" />
        </Style>
        <!-- Active sidebar item (selected page) -->
        <Style Selector="Button.sidebar-btn-active">
            <Setter Property="Background" Value="{DynamicResource MesPrimaryBlue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
        <Style Selector="Button.sidebar-btn-active:pointerover">
            <Setter Property="Background" Value="{DynamicResource MesPrimaryBlue}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <!-- Icon button style (toolbar) -->
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverOverlayBrush}" />
        </Style>
        <!-- Sidebar section header -->
        <Style Selector="TextBlock.sidebar-section">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource MesSlateGray}" />
            <Setter Property="Margin" Value="16,14,0,6" />
        </Style>
        <!-- Disabled sidebar item -->
        <Style Selector="Button.sidebar-disabled">
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Opacity" Value="0.4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SidebarTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- ═══ TOOLBAR (UST) ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                Height="52"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Sol: Sidebar toggle + Baslik -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <Button x:Name="SidebarToggleBtn" Classes="icon-btn"
                            ToolTip.Tip="MesTech Entegrator"
                            Click="OnSidebarToggle">
                        <PathIcon Data="{StaticResource IconMenu}" Width="20" Height="20"/>
                    </Button>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="MesTech Entegratör"
                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <!-- DEV2-03: Breadcrumb -->
                        <TextBlock Text="{Binding Breadcrumb}"
                                   FontSize="11"
                                   Foreground="{DynamicResource MesSlateGray}"
                                   Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Orta: Arama -->
                <TextBox Grid.Column="1"
                         Watermark="Ara..." AutomationProperties.Name="Ara..."
                         MaxWidth="400" Margin="24,0"
                         VerticalAlignment="Center"
                         FontSize="{StaticResource FontSizeBody}"/>

                <!-- Sag: Saat + Bildirim + Profil -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0" Spacing="4">
                    <!-- G091/G109: Plan tier badge -->
                    <controls:PlanBadgeControl Margin="0,0,8,0" />
                    <TextBlock x:Name="ToolbarClock" Text="00:00"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Classes="icon-btn" ToolTip.Tip="Bildirimler">
                        <PathIcon Data="{StaticResource IconNotification}" Width="18" Height="18"/>
                    </Button>
                    <Button Classes="icon-btn" ToolTip.Tip="Profil">
                        <PathIcon Data="{StaticResource IconPerson}" Width="18" Height="18"/>
                    </Button>
                    <TextBlock Text="Admin"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ STATUSBAR (ALT) ═══ -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                Height="30"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="Bağlı" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="PostgreSQL 17" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="v1.0.0" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="StatusUser" Text="admin"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SIDEBAR (SOL) + CONTENT (ORTA) ═══ -->
        <Grid ColumnDefinitions="Auto,*">

            <!-- SIDEBAR -->
            <Border x:Name="SidebarPanel" Grid.Column="0" Width="60"
                    Background="{DynamicResource SidebarBackgroundBrush}">
                <DockPanel>

                    <!-- Sidebar ust: MesTech mini logo -->
                    <Border DockPanel.Dock="Top" Height="48" Padding="16,0"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <PathIcon Data="{StaticResource IconMenu}"
                                      Foreground="{DynamicResource SidebarTextActiveBrush}"
                                      Width="16" Height="16"/>
                            <TextBlock x:Name="SidebarTitle" Text="MesTech"
                                       Foreground="{DynamicResource SidebarTextActiveBrush}"
                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       IsVisible="False"/>
                        </StackPanel>
                    </Border>

                    <!-- Sidebar alt: Footer -->
                    <Border x:Name="SidebarFooter" DockPanel.Dock="Bottom" Padding="16,10"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="0,1,0,0"
                            IsVisible="False">
                        <TextBlock Text="Dalga 14+15 — Avalonia Shell" FontSize="{StaticResource FontSizeCaption1}"
                                   Foreground="{DynamicResource MesTextSlate}"/>
                    </Border>

                    <!-- Sidebar menu — ScrollViewer icinde -->
                    <ScrollViewer x:Name="SidebarScroll">
                        <StackPanel Margin="0,4" Spacing="1">

                            <!-- 0. ANA SAYFA -->
                            <TextBlock Classes="sidebar-section" Text="ANA SAYFA"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Ana Sayfa Hub — gunluk ozet + hizli aksiyonlar"
                                    AutomationProperties.Name="Ana Sayfa Hub — gunluk ozet + hizli aksiyonlar"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="AppHub">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconHome}" Width="16" Height="16"/>
                                    <TextBlock Text="Ana Sayfa" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <!-- 1. DASHBOARD -->
                            <TextBlock Classes="sidebar-section" Text="DASHBOARD"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kontrol Paneli"
                                    AutomationProperties.Name="Kontrol Paneli"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Dashboard">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDashboard}" Width="16" Height="16"/>
                                    <TextBlock Text="Kontrol Paneli"/>
                                </StackPanel>
                            </Button>

                            <!-- 2. URUNLER -->
                            <TextBlock Classes="sidebar-section" Text="ÜRÜNLER"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Urun Listesi"
                                    AutomationProperties.Name="Urun Listesi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Products">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16"/>
                                    <TextBlock Text="Ürün Listesi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Toplu Ice Aktarma"
                                    AutomationProperties.Name="Toplu Ice Aktarma"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ImportProducts">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconUpload}" Width="16" Height="16"/>
                                    <TextBlock Text="Toplu İçe Aktarma"/>
                                </StackPanel>
                            </Button>

                            <!-- 3. SIPARISLER -->
                            <TextBlock Classes="sidebar-section" Text="SİPARİŞLER"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Siparisler"
                                    AutomationProperties.Name="Siparisler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Orders">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconShoppingCart}" Width="16" Height="16"/>
                                    <TextBlock Text="Siparişler"/>
                                </StackPanel>
                            </Button>

                            <!-- 4. STOK -->
                            <TextBlock Classes="sidebar-section" Text="STOK"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Stok Takibi"
                                    AutomationProperties.Name="Stok Takibi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Stock">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconInventory}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Takibi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Envanter"
                                    AutomationProperties.Name="Envanter"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Inventory">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarcode}" Width="16" Height="16"/>
                                    <TextBlock Text="Envanter"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Stok Guncelleme"
                                    AutomationProperties.Name="Stok Guncelleme"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="StockMovement">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Güncelleme"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn" ToolTip.Tip="Stok Yerlesim" AutomationProperties.Name="Stok Yerlesim"
                                    Command="{Binding NavigateToCommand}" CommandParameter="StockPlacement">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconStar}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Yerlesim"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn" ToolTip.Tip="Lot Ekleme" AutomationProperties.Name="Lot Ekleme"
                                    Command="{Binding NavigateToCommand}" CommandParameter="StockLot">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconStar}" Width="16" Height="16"/>
                                    <TextBlock Text="Lot Ekleme"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn" ToolTip.Tip="Depolar Arasi Transfer" AutomationProperties.Name="Depolar Arasi Transfer"
                                    Command="{Binding NavigateToCommand}" CommandParameter="StockTransfer">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconStar}" Width="16" Height="16"/>
                                    <TextBlock Text="Depolar Arasi Transfer"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn" ToolTip.Tip="Stok Uyarilari" AutomationProperties.Name="Stok Uyarilari"
                                    Command="{Binding NavigateToCommand}" CommandParameter="StockAlert">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconStar}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Uyarilari"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn" ToolTip.Tip="Depo Yonetimi" AutomationProperties.Name="Depo Yonetimi"
                                    Command="{Binding NavigateToCommand}" CommandParameter="Warehouse">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconStar}" Width="16" Height="16"/>
                                    <TextBlock Text="Depo Yonetimi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn" ToolTip.Tip="Stok Hareket Geçmişi" AutomationProperties.Name="Stok Hareket Geçmişi"
                                    Command="{Binding NavigateToCommand}" CommandParameter="StockTimeline">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDocument}" Width="16" Height="16"/>
                                    <TextBlock Text="Stok Hareket Geçmişi"/>
                                </StackPanel>
                            </Button>

                            <!-- 5. KATEGORILER -->
                            <TextBlock Classes="sidebar-section" Text="KATEGORİLER"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kategoriler"
                                    AutomationProperties.Name="Kategoriler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Category">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconCategory}" Width="16" Height="16"/>
                                    <TextBlock Text="Kategoriler"/>
                                </StackPanel>
                            </Button>

                            <!-- 6. KARGO [Pro+] -->
                            <TextBlock Classes="sidebar-section" Text="KARGO"
                                       IsVisible="{Binding ShowCargo}"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kargo Takip"
                                    AutomationProperties.Name="Kargo Takip"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CargoTracking"
                                    IsVisible="{Binding ShowCargo}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconTruck}" Width="16" Height="16"/>
                                    <TextBlock Text="Kargo Takip"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kargo Firmalari"
                                    AutomationProperties.Name="Kargo Firmalari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CargoProviders"
                                    IsVisible="{Binding ShowCargo}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconTruck}" Width="16" Height="16"/>
                                    <TextBlock Text="Kargo Firmalari"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Toplu Gonderim"
                                    AutomationProperties.Name="Toplu Gonderim"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="BulkShipment"
                                    IsVisible="{Binding ShowCargo}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconTruck}" Width="16" Height="16"/>
                                    <TextBlock Text="Toplu Gonderim"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Etiket Yazdir"
                                    AutomationProperties.Name="Etiket Yazdir"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="LabelPreview"
                                    IsVisible="{Binding ShowCargo}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPrint}" Width="16" Height="16"/>
                                    <TextBlock Text="Etiket Yazdir"/>
                                </StackPanel>
                            </Button>

                            <!-- IADELER -->
                            <TextBlock Classes="sidebar-section" Text="IADELER"
                                       IsVisible="{Binding ShowCargo}"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Iade Listesi"
                                    AutomationProperties.Name="Iade Listesi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ReturnList"
                                    IsVisible="{Binding ShowCargo}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/>
                                    <TextBlock Text="Iade Listesi"/>
                                </StackPanel>
                            </Button>

                            <!-- 7. E-FATURA [Pro+] -->
                            <TextBlock Classes="sidebar-section" Text="E-FATURA"
                                       IsVisible="{Binding ShowInvoice}"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fatura Yonetimi"
                                    AutomationProperties.Name="Fatura Yonetimi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceManagement"
                                    IsVisible="{Binding ShowInvoice}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Yönetimi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fatura Listesi"
                                    AutomationProperties.Name="Fatura Listesi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceList"
                                    IsVisible="{Binding ShowInvoice}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Listesi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fatura Olustur"
                                    AutomationProperties.Name="Fatura Olustur"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceCreate"
                                    IsVisible="{Binding ShowInvoice}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconAdd}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Oluştur"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Toplu Fatura"
                                    AutomationProperties.Name="Toplu Fatura"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="BulkInvoice"
                                    IsVisible="{Binding ShowInvoice}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconReceipt}" Width="16" Height="16"/>
                                    <TextBlock Text="Toplu Fatura"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Provider Ayarlari"
                                    AutomationProperties.Name="Provider Ayarlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceProviders"
                                    IsVisible="{Binding ShowInvoice}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSettings}" Width="16" Height="16"/>
                                    <TextBlock Text="Provider Ayarları"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Fatura Raporlari"
                                    AutomationProperties.Name="Fatura Raporlari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="InvoiceReport"
                                    IsVisible="{Binding ShowInvoice}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Fatura Raporları"/>
                                </StackPanel>
                            </Button>

                            <!-- 8. FINANS -->
                            <TextBlock Classes="sidebar-section" Text="FİNANS"
                                       IsVisible="{Binding ShowReports}"/>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Kar / Zarar Raporu"
                                    AutomationProperties.Name="Kar / Zarar Raporu"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="ProfitLoss"
                                    IsVisible="{Binding ShowReports}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Kâr / Zarar Raporu"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Giderler"
                                    AutomationProperties.Name="Giderler"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Expenses"
                                    IsVisible="{Binding ShowReports}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Giderler"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Banka Hesaplari"
                                    AutomationProperties.Name="Banka Hesaplari"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="BankAccounts"
                                    IsVisible="{Binding ShowReports}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconSave}" Width="16" Height="16"/>
                                    <TextBlock Text="Banka Hesapları"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Cari Hesaplar"
                                    AutomationProperties.Name="Cari Hesaplar"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="CariHesaplar"
                                    IsVisible="{Binding ShowReports}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconPerson}" Width="16" Height="16"/>
                                    <TextBlock Text="Cari Hesaplar"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Nakit Akisi"
                                    AutomationProperties.Name="Nakit Akisi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="NakitAkis"
                                    IsVisible="{Binding ShowReports}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Nakit Akışı"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Teklif Yonetimi"
                                    AutomationProperties.Name="Teklif Yonetimi"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Quotation"
                                    IsVisible="{Binding ShowReports}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconDocument}" Width="16" Height="16"/>
                                    <TextBlock Text="Teklif Yönetimi"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn"
                                    ToolTip.Tip="Abonelik ve Faturalama"
                                    AutomationProperties.Name="Abonelik ve Faturalama"
                                    Command="{Binding NavigateToCommand}"
                                    CommandParameter="Billing"
                                    IsVisible="{Binding ShowReports}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <PathIcon Data="{StaticResource IconBarChart}" Width="16" Height="16"/>
                                    <TextBlock Text="Abonelik / Faturalama"/>
                                </StackPanel>
                            </Button>

