<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.OrdersAvaloniaView"
             x:DataType="vm:OrdersAvaloniaViewModel">

    <!-- Avalonia Orders — DataGrid with 15 demo orders + status filter -->

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Siparis Yonetimi" Foreground="White"
                               FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="10,4">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} siparis'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Row 1: Filters -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="280" Watermark="Siparis no veya musteri ara..."
                         Text="{Binding SearchText}" />
                <ComboBox Width="180"
                          ItemsSource="{Binding Statuses}"
                          SelectedItem="{Binding SelectedStatus}" />
            </StackPanel>
        </Border>

        <!-- Row 2: Orders DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Orders}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="White"
                  Margin="0"
                  IsVisible="{Binding !IsLoading}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderNo}" Width="160" />
                <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="120" />
                <DataGridTextColumn Header="Musteri" Binding="{Binding Customer}" Width="200" />
                <DataGridTextColumn Header="Tutar" Binding="{Binding Amount}" Width="150" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="130" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State: Orders -->
        <TextBlock Grid.Row="2"
                   Text="Kayıt bulunamadı"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,40"
                   Opacity="0.5"
                   FontSize="16"
                   IsVisible="{Binding !Orders.Count}" />

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Siparisler yukleniyor..."
                           FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#F5F7FA"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Kayit bulunamadi" FontSize="20"
                           HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,0,0,8" />
                <TextBlock Text="Arama kriterlerine uygun siparis bulunamadi"
                           FontSize="16" Foreground="#64748B"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#F5F7FA"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="#FFF3F3" CornerRadius="8" Padding="24" HorizontalAlignment="Center">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Hata Olustu" FontWeight="Bold" Foreground="#E74C3C" FontSize="16" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="14" Foreground="#666"
                                   TextWrapping="Wrap" MaxWidth="400" />
                        <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                                Command="{Binding RefreshCommand}"
                                Padding="16,6" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
