<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.OrdersAvaloniaView"
             x:DataType="vm:OrdersAvaloniaViewModel">

    <!-- Stub view for Orders management — Dalga 10 -->

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="#D97706" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Siparis Yonetimi"
                           Foreground="White" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#D97706" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Placeholder Content -->
        <Border Grid.Row="1" Background="#F8FAFC" Margin="24"
                CornerRadius="12" BorderBrush="#E0E6ED" BorderThickness="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <Border Background="#FFFBEB" CornerRadius="50" Width="80" Height="80"
                        HorizontalAlignment="Center">
                    <TextBlock Text="&#x1F4CB;" FontSize="36"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Siparis Yonetimi" FontSize="22" FontWeight="Bold"
                           Foreground="#1E293B" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Summary}" FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"
                           TextAlignment="Center" />
                <TextBlock Text="Platform siparisleri | Kargo takibi | Faturalama | Iade yonetimi"
                           FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Siparisler yukleniyor..."
                           FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#F5F7FA"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Siparis bulunamadi" FontSize="48"
                           HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8" />
                <TextBlock Text="Henuz siparis kaydedilmemis"
                           FontSize="16" Foreground="#6C757D"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#F5F7FA"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#DC3545"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="#DC3545"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
