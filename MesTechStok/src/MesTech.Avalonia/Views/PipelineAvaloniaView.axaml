<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.PipelineAvaloniaView"
             x:Name="RootPipelineAvaloniaView"
             x:DataType="vm:PipelineAvaloniaViewModel"
             AutomationProperties.Name="Satis Pipeline">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Pipeline" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} firsat'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalValue}" Foreground="{DynamicResource MesBgPrimary}"
                                   FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22" Spacing="16">

                <!-- Loading -->
                <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                           Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" Margin="0,20" />

                        <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

                <!-- Empty -->
                <TextBlock Text="Pipeline verisi bulunmuyor."
                           IsVisible="{Binding IsEmpty}" Foreground="{DynamicResource MesMutedGray}"
                           HorizontalAlignment="Center" Margin="0,40" FontSize="{StaticResource FontSizeBody}" />

                <!-- Pipeline Stages as horizontal bars -->
                <ItemsControl ItemsSource="{Binding Stages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PipelineStageVm">
                            <Border Margin="0,0,0,12" Padding="20" Background="{DynamicResource MesBgPrimary}"
                                    CornerRadius="{StaticResource MesRadiusMdLg}" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                    <!-- Color indicator -->
                                    <Border Grid.Column="0" Width="6" CornerRadius="3" Margin="0,0,16,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Color}" />
                                        </Border.Background>
                                    </Border>
                                    <!-- Stage info -->
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBodyLg}" />
                                        <TextBlock Text="{Binding DealCount, StringFormat='{}{0} firsat'}"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                    </StackPanel>
                                    <!-- Amount -->
                                    <TextBlock Grid.Column="2" Text="{Binding Amount}"
                                               FontWeight="Bold" FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesPrimaryBlue}"
                                               VerticalAlignment="Center" Margin="0,0,20,0" />
                                    <!-- Percentage -->
                                    <Border Grid.Column="3" CornerRadius="{StaticResource MesRadiusSm}" Padding="10,4"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Color}" Opacity="0.15" />
                                        </Border.Background>
                                        <TextBlock Text="{Binding Percentage, StringFormat='%{0}'}" FontWeight="Bold" FontSize="{StaticResource FontSizeCallout}">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding Color}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
<!-- Loading Skeleton -->        <Border Grid.Row="0" Grid.RowSpan="2"                Background="{DynamicResource MesBgPage}"                IsVisible="{Binding IsLoading}"                ZIndex="100">            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />        </Border>
    </Grid>
</UserControl>
