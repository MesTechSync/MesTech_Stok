<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="MesTech.Avalonia.Views.ImportProductsAvaloniaView"
             x:Name="ImportProductsAvaloniaView"
             x:DataType="vm:ImportProductsAvaloniaViewModel">

    <UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding LoadDataCommand}" />    </UserControl.KeyBindings>

    <!-- 4-Step Import Wizard: File Selection → Preview → Column Mapping → Import Progress -->

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource MesBgPage}">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Urun Iceri Aktarma" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH2}" FontWeight="Bold" VerticalAlignment="Center" />
                <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="10,4">
                    <TextBlock Text="{Binding StepTitle}" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Row 1: Step Indicators -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="20,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,*,*,*" HorizontalAlignment="Stretch">
                <!-- Step 1 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="{StaticResource MesRadiusLgXl}"
                            Background="{Binding Step1Color}">
                        <TextBlock Text="1" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                   FontSize="{StaticResource FontSizeCallout}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Dosya Secimi" VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{Binding Step1TextColor}" FontWeight="SemiBold" />
                </StackPanel>
                <!-- Step 2 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="{StaticResource MesRadiusLgXl}"
                            Background="{Binding Step2Color}">
                        <TextBlock Text="2" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                   FontSize="{StaticResource FontSizeCallout}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="On Izleme" VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{Binding Step2TextColor}" FontWeight="SemiBold" />
                </StackPanel>
                <!-- Step 3 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="{StaticResource MesRadiusLgXl}"
                            Background="{Binding Step3Color}">
                        <TextBlock Text="3" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                   FontSize="{StaticResource FontSizeCallout}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Kolon Eslestirme" VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{Binding Step3TextColor}" FontWeight="SemiBold" />
                </StackPanel>
                <!-- Step 4 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="{StaticResource MesRadiusLgXl}"
                            Background="{Binding Step4Color}">
                        <TextBlock Text="4" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                   FontSize="{StaticResource FontSizeCallout}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Aktarma" VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{Binding Step4TextColor}" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Step Content -->
        <Grid Grid.Row="2" Margin="20">

            <!-- Step 1: File Selection -->
            <Border IsVisible="{Binding IsStep1}" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                    Padding="32" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                    <!-- Drag-Drop Area -->
                    <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusLg}" Padding="48,32"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="2"
                            HorizontalAlignment="Stretch">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="Dosya Surukle-Birak" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                            <TextBlock Text="Excel (.xlsx, .xls) veya CSV dosyasi yukleyin"
                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="Maksimum 50.000 satir"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- File Dialog Button -->
                    <Button Content="Dosya Sec" Command="{Binding SelectFileCommand}"
                            ToolTip.Tip="Dosya Sec"
                            Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="24,12" CornerRadius="{StaticResource MesRadiusBase}" FontSize="{StaticResource FontSizeBody}"
                            HorizontalAlignment="Center" />

                    <!-- Selected File Info -->
                    <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusBase}" Padding="16,10"
                            IsVisible="{Binding HasFile}" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="Dosya:" FontWeight="SemiBold" Foreground="{DynamicResource MesGreen}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedFileName}" Foreground="{DynamicResource MesGreen}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding FileSizeText}" Foreground="{DynamicResource MesEmerald}" VerticalAlignment="Center" FontSize="{StaticResource FontSizeSmall}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Step 2: Preview -->
            <Grid IsVisible="{Binding IsStep2}" RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="8,8,0,0" Padding="16,12"
                        BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1,1,1,0">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Text="On Izleme (ilk 10 satir)" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                        <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="10,4">
                            <TextBlock Text="{Binding TotalRowCount, StringFormat='{}{0} satir'}"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesPrimaryBlue}" />
                        </Border>
                        <Border Background="{Binding ErrorCountBackground}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="10,4"
                                IsVisible="{Binding HasPreviewErrors}">
                            <TextBlock Text="{Binding ErrorRowCount, StringFormat='{}{0} hata'}"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesRedAlert}" />
                        </Border>
                    </StackPanel>
                </Border>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding PreviewRows}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                          IsReadOnly="True"
                          GridLinesVisibility="All"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource MesBorderMedium}"
                          Background="{DynamicResource MesBgPrimary}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Satir" Binding="{Binding RowNumber}" Width="60" />
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="80" />
                        <DataGridTextColumn Header="Kolon A" Binding="{Binding ColumnA}" Width="160" />
                        <DataGridTextColumn Header="Kolon B" Binding="{Binding ColumnB}" Width="160" />
                        <DataGridTextColumn Header="Kolon C" Binding="{Binding ColumnC}" Width="120" />
                        <DataGridTextColumn Header="Kolon D" Binding="{Binding ColumnD}" Width="120" />
                        <DataGridTextColumn Header="Kolon E" Binding="{Binding ColumnE}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
<!-- Empty State -->        <TextBlock Grid.Row="1" Text="Icerik bulunamadi"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !PreviewRows.Count}" />
                <Border Grid.Row="2" Background="{DynamicResource MesBgAmberLight}" CornerRadius="0,0,8,8" Padding="16,10"
                        BorderBrush="{DynamicResource MesBorderAmber}" BorderThickness="1,0,1,1"
                        IsVisible="{Binding HasPreviewErrors}">
                    <TextBlock Text="{Binding PreviewErrorSummary}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesAmberDark}" TextWrapping="Wrap" />
                </Border>
            </Grid>

            <!-- Step 3: Column Mapping -->
            <Border IsVisible="{Binding IsStep3}" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                    Padding="24" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                <ScrollViewer>
                    <StackPanel Spacing="16">
                        <TextBlock Text="Alan Eslestirme" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        <TextBlock Text="Kaynak dosyadaki kolonlari hedef sistem alanlarina esleyin"
                                   FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" />

                        <!-- Mapping Header -->
                        <Grid ColumnDefinitions="*,40,*" Margin="0,8,0,0">
                            <TextBlock Grid.Column="0" Text="Kaynak Kolon" FontWeight="SemiBold" Foreground="{DynamicResource MesTextSlate}" FontSize="{StaticResource FontSizeSmall}" />
                            <TextBlock Grid.Column="2" Text="Hedef Alan" FontWeight="SemiBold" Foreground="{DynamicResource MesTextSlate}" FontSize="{StaticResource FontSizeSmall}" />
                        </Grid>

                        <!-- Mapping Rows -->
                        <ItemsControl ItemsSource="{Binding FieldMappings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ImportColumnMappingDto">
                                    <Grid ColumnDefinitions="*,40,*" Margin="0,4">
                                        <Border Grid.Column="0" Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusBase}" Padding="12,8">
                                            <TextBlock Text="{Binding SourceColumn}" Foreground="{DynamicResource MesTextSlate}" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" Foreground="{DynamicResource MesMutedGray}" FontSize="{StaticResource FontSizeSubtitle}" />
                                        <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding $parent[ItemsControl].((vm:ImportProductsAvaloniaViewModel)DataContext).TargetFields}"
                                                  SelectedItem="{Binding TargetField}"
                                                  Padding="8,6" AutomationProperties.Name="Hedef Alan Sec"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Step 4: Import Progress -->
            <Border IsVisible="{Binding IsStep4}" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                    Padding="32" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20" MinWidth="400">
                    <!-- Progress -->
                    <StackPanel Spacing="8" IsVisible="{Binding IsImporting}">
                        <TextBlock Text="Urunler aktariliyor..." FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        <ProgressBar Value="{Binding ImportProgress}" Minimum="0" Maximum="100"
                                     Height="8" Foreground="{DynamicResource MesPrimaryBlue}" />
                        <TextBlock Text="{Binding ImportProgress, StringFormat='%{0:N0}'}"
                                   FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Basla Button (visible before import starts) -->
                    <Button Content="Baslat" Command="{Binding ImportCommand}"
                            ToolTip.Tip="Aktarimi baslat"
                            IsVisible="{Binding !IsImporting}"
                            Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="32,12" CornerRadius="{StaticResource MesRadiusBase}" FontSize="{StaticResource FontSizeBody}"
                            HorizontalAlignment="Center" />

                    <!-- Result Summary -->
                    <Border IsVisible="{Binding ImportCompleted}" Background="{DynamicResource MesBgSurface}"
                            CornerRadius="{StaticResource MesRadiusMd}" Padding="24">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Aktarma Tamamlandi" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesGreen}" HorizontalAlignment="Center" />
                            <Grid ColumnDefinitions="*,*,*" HorizontalAlignment="Center">
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="16,0">
                                    <TextBlock Text="{Binding SuccessCount}" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                                               Foreground="{DynamicResource MesGreen}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Basarili" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesGreen}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="16,0">
                                    <TextBlock Text="{Binding SkippedCount}" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                                               Foreground="{DynamicResource MesAmberMuted}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Atlanan" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesAmberText}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="16,0">
                                    <TextBlock Text="{Binding FailedCount}" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold"
                                               Foreground="{DynamicResource MesRedAlert}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Hatali" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesRedDark}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding ImportDuration, StringFormat='Sure: {0}'}"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <!-- ImportResultMessage — WPF015 spec -->
                            <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusBase}" Padding="12,8"
                                    IsVisible="{Binding ImportResultMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding ImportResultMessage}"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesDarkSlate}"
                                           HorizontalAlignment="Center" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Error Summary -->
                    <Border IsVisible="{Binding HasImportErrors}" Background="{DynamicResource MesBgDangerLight}"
                            CornerRadius="{StaticResource MesRadiusMd}" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Hatali Satirlar" FontWeight="SemiBold" Foreground="{DynamicResource MesRedDark}" />
                            <ItemsControl ItemsSource="{Binding ImportErrors}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ImportErrorDto">
                                        <TextBlock Text="{Binding Message}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesRedAlert}"
                                                   TextWrapping="Wrap" Margin="0,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 3: Navigation Buttons -->
        <Border Grid.Row="3" Background="{DynamicResource MesBgPrimary}" Padding="20,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Content="Geri" Command="{Binding GoBackCommand}"
                        ToolTip.Tip="Geri"
                        IsVisible="{Binding CanGoBack}"
                        Background="{DynamicResource MesMutedGray}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="20,10" CornerRadius="{StaticResource MesRadiusBase}" />
                <Button Grid.Column="2" Content="{Binding NextButtonText}" Command="{Binding GoNextCommand}"
                        ToolTip.Tip="{Binding NextButtonText}"
                        IsVisible="{Binding CanGoNext}"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="20,10" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesOverlayLight}" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Dosya isleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Urun bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz urun bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding LoadDataCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
