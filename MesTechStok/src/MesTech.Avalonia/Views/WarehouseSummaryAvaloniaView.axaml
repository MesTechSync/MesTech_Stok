<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.WarehouseSummaryAvaloniaView"
             x:DataType="vm:WarehouseSummaryAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- I-06 Gorev 6: Depo Ozet Kartlari — kapasite + kritik urun + doluluk cubugu -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesTeal}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Depo Ozet Paneli" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalWarehouses, StringFormat='{}{0} depo'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Warehouse Cards Grid -->
        <TextBlock Grid.Row="1" Text="Kayit bulunamadi"
                   FontSize="{StaticResource FontSizeTitle}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource MesMutedGray}"
                   IsVisible="{Binding !WarehouseCards.Count}"
                   Opacity="0.5" />
        <ScrollViewer Grid.Row="1" Padding="16">
            <ItemsControl ItemsSource="{Binding WarehouseCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:WarehouseSummaryCardDto">
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="20" Margin="0,0,12,12"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Width="320">
                            <StackPanel Spacing="12">
                                <!-- Warehouse Name -->
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                               Foreground="{DynamicResource MesDarkSlate}" />
                                    <TextBlock Text="{Binding Location}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                </StackPanel>

                                <!-- Product Count -->
                                <TextBlock Text="{Binding ProductCountText}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextSlate}" />

                                <!-- Capacity Bar -->
                                <StackPanel Spacing="4">
                                    <Grid>
                                        <Border Height="10" CornerRadius="5" Background="{DynamicResource MesBorderLight}" />
                                        <Border Height="10" CornerRadius="5"
                                                Background="{Binding CapacityBarColor}"
                                                Width="{Binding CapacityBarWidth}"
                                                HorizontalAlignment="Left" />
                                    </Grid>
                                    <TextBlock Text="{Binding CapacityText}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                                </StackPanel>

                                <!-- Stock Health -->
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                IsVisible="{Binding HasOutOfStock}">
                                        <Border Width="8" Height="8" CornerRadius="{StaticResource MesRadiusSm}" Background="{DynamicResource MesRedAlert}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding OutOfStockText}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesRedAlert}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                IsVisible="{Binding HasCritical}">
                                        <Border Width="8" Height="8" CornerRadius="{StaticResource MesRadiusSm}" Background="{DynamicResource MesAmberDark}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding CriticalText}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesAmber}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                IsVisible="{Binding IsHealthy}">
                                        <Border Width="8" Height="8" CornerRadius="{StaticResource MesRadiusSm}" Background="{DynamicResource MesGreen}" VerticalAlignment="Center" />
                                        <TextBlock Text="Saglikli" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesGreen}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding NormalText}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                </StackPanel>

                                <!-- Detail Button -->
                                <Button Content="Detay &#x2192;" HorizontalAlignment="Right"
                                        ToolTip.Tip="Detay &#x2192;"
                                        Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesTextSlate}"
                                        Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" FontSize="{StaticResource FontSizeSmall}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Depo verileri yukleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
