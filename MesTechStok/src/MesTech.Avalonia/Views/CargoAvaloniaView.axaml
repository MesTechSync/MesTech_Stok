<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.CargoAvaloniaView"
             x:Name="RootCargoAvaloniaView"
             x:DataType="vm:CargoAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- M1 Avalonia canlandirma — Kargo Takip -->
    <!-- DataGrid: Takip No, Firma, Tarih, Durum, Alici. 10 demo cargo. Cargo company filter. -->
    <!-- Brand color #0078D4 -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Kargo Takip" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kargo'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Kargo Olustur" ToolTip.Tip="Yeni kargo olustur"
                            Command="{Binding CreateShipmentCommand}"
                            Background="{DynamicResource StatusSuccessBrush}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Etiket Yazdir" ToolTip.Tip="Secili kargo etiketi yazdir"
                            Command="{Binding PrintLabelCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Takip Et" ToolTip.Tip="Secili kargo takip bilgisi"
                            Command="{Binding TrackShipmentCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search + Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBox Width="280" Watermark="Takip no veya alici ara..." AutomationProperties.Name="Takip no veya alici ara..."
                         Text="{Binding SearchText}"
                         HorizontalAlignment="Left" />
                <ComboBox ItemsSource="{Binding Companies}"
                          SelectedItem="{Binding SelectedCompany}"
                          MinWidth="180"  AutomationProperties.Name="Company seciniz"/>
            </StackPanel>
        </Border>

        <!-- Cargo DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Cargos}"
                  SelectedItem="{Binding SelectedCargo}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Takip No" Binding="{Binding TrackingNo}" Width="180" />
                <DataGridTextColumn Header="Kargo Firmasi" Binding="{Binding Company}" Width="160" />
                <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="120" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="160" />
                <DataGridTextColumn Header="Alici" Binding="{Binding Receiver}" Width="180" />
            </DataGrid.Columns>
        </DataGrid>
<!-- Empty State -->        <TextBlock Grid.Row="2" Text="Kayıt bulunamadı"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !Cargos.Count}" />

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Kargo verileri yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Kargo bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Arama kriterlerine uygun kargo kaydi yok"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
