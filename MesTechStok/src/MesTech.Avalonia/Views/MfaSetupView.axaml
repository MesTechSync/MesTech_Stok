<base:BaseView xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:base="using:MesTech.Avalonia.Views.Base"
             x:Class="MesTech.Avalonia.Views.MfaSetupView"
             x:Name="RootMfaSetupView"
             x:DataType="vm:MfaSetupViewModel"
             AutomationProperties.Name="MFA Iki Faktorlu Kimlik Dogrulama Ayarlari">

    <base:BaseView.KeyBindings>
        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
    </base:BaseView.KeyBindings>

    <!-- STD006: MFA Setup — QR kod + TOTP doğrulama -->

    <Panel>
    <!-- Loading -->
    <Border IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="12" HorizontalAlignment="Center">
            <ProgressBar IsIndeterminate="True" Width="200" />
            <TextBlock Text="MFA durumu kontrol ediliyor..." Foreground="{DynamicResource MesTextSecondary}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Border>

    <!-- Main Content -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="540" Margin="40,24" Spacing="20" HorizontalAlignment="Center">

        <!-- Header -->
        <StackPanel Spacing="4">
            <TextBlock Text="Iki Faktorlu Kimlik Dogrulama (MFA)" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource MesDarkSlate}" />
            <TextBlock Text="OWASP ASVS V2.8 — Google Authenticator ile hesabinizi koruyun."
                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesTextSecondary}" />
        </StackPanel>

        <!-- Status: MFA Already Enabled -->
        <Border IsVisible="{Binding IsMfaEnabled}" Background="{DynamicResource MesBgSuccessLight}" CornerRadius="{StaticResource MesRadiusLg}"
                Padding="20">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="✅" FontSize="24" VerticalAlignment="Center" />
                <StackPanel Spacing="4">
                    <TextBlock Text="MFA Aktif" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource MesGreenSuccess}" />
                    <TextBlock Text="Hesabiniz iki faktorlu kimlik dogrulama ile korunuyor."
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesGreenSuccess}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Step 1: Enable MFA Button -->
        <Border IsVisible="{Binding !IsSetupStarted}" Background="{DynamicResource MesBgPrimary}"
                CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                BoxShadow="{DynamicResource MesElevation1}">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <TextBlock Text="🔐" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock Text="MFA henuz etkin degil." FontSize="{StaticResource FontSizeSubtitle}"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesTextSecondary}" />
                <TextBlock Text="Hesap guvenliginizi artirmak icin iki faktorlu dogrulamayi etkinlestirin."
                           FontSize="{StaticResource FontSizeSmall}" HorizontalAlignment="Center"
                           Foreground="{DynamicResource MesTextTertiary}" TextAlignment="Center" />
                <Button Content="MFA Etkinlestir" Command="{Binding StartSetupCommand}"
                        HorizontalAlignment="Center" Padding="24,12"
                        ToolTip.Tip="TOTP iki faktorlu kimlik dogrulamayi etkinlestir"
                        AutomationProperties.Name="MFA etkinlestir butonu"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                        FontWeight="Bold" FontSize="16" CornerRadius="{StaticResource MesRadiusMd}" />
            </StackPanel>
        </Border>

        <!-- Step 2: QR Code + Secret -->
        <Border IsVisible="{Binding IsSetupStarted}" Background="{DynamicResource MesBgPrimary}"
                CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                BoxShadow="{DynamicResource MesElevation1}">
            <StackPanel Spacing="16">
                <TextBlock Text="Adim 1: QR Kodu Tarayin" FontWeight="Bold" FontSize="16"
                           Foreground="{DynamicResource MesDarkSlate}" />
                <TextBlock Text="Google Authenticator veya benzeri bir TOTP uygulamasi ile asagidaki QR kodu tarayin."
                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesTextSecondary}"
                           TextWrapping="Wrap" />

                <!-- QR Code URI (text — gerçek QR render için SkiaSharp QR kütüphanesi gerekli) -->
                <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusMd}"
                        Padding="16" HorizontalAlignment="Center">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="📱 QR Kod" FontSize="48" HorizontalAlignment="Center" />
                        <TextBlock Text="(QR render icin SkiaSharp.QrCode entegrasyonu planlanmaktadir)"
                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesTextTertiary}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Manual Secret Key -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Manuel giris icin anahtar:" FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{DynamicResource MesTextSecondary}" />
                    <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusMd}" Padding="12,8">
                        <SelectableTextBlock Text="{Binding SecretKey}" FontFamily="Consolas" FontSize="14"
                                             FontWeight="Bold" Foreground="{DynamicResource MesDarkSlate}" />
                    </Border>
                </StackPanel>

                <!-- Step 3: Verification Code -->
                <TextBlock Text="Adim 2: Dogrulama Kodu" FontWeight="Bold" FontSize="16"
                           Foreground="{DynamicResource MesDarkSlate}" Margin="0,12,0,0" />
                <TextBlock Text="Uygulamadaki 6 haneli kodu girin:"
                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesTextSecondary}" />

                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    <TextBox Text="{Binding VerificationCode}" Width="200"
                             MaxLength="6" FontSize="24" FontWeight="Bold"
                             TextAlignment="Center" Watermark="000000"
                             CornerRadius="{StaticResource MesRadiusMd}" />
                    <Button Content="Dogrula" Command="{Binding VerifyCodeCommand}"
                            ToolTip.Tip="TOTP kodunu dogrula"
                            Padding="20,10" VerticalAlignment="Center"
                            Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                            FontWeight="SemiBold" CornerRadius="{StaticResource MesRadiusMd}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status Message -->
        <TextBlock Text="{Binding StatusMessage}" FontSize="{StaticResource FontSizeSmall}"
                   HorizontalAlignment="Center" Foreground="{DynamicResource MesPrimaryBlue}"
                   IsVisible="{Binding StatusMessage.Length}" />

        <!-- Empty State -->
        <Border IsVisible="{Binding IsEmpty}" HorizontalAlignment="Center" Padding="0,20">
            <TextBlock Text="MFA ayari bulunamadi" FontSize="{StaticResource FontSizeSubtitle}"
                       HorizontalAlignment="Center" Opacity="0.6" />
        </Border>

        <!-- Error -->
        <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}"
                CornerRadius="{StaticResource MesRadiusMd}" Padding="12">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" TextWrapping="Wrap" />
        </Border>

    </StackPanel>
    </ScrollViewer>
    </Panel>
</base:BaseView>
