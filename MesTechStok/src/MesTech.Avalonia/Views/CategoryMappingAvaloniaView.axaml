<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.CategoryMappingAvaloniaView"
             x:DataType="vm:CategoryMappingAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Kategori Eslestirme — dual-tree + AI eslestirme + ilerleme gostergesi -->

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Kategori Eslestirme" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} eslesme'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <ComboBox Grid.Column="1" ItemsSource="{Binding PlatformList}"
                          SelectedItem="{Binding SelectedPlatform}" Width="160" Margin="0,0,12,0" />
                <Button Grid.Column="2" Content="Sync"
                        ToolTip.Tip="Sync"
                        Command="{Binding SyncPlatformCategoriesCommand}"
                        Background="{DynamicResource MesTeal}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <Button Grid.Column="3" Content="AI Otomatik Eslestir"
                        ToolTip.Tip="AI Otomatik Eslestir"
                        Command="{Binding AiAutoMapCommand}"
                        Background="{DynamicResource MesBrandAccent}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <Button Grid.Column="4" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Progress Bar -->
        <Border Grid.Row="1" Padding="16,12,16,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Eslestirme Durumu:" FontSize="{StaticResource FontSizeCallout}"
                           Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" Margin="0,0,12,0" />
                <ProgressBar Grid.Column="1" Minimum="0" Maximum="100"
                             Value="{Binding MappingPercentage}" Height="10"
                             Foreground="{DynamicResource MesGreenMaterial}" Background="{DynamicResource MesBorderLight}" CornerRadius="5" />
                <TextBlock Grid.Column="2" Text="{Binding MappingPercentage, StringFormat='%{0:N0} eslesmis'}"
                           FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" Foreground="{DynamicResource MesGreenMaterial}"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
            </Grid>
        </Border>

        <!-- Dual Tree Panels -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,*" Margin="16,8,16,8">

            <!-- Left: MesTech Categories (TreeView) -->
            <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="12"
                    BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="MesTech Kategorileri" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                    <TextBox DockPanel.Dock="Top" Watermark="Kategori ara..." AutomationProperties.Name="Kategori ara..."
                             Text="{Binding LocalSearchText}" Margin="0,0,0,8"
                             Height="32" FontSize="{StaticResource FontSizeCallout}" CornerRadius="{StaticResource MesRadiusSm}" />
                    <TreeView ItemsSource="{Binding LocalCategoryTree}"
                              SelectedItem="{Binding SelectedLocalCategoryNode}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="vm:CategoryTreeNodeDto">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="10" Height="10" CornerRadius="5"
                                            Background="{Binding StatusColor}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" FontSize="{StaticResource FontSizeCallout}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StatusText}" FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource MesMutedGray}" VerticalAlignment="Center" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Map Buttons -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12" Spacing="8">
                <Button Content="Esle >" Command="{Binding MapCategoryCommand}"
                        ToolTip.Tip="Esle >"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" HorizontalAlignment="Stretch" />
                <Button Content="&lt; Kaldir" Command="{Binding UnmapCategoryCommand}"
                        ToolTip.Tip="&lt; Kaldir"
                        Background="{DynamicResource MesDanger}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Right: Platform Categories (TreeView) -->
            <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="12"
                    BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding SelectedPlatform, StringFormat='{}{0} Kategorileri'}"
                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                    <TextBox DockPanel.Dock="Top" Watermark="Kategori ara..." AutomationProperties.Name="Kategori ara..."
                             Text="{Binding PlatformSearchText}" Margin="0,0,0,8"
                             Height="32" FontSize="{StaticResource FontSizeCallout}" CornerRadius="{StaticResource MesRadiusSm}" />
                    <TreeView ItemsSource="{Binding PlatformCategoryTree}"
                              SelectedItem="{Binding SelectedPlatformCategoryNode}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="vm:CategoryTreeNodeDto">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Name}" FontSize="{StaticResource FontSizeCallout}" VerticalAlignment="Center" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Mappings Table -->
        <Border Grid.Row="3" Background="{DynamicResource MesBgPrimary}" Margin="16,0,16,8" CornerRadius="{StaticResource MesRadiusMd}"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1" MaxHeight="220">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Mevcut Eslestirmeler" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesDarkSlate}" Padding="12,8" />
                <DataGrid ItemsSource="{Binding Mappings}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Yerel Kategori" Binding="{Binding LocalCategory}" Width="*" />
                        <DataGridTextColumn Header="Platform Kategori" Binding="{Binding PlatformCategory}" Width="*" />
                        <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="100" />
                        <DataGridTextColumn Header="Durum" Binding="{Binding StatusLabel}" Width="120" />
                        <DataGridTextColumn Header="Kaynak" Binding="{Binding Source}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
<!-- Empty State -->        <TextBlock Text="Eslestirme bulunamadi"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !Mappings.Count}" />
            </DockPanel>
        </Border>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="4" Background="{DynamicResource MesBgMist}" Padding="16,10">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" Margin="0,0,20,0">
                    <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource MesGreenMaterial}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding MappedCount, StringFormat='Eslesmis: {0}'}"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="0,0,20,0">
                    <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource MesBrandAccent}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding AiSuggestionCount, StringFormat='AI Onerisi: {0}'}"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                    <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource MesDanger}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding UnmappedCount, StringFormat='Eslesmemis: {0}'}"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="4" Text="{Binding LastSyncText}"
                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{DynamicResource MesOverlayLight}" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Kategoriler yukleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Platform verisi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz platform verisi bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
