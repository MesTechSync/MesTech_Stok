<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.StockPlacementAvaloniaView"
             x:Name="RootStockPlacementAvaloniaView"
             x:DataType="vm:StockPlacementAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-06 Gorev 4A: Stok Yerlesim — depo/raf bazli urun goruntuleme -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Stok Yerlesim" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} urun'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Filter Bar: Depo + Raf + Arama -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Depo:" VerticalAlignment="Center" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                    <ComboBox Width="180" ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"  AutomationProperties.Name="Depo:"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Raf:" VerticalAlignment="Center" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                    <ComboBox Width="120" ItemsSource="{Binding Shelves}"
                              SelectedItem="{Binding SelectedShelf}"
                              PlaceholderText="Tumu"  AutomationProperties.Name="Tumu"/>
                </StackPanel>
                <TextBox Width="280" Watermark="SKU veya urun adi ara..." AutomationProperties.Name="SKU veya urun adi ara..."
                         Text="{Binding SearchText}" />
            </StackPanel>
        </Border>

        <!-- Placement DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="130" />
                <DataGridTextColumn Header="Urun Adi" Binding="{Binding Ad}" Width="250" />
                <DataGridTextColumn Header="Depo" Binding="{Binding Depo}" Width="120" />
                <DataGridTextColumn Header="Raf" Binding="{Binding Raf}" Width="80" />
                <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar}" Width="90" />
                <DataGridTextColumn Header="Min Stok" Binding="{Binding MinimumStock}" Width="90" />
                <DataGridTextColumn Header="Durum" Binding="{Binding StokDurum}" Width="100" />
            </DataGrid.Columns>

            <DataGrid.Styles>
                <!-- EMR-06 renk tablosu — stok durumu satir renklendirme -->
                <Style Selector="DataGridRow" x:DataType="vm:PlacementItemDto">
                    <Style Selector="^[Tag=TUKENDI]">
                        <Setter Property="Background" Value="{DynamicResource MesRedAlert}" />
                        <Setter Property="Foreground" Value="{DynamicResource MesBgPrimary}" />
                    </Style>
                    <Style Selector="^[Tag=KRITIK]">
                        <Setter Property="Background" Value="{DynamicResource MesRedAlert}" />
                        <Setter Property="Foreground" Value="{DynamicResource MesBgPrimary}" />
                    </Style>
                    <Style Selector="^[Tag=DUSUK]">
                        <Setter Property="Background" Value="{DynamicResource MesWarning}" />
                        <Setter Property="Foreground" Value="{DynamicResource MesBgPrimary}" />
                    </Style>
                    <Style Selector="^[Tag=YETERLI]">
                        <Setter Property="Background" Value="{DynamicResource MesBgSurface}" />
                    </Style>
                </Style>
            </DataGrid.Styles>
        </DataGrid>
<!-- Empty State -->        <TextBlock Grid.Row="2" Text="Kayıt bulunamadı"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !Items.Count}" />

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Yerlesim verisi bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Secili depo/raf icin urun bulunamadi"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
