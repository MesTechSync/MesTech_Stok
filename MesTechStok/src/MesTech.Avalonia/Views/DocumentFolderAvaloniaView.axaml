<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.DocumentFolderAvaloniaView"
             x:DataType="vm:DocumentFolderAvaloniaViewModel">

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Belge Klasorleri" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} klasor'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Klasor"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content: Split Panel -->
        <Grid Grid.Row="1" ColumnDefinitions="280,*">

            <!-- Left: Folders -->
            <Border Grid.Column="0" Background="White" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Loading -->
                        <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                                   Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" Margin="0,20" />

                        <!-- Folder List -->
                        <ItemsControl ItemsSource="{Binding Folders}" Margin="8" IsVisible="{Binding !IsLoading}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:DocFolderItemVm">
                                    <Border Margin="0,0,0,4" Padding="12,10" Background="{DynamicResource MesBgPage}"
                                            CornerRadius="6" Cursor="Hand">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0" Background="{DynamicResource MesPrimaryBlue}" CornerRadius="4"
                                                    Width="32" Height="32" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Icon}" Foreground="White"
                                                           FontSize="14" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Column="2" Background="{DynamicResource MesBorderSoft}" CornerRadius="10"
                                                    Padding="6,2">
                                                <TextBlock Text="{Binding FileCount}" FontSize="11"
                                                           Foreground="{DynamicResource MesSlateGray}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right: Files -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16" Spacing="0">
                    <!-- Error -->
                    <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}"
                            CornerRadius="8" Padding="16" BorderBrush="{DynamicResource MesBorderDanger}" BorderThickness="1"
                            Margin="0,0,0,12">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" TextWrapping="Wrap" />
                    </Border>

                    <!-- Empty -->
                    <TextBlock Text="Dosya bulunmuyor."
                               IsVisible="{Binding IsEmpty}" Foreground="{DynamicResource MesMutedGray}"
                               HorizontalAlignment="Center" Margin="0,40" FontSize="14" />

                    <!-- File List -->
                    <ItemsControl ItemsSource="{Binding Files}" IsVisible="{Binding !IsLoading}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:DocFileItemVm">
                                <Border Margin="0,0,0,8" Padding="14" Background="White"
                                        CornerRadius="6" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                                            <TextBlock Text="{Binding ModifiedDisplay}" FontSize="11" Foreground="{DynamicResource MesSlateGray}" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{DynamicResource MesBgMist}" CornerRadius="4"
                                                Padding="6,2" Margin="8,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Type}" FontSize="10" Foreground="{DynamicResource MesSlateGray}" />
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Size}"
                                                   FontSize="11" Foreground="{DynamicResource MesMutedGray}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
