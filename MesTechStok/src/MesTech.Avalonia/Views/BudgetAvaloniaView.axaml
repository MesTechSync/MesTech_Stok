<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.BudgetAvaloniaView"
             x:Name="RootBudgetAvaloniaView"
             x:DataType="vm:BudgetAvaloniaViewModel"
             xmlns:vm="clr-namespace:MesTech.Avalonia.ViewModels">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

  <Grid RowDefinitions="Auto,Auto,Auto,*">

    <!-- Header -->
    <Border Grid.Row="0" Background="{DynamicResource MesPurple}" Padding="16" CornerRadius="{StaticResource MesRadiusMd}" Margin="0,0,0,12">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel>
          <TextBlock Text="Butce &amp; Gerceklesme" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesBgPrimary}"/>
          <TextBlock Text="Aylik butce takibi ve gerceklesme karsilastirmasi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesTextTertiary}"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}" Classes="accent"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- KPI Cards -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="0,0,0,12">
      <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="0,0,8,0" BoxShadow="{DynamicResource MesElevation1}">
        <StackPanel>
          <TextBlock Text="BUTCE" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesCoolGray}"/>
          <TextBlock Text="{Binding TotalBudget}" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="4,0,4,0" BoxShadow="{DynamicResource MesElevation1}">
        <StackPanel>
          <TextBlock Text="GERCEKLESEN" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesCoolGray}"/>
          <TextBlock Text="{Binding TotalActual}" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold" Foreground="{DynamicResource MesTeal}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="4,0,4,0" BoxShadow="{DynamicResource MesElevation1}">
        <StackPanel>
          <TextBlock Text="KALAN" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesCoolGray}"/>
          <TextBlock Text="{Binding TotalRemaining}" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold" Foreground="{DynamicResource MesAmber}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="8,0,0,0" BoxShadow="{DynamicResource MesElevation1}">
        <StackPanel>
          <TextBlock Text="KULLANIM ORANI" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesCoolGray}"/>
          <TextBlock Text="{Binding UsageRate}" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold" Foreground="{DynamicResource MesPurple}"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Filters -->
    <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="12" Margin="0,0,0,12" BoxShadow="{DynamicResource MesElevation1}">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}" Width="120" PlaceholderText="Ay" AutomationProperties.Name="Ay" />
        <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" Width="100" PlaceholderText="Yil" AutomationProperties.Name="Yil" />
      </StackPanel>
    </Border>

    <!-- Budget DataGrid -->
    <Border Grid.Row="3" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="8" BoxShadow="{DynamicResource MesElevation1}">
      <Panel>
        <DataGrid ItemsSource="{Binding Items}" IsReadOnly="True" CanUserResizeColumns="True" CanUserReorderColumns="True" AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal" BorderThickness="0"
                 >
          <DataGrid.Columns>
            <DataGridTextColumn Header="Kategori" Binding="{Binding CategoryName}" Width="*"/>
            <DataGridTextColumn Header="Butce" Binding="{Binding BudgetFormatted}" Width="120"/>
            <DataGridTextColumn Header="Gerceklesen" Binding="{Binding ActualFormatted}" Width="120"/>
            <DataGridTextColumn Header="Kalan" Binding="{Binding RemainingFormatted}" Width="120"/>
            <DataGridTextColumn Header="Durum" Binding="{Binding StatusText}" Width="100"/>
          </DataGrid.Columns>
        </DataGrid>
<!-- Empty State -->        <TextBlock Text="Kayıt bulunamadı"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !Items.Count}" />

        <!-- Loading overlay -->
        <Border Background="{DynamicResource MesOverlayMedium}" IsVisible="{Binding IsLoading}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Yukleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesCoolGray}"/>
          </StackPanel>
        </Border>

        <!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Butce verisi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Bu donem icin butce tanimlanmamis" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>
      </Panel>
    </Border>

<!-- Loading Skeleton -->        <Border Grid.Row="0" Grid.RowSpan="4"                Background="{DynamicResource MesBgPage}"                IsVisible="{Binding IsLoading}"                ZIndex="100">            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />        </Border>
  </Grid>
</UserControl>
