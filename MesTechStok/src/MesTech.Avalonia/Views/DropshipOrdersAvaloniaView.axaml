<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.DropshipOrdersAvaloniaView"
             x:DataType="vm:DropshipOrdersAvaloniaViewModel">

    <!-- Dropshipping Siparisler — siparis DataGrid + durum filtre + tedarikci iletme -->

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Dropshipping Siparişleri" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} sipariş'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Durum:" VerticalAlignment="Center" FontSize="13" Foreground="#64748B" />
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}" Width="200" />
            </StackPanel>
        </Border>

        <!-- Orders DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Orders}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="White"
                  Margin="0"
                  IsVisible="{Binding !IsLoading}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sipariş No" Binding="{Binding OrderId}" Width="140" />
                <DataGridTextColumn Header="Müşteri" Binding="{Binding Customer}" Width="160" />
                <DataGridTextColumn Header="Tedarikçi" Binding="{Binding Supplier}" Width="160" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="160" />
                <DataGridTextColumn Header="Müşteri Fiyat" Binding="{Binding CustomerPrice, StringFormat='₺{0:N2}'}" Width="130" />
                <DataGridTextColumn Header="Tedarikçi Fiyat" Binding="{Binding SupplierPrice, StringFormat='₺{0:N2}'}" Width="130" />
                <DataGridTextColumn Header="Net Kâr" Binding="{Binding NetProfit, StringFormat='₺{0:N2}'}" Width="120" />
                <DataGridTemplateColumn Header="İşlem" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="vm:DropshipOrderItemDto">
                            <Button Content="Tedarikçiye İlet"
                                    Command="{Binding $parent[DataGrid].((vm:DropshipOrdersAvaloniaViewModel)DataContext).ForwardToSupplierCommand}"
                                    CommandParameter="{Binding}"
                                    Background="#FF6F00" Foreground="White"
                                    FontSize="11" FontWeight="SemiBold"
                                    Padding="8,4" CornerRadius="4"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Siparisler yukleniyor..." FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" Background="#F7F9FC" IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Sipariş Bulunamadı" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#1E293B" Margin="0,0,0,8" />
                <TextBlock Text="Seçilen filtreye uygun sipariş yok"
                           FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
