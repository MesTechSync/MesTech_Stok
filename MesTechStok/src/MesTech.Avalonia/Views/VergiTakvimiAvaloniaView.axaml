<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.VergiTakvimiAvaloniaView"
             x:Name="RootVergiTakvimiAvaloniaView"
             x:DataType="vm:VergiTakvimiAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPurple}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Vergi Takvimi" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPurple}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- KPI Row -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPage}" Padding="16,12">
            <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Gecikmi&#x15F;" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding OverdueCount}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesRedBright}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Yaklasan" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding UpcomingCount}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesAmber}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Tamamlanan" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding CompletedCount}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesEmerald}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}"
                          Width="140"  AutomationProperties.Name="Month seciniz"/>
                <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"
                          Width="100"  AutomationProperties.Name="Year seciniz"/>
                <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}"
                          Width="160"  AutomationProperties.Name="Status filter seciniz"/>
            </StackPanel>
        </Border>

        <!-- Card List -->
        <ScrollViewer Grid.Row="3" Margin="16">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="20" Margin="0,0,0,12"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1"
                                BoxShadow="{DynamicResource MesElevationCard}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Status Indicator -->
                                <Border Grid.Column="0" Width="6" CornerRadius="3" Margin="0,0,16,0"
                                        Background="{Binding StatusColor}" />
                                <!-- Details -->
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding TaxName}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MesDarkSlate}" />
                                    <TextBlock Text="{Binding DueDateFormatted}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" />
                                    <TextBlock Text="{Binding StatusText}" FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{Binding StatusColor}" FontWeight="SemiBold" />
                                </StackPanel>
                                <!-- Amount -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding AmountFormatted}" FontSize="{StaticResource FontSizeH3}" FontWeight="Bold"
                                               Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="True" ShowChart="True" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Kayit bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Secilen donem icin vergi takvimi kaydi yok"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="1" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
