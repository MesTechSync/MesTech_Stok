<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.VergiTakvimiAvaloniaView"
             x:DataType="vm:VergiTakvimiAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPurple}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Vergi Takvimi" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPurple}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- KPI Row -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPage}" Padding="16,12">
            <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16" Margin="4"
                        BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Gecikmi&#x15F;" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding OverdueCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource MesRedBright}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16" Margin="4"
                        BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Yaklasan" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding UpcomingCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource MesAmber}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="16" Margin="4"
                        BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Tamamlanan" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding CompletedCount}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource MesEmerald}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="2" Background="White" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}"
                          Width="140" />
                <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"
                          Width="100" />
                <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}"
                          Width="160" />
            </StackPanel>
        </Border>

        <!-- Card List -->
        <ScrollViewer Grid.Row="3" Margin="16">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,12"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1"
                                BoxShadow="0 2 8 0 #14000000">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Status Indicator -->
                                <Border Grid.Column="0" Width="6" CornerRadius="3" Margin="0,0,16,0"
                                        Background="{Binding StatusColor}" />
                                <!-- Details -->
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding TaxName}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MesDarkSlate}" />
                                    <TextBlock Text="{Binding DueDateFormatted}" FontSize="13" Foreground="{DynamicResource MesSlateGray}" />
                                    <TextBlock Text="{Binding StatusText}" FontSize="12"
                                               Foreground="{Binding StatusColor}" FontWeight="SemiBold" />
                                </StackPanel>
                                <!-- Amount -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding AmountFormatted}" FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Right" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Vergi takvimi yukleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Kayit bulunamadi" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Secilen donem icin vergi takvimi kaydi yok"
                           FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
