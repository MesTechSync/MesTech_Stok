<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.CargoSettingsAvaloniaView"
             x:DataType="vm:CargoSettingsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Kargo Ayarlari" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet"
                        Command="{Binding SaveCommand}"
                        Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Settings Form -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Left">

                <!-- Varsayilan Kargo Firmasi -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Varsayilan Kargo Firmasi" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <ComboBox ItemsSource="{Binding CargoProviders}"
                                  SelectedItem="{Binding SelectedCargoProvider}"
                                  Width="300"  AutomationProperties.Name="Varsayilan Kargo Firmasi"/>
                    </StackPanel>
                </Border>

                <!-- Kargo Desi Ayarlari -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Desi Hesaplama" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Desi Katsayisi:"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding DesiMultiplier}"
                                          Minimum="1" Maximum="10000" FormatString="N0" Width="160"
                                          HorizontalAlignment="Left"  AutomationProperties.Name="Desi Katsayisi:"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Min. Desi:"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center"
                                       Margin="0,8,0,0" />
                            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding MinDesi}"
                                          Minimum="0" FormatString="N1" Width="160"
                                          HorizontalAlignment="Left" Margin="0,8,0,0"  AutomationProperties.Name="Min. Desi:"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Max. Desi:"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center"
                                       Margin="0,8,0,0" />
                            <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding MaxDesi}"
                                          Minimum="0" FormatString="N1" Width="160"
                                          HorizontalAlignment="Left" Margin="0,8,0,0"  AutomationProperties.Name="Max. Desi:"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Otomatik Kargo Olusturma -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Otomasyon" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Siparis onayinda otomatik kargo olustur"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoCreateShipment}"
                                          OnContent="Acik" OffContent="Kapali"  AutomationProperties.Name="Siparis onayinda otomatik kargo olustur"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Kargo takip numarasini otomatik guncelle"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoUpdateTracking}"
                                          OnContent="Acik" OffContent="Kapali"  AutomationProperties.Name="Kargo takip numarasini otomatik guncelle"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- API Bilgileri -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="API Baglanti Bilgileri" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="API Anahtari" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding ApiKey}" Watermark="Kargo API anahtari" AutomationProperties.Name="Kargo API anahtari"
                                     PasswordChar="*" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="API Sifresi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding ApiSecret}" Watermark="Kargo API sifresi" AutomationProperties.Name="Kargo API sifresi"
                                     PasswordChar="*" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Kargo ayarlari yukleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
