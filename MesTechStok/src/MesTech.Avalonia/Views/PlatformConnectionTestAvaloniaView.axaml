<base:BaseView xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:base="using:MesTech.Avalonia.Views.Base"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.PlatformConnectionTestAvaloniaView"
             x:Name="RootPlatformConnectionTestAvaloniaView"
             x:DataType="vm:PlatformConnectionTestAvaloniaViewModel"
             AutomationProperties.Name="Platform Baglanti Testi">
<base:BaseView.KeyBindings>
    <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
</base:BaseView.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Platform Baglanti Durumu" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} platform — {1} bagli / {2} hata">
                                    <Binding Path="TotalPlatforms" />
                                    <Binding Path="ConnectedCount" />
                                    <Binding Path="ErrorCount" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Tumu Test Et" ToolTip.Tip="Tum platformlari test et"
                            Command="{Binding TestAllCommand}"
                            IsEnabled="{Binding !IsTesting}"
                            Background="{DynamicResource MesGreenSuccess}" Foreground="White" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile (F5)"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Skeleton -->
        <Border Grid.Row="1"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Platform bulunamadi" FontSize="{StaticResource FontSizeTitle}"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesMutedGray}" Margin="0,0,0,8" />
                <TextBlock Text="Henuz platform tanimlanmamis veya adapter yuklenmemis"
                           FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

        <!-- Platform Cards Grid -->
        <ScrollViewer Grid.Row="1" Padding="16">
            <ItemsControl ItemsSource="{Binding Platforms}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PlatformTestItemVm">
                        <Border Background="{DynamicResource MesBgPrimary}"
                                CornerRadius="{StaticResource MesRadiusMd}"
                                BorderBrush="{DynamicResource MesBorderLight}"
                                BorderThickness="1"
                                Padding="16,14"
                                Margin="0,0,12,12"
                                MinWidth="260" MaxWidth="300">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                                <!-- Platform Name + Status Badge -->
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                    <TextBlock Grid.Column="0" Text="{Binding PlatformName}"
                                               FontSize="{StaticResource FontSizeBodyLg}" FontWeight="Bold"
                                               Foreground="{DynamicResource MesDarkSlate}" />
                                    <Border Grid.Column="1" Background="{Binding StatusColor}"
                                            CornerRadius="10" Padding="8,2">
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White" FontSize="10" FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <!-- Stats -->
                                <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,0,0,6">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Urun" FontSize="10" Foreground="{DynamicResource MesSlateGray}" Opacity="0.7" />
                                        <TextBlock Text="{Binding ProductCount}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MesDarkSlate}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Siparis" FontSize="10" Foreground="{DynamicResource MesSlateGray}" Opacity="0.7" />
                                        <TextBlock Text="{Binding OrderCount}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MesDarkSlate}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Store count + Adapter -->
                                <Grid Grid.Row="2" ColumnDefinitions="*,*" Margin="0,0,0,6">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Magaza" FontSize="10" Foreground="{DynamicResource MesSlateGray}" Opacity="0.7" />
                                        <TextBlock FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesDarkSlate}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}/{1} aktif">
                                                    <Binding Path="ActiveStoreCount" />
                                                    <Binding Path="StoreCount" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Son Sync" FontSize="10" Foreground="{DynamicResource MesSlateGray}" Opacity="0.7" />
                                        <TextBlock Text="{Binding LastSync}" FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{DynamicResource MesDarkSlate}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Test Status -->
                                <TextBlock Grid.Row="3" Text="{Binding TestStatus}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesPrimaryBlue}"
                                           IsVisible="{Binding TestStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</base:BaseView>
