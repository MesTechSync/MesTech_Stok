<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ErpSettingsAvaloniaView"
             x:DataType="vm:ErpSettingsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- ERP Entegrasyon Ayarlari -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource BackgroundBrush}">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBlueBrush}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <PathIcon Data="{StaticResource IconSettings}" Width="22" Height="22" Foreground="{DynamicResource MesBgPrimary}"/>
                    <TextBlock Text="ERP Entegrasyon Ayarlari" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeHeader}" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Baglanti Test"
                        Command="{Binding TestConnectionCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource PrimaryBlueBrush}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource CornerRadiusMedium}"
                        Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet"
                        Command="{Binding SaveSettingsCommand}"
                        Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource CornerRadiusMedium}"/>
            </Grid>
        </Border>

        <!-- Row 1: Settings Form -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="20" MaxWidth="800" HorizontalAlignment="Left">

                <!-- Provider Selection -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <TextBlock Text="ERP Saglayici Secimi"
                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ComboBox ItemsSource="{Binding ErpProviders}"
                                  SelectedItem="{Binding SelectedErpProvider}"
                                  Width="300"/>

                        <!-- Connection Status Indicator -->
                        <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding IsProviderSelected}">
                            <Border Grid.Column="0" Width="12" Height="12"
                                    CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding ConnectionStatusColor}"/>
                                </Border.Background>
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding LastTestResult}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Logo Fields -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        IsVisible="{Binding IsLogoSelected}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Logo ERP Ayarlari"
                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Base URL" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding LogoBaseUrl}"
                                     Watermark="Orn: https://firma.logo.com.tr/logo-rest/api/" AutomationProperties.Name="Orn: https://firma.logo.com.tr/logo-rest/api/"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Kullanici Adi" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding LogoUsername}" Watermark="Logo kullanici adi" AutomationProperties.Name="Logo kullanici adi"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Sifre" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding LogoPassword}" PasswordChar="*"
                                         Watermark="Logo sifresi" AutomationProperties.Name="Logo sifresi"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Firma Numarasi" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding LogoFirmNumber}" Watermark="Orn: 001" AutomationProperties.Name="Orn: 001"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Donem Numarasi" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding LogoPeriodNumber}" Watermark="Orn: 01" AutomationProperties.Name="Orn: 01"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Netsis Fields -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        IsVisible="{Binding IsNetsisSelected}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Netsis ERP Ayarlari"
                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Base URL" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding NetsisBaseUrl}"
                                     Watermark="Orn: https://FIRMA.netsis.com.tr/api/v2" AutomationProperties.Name="Orn: https://FIRMA.netsis.com.tr/api/v2"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Kullanici Adi" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding NetsisUsername}" Watermark="Netsis kullanici adi" AutomationProperties.Name="Netsis kullanici adi"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Sifre" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding NetsisPassword}" PasswordChar="*"
                                         Watermark="Netsis sifresi" AutomationProperties.Name="Netsis sifresi"/>
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Sirket Kodu" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding NetsisCompanyCode}" Watermark="Orn: MESTECH" AutomationProperties.Name="Orn: MESTECH"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Sube Kodu" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding NetsisBranchCode}" Watermark="Orn: MERKEZ" AutomationProperties.Name="Orn: MERKEZ"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Nebim Fields -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        IsVisible="{Binding IsNebimSelected}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Nebim ERP Ayarlari"
                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Base URL" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding NebimBaseUrl}"
                                     Watermark="Orn: https://firma.nebim.com/api/v3" AutomationProperties.Name="Orn: https://firma.nebim.com/api/v3"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="API Key" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding NebimApiKey}" PasswordChar="*"
                                     Watermark="Nebim API anahtari" AutomationProperties.Name="Nebim API anahtari"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Veritabani Kodu" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding NebimDatabaseCode}" Watermark="Orn: NEBIMDB" AutomationProperties.Name="Orn: NEBIMDB"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Ofis Kodu" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding NebimOfficeCode}" Watermark="Orn: MERKEZ" AutomationProperties.Name="Orn: MERKEZ"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Parasut Fields -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        IsVisible="{Binding IsParasutSelected}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Parasut Ayarlari"
                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Client ID" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding ParasutClientId}" Watermark="OAuth Client ID" AutomationProperties.Name="OAuth Client ID"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Client Secret" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBox Text="{Binding ParasutClientSecret}" PasswordChar="*"
                                         Watermark="OAuth Client Secret" AutomationProperties.Name="OAuth Client Secret"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Company ID" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBox Text="{Binding ParasutCompanyId}" Watermark="Parasut sirket ID" AutomationProperties.Name="Parasut sirket ID"
                                     Width="300" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Sandbox Modu"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ParasutSandbox}"
                                          OnContent="Acik" OffContent="Kapali"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Sync Settings -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        IsVisible="{Binding IsProviderSelected}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Senkronizasyon Ayarlari"
                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Otomatik stok senkronizasyonu"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoSyncStock}"
                                          OnContent="Acik" OffContent="Kapali"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Fatura otomatik aktarimi"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoSyncInvoice}"
                                          OnContent="Acik" OffContent="Kapali"/>
                        </Grid>
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Stok senk. araligi (dk):"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="1" Value="{Binding StockSyncPeriodMinutes}"
                                          Minimum="5" Maximum="1440" FormatString="N0" Width="160"
                                          HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Fiyat senk. araligi (dk):"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Column="1" Value="{Binding PriceSyncPeriodMinutes}"
                                          Minimum="5" Maximum="1440" FormatString="N0" Width="160"
                                          HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Sync History -->
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        IsVisible="{Binding IsProviderSelected}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Son Senkronizasyon Gecmisi"
                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Kayit bulunamadi"
                                   FontSize="{StaticResource FontSizeTitle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource MesMutedGray}"
                                   IsVisible="{Binding !SyncHistory.Count}"
                                   Opacity="0.5" Margin="0,12" />

                        <ItemsControl ItemsSource="{Binding SyncHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ErpSyncHistoryItem">
                                    <Border Padding="12,8" Margin="0,2"
                                            Background="{DynamicResource MesBgPage}" CornerRadius="{StaticResource MesRadiusBase}">
                                        <Grid ColumnDefinitions="140,80,80,*,60">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding SyncDate, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SyncType}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding RecordCount}"/>
                                                <Run Text=" kayit"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="3" Text="{Binding Status}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding StatusColor}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                            <TextBlock Grid.Column="4" Text="{Binding Duration}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12"/>
                <TextBlock Text="ERP ayarlari yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <PathIcon Data="{StaticResource IconWarning}" Width="48" Height="48"
                          Foreground="{DynamicResource ErrorRedBrush}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource ErrorRedBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400"/>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
