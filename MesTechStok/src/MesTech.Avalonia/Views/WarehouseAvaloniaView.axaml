<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.WarehouseAvaloniaView"
             x:Name="RootWarehouseAvaloniaView"
             x:DataType="vm:WarehouseAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-06 Gorev 4E: Depolar — kart gorunumu + kapasite doluluk cubugu + yeni depo ekleme -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Depolar" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} depo'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yeni Depo Ekle"
                        ToolTip.Tip="Yeni Depo Ekle"
                        Command="{Binding AddWarehouseCommand}"
                        Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <TextBox Width="320" Watermark="Depo adi veya konum ara..." AutomationProperties.Name="Depo adi veya konum ara..."
                     Text="{Binding SearchText}"
                     HorizontalAlignment="Left" />
        </Border>

        <!-- Warehouse Cards Grid -->        <ScrollViewer Grid.Row="2" Padding="16">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:WarehouseCardDto">
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="20"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1"
                                Margin="0,0,16,16" Width="320">
                            <StackPanel Spacing="10">
                                <!-- Depo Adi + Konum -->
                                <TextBlock Text="{Binding Name}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="{Binding Location}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" />

                                <!-- KPI Row -->
                                <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Urun" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" />
                                        <TextBlock Text="{Binding ProductCount}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                                   Foreground="{DynamicResource MesDarkSlate}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="Toplam Stok" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" />
                                        <TextBlock Text="{Binding TotalStock}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                                   Foreground="{DynamicResource MesDarkSlate}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="2">
                                        <TextBlock Text="Alarm" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" />
                                        <TextBlock Text="{Binding AlarmCount}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                                   Foreground="{DynamicResource MesRedBright}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Kapasite Doluluk Cubugu -->
                                <StackPanel Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="Kapasite Dolulugu" FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{DynamicResource MesMutedGray}" />
                                        <TextBlock Grid.Column="1" Text="{Binding CapacityPercent, StringFormat='{}{0}%'}"
                                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" FontWeight="SemiBold" />
                                    </Grid>
                                    <Border Background="{DynamicResource MesBorderSoft}" CornerRadius="3" Height="8">
                                        <Border Background="{Binding CapacityColor}" CornerRadius="3"
                                                HorizontalAlignment="Left"
                                                Width="{Binding CapacityBarWidth}" />
                                    </Border>
                                </StackPanel>

                                <!-- Raf Sayisi -->
                                <TextBlock Text="{Binding ShelfCount, StringFormat='{}{0} raf'}"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- New Warehouse Dialog (inline panel) -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBrandSecondary}"
                IsVisible="{Binding IsAddingWarehouse}"
                ZIndex="200">
            <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="28"
                    Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Yeni Depo Ekle" FontSize="{StaticResource FontSizeH3}" FontWeight="Bold"
                               Foreground="{DynamicResource MesDarkSlate}" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Depo Adi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                        <TextBox Text="{Binding NewWarehouseName}" Watermark="Orn: Sube 2 Depo" AutomationProperties.Name="Orn: Sube 2 Depo" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Konum" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                        <TextBox Text="{Binding NewWarehouseLocation}" Watermark="Orn: Istanbul, Ikitelli" AutomationProperties.Name="Orn: Istanbul, Ikitelli" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Kapasite" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                        <NumericUpDown Value="{Binding NewWarehouseCapacity}" Minimum="1"
                                       FormatString="N0"  AutomationProperties.Name="Kapasite"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,8,*" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="Iptal" Command="{Binding CancelAddWarehouseCommand}"
                                ToolTip.Tip="Iptal"
                                Background="{DynamicResource MesBorderSoft}" Foreground="{DynamicResource MesTextSlate}" FontWeight="SemiBold"
                                Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="2" Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet" Command="{Binding SaveWarehouseCommand}"
                                Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Depo bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Henuz depo tanimlanmamis veya arama sonucu bos"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
