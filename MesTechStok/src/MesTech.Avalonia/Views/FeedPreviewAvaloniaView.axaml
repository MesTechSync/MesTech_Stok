<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.FeedPreviewAvaloniaView"
             x:DataType="vm:FeedPreviewAvaloniaViewModel">

    <!-- Feed Onizleme — URL girisi + urun onizleme + dogrulama hatalari -->

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <TextBlock Text="Feed Önizleme" Foreground="White"
                       FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Border>

        <!-- URL Input -->
        <Border Grid.Row="1" Background="White" Padding="16,12"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="500" Watermark="Feed URL giriniz..."
                         Text="{Binding FeedUrl}" Padding="10,8" />
                <ComboBox ItemsSource="{Binding FormatOptions}"
                          SelectedItem="{Binding FeedFormat}" Width="100" />
                <Button Content="Çek" Command="{Binding PreviewFeedCommand}"
                        Background="#0078D4" Foreground="White" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </StackPanel>
        </Border>

        <!-- Preview Content -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*,Auto" Margin="16"
              IsVisible="{Binding PreviewLoaded}">

            <!-- Stats -->
            <Border Grid.Row="0" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <Border Background="White" CornerRadius="8" Padding="16" BorderBrush="#E5E9F2" BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Toplam Ürün" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding TotalProducts}" FontSize="20" FontWeight="Bold" Foreground="#1E293B" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="16" BorderBrush="#E5E9F2" BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Geçerli" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding ValidProducts}" FontSize="20" FontWeight="Bold" Foreground="#4CAF50" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="16" BorderBrush="#E5E9F2" BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Hata" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding ErrorCount}" FontSize="20" FontWeight="Bold" Foreground="#F44336" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Preview DataGrid -->
            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    BorderBrush="#E5E9F2" BorderThickness="1">
${INDENT}<Grid>
                <DataGrid ItemsSource="{Binding PreviewItems}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" BorderThickness="0" Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="140" />
                        <DataGridTextColumn Header="Ürün Adı" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Fiyat (TL)" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="120" />
                        <DataGridTextColumn Header="Stok" Binding="{Binding Stock}" Width="80" />
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
<!-- Empty State -->                    <TextBlock Text="Kayıt bulunamadı"                               HorizontalAlignment="Center"                               VerticalAlignment="Center"                               Margin="0,40"                               Opacity="0.5"                               FontSize="16"                               IsVisible="{Binding !PreviewItems.Count}" />                </Grid>
            </Border>

            <!-- Validation Errors -->
            <Border Grid.Row="2" Background="#FFF3E0" CornerRadius="8" Padding="12" Margin="0,12,0,0"
                    IsVisible="{Binding ErrorCount}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Doğrulama Uyarıları" FontSize="13" FontWeight="SemiBold" Foreground="#E65100" />
                    <ItemsControl ItemsSource="{Binding ValidationErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#BF360C" Padding="4,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Feed okunuyor..." FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#F7F9FC" IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#E53935" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="#E53935"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
