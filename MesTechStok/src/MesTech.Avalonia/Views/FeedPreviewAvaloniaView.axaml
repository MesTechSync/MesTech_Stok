<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.FeedPreviewAvaloniaView"
             x:DataType="vm:FeedPreviewAvaloniaViewModel">

    <!-- Feed Onizleme — URL girisi + urun onizleme + dogrulama hatalari -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <TextBlock Text="Feed Önizleme" Foreground="{DynamicResource MesBgPrimary}"
                       FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Border>

        <!-- URL Input -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="500" Watermark="Feed URL giriniz..." AutomationProperties.Name="Feed URL giriniz..."
                         Text="{Binding FeedUrl}" Padding="10,8" />
                <ComboBox ItemsSource="{Binding FormatOptions}"
                          SelectedItem="{Binding FeedFormat}" Width="100" />
                <Button Content="Çek" Command="{Binding PreviewFeedCommand}"
                        ToolTip.Tip="Cek"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </StackPanel>
        </Border>

        <!-- Preview Content -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*,Auto" Margin="16"
              IsVisible="{Binding PreviewLoaded}">

            <!-- Stats -->
            <Border Grid.Row="0" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Toplam Ürün" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TotalProducts}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Geçerli" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding ValidProducts}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesGreenMaterial}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Hata" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding ErrorCount}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesRedClassic}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Preview DataGrid -->
            <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                    BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
            <Grid>
                <DataGrid ItemsSource="{Binding PreviewItems}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                          GridLinesVisibility="Horizontal" BorderThickness="0" Background="{DynamicResource MesBgPrimary}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="140" />
                        <DataGridTextColumn Header="Ürün Adı" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Fiyat (TL)" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="120" />
                        <DataGridTextColumn Header="Stok" Binding="{Binding Stock}" Width="80" />
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
                <!-- Empty State -->
                <TextBlock Text="Urun bulunamadi"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,40"
                           Opacity="0.5"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           IsVisible="{Binding !PreviewItems.Count}" />
            </Grid>
            </Border>

            <!-- Validation Errors -->
            <Border Grid.Row="2" Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="12" Margin="0,12,0,0"
                    IsVisible="{Binding ErrorCount}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Doğrulama Uyarıları" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" Foreground="{DynamicResource MesAmber}" />
                    <ItemsControl ItemsSource="{Binding ValidationErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesRedDark}" Padding="4,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesOverlayLight}" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Feed okunuyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Feed bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz feed bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}" IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
