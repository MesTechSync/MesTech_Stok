<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ImportSettingsAvaloniaView"
             x:DataType="vm:ImportSettingsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Icerik Aktarma Ayarlari — kolon eslestirme sablon yonetimi -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="İçe Aktarma Şablonları" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} şablon'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Şablon"
                        ToolTip.Tip="+ Yeni Sablon"
                        Command="{Binding CreateTemplateCommand}"
                        Background="{DynamicResource MesGreenMaterial}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content: Template List or Edit Mode -->
        <Grid Grid.Row="1">

            <!-- Template List (when not editing) -->
            <DataGrid ItemsSource="{Binding Templates}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource MesBgPrimary}"
                      Margin="16"
                      IsVisible="{Binding !IsEditing}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Şablon Adı" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="100" />
                    <DataGridTextColumn Header="Alan Sayısı" Binding="{Binding FieldCount}" Width="100" />
                    <DataGridTextColumn Header="Son Kullanım" Binding="{Binding LastUsed}" Width="140" />
                    <DataGridTemplateColumn Header="İşlem" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:ImportTemplateDto">
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                    <Button Content="Düzenle"
                                            ToolTip.Tip="Duzenle"
                                            Command="{Binding $parent[DataGrid].((vm:ImportSettingsAvaloniaViewModel)DataContext).EditTemplateCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                                            FontSize="{StaticResource FontSizeCaption}" Padding="8,3" CornerRadius="{StaticResource MesRadiusSm}" />
                                    <Button Content="Sil"
                                            ToolTip.Tip="Sil"
                                            Command="{Binding $parent[DataGrid].((vm:ImportSettingsAvaloniaViewModel)DataContext).DeleteTemplateCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource MesBgDangerLight}" Foreground="{DynamicResource MesRedAlert}"
                                            FontSize="{StaticResource FontSizeCaption}" Padding="8,3" CornerRadius="{StaticResource MesRadiusSm}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
<!-- Empty State -->        <TextBlock Text="Icerik bulunamadi"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !Templates.Count}" />

            <!-- Edit Mode -->
            <ScrollViewer IsVisible="{Binding IsEditing}" Padding="24">
                <StackPanel MaxWidth="600" Spacing="16">
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Şablon Düzenle" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="Şablon Adı" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding EditTemplateName}" Padding="10,8" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Alan Eşleştirmeleri" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <Button Grid.Column="1" Content="+ Ekle" Command="{Binding AddFieldMappingCommand}"
                                        ToolTip.Tip="+ Ekle"
                                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" Padding="8,4" CornerRadius="{StaticResource MesRadiusSm}" FontSize="{StaticResource FontSizeSmall}" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding EditMappings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ImportFieldMappingDto">
                                        <Grid ColumnDefinitions="*,Auto,*,Auto" Margin="0,4">
                                            <TextBox Grid.Column="0" Text="{Binding SourceColumn}" Watermark="Kaynak" AutomationProperties.Name="Kaynak" Padding="8,6" Margin="0,0,6,0" />
                                            <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center" Foreground="{DynamicResource MesMutedGray}" Margin="4,0" />
                                            <TextBox Grid.Column="2" Text="{Binding TargetField}" Watermark="Hedef" AutomationProperties.Name="Hedef" Padding="8,6" Margin="0,0,6,0" />
                                            <Button Grid.Column="3" Content="X" FontSize="{StaticResource FontSizeCaption}"
                                                    ToolTip.Tip="X"
                                                    Command="{Binding $parent[ItemsControl].((vm:ImportSettingsAvaloniaViewModel)DataContext).RemoveFieldMappingCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource MesBgDangerLight}" Foreground="{DynamicResource MesRedAlert}"
                                                    Padding="6,2" CornerRadius="{StaticResource MesRadiusSm}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet" Command="{Binding SaveTemplateCommand}"
                                Background="{DynamicResource MesGreenMaterial}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                Padding="20,10" CornerRadius="{StaticResource MesRadiusBase}" IsEnabled="{Binding !IsSaving}" />
                        <Button Content="İptal" Command="{Binding CancelEditCommand}"
                                ToolTip.Tip="Iptal"
                                Background="{DynamicResource MesMutedGray}" Foreground="{DynamicResource MesBgPrimary}" Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Sablonlar yukleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgSurface}" IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Şablon Bulunamadı" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Henüz içe aktarma şablonu tanımlanmamış"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
