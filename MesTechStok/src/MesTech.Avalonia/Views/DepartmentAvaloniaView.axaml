<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.DepartmentAvaloniaView"
             x:DataType="vm:DepartmentAvaloniaViewModel">

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Departmanlar" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} departman'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Departman"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Loading -->
            <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Error -->
            <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}" Margin="22"
                    CornerRadius="8" Padding="16" BorderBrush="{DynamicResource MesBorderDanger}" BorderThickness="1"
                    VerticalAlignment="Top">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" TextWrapping="Wrap" />
            </Border>

            <!-- Empty -->
            <TextBlock Text="Henuz departman bulunmuyor."
                       IsVisible="{Binding IsEmpty}" Foreground="{DynamicResource MesMutedGray}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />

            <!-- Department Cards -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding !IsLoading}">
                <ItemsControl ItemsSource="{Binding Departments}" Margin="22">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:DepartmentItemVm">
                            <Border Width="280" Margin="0,0,12,12" Padding="20"
                                    Background="White" CornerRadius="10"
                                    BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Yonetici:" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBlock Text="{Binding Manager}" FontSize="12" Foreground="{DynamicResource MesPrimaryBlue}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="Calisan:" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBlock Text="{Binding EmployeeCount}" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <Border Background="{DynamicResource MesBgSurface}" CornerRadius="4" Padding="8,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{DynamicResource MesGreen}" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
