<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.MultiTenantAvaloniaView"
             x:Name="MultiTenantAvaloniaView"
             x:DataType="vm:MultiTenantAvaloniaViewModel"
             AutomationProperties.Name="Multi-Tenant Yonetimi">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-12: Multi-Tenant Yonetimi — tenant listesi + secim + ayarlar -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Multi-Tenant Yonetimi" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="16">

                <!-- Active Tenant Card -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Aktif Tenant" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding ActiveTenantName}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding ActiveTenantId, StringFormat='ID: {0}'}"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusSm}" Padding="12,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="Aktif" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" Foreground="{DynamicResource MesTeal}" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Tenant List -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Tum Tenantlar" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                <Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Tenants}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource MesBgPrimary}"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tenant Adi" Binding="{Binding Name}" Width="200" />
                                <DataGridTextColumn Header="Veritabani" Binding="{Binding Database}" Width="180" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="100" />
                                <DataGridTextColumn Header="Olusturma Tarihi" Binding="{Binding CreatedAt}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayit bulunamadi" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,40" Opacity="0.5" FontSize="{StaticResource FontSizeTitle}"
                               Foreground="{DynamicResource MesMutedGray}"
                               IsVisible="{Binding !Tenants.Count}" />
                </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Tenant bilgileri yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Tenant bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz tenant kaydi bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
