<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.MultiTenantAvaloniaView"
             x:DataType="vm:MultiTenantAvaloniaViewModel">

    <!-- EMR-12: Multi-Tenant Yonetimi — tenant listesi + secim + ayarlar -->

    <Grid RowDefinitions="Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Multi-Tenant Yonetimi" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="16">

                <!-- Active Tenant Card -->
                <Border Background="White" CornerRadius="8" Padding="20"
                        BorderBrush="#E0E6ED" BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Aktif Tenant" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding ActiveTenantName}" FontSize="20" FontWeight="Bold"
                                       Foreground="#1E293B" />
                            <TextBlock Text="{Binding ActiveTenantId, StringFormat='ID: {0}'}"
                                       FontSize="13" Foreground="#64748B" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="4" Padding="12,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="Aktif" FontSize="13" FontWeight="SemiBold" Foreground="#059669" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Tenant List -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="#E0E6ED" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
                            <TextBlock Text="Tum Tenantlar" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#1E293B" />
                        </Border>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Tenants}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="White"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tenant Adi" Binding="{Binding Name}" Width="200" />
                                <DataGridTextColumn Header="Veritabani" Binding="{Binding Database}" Width="180" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="100" />
                                <DataGridTextColumn Header="Olusturma Tarihi" Binding="{Binding CreatedAt}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Tenant bilgileri yukleniyor..."
                           FontSize="14" Foreground="#555555" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
