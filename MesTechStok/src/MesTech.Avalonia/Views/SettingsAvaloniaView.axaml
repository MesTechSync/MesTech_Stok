<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.SettingsAvaloniaView"
             x:Name="SettingsAvaloniaView"
             x:DataType="vm:SettingsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Avalonia port — Ayarlar (Settings) -->
    <!-- Tab-like sections: API Ayarlari, Bildirimler, Tema -->
    <!-- Brand color #0078D4 -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Ayarlar" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1" Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet"
                        Command="{Binding SaveCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <TextBlock Grid.Column="2" Text="{Binding AppVersion}"
                           Foreground="{DynamicResource MesOverlayLight}" FontSize="{StaticResource FontSizeSmall}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="24" MaxWidth="640">

                <!-- Save Success Message -->
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="14,10"
                        IsVisible="{Binding IsSaved}"
                        BorderBrush="{DynamicResource MesBorderSuccess}" BorderThickness="1">
                    <TextBlock Text="Ayarlar basariyla kaydedildi."
                               Foreground="{DynamicResource MesTeal}" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" />
                </Border>

                <!-- Section 1: API Ayarlari -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="API Ayarlari" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Platform API baglanti yapilandirmasi"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="API URL" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBox Text="{Binding ApiUrl}"
                                     Watermark="https://api.mestech.com/v1" AutomationProperties.Name="https://api.mestech.com/v1"
                                     Padding="12,10" CornerRadius="{StaticResource MesRadiusMd}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="API Key" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBox Text="{Binding ApiKey}"
                                     Watermark="API anahtarinizi giriniz" AutomationProperties.Name="API anahtarinizi giriniz"
                                     PasswordChar="●"
                                     Padding="12,10" CornerRadius="{StaticResource MesRadiusMd}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="Test Baglanti"
                                    ToolTip.Tip="Test Baglanti"
                                    Command="{Binding TestConnectionCommand}"
                                    Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                                    FontWeight="SemiBold"
                                    Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />

                            <!-- Connection Result -->
                            <TextBlock Text="{Binding ConnectionMessage}"
                                       FontSize="{StaticResource FontSizeCallout}" VerticalAlignment="Center"
                                       IsVisible="{Binding IsConnectionTested}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section 2: Platform Kimlik Bilgileri (G017) -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Platform API Anahtarlari" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Pazaryeri entegrasyon kimlik bilgileri"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Platform Ekle" ToolTip.Tip="Yeni platform ekle"
                                        Command="{Binding AddPlatformCommand}"
                                        Background="{DynamicResource StatusSuccessBrush}" Foreground="{DynamicResource MesBgPrimary}"
                                        FontWeight="SemiBold" Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" />
                            </StackPanel>
                        </Grid>

                        <DataGrid ItemsSource="{Binding PlatformCredentials}"
                                  SelectedItem="{Binding SelectedCredential}"
                                  AutoGenerateColumns="False" CanUserSortColumns="True"
                                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                                  BorderThickness="0" MinHeight="180"
                                  IsVisible="{Binding PlatformCredentials.Count}"
                                  Background="{DynamicResource MesBgPrimary}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="160" />
                                <DataGridTextColumn Header="API Key" Binding="{Binding ApiKey}" Width="200" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="160" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <!-- Empty state — platform listesi bos -->
                        <Border IsVisible="{Binding !PlatformCredentials.Count}"
                                Background="{DynamicResource MesBgSecondary}" CornerRadius="{StaticResource MesRadiusBase}"
                                Padding="24" MinHeight="120" HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="📦" FontSize="32" HorizontalAlignment="Center" />
                                <TextBlock Text="Hicbir platform yapilandirilmamis"
                                           FontSize="14" Foreground="{DynamicResource MesTextSecondary}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Yukaridaki 'Platform Ekle' butonuyla baslayin."
                                           FontSize="12" Foreground="{DynamicResource MesTextTertiary}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Duzenle" ToolTip.Tip="Secili platform ayarlarini duzenle"
                                    Command="{Binding EditCredentialCommand}"
                                    Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                                    FontWeight="SemiBold" Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" />
                            <Button Content="Test Et" ToolTip.Tip="API baglanti testi"
                                    Command="{Binding TestPlatformConnectionCommand}"
                                    Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" />
                            <Button Content="Kaldir" ToolTip.Tip="Platformu kaldir"
                                    Command="{Binding RemoveCredentialCommand}"
                                    Foreground="{DynamicResource StatusDangerBrush}"
                                    Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section 3: Bildirimler -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Bildirimler" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Bildirim kanali tercihleri"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="E-posta Bildirimleri" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Siparis ve stok uyarilari e-posta ile gonderilir"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEmailEnabled}"
                                          OnContent="" OffContent=""  AutomationProperties.Name="Siparis ve stok uyarilari e-posta ile gonderilir"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource MesBgMist}" />

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="SMS Bildirimleri" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Kritik stok uyarilari SMS ile gonderilir"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsSmsEnabled}"
                                          OnContent="" OffContent=""  AutomationProperties.Name="Kritik stok uyarilari SMS ile gonderilir"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource MesBgMist}" />

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Push Bildirimleri" FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Anlık bildirimler masaustu uygulamasinda gosterilir"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsPushEnabled}"
                                          OnContent="" OffContent=""  AutomationProperties.Name="Push Bildirimleri"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section 3: Tema -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Tema" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Uygulama gorunum tercihi"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <!-- G116: Theme switcher with 3 options + visual indicator -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="☀ Acik" Padding="16,10" CornerRadius="12"
                                    FontWeight="SemiBold" FontSize="{StaticResource FontSizeSmall}"
                                    Command="{Binding SetThemeCommand}" CommandParameter="Light"
                                    Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesDarkSlate}" />
                            <Button Content="🌙 Koyu" Padding="16,10" CornerRadius="12"
                                    FontWeight="SemiBold" FontSize="{StaticResource FontSizeSmall}"
                                    Command="{Binding SetThemeCommand}" CommandParameter="Dark"
                                    Background="{DynamicResource MesDarkSlate}" Foreground="{DynamicResource MesBgPrimary}" />
                            <Button Content="💻 Sistem" Padding="16,10" CornerRadius="12"
                                    FontWeight="SemiBold" FontSize="{StaticResource FontSizeSmall}"
                                    Command="{Binding SetThemeCommand}" CommandParameter="System"
                                    Background="{DynamicResource MesPrimaryBlue}" Foreground="White" />
                        </StackPanel>
                        <TextBlock FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesTextTertiary}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}Secili tema: {0}">
                                    <Binding Path="SelectedTheme" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Ayarlar yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
