<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ContactAvaloniaView"
             x:DataType="vm:ContactAvaloniaViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Kisiler" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Kisi"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="260" Watermark="Isim, e-posta veya telefon ara..."
                         Text="{Binding SearchText}" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Loading -->
            <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                       Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Error -->
            <Border IsVisible="{Binding HasError}" Background="#FEF2F2" Margin="22"
                    CornerRadius="8" Padding="16" BorderBrush="#FECACA" BorderThickness="1"
                    VerticalAlignment="Top">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap" />
            </Border>

            <!-- Empty -->
            <TextBlock Text="Henuz kisi bulunmuyor."
                       IsVisible="{Binding IsEmpty}" Foreground="#94A3B8"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />

            <!-- Data Grid -->
                <Grid>
            <DataGrid ItemsSource="{Binding Contacts}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="White"
                      IsVisible="{Binding !IsLoading}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ad Soyad" Binding="{Binding FullName}" Width="180" />
                    <DataGridTextColumn Header="Sirket" Binding="{Binding Company}" Width="150" />
                    <DataGridTextColumn Header="E-posta" Binding="{Binding Email}" Width="200" />
                    <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="140" />
                    <DataGridTextColumn Header="Sehir" Binding="{Binding City}" Width="110" />
                    <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="16"
                               IsVisible="{Binding !Contacts.Count}" />
                </Grid>
        </Grid>
    </Grid>
</UserControl>
