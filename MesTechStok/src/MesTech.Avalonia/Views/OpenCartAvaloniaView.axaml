<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.OpenCartAvaloniaView"
             x:Name="RootOpenCartAvaloniaView"
             x:DataType="vm:OpenCartAvaloniaViewModel"
             AutomationProperties.Name="OpenCart Entegrasyonu">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="OpenCart Entegrasyonu" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesOverlayLight}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2"
                            IsVisible="{Binding IsConnected}">
                        <TextBlock Text="Bagli" Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2"
                            IsVisible="{Binding !IsConnected}">
                        <TextBlock Text="Bagli Degil" Foreground="{DynamicResource MesRedBright}" FontSize="{StaticResource FontSizeSmall}"
                                   VerticalAlignment="Center" />
                    </Border>
                    <!-- Store Selector -->
                    <ComboBox ItemsSource="{Binding Stores}"
                              SelectedItem="{Binding SelectedStore}"
                              MinWidth="160"
                              VerticalAlignment="Center"
                              Background="{DynamicResource MesOverlayLight}"
                              Foreground="{DynamicResource MesBgPrimary}"
                              BorderThickness="0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Senkronize Et" ToolTip.Tip="Platform verilerini senkronize et" Command="{Binding SyncCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesOverlayLight}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- KPI Cards -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="16">
            <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Margin="6"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" ClipToBounds="True">
                <Grid ColumnDefinitions="6,*">
                    <Border Grid.Column="0" Background="{DynamicResource MesBrandOpenCart}" />
                    <StackPanel Grid.Column="1" Margin="16">
                        <TextBlock Text="Toplam Urun" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding ProductCount}"
                                   FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesBrandOpenCart}"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="OpenCart'taki urun sayisi"
                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Margin="6"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" ClipToBounds="True">
                <Grid ColumnDefinitions="6,*">
                    <Border Grid.Column="0" Background="{DynamicResource MesEmerald}" />
                    <StackPanel Grid.Column="1" Margin="16">
                        <TextBlock Text="Aktif Siparis" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding OrderCount}"
                                   FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesEmerald}"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Bekleyen siparis sayisi"
                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Margin="6"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" ClipToBounds="True">
                <Grid ColumnDefinitions="6,*">
                    <Border Grid.Column="0" Background="{DynamicResource MesAmber}" />
                    <StackPanel Grid.Column="1" Margin="16">
                        <TextBlock Text="Gunluk Ciro" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding DailyRevenue, StringFormat='₺{0:N0}'}"
                                   FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesAmber}"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Bugunku toplam ciro"
                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="3" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Margin="6"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" ClipToBounds="True">
                <Grid ColumnDefinitions="6,*">
                    <Border Grid.Column="0" Background="{DynamicResource MesPrimaryBlue}" />
                    <StackPanel Grid.Column="1" Margin="16">
                        <TextBlock Text="Stok Senkron" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding SyncStatus}"
                                   FontSize="{StaticResource FontSizeH3}" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="{Binding LastSyncTime, StringFormat='Son: {0}'}"
                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- TabControl -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Margin="22,0,22,22"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}" Background="Transparent" Padding="0">

                <!-- Tab 1: Ürünler -->
                <TabItem Header="Ürünler" Padding="16,10">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,10"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="OpenCart Ürünleri" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <Button Grid.Column="1" Content="Senkronize Et" Command="{Binding SyncCommand}"
                                        ToolTip.Tip="Urunleri senkronize et"
                                        Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}"
                                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" />
                            </Grid>
                        </Border>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Products}"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource MesBgPrimary}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" />
                                <DataGridTextColumn Header="Ürün Adı" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Fiyat" Binding="{Binding Price, StringFormat='₺{0:N2}'}" Width="130" />
                                <DataGridTextColumn Header="Stok" Binding="{Binding Stock}" Width="80" />
                                <DataGridTextColumn Header="MesTech'te Var mı?" Binding="{Binding InMesTechDisplay}" Width="140" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Tab 2: Siparişler -->
                <TabItem Header="Siparişler" Padding="16,10">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,10"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                <TextBlock Text="OpenCart Siparişleri" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding SearchText}" Watermark="Ara..." AutomationProperties.Name="Ara..."
                                         Width="240" Padding="10,8"
                                         CornerRadius="{StaticResource MesRadiusMd}"
                                         FontSize="{StaticResource FontSizeBody}" Margin="12,0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}"
                                           VerticalAlignment="Center" Margin="8,0" />
                                <Button Grid.Column="3" Content="Senkronize Et" Command="{Binding SyncCommand}"
                                        ToolTip.Tip="Siparisleri senkronize et"
                                        Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}"
                                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" />
                            </Grid>
                        </Border>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Orders}"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource MesBgPrimary}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderNumber}" Width="200" />
                                <DataGridTextColumn Header="Tarih" Binding="{Binding OrderDate}" Width="120" />
                                <DataGridTextColumn Header="Musteri" Binding="{Binding CustomerName}" Width="*" />
                                <DataGridTextColumn Header="Tutar" Binding="{Binding TotalAmount}" Width="150" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="130" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Tab 3: Kategoriler -->
                <TabItem Header="Kategoriler" Padding="16,10">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,10"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Platform ↔ MesTech Kategori Eşleme" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <Button Grid.Column="1" Content="Senkronize Et" Command="{Binding SyncCommand}"
                                        ToolTip.Tip="Kategorileri senkronize et"
                                        Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}"
                                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" />
                            </Grid>
                        </Border>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding CategoryMappings}"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource MesBgPrimary}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Platform Kategorisi" Binding="{Binding PlatformCategory}" Width="*" />
                                <DataGridTextColumn Header="MesTech Kategorisi" Binding="{Binding MesTechCategory}" Width="*" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding MappedDisplay}" Width="140" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Tab 4: Ayarlar -->
                <TabItem Header="Ayarlar" Padding="16,10">
                    <ScrollViewer>
                        <StackPanel Margin="24" Spacing="16" MaxWidth="560">
                            <TextBlock Text="Bağlantı Ayarları" FontSize="{StaticResource FontSizeSubtitle}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />

                            <!-- URL -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Mağaza URL" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesCoolGray}" />
                                <TextBox Text="{Binding StoreUrl}"
                                         Watermark="https://mymağaza.com"
                                         Padding="12,8"
                                         CornerRadius="{StaticResource MesRadiusBase}" />
                            </StackPanel>

                            <!-- API Key (masked) -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="API Key" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesCoolGray}" />
                                <TextBox Text="{Binding ApiKey}"
                                         PasswordChar="*"
                                         Watermark="OpenCart API anahtarını girin"
                                         Padding="12,8"
                                         CornerRadius="{StaticResource MesRadiusBase}" />
                            </StackPanel>

                            <!-- Test Connection -->
                            <Button Content="Bağlantı Test" Command="{Binding TestConnectionCommand}"
                                    ToolTip.Tip="OpenCart API baglanti testi yap"
                                    Padding="16,9" CornerRadius="{StaticResource MesRadiusBase}"
                                    Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                                    FontWeight="SemiBold" HorizontalAlignment="Left" />

                            <!-- Result badge -->
                            <Border IsVisible="{Binding ConnectionTestRan}"
                                    CornerRadius="{StaticResource MesRadiusBase}" Padding="12,8"
                                    Background="{DynamicResource MesEmerald}"
                                    IsEnabled="{Binding ConnectionTestSuccess}">
                                <Border.Styles>
                                    <Style Selector="Border">
                                        <Setter Property="Background" Value="{DynamicResource MesBgDangerLight}" />
                                    </Style>
                                    <Style Selector="Border[IsEnabled=True]">
                                        <Setter Property="Background" Value="{DynamicResource MesBgSuccessLight}" />
                                    </Style>
                                </Border.Styles>
                                <TextBlock Text="{Binding ConnectionTestResult}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Border>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="True" ShowChart="True" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Veri bulunamadi" FontSize="{StaticResource FontSizeTitle}"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesMutedGray}" Margin="0,0,0,8" />
                <TextBlock Text="OpenCart entegrasyonundan henuz veri cekilemedi"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" />
                <Button Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Margin="0,16,0,0" Padding="16,8" />
            </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>
    </Grid>
</UserControl>
