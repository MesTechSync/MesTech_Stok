<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.DocumentsAvaloniaView"
             x:Name="RootDocumentsAvaloniaView"
             x:DataType="vm:DocumentsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPurple}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Belge Yonetimi" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} belge'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPurple}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Watermark="Belge adi, tipi veya klasor ara..." AutomationProperties.Name="Belge adi, tipi veya klasor ara..."
                         Text="{Binding SearchText}" Width="280" HorizontalAlignment="Left" />
                <ComboBox Grid.Column="1" PlaceholderText="Belge Tipi" Width="140" Margin="8,0"  AutomationProperties.Name="Belge Tipi" />
                <Button Grid.Column="2" Content="+ Belge Yukle" Command="{Binding UploadCommand}"
                        Background="{DynamicResource MesPurple}" Foreground="{DynamicResource MesBgPrimary}"
                        ToolTip.Tip="Yeni belge yukle"
                        FontWeight="SemiBold" Padding="12,6" CornerRadius="{StaticResource MesRadiusSm}" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2" Margin="16">
            <!-- Loading Skeleton -->
            <Border
                    Background="{DynamicResource MesBgPage}"
                    IsVisible="{Binding IsLoading}"
                    ZIndex="100">
                <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
            </Border>

            <!-- Main Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">

                    <!-- Summary Card -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Belge Yonetimi" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding Summary}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Document Categories -->
                    <Grid ColumnDefinitions="*,*,*,*" Margin="0,4,0,0">
                        <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="0,0,8,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="FATURALAR" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesPurple}" />
                                <TextBlock Text="Alis ve satis faturalari" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="4,0,4,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="IRSALIYELER" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesPrimaryBlue}" />
                                <TextBlock Text="Sevk ve teslimat belgeleri" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="4,0,4,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="SOZLESMELER" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesTeal}" />
                                <TextBlock Text="Tedarikci ve musteri sozlesmeleri" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="8,0,0,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="DIGER" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesAmber}" />
                                <TextBlock Text="Raporlar ve ek belgeler" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Empty Table Placeholder -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="24"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1" MinHeight="200">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="Belge listesi bos" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="Belgeler yuklendiginde burada listelenecek" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Belge bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz belge yuklenmemis" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
