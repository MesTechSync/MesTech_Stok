<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.PlatformMessagesAvaloniaView"
             x:DataType="vm:PlatformMessagesAvaloniaViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Platform Mesajlari" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} mesaj'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox Width="160" PlaceholderText="Durum"
                          ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedStatusFilter}" />
                <ComboBox Width="160" PlaceholderText="Platform"
                          ItemsSource="{Binding PlatformFilters}"
                          SelectedItem="{Binding SelectedPlatformFilter}" />
            </StackPanel>
        </Border>

        <!-- Content: Master-Detail -->
        <Grid Grid.Row="2">
            <!-- Loading -->
            <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                       Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Error -->
            <Border IsVisible="{Binding HasError}" Background="#FEF2F2" Margin="22"
                    CornerRadius="8" Padding="16" BorderBrush="#FECACA" BorderThickness="1"
                    VerticalAlignment="Top">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap" />
            </Border>

            <!-- Empty -->
            <TextBlock Text="Mesaj bulunmuyor."
                       IsVisible="{Binding IsEmpty}" Foreground="#94A3B8"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />

            <!-- Master-Detail Layout -->
            <Grid ColumnDefinitions="360,*" IsVisible="{Binding !IsLoading}">

                <!-- Left: Message List -->
                <Border Grid.Column="0" BorderBrush="#E5E9F2" BorderThickness="0,0,1,0">
                    <ListBox ItemsSource="{Binding Messages}"
                             SelectedItem="{Binding SelectedMessage}"
                             Background="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlatformMessageItemVm">
                                <Border Padding="12,10" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                        <!-- Platform Badge -->
                                        <Border Grid.Column="0" Grid.RowSpan="2"
                                                CornerRadius="4" Padding="6,2" Margin="0,0,10,0"
                                                VerticalAlignment="Top">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding PlatformColor}" />
                                            </Border.Background>
                                            <TextBlock Text="{Binding Platform}" Foreground="White"
                                                       FontSize="10" FontWeight="Bold" />
                                        </Border>
                                        <!-- Sender + Subject -->
                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{Binding SenderName}"
                                                   FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Grid.Column="1" Grid.Row="1"
                                                   Text="{Binding Subject}"
                                                   FontSize="11" Foreground="#64748B"
                                                   TextTrimming="CharacterEllipsis" />
                                        <!-- Time -->
                                        <TextBlock Grid.Column="2" Grid.Row="0"
                                                   Text="{Binding ReceivedAtDisplay}"
                                                   FontSize="10" Foreground="#94A3B8"
                                                   VerticalAlignment="Top" />
                                        <!-- AI indicator -->
                                        <TextBlock Grid.Column="2" Grid.Row="1"
                                                   Text="AI" FontSize="10" FontWeight="Bold"
                                                   Foreground="#8B5CF6"
                                                   IsVisible="{Binding HasAiSuggestion}"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Right: Message Detail -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" Spacing="16"
                                IsVisible="{Binding SelectedMessage, Converter={x:Static ObjectConverters.IsNotNull}}">

                        <!-- Message Header -->
                        <Border Background="White" CornerRadius="10" Padding="20"
                                BorderBrush="#E0E6ED" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding SelectedMessage.Subject}"
                                               FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <Border Grid.Column="1" CornerRadius="4" Padding="8,3">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding SelectedMessage.PlatformColor}" />
                                        </Border.Background>
                                        <TextBlock Text="{Binding SelectedMessage.Platform}"
                                                   Foreground="White" FontSize="11" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock FontSize="12" Foreground="#64748B">
                                        <Run Text="Gonderen: " />
                                        <Run Text="{Binding SelectedMessage.SenderName}" FontWeight="SemiBold" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding SelectedMessage.ReceivedAtDisplay}"
                                               FontSize="12" Foreground="#94A3B8" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Message Body -->
                        <Border Background="White" CornerRadius="10" Padding="20"
                                BorderBrush="#E0E6ED" BorderThickness="1">
                            <TextBlock Text="{Binding SelectedMessage.BodyPreview}"
                                       TextWrapping="Wrap" FontSize="13" LineHeight="22" />
                        </Border>

                        <!-- AI Suggestion Box -->
                        <Border Background="#F5F3FF" CornerRadius="10" Padding="16"
                                BorderBrush="#DDD6FE" BorderThickness="1"
                                IsVisible="{Binding SelectedMessage.AiSuggestedReply, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="MESA AI Onerisi" FontWeight="Bold" FontSize="13" Foreground="#7C3AED" />
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedMessage.AiSuggestedReply}"
                                           TextWrapping="Wrap" FontSize="12" Foreground="#4C1D95" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Kullan" Command="{Binding UseAiSuggestionCommand}"
                                            Background="#7C3AED" Foreground="White" Padding="12,6"
                                            CornerRadius="6" FontWeight="SemiBold" FontSize="12" />
                                    <Button Content="Yoksay" Command="{Binding DismissAiSuggestionCommand}"
                                            Background="#E5E7EB" Foreground="#374151" Padding="12,6"
                                            CornerRadius="6" FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Reply Box -->
                        <Border Background="White" CornerRadius="10" Padding="16"
                                BorderBrush="#E0E6ED" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Yanit Yaz" FontWeight="SemiBold" FontSize="13" />
                                <TextBox Text="{Binding ReplyText}"
                                         Watermark="Yanitinizi buraya yazin..."
                                         MinHeight="80"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap" />
                                <Button Content="Yanitla" Command="{Binding SendReplyCommand}"
                                        Background="#0078D4" Foreground="White" Padding="16,8"
                                        CornerRadius="6" FontWeight="SemiBold"
                                        HorizontalAlignment="Right"
                                        IsEnabled="{Binding !IsSendingReply}" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
