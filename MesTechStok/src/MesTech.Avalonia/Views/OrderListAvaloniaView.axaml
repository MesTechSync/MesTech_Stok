<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.OrderListAvaloniaView"
             x:DataType="vm:OrderListAvaloniaViewModel">

    <!-- EMR-12: Siparis Listesi — DataGrid + arama + filtre -->

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Siparis Listesi" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} siparis'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,12"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="360" Watermark="Siparis no, musteri adi ile arama..."
                         Text="{Binding SearchText}"
                         FontSize="14" Padding="10,8" />
                <Button Content="Ara" Command="{Binding RefreshCommand}"
                        Background="#0078D4" Foreground="White" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </StackPanel>
        </Border>

        <!-- Orders DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Orders}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="White"
                  Margin="16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderNumber}" Width="140" />
                <DataGridTextColumn Header="Musteri" Binding="{Binding CustomerName}" Width="200" />
                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="120" />
                <DataGridTextColumn Header="Tarih" Binding="{Binding OrderDate}" Width="120" />
                <DataGridTextColumn Header="Tutar" Binding="{Binding TotalAmount, StringFormat='{}{0:N2} TL'}" Width="120" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State -->
        <Border Grid.Row="2"
                Background="#F7F9FC"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Siparis Bulunamadi" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#1E293B" Margin="0,0,0,8" />
                <TextBlock Text="Arama kriterlerinize uygun siparis bulunamadi"
                           FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Siparisler yukleniyor..."
                           FontSize="14" Foreground="#555555" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
