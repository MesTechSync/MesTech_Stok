<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ActivityAvaloniaView"
             x:DataType="vm:ActivityAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Aktiviteler" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox Width="160" PlaceholderText="Aktivite tipi"
                          ItemsSource="{Binding FilterOptions}"
                          SelectedItem="{Binding SelectedFilter}" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22" Spacing="0">

                <!-- Loading -->
                <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                           Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" Margin="0,20" />

                <!-- Error -->
                <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}"
                        CornerRadius="{StaticResource MesRadiusMd}" Padding="16" BorderBrush="{DynamicResource MesBorderDanger}" BorderThickness="1">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" TextWrapping="Wrap" />
                </Border>

                <!-- Empty -->
                <TextBlock Text="Henuz aktivite bulunmuyor."
                           IsVisible="{Binding IsEmpty}" Foreground="{DynamicResource MesMutedGray}"
                           HorizontalAlignment="Center" Margin="0,40" FontSize="{StaticResource FontSizeBody}" />

                <!-- Timeline -->
                <ItemsControl ItemsSource="{Binding Activities}" IsVisible="{Binding !IsLoading}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ActivityItemVm">
                            <Border Margin="0,0,0,12" Padding="16" Background="{DynamicResource MesBgPrimary}"
                                    CornerRadius="{StaticResource MesRadiusMd}" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Icon -->
                                    <Border Grid.Column="0" Background="{DynamicResource MesPrimaryBlue}" CornerRadius="18"
                                            Width="36" Height="36" Margin="0,0,14,0">
                                        <TextBlock Text="{Binding TypeIcon}" Foreground="{DynamicResource MesBgPrimary}"
                                                   FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <!-- Content -->
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}" />
                                        <TextBlock Text="{Binding Description}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}"
                                                   TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding ContactName}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesPrimaryBlue}" />
                                            <TextBlock Text="|" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesBorderMuted}" />
                                            <TextBlock Text="{Binding CreatedBy}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- Time -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding TimeAgo}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}"
                                                   HorizontalAlignment="Right" />
                                        <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusSm}" Padding="6,2" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Type}" FontSize="{StaticResource FontSizeCaption1}" Foreground="{DynamicResource MesSlateGray}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
