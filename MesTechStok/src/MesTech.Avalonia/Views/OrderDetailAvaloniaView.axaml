<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.OrderDetailAvaloniaView"
             x:DataType="vm:OrderDetailAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-12: Siparis Detay — siparis bilgileri + kalem listesi -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Siparis Detay" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding OrderNumber, StringFormat='#{0}'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                    <Border CornerRadius="4" Padding="8,2"
                            Background="{Binding StatusColor}">
                        <TextBlock Text="{Binding OrderStatus}" FontSize="11"
                                   Foreground="White" FontWeight="Bold" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="16">

                <!-- Order Info Card -->
                <Border Background="White" CornerRadius="8" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                            <TextBlock Text="Musteri" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding CustomerName}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                            <TextBlock Text="Siparis Tarihi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding OrderDate}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                            <TextBlock Text="Toplam Tutar" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2} TL'}" FontSize="15"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MesTeal}" />
                        </StackPanel>
                        <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Platform" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding Platform}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Kargo Firmasi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding CargoCompany}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Takip No" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TrackingNumber}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Order Items DataGrid -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Siparis Kalemleri" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                <Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding OrderItems}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="White"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Urun Adi" Binding="{Binding ProductName}" Width="250" />
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" />
                                <DataGridTextColumn Header="Adet" Binding="{Binding Quantity}" Width="80" />
                                <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding UnitPrice, StringFormat='{}{0:N2} TL'}" Width="120" />
                                <DataGridTextColumn Header="Toplam" Binding="{Binding LineTotal, StringFormat='{}{0:N2} TL'}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="16"
                               IsVisible="{Binding !OrderItems.Count}" />
                </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Siparis detaylari yukleniyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
