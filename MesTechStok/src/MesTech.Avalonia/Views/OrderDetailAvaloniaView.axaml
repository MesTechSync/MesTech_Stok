<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.OrderDetailAvaloniaView"
             x:Name="RootOrderDetailAvaloniaView"
             x:DataType="vm:OrderDetailAvaloniaViewModel"
             AutomationProperties.Name="Siparis Detayi">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-12: Siparis Detay — siparis bilgileri + kalem listesi -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Siparis Detay" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding OrderNumber, StringFormat='#{0}'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                    <Border CornerRadius="{StaticResource MesRadiusSm}" Padding="8,2"
                            Background="{Binding OrderStatus, Converter={StaticResource StatusToColorConverter}}">
                        <TextBlock Text="{Binding OrderStatus}" FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Fatura Kes" ToolTip.Tip="Bu siparis icin fatura olustur"
                            Command="{Binding CreateInvoiceCommand}"
                            Background="{DynamicResource MesSuccessGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <TextBox Width="280" Watermark="Urun adi veya SKU ara..."
                     AutomationProperties.Name="Urun adi veya SKU ara..."
                     Text="{Binding SearchText}" HorizontalAlignment="Left" />
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" Padding="20">
            <StackPanel Spacing="16">

                <!-- Order Info Card -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                            <TextBlock Text="Musteri" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding CustomerName}" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                            <TextBlock Text="Siparis Tarihi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding OrderDate}" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="0" Spacing="4" Margin="0,0,0,12">
                            <TextBlock Text="Toplam Tutar" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TotalAmount, StringFormat='{}{0:N2} TL'}" FontSize="{StaticResource FontSizeBodyLg}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MesTeal}" />
                        </StackPanel>
                        <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Platform" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding Platform}" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Kargo Firmasi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding CargoCompany}" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Grid.Row="1" Spacing="4">
                            <TextBlock Text="Takip No" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TrackingNumber}" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Adres + Finans Detay -->
                <Grid ColumnDefinitions="*,*">
                    <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="0,0,8,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Teslimat Adresi" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding CustomerAddress}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="8,0,0,0">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ara Toplam" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SubTotal, StringFormat='{}{0:N2} TL'}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="KDV" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TaxAmount, StringFormat='{}{0:N2} TL'}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Toplam" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold" Foreground="{DynamicResource MesTeal}" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalAmount, StringFormat='{}{0:N2} TL'}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold" Foreground="{DynamicResource MesTeal}" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Odeme Durumu" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PaymentStatus}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" Margin="0,8,0,0" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Order Items DataGrid -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Siparis Kalemleri" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                <Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding OrderItems}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource MesBgPrimary}"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Urun Adi" Binding="{Binding ProductName}" Width="250" />
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" />
                                <DataGridTextColumn Header="Adet" Binding="{Binding Quantity}" Width="80" />
                                <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding UnitPrice, StringFormat='{}{0:N2} TL'}" Width="120" />
                                <DataGridTextColumn Header="Toplam" Binding="{Binding LineTotal, StringFormat='{}{0:N2} TL'}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayit bulunamadi"
                               FontSize="{StaticResource FontSizeTitle}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource MesMutedGray}"
                               IsVisible="{Binding !OrderItems.Count}"
                               Opacity="0.5" />
                </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Siparis bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz siparis bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>
    </Grid>
</UserControl>
