<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.CrmDashboardAvaloniaView"
             x:DataType="vm:CrmDashboardAvaloniaViewModel">

    <Grid RowDefinitions="Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="CRM Dashboard" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"
                           Grid.Column="0" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22" Spacing="16">

                <!-- Loading -->
                <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                           Foreground="#64748B" HorizontalAlignment="Center" Margin="0,20" />

                <!-- Error -->
                <Border IsVisible="{Binding HasError}" Background="#FEF2F2"
                        CornerRadius="8" Padding="16" BorderBrush="#FECACA" BorderThickness="1">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap" />
                </Border>

                <!-- Empty state -->
                <TextBlock Text="Henuz CRM verisi yok." IsVisible="{Binding IsEmpty}"
                           Foreground="#94A3B8" HorizontalAlignment="Center" FontSize="14" Margin="0,20" />

                <!-- KPI Cards Row 1 — 4 cards -->
                <UniformGrid Columns="4" IsVisible="{Binding !IsLoading}">
                    <!-- Total Customers -->
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Toplam Musteri" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding TotalCustomers}" FontSize="28" FontWeight="Bold" Foreground="#0078D4" />
                        </StackPanel>
                    </Border>
                    <!-- New This Month -->
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Aktif Musteri" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding NewThisMonth}" FontSize="28" FontWeight="Bold" Foreground="#10B981" />
                        </StackPanel>
                    </Border>
                    <!-- VIP Customers -->
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="VIP Musteri" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding VipCustomers}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" />
                        </StackPanel>
                    </Border>
                    <!-- Pipeline Value -->
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Pipeline Degeri" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding PipelineValue}" FontSize="20" FontWeight="Bold" Foreground="#8B5CF6" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- KPI Cards Row 2 — 4 cards -->
                <UniformGrid Columns="4" IsVisible="{Binding !IsLoading}">
                    <!-- Open Deals -->
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Acik Firsatlar" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding OpenDeals}" FontSize="28" FontWeight="Bold" Foreground="#3B82F6" />
                        </StackPanel>
                    </Border>
                    <!-- Unread Messages -->
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Okunmamis Mesaj" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding UnreadMessages}" FontSize="28" FontWeight="Bold" Foreground="#D32F2F" />
                        </StackPanel>
                    </Border>
                    <!-- Pending Replies -->
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Yanit Bekleyen" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding PendingReplies}" FontSize="28" FontWeight="Bold" Foreground="#F57C00" />
                        </StackPanel>
                    </Border>
                    <!-- Total Leads -->
                    <Border Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Potansiyel" FontSize="12" Foreground="#64748B" />
                            <TextBlock Text="{Binding TotalLeads}" FontSize="28" FontWeight="Bold" Foreground="#388E3C" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Pipeline Summary + Recent Activities -->
                <Grid ColumnDefinitions="*,*" IsVisible="{Binding !IsLoading}">
                    <!-- Pipeline Summary -->
                    <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Pipeline Ozeti" FontWeight="SemiBold" FontSize="15" />
                            <ItemsControl ItemsSource="{Binding PipelineSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CrmPipelineSummaryVm">
                                        <Border Margin="0,0,0,8" Padding="12" Background="#F8FAFC"
                                                CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,10,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding Color}" />
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Stage}" FontWeight="SemiBold" FontSize="13" />
                                                    <TextBlock Text="{Binding Count, StringFormat='{}{0} firsat'}"
                                                               FontSize="11" Foreground="#64748B" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Amount}"
                                                           FontWeight="Bold" FontSize="13" Foreground="#0078D4"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Recent Activities -->
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="4" Padding="16"
                            BorderBrush="#E0E6ED" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Son Aktiviteler" FontWeight="SemiBold" FontSize="15" />
                            <ItemsControl ItemsSource="{Binding RecentActivities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CrmRecentActivityVm">
                                        <Border Margin="0,0,0,8" Padding="12" Background="#F8FAFC"
                                                CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Border Grid.Column="0" Background="#0078D4" CornerRadius="14"
                                                        Width="28" Height="28" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding Type}"
                                                               Foreground="White" FontSize="9" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Description}" FontSize="13" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Time}" FontSize="11" Foreground="#64748B" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Last Updated -->
                <TextBlock Text="{Binding LastUpdated, StringFormat='Son guncelleme: {0}'}"
                           FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right"
                           IsVisible="{Binding !IsLoading}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
