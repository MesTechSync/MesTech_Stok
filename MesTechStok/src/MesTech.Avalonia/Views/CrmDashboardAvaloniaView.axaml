<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.CrmDashboardAvaloniaView"
             x:DataType="vm:CrmDashboardAvaloniaViewModel"
             AutomationProperties.Name="CRM Paneli">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="CRM Dashboard" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center"
                           Grid.Column="0" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22" Spacing="16">

                <!-- Loading -->
                <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                           Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" Margin="0,20" />

                <!-- Error -->
                <Border IsVisible="{Binding HasError}" Background="{DynamicResource MesBgDangerLight}"
                        CornerRadius="{StaticResource MesRadiusMd}" Padding="16" BorderBrush="{DynamicResource MesBorderDanger}" BorderThickness="1">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" TextWrapping="Wrap" />
                </Border>

                <!-- Empty state -->
                <TextBlock Text="Henuz CRM verisi yok." IsVisible="{Binding IsEmpty}"
                           Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center" FontSize="{StaticResource FontSizeBody}" Margin="0,20" />

                <!-- KPI Cards Row 1 — 4 cards -->
                <UniformGrid Columns="4" IsVisible="{Binding !IsLoading}">
                    <!-- Total Customers -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Toplam Musteri" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TotalCustomers}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" />
                        </StackPanel>
                    </Border>
                    <!-- New This Month -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Aktif Musteri" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding NewThisMonth}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesEmerald}" />
                        </StackPanel>
                    </Border>
                    <!-- VIP Customers -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="VIP Musteri" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding VipCustomers}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesAmber}" />
                        </StackPanel>
                    </Border>
                    <!-- Pipeline Value -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Pipeline Degeri" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding PipelineValue}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesPurple}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- KPI Cards Row 2 — 4 cards -->
                <UniformGrid Columns="4" IsVisible="{Binding !IsLoading}">
                    <!-- Open Deals -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Acik Firsatlar" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding OpenDeals}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" />
                        </StackPanel>
                    </Border>
                    <!-- Unread Messages -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Okunmamis Mesaj" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding UnreadMessages}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesRedAlert}" />
                        </StackPanel>
                    </Border>
                    <!-- Pending Replies -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Yanit Bekleyen" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding PendingReplies}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesAmber}" />
                        </StackPanel>
                    </Border>
                    <!-- Total Leads -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Potansiyel" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TotalLeads}" FontSize="{StaticResource FontSizeLargeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesGreenMaterial}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Pipeline Summary + Recent Activities -->
                <Grid ColumnDefinitions="*,*" IsVisible="{Binding !IsLoading}">
                    <!-- Pipeline Summary -->
                    <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Pipeline Ozeti" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBodyLg}" />
                            <ItemsControl ItemsSource="{Binding PipelineSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CrmPipelineSummaryVm">
                                        <Border Margin="0,0,0,8" Padding="12" Background="{DynamicResource MesBgPage}"
                                                CornerRadius="{StaticResource MesRadiusBase}" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,10,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding Color}" />
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Stage}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeCallout}" />
                                                    <TextBlock Text="{Binding Count, StringFormat='{}{0} firsat'}"
                                                               FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Amount}"
                                                           FontWeight="Bold" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesPrimaryBlue}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Recent Activities -->
                    <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Margin="4" Padding="16"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Son Aktiviteler" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBodyLg}" />
                            <ItemsControl ItemsSource="{Binding RecentActivities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CrmRecentActivityVm">
                                        <Border Margin="0,0,0,8" Padding="12" Background="{DynamicResource MesBgPage}"
                                                CornerRadius="{StaticResource MesRadiusBase}" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Border Grid.Column="0" Background="{DynamicResource MesPrimaryBlue}" CornerRadius="{StaticResource MesRadiusLgXl}"
                                                        Width="28" Height="28" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding Type}"
                                                               Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeCaption2}" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Description}" FontSize="{StaticResource FontSizeCallout}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Time}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Last Updated -->
                <TextBlock Text="{Binding LastUpdated, StringFormat='Son guncelleme: {0}'}"
                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Right"
                           IsVisible="{Binding !IsLoading}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
