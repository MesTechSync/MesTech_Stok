<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.AuditLogAvaloniaView"
             x:DataType="vm:AuditLogAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Denetim Kayitlari — İ-11 Görev 4C -->
    <!-- Filter bar, DataGrid, CSV export, detail panel -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Denetim Kayitlari" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1" Content="CSV Disari Aktar"
                        ToolTip.Tip="CSV Disari Aktar"
                        Command="{Binding ExportCsvCommand}"
                        Background="{DynamicResource MesBadgeOverlay}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Kullanici" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                    <ComboBox Width="180"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"  AutomationProperties.Name="Kullanici"/>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="Islem Tipi" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                    <ComboBox Width="140"
                              ItemsSource="{Binding ActionTypes}"
                              SelectedItem="{Binding SelectedAction}"  AutomationProperties.Name="Islem Tipi"/>
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="Baslangic" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                    <DatePicker SelectedDate="{Binding StartDate}" Width="150"  AutomationProperties.Name="Baslangic" />
                </StackPanel>
                <StackPanel Spacing="4">
                    <TextBlock Text="Bitis" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                    <DatePicker SelectedDate="{Binding EndDate}" Width="150"  AutomationProperties.Name="Bitis" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Export Success Message -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgSurface}" CornerRadius="0" Padding="12,8"
                IsVisible="{Binding IsExported}"
                BorderBrush="{DynamicResource MesBorderSuccess}" BorderThickness="0,0,0,1"
                Margin="0,52,0,0">
            <TextBlock Text="{Binding ExportMessage}"
                       Foreground="{DynamicResource MesTeal}" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" />
        </Border>

        <!-- Main Content: DataGrid + Detail Panel -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">

            <!-- Audit Log DataGrid -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding LogEntries}"
                      SelectedItem="{Binding SelectedEntry}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource MesBgPrimary}"
                      IsVisible="{Binding !IsLoading}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Zaman" Binding="{Binding Timestamp}" Width="150" />
                    <DataGridTextColumn Header="Kullanici" Binding="{Binding User}" Width="180" />
                    <DataGridTextColumn Header="Islem" Binding="{Binding Action}" Width="90" />
                    <DataGridTextColumn Header="Varlik Tipi" Binding="{Binding EntityType}" Width="100" />
                    <DataGridTextColumn Header="Varlik ID" Binding="{Binding EntityId}" Width="100" />
                    <DataGridTextColumn Header="Ozet" Binding="{Binding Summary}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty State: AuditLog -->
            <TextBlock Grid.Row="2"
                       Text="Kayıt bulunamadı"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,40"
                       Opacity="0.5"
                       FontSize="{StaticResource FontSizeSubtitle}"
                       IsVisible="{Binding !LogEntries.Count}" />

            <!-- Detail Panel -->
            <Border Grid.Column="1" Width="320" Background="{DynamicResource MesBgPrimary}"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1,0,0,0"
                    Padding="20" IsVisible="{Binding IsDetailVisible}">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Detay" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="X"
                                ToolTip.Tip="X"
                                Command="{Binding CloseDetailCommand}"
                                Background="Transparent" Foreground="{DynamicResource MesMutedGray}"
                                FontWeight="Bold" Padding="8,4" />
                    </Grid>

                    <Border Height="1" Background="{DynamicResource MesBorderLight}" />

                    <StackPanel Spacing="8" DataContext="{Binding SelectedEntry}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Zaman" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding Timestamp}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Kullanici" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding User}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Islem" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding Action}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Varlik" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}">
                                <Run Text="{Binding EntityType}" />
                                <Run Text=" / " />
                                <Run Text="{Binding EntityId}" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Ozet" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding Summary}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource MesBorderLight}" Margin="0,8" />

                        <!-- Old Values -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Eski Deger" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesRedAlert}" />
                            <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="{StaticResource MesRadiusBase}" Padding="12,8">
                                <TextBlock Text="{Binding OldValues}" FontSize="{StaticResource FontSizeCallout}"
                                           Foreground="{DynamicResource MesRedDark}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>

                        <!-- New Values -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Yeni Deger" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesGreen}" />
                            <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusBase}" Padding="12,8">
                                <TextBlock Text="{Binding NewValues}" FontSize="{StaticResource FontSizeCallout}"
                                           Foreground="{DynamicResource MesGreen}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Denetim kayitlari yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Kayit bulunamadi" FontSize="{StaticResource FontSizeTitle}"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesMutedGray}" Margin="0,0,0,8" />
                <TextBlock Text="Secili filtrelere uygun denetim kaydi bulunamadi"
                           FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
