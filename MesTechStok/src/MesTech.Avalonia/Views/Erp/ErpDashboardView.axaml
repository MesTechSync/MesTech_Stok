<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels.Erp"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.Erp.ErpDashboardView"
             x:Name="RootErpDashboardView"
             x:DataType="vm:ErpDashboardViewModel"
             AutomationProperties.Name="ERP Dashboard">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- E-01 ERP Dashboard — Provider cards + sync log -->
    <!-- Brand color #0078D4 -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="ERP Entegrasyon" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding ConnectedCount, StringFormat='{}{0} bagli'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile (F5)"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Provider Cards -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                      MaxHeight="260">
            <ItemsControl ItemsSource="{Binding Providers}" Margin="16,12,16,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource MesBgPrimary}"
                                CornerRadius="{StaticResource MesRadiusMd}"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                Padding="16" Margin="0,0,12,12" Width="220" MinHeight="180">
                            <StackPanel Spacing="8">
                                <!-- Provider Name -->
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           FontSize="{StaticResource FontSizeSubtitle}"
                                           Foreground="{DynamicResource MesTextPrimary}" />

                                <!-- Connection Status Badge -->
                                <Border CornerRadius="{StaticResource MesRadiusSm}" Padding="8,3"
                                        HorizontalAlignment="Left"
                                        Background="{Binding StatusBadgeBackground}">
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource MesBgPrimary}" FontWeight="Medium" />
                                </Border>

                                <!-- Last Sync -->
                                <TextBlock Text="{Binding LastSyncDisplay}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesTextMuted}" />

                                <!-- Buttons -->
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                    <Button Content="Test Baglanti" ToolTip.Tip="ERP baglanti testi yap"
                                            Command="{Binding $parent[ItemsControl].((vm:ErpDashboardViewModel)DataContext).TestConnectionCommand}"
                                            CommandParameter="{Binding Name}"
                                            Padding="10,5" FontSize="{StaticResource FontSizeSmall}"
                                            Background="{DynamicResource MesPrimaryBlue}"
                                            Foreground="{DynamicResource MesBgPrimary}"
                                            CornerRadius="{StaticResource MesRadiusSm}" />
                                    <Button Content="Ayarlar" ToolTip.Tip="ERP provider ayarlarina git"
                                            Command="{Binding $parent[ItemsControl].((vm:ErpDashboardViewModel)DataContext).OpenSettingsCommand}"
                                            CommandParameter="{Binding Name}"
                                            Padding="10,5" FontSize="{StaticResource FontSizeSmall}"
                                            Background="{DynamicResource MesBgSecondary}"
                                            Foreground="{DynamicResource MesTextPrimary}"
                                            CornerRadius="{StaticResource MesRadiusSm}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Sync Log DataGrid -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="16,0,16,16">
            <TextBlock Grid.Row="0" Text="Son Senkronizasyon Kayitlari"
                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimary}" Margin="0,8,0,8" />

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding SyncLogs}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource MesBgPrimary}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tarih" Binding="{Binding SyncTime}" Width="180" />
                    <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="140" />
                    <DataGridTextColumn Header="Yon" Binding="{Binding Direction}" Width="120" />
                    <DataGridTextColumn Header="Kayit Sayisi" Binding="{Binding RecordCount}" Width="120" />
                    <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="160" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty State for DataGrid -->
            <TextBlock Grid.Row="1" Text="Senkronizasyon kaydi bulunamadi"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,40" Opacity="0.5"
                       FontSize="{StaticResource FontSizeSubtitle}"
                       IsVisible="{Binding !SyncLogs.Count}" />
        </Grid>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="True" ShowChart="True" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <TextBlock Text="ERP verisi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}"
                           HorizontalAlignment="Center" Opacity="0.6" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <TextBlock Text="Hata Olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource MesErrorRed}" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource MesTextMuted}" TextWrapping="Wrap"
                           MaxWidth="400" HorizontalAlignment="Center" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Verileri tekrar yukle"
                        Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
