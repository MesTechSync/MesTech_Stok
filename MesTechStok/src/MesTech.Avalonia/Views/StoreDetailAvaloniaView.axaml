<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StoreDetailAvaloniaView"
             x:DataType="vm:StoreDetailAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Magaza Detay — magaza bilgi + sync gecmisi + adapter saglik -->

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Mağaza Detayı" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Store Info Card -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Margin="16,16,16,0" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
            <Grid ColumnDefinitions="*,*,*,*">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Mağaza" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBlock Text="{Binding StoreName}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Platform" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBlock Text="{Binding PlatformName}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesPrimaryBlue}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="Ürün Sayısı" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBlock Text="{Binding ProductCount, StringFormat='{}{0:N0}'}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Spacing="4">
                    <TextBlock Text="API Durumu" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBlock Text="{Binding ApiStatus}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesGreenMaterial}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sync History DataGrid -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" Margin="16" CornerRadius="{StaticResource MesRadiusMd}"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Senkronizasyon Geçmişi (Son 10)" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesDarkSlate}" Padding="16,12" />
                <DataGrid ItemsSource="{Binding SyncHistory}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" BorderThickness="0" Background="{DynamicResource MesBgPrimary}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Zaman" Binding="{Binding SyncTime}" Width="180" />
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120" />
                        <DataGridTextColumn Header="Senkronize Ürün" Binding="{Binding ProductsSynced, StringFormat='{}{0:N0}'}" Width="140" />
                        <DataGridTextColumn Header="Hata" Binding="{Binding Errors}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
                <!-- Empty State -->
                <TextBlock Text="Magaza bulunamadi" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,40" Opacity="0.5" FontSize="{StaticResource FontSizeBody}"
                           IsVisible="{Binding !IsLoading}" />
            </DockPanel>
        </Border>

        <!-- Adapter Health -->
        <Border Grid.Row="3" Background="{DynamicResource MesBgPrimary}" Margin="16,0,16,16" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="32">
                <StackPanel Spacing="2">
                    <TextBlock Text="Adapter Durumu" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBlock Text="{Binding AdapterHealth}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesGreenMaterial}" />
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Adapter Versiyon" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBlock Text="{Binding AdapterVersion}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesOverlayLight}" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Magaza detaylari yukleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
