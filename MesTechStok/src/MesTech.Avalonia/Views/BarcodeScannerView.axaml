<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.BarcodeScannerView"
             x:DataType="vm:BarcodeScannerViewModel">

    <!-- I-06 Gorev 1: Barkod Tarama Modu — tara > aninda sonuc > aksiyon -->

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPurple}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Barkod Tarama Modu" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding ScanSummary}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Temizle" Command="{Binding ClearCommand}"
                            Background="{DynamicResource MesBadgeOverlay}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="12,8" CornerRadius="6" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Barcode Input (USB HID wedge — auto-focus, Enter triggers search) -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,14"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Barkod / SKU:" VerticalAlignment="Center" FontSize="14"
                           Foreground="{DynamicResource MesTextSlate}" FontWeight="SemiBold" Margin="0,0,12,0" />
                <TextBox Grid.Column="1" Watermark="Barkod okutun veya SKU girin... (Enter ile tara)" AutomationProperties.Name="Barkod okutun veya SKU girin... (Enter ile tara)"
                         Text="{Binding ScanInput}"
                         FontSize="16" Padding="12,10"
                         Name="ScanInputBox" />
                <Button Grid.Column="2" Content="Tara" Command="{Binding ScanCommand}"
                        Background="{DynamicResource MesPurple}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="20,10" CornerRadius="6" Margin="12,0,0,0" />
            </Grid>
        </Border>

        <!-- Stats Bar -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgMist}" Padding="16,8"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="24">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Taranan:" FontSize="12" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalScanned}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Bulunan:" FontSize="12" Foreground="{DynamicResource MesGreen}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FoundCount}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource MesGreen}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Bulunamayan:" FontSize="12" Foreground="{DynamicResource MesRedBright}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding NotFoundCount}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource MesRedBright}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Son yanit:" FontSize="12" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LastResponseTime, StringFormat='{}{0} ms'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource MesPurple}" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Scan Results List -->
        <ScrollViewer Grid.Row="3" Padding="16">
            <ItemsControl ItemsSource="{Binding ScanResults}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ScanResultItem">
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="0,0,0,8"
                                BorderBrush="{Binding BorderColor}" BorderThickness="1,1,1,1">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Status Icon -->
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                        Background="{Binding IconBackground}" Margin="0,0,14,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusIcon}" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold" />
                                </Border>

                                <!-- Product Info -->
                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Barcode}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MesDarkSlate}" />
                                        <TextBlock Text="{Binding ProductName}" FontSize="14"
                                                   Foreground="{DynamicResource MesTextSlate}" IsVisible="{Binding Found}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="12" IsVisible="{Binding Found}">
                                        <TextBlock Text="{Binding StockText}" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBlock Text="{Binding PriceText}" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBlock Text="{Binding WarehouseName}" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <Border CornerRadius="{StaticResource MesRadiusSm}" Padding="6,1" Background="{Binding StockLevelColor}">
                                            <TextBlock Text="{Binding StockLevelText}" FontSize="10"
                                                       Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Urun bulunamadi" FontSize="12" Foreground="{DynamicResource MesRedBright}"
                                               IsVisible="{Binding !Found}" />
                                </StackPanel>

                                <!-- Response Time -->
                                <TextBlock Grid.Column="2" Text="{Binding ResponseTimeText}"
                                           FontSize="11" Foreground="{DynamicResource MesMutedGray}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Barkod taraniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="3" Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Barkod Taramaya Baslayin" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" />
                <TextBlock Text="USB barkod okuyucu ile tarayin veya SKU/barkod girin"
                           FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
                <TextBlock Text="Her tarama &lt; 200ms hedefi"
                           FontSize="12" Foreground="{DynamicResource MesPurple}"
                           HorizontalAlignment="Center" Opacity="0.6" Margin="0,4,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
