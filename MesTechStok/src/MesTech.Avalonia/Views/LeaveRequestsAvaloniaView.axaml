<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.LeaveRequestsAvaloniaView"
             x:Name="RootLeaveRequestsAvaloniaView"
             x:DataType="vm:LeaveRequestsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesTeal}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Izin Talepleri" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} talep'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Text="{Binding SearchText}"
                         Watermark="Ara..." AutomationProperties.Name="Ara..."
                         Width="240" Padding="10,8"
                         CornerRadius="{StaticResource MesRadiusMd}"
                         FontSize="{StaticResource FontSizeBody}" HorizontalAlignment="Left" />
                <ComboBox Grid.Column="1" PlaceholderText="Durum" Width="120" Margin="8,0"  AutomationProperties.Name="Durum" />
                <Button Grid.Column="2" Content="+ Yeni Talep" Command="{Binding AddCommand}"
                        Background="{DynamicResource MesTeal}" Foreground="{DynamicResource MesBgPrimary}"
                        ToolTip.Tip="Yeni izin talebi olustur"
                        FontWeight="SemiBold" Padding="12,6" CornerRadius="{StaticResource MesRadiusSm}" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2" Margin="16">
            <!-- Loading Skeleton -->
            <Border Background="{DynamicResource MesBgPage}" IsVisible="{Binding IsLoading}"
                    CornerRadius="{StaticResource MesRadiusMd}" ZIndex="10">
                <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
            </Border>

            <!-- Main Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">

                    <!-- Summary Card -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Izin Talepleri" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding Summary}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Leave Type Cards -->
                    <Grid ColumnDefinitions="*,*,*,*" Margin="0,4,0,0">
                        <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="0,0,8,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="IZIN BASVURUSU" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesTeal}" />
                                <TextBlock Text="Yeni izin talebi olusturma" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="4,0,4,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="ONAY SURECI" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesPrimaryBlue}" />
                                <TextBlock Text="Yonetici onay adimlari" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="4,0,4,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="YILLIK IZIN" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesPurple}" />
                                <TextBlock Text="Kalan ve kullanilan izin gunleri" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="8,0,0,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="TAKVIM" FontSize="{StaticResource FontSizeCaption}" FontWeight="DemiBold" Foreground="{DynamicResource MesAmber}" />
                                <TextBlock Text="Izin takvimi ve planlamasi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Empty Table Placeholder -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="24"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1" MinHeight="200">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="Izin talebi listesi bos" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="Izin talepleri yuklendiginde burada listelenecek" FontSize="{StaticResource FontSizeCallout}"
                                       Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Personel kaydi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz personel kaydi bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

</Grid>
</UserControl>
