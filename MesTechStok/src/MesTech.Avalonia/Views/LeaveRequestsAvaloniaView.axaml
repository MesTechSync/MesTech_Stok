<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.LeaveRequestsAvaloniaView"
             x:DataType="vm:LeaveRequestsAvaloniaViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0D9488" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Izin Talepleri" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} talep'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0D9488" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" Padding="16,10" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Watermark="Talep ara..." AutomationProperties.Name="Talep ara..." Width="250" HorizontalAlignment="Left" />
                <ComboBox Grid.Column="1" PlaceholderText="Durum" Width="120" Margin="8,0" />
                <Button Grid.Column="2" Content="+ Yeni Talep" Background="#0D9488" Foreground="White"
                        FontWeight="SemiBold" Padding="12,6" CornerRadius="4" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2" Margin="16">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        IsVisible="{Binding IsLoading}" Spacing="8">
                <TextBlock Text="Yukleniyor..." FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        IsVisible="{Binding !IsLoading}" Spacing="12">
                <Border Background="#F0FDFA" CornerRadius="50" Width="72" Height="72"
                        HorizontalAlignment="Center">
                    <TextBlock Text="&#x1F4C5;" FontSize="32"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Izin Talepleri" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Summary}" FontSize="13" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"
                           TextAlignment="Center" />
                <TextBlock Text="Izin basvurusu | Onay sureci | Yillik izin takibi | Takvim"
                           FontSize="11" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
                <Button Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Center" Padding="16,6" CornerRadius="4"
                        Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
