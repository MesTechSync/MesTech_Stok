<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels.Orders"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.Orders.OrderKanbanView"
             x:Name="RootOrderKanbanView"
             x:DataType="vm:OrderKanbanViewModel">
<UserControl.KeyBindings>
    <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
</UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Siparis Kanban" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH2}" FontWeight="Bold" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding PlatformFilters}"
                          SelectedItem="{Binding SelectedPlatform}"
                          PlaceholderText="Tum Platformlar" Width="160" Margin="8,0"  AutomationProperties.Name="Tum Platformlar"/>
                <Button Grid.Column="2" Content="Yenile" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Yenile"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}"
                        FontWeight="SemiBold" Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Kolon ozet bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,8"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
            <ItemsControl ItemsSource="{Binding ColumnSummaries}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding HeaderColor}" CornerRadius="{StaticResource MesRadiusSm}"
                                Padding="12,4" MinWidth="100">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding StatusName}" Foreground="{DynamicResource MesBgPrimary}"
                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeSmall}" />
                                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}"
                                        Padding="6,1" Opacity="0.9">
                                    <TextBlock Text="{Binding Count}" FontWeight="Bold"
                                               FontSize="{StaticResource FontSizeCaption}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Kanban Board -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" Margin="16,12">
            <ItemsControl ItemsSource="{Binding KanbanColumns}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="260" Background="{DynamicResource MesBgMist}"
                                CornerRadius="{StaticResource MesRadiusMd}" Padding="8">
                            <Grid RowDefinitions="Auto,*">
                                <!-- Kolon basligi -->
                                <Border Grid.Row="0" Background="{Binding HeaderColor}"
                                        CornerRadius="{StaticResource MesRadiusSm}" Padding="10,6" Margin="0,0,0,8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{Binding StatusName}" Foreground="{DynamicResource MesBgPrimary}"
                                                   FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Orders.Count, StringFormat='({0})'}"
                                                   Foreground="{DynamicResource MesBgPrimary}" Opacity="0.8"
                                                   FontSize="{StaticResource FontSizeSmall}" />
                                    </Grid>
                                </Border>

                                <!-- Siparis kartlari -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Orders}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource MesBgPrimary}"
                                                        CornerRadius="{StaticResource MesRadiusSm}"
                                                        Padding="10" Margin="0,0,0,6"
                                                        BorderBrush="{DynamicResource MesBorderLight}"
                                                        BorderThickness="1" Cursor="Hand"
                                                        BoxShadow="{DynamicResource MesElevation1}">
                                                    <StackPanel Spacing="4">
                                                        <!-- Ust: Platform + Siparis no -->
                                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                                            <Border Background="{Binding PlatformColor}"
                                                                    CornerRadius="{StaticResource MesRadiusSm}"
                                                                    Padding="6,2">
                                                                <TextBlock Text="{Binding PlatformShort}"
                                                                           Foreground="{DynamicResource MesBgPrimary}"
                                                                           FontSize="{StaticResource FontSizeCaption1}"
                                                                           FontWeight="Bold" />
                                                            </Border>
                                                            <TextBlock Grid.Column="1" Text="{Binding OrderNumber}"
                                                                       FontWeight="SemiBold" Margin="6,0"
                                                                       FontSize="{StaticResource FontSizeSmall}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="2" Text="{Binding TimeAgo}"
                                                                       FontSize="{StaticResource FontSizeCaption1}"
                                                                       Opacity="0.6" />
                                                        </Grid>
                                                        <!-- Musteri -->
                                                        <TextBlock Text="{Binding CustomerName}"
                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource MesSlateGray}" />
                                                        <!-- Alt: Tutar + Urun sayisi -->
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Text="{Binding TotalAmountText}"
                                                                       FontWeight="Bold"
                                                                       FontSize="{StaticResource FontSizeCallout}" />
                                                            <TextBlock Grid.Column="1" Text="{Binding ItemCountText}"
                                                                       FontSize="{StaticResource FontSizeCaption}"
                                                                       Opacity="0.6" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsVisible="{Binding IsEmpty}" Spacing="8">
            <TextBlock Text="Siparis bulunamadi" FontSize="{StaticResource FontSizeH3}"
                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
            <TextBlock Text="Secili filtrede siparis yok" FontSize="{StaticResource FontSizeBody}"
                       Foreground="{DynamicResource MesCoolGray}" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Loading -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Siparisler yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    
                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

${skeleton}
</Grid>
</UserControl>
