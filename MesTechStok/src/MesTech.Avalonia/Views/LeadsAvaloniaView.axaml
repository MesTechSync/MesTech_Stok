<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.LeadsAvaloniaView"
             x:Name="LeadsAvaloniaView"
             x:DataType="vm:LeadsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding LoadDataCommand}" />    </UserControl.KeyBindings>

    <!-- Avalonia port of WPF Views/Crm/LeadsView.xaml -->
    <!-- Key changes:
         - xmlns → avaloniaui
         - md:HintAssist.Hint → Watermark
         - MaterialDesignOutlinedTextBox → Fluent default
         - MaterialDesignRaisedButton → Fluent default
         - ViewModel: LeadsAvaloniaViewModel (95% identical to WPF LeadsViewModel) -->

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Loading State -->
        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="3" Grid.Row="0" />

        <!-- Header Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Potansiyel Musteriler" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Lead"
                        ToolTip.Tip="+ Yeni Lead"
                        Command="{Binding CreateLeadCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="220" Watermark="Isim, e-posta veya telefon ara..." AutomationProperties.Name="Isim, e-posta veya telefon ara..."
                         Text="{Binding SearchText}" />
                <ComboBox Width="140" PlaceholderText="Durum"
                          ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}"  AutomationProperties.Name="Durum"/>
                <ComboBox Width="160" PlaceholderText="Kaynak"
                          ItemsSource="{Binding SourceOptions}"  AutomationProperties.Name="Kaynak"/>
            </StackPanel>
        </Border>

        <!-- Lead List -->
                <Grid>
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Leads}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Ad Soyad" Binding="{Binding FullName}" Width="180" />
                <DataGridTextColumn Header="Sirket" Binding="{Binding Company}" Width="150" />
                <DataGridTextColumn Header="E-posta" Binding="{Binding Email}" Width="200" />
                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="130" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="130" />
                <DataGridTextColumn Header="Kaynak" Binding="{Binding Source}" Width="110" />
                <DataGridTextColumn Header="Tarih" Binding="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Potansiyel musteri bulunamadi"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               IsVisible="{Binding !Leads.Count}" />
                </Grid>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Kisi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz kayitli kisi bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding LoadDataCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
