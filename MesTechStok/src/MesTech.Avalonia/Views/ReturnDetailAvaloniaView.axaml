<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ReturnDetailAvaloniaView"
             x:DataType="vm:ReturnDetailAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Iade Detay — I-05 -->

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesBrandAccent}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Iade Detay" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding IadeNo}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding Durum}"
                                   Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesAmber}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Background="White">
            <StackPanel Margin="24,20" Spacing="24">

                <!-- Info Cards Row -->
                <Grid ColumnDefinitions="*,*,*">
                    <!-- Siparis Bilgisi -->
                    <Border Grid.Column="0" Background="{DynamicResource MesBgPage}" CornerRadius="8" Padding="16" Margin="0,0,8,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Siparis Bilgisi" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding SiparisNo, StringFormat='Siparis: {0}'}" FontSize="13" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding Musteri, StringFormat='Musteri: {0}'}" FontSize="13" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding Platform, StringFormat='Platform: {0}'}" FontSize="13" Foreground="{DynamicResource MesTextSlate}" />
                        </StackPanel>
                    </Border>

                    <!-- Iade Bilgisi -->
                    <Border Grid.Column="1" Background="{DynamicResource MesBgPage}" CornerRadius="8" Padding="16" Margin="4,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Iade Bilgisi" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding Tutar, StringFormat='Tutar: {0:N2} TL'}" FontSize="13" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding Sebep, StringFormat='Sebep: {0}'}" FontSize="13" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding TalepTarihi, StringFormat='Tarih: {0:dd.MM.yyyy}'}" FontSize="13" Foreground="{DynamicResource MesTextSlate}" />
                        </StackPanel>
                    </Border>

                    <!-- Aciklama -->
                    <Border Grid.Column="2" Background="{DynamicResource MesBgPage}" CornerRadius="8" Padding="16" Margin="8,0,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Aciklama" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding Aciklama}" FontSize="13" Foreground="{DynamicResource MesTextSlate}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Timeline -->
                <Border Background="{DynamicResource MesBgPage}" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Iade Sureci" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Timeline}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4">
                                        <Ellipse Width="12" Height="12" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{DynamicResource MesEmerald}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Step}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MesDarkSlate}" />
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <Border Background="{DynamicResource MesBgPage}" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Islemler" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="Onayla" Command="{Binding ApproveCommand}"
                                    Background="{DynamicResource MesGreenMaterial}" Foreground="White" FontWeight="SemiBold"
                                    Padding="20,10" CornerRadius="6" />
                            <ComboBox Width="200"
                                      ItemsSource="{Binding RejectReasons}"
                                      SelectedItem="{Binding SelectedRejectReason}" />
                            <Button Content="Reddet" Command="{Binding RejectCommand}"
                                    Background="{DynamicResource MesRedBright}" Foreground="White" FontWeight="SemiBold"
                                    Padding="20,10" CornerRadius="6" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Iade detaylari yukleniyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
