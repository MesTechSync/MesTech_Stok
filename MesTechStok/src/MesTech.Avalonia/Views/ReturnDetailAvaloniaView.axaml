<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.ReturnDetailAvaloniaView"
             x:Name="RootReturnDetailAvaloniaView"
             x:DataType="vm:ReturnDetailAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Iade Detay — I-05 -->

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesBrandAccent}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Iade Detay" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding IadeNo}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding Durum}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesAmber}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <TextBox Width="280" Watermark="Siparis no, sebep veya durum ara..."
                     AutomationProperties.Name="Siparis no, sebep veya durum ara..."
                     Text="{Binding SearchText}" HorizontalAlignment="Left" />
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" Background="{DynamicResource MesBgPrimary}">
            <StackPanel Margin="24,20" Spacing="24">

                <!-- Info Cards Row -->
                <Grid ColumnDefinitions="*,*,*">
                    <!-- Siparis Bilgisi -->
                    <Border Grid.Column="0" Background="{DynamicResource MesBgPage}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="0,0,8,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Siparis Bilgisi" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding SiparisNo, StringFormat='Siparis: {0}'}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding Musteri, StringFormat='Musteri: {0}'}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding Platform, StringFormat='Platform: {0}'}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                        </StackPanel>
                    </Border>

                    <!-- Iade Bilgisi -->
                    <Border Grid.Column="1" Background="{DynamicResource MesBgPage}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="4,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Iade Bilgisi" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding Tutar, StringFormat='Tutar: {0:N2} TL'}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding Sebep, StringFormat='Sebep: {0}'}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding TalepTarihi, StringFormat='Tarih: {0:dd.MM.yyyy}'}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                        </StackPanel>
                    </Border>

                    <!-- Aciklama -->
                    <Border Grid.Column="2" Background="{DynamicResource MesBgPage}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="8,0,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Aciklama" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding Aciklama}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Timeline -->
                <Border Background="{DynamicResource MesBgPage}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Iade Sureci" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Timeline}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4">
                                        <Ellipse Width="12" Height="12" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{DynamicResource MesEmerald}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Step}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MesDarkSlate}" />
                                            <TextBlock Text="{Binding Description}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Kayit bulunamadi"
                                   FontSize="{StaticResource FontSizeTitle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource MesMutedGray}"
                                   IsVisible="{Binding !Timeline.Count}"
                                   Opacity="0.5" />
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <Border Background="{DynamicResource MesBgPage}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Islemler" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Content="Onayla" Command="{Binding ApproveCommand}"
                                    ToolTip.Tip="Onayla"
                                    Background="{DynamicResource MesGreenMaterial}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                    Padding="20,10" CornerRadius="{StaticResource MesRadiusBase}" />
                            <ComboBox Width="200"
                                      ItemsSource="{Binding RejectReasons}"
                                      SelectedItem="{Binding SelectedRejectReason}"  AutomationProperties.Name="Reject reason seciniz"/>
                            <Button Content="Reddet" Command="{Binding RejectCommand}"
                                    ToolTip.Tip="Reddet"
                                    Background="{DynamicResource MesRedBright}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                    Padding="20,10" CornerRadius="{StaticResource MesRadiusBase}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Iade bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz iade kaydi bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>
    </Grid>
</UserControl>
