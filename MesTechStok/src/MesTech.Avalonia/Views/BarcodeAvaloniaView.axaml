<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.BarcodeAvaloniaView"
             x:DataType="vm:BarcodeAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-06 Gorev 4E: Barkod Islemleri — USB HID wedge + urun karti + stok breakdown + hizli guncelleme -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Barkod Islemleri" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} sorgu'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Barcode Scan Input (USB HID keyboard wedge) -->
        <Border Grid.Row="1" Background="White" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Barkod:" VerticalAlignment="Center" FontSize="14"
                           Foreground="{DynamicResource MesTextSlate}" FontWeight="SemiBold" />
                <TextBox Width="360" Watermark="Barkod okutun veya manuel girin (Enter ile sorgula)..." AutomationProperties.Name="Barkod okutun veya manuel girin (Enter ile sorgula)..."
                         Text="{Binding SearchText}"
                         FontSize="15" Padding="10,8"
                         Name="BarcodeInput" />
                <Button Content="Sorgula" Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="White" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="2" Padding="16">
            <StackPanel Spacing="16" IsVisible="{Binding HasProduct}">

                <!-- Product Card -->
                <Border Background="White" CornerRadius="8" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{Binding ProductName}" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{Binding ProductSku, StringFormat='SKU: {0}'}"
                                           FontSize="13" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBlock Text="{Binding ProductBarcode, StringFormat='Barkod: {0}'}"
                                           FontSize="13" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <TextBlock Text="{Binding ProductPrice, StringFormat='Fiyat: {0:N2} TL'}"
                                           FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <Border CornerRadius="4" Padding="8,2"
                                        Background="{Binding StokDurumRenk}">
                                    <TextBlock Text="{Binding StokDurum}" FontSize="11"
                                               Foreground="White" FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Toplam Stok" FontSize="11" Foreground="{DynamicResource MesSlateGray}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalStock}" FontSize="32" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Warehouse Breakdown -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Depo Bazli Stok Dagilimi" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding WarehouseStocks}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="White"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Depo" Binding="{Binding WarehouseName}" Width="200" />
                                <DataGridTextColumn Header="Raf" Binding="{Binding ShelfCode}" Width="100" />
                                <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity}" Width="100" />
                                <DataGridTextColumn Header="Min Stok" Binding="{Binding MinStock}" Width="100" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding StokDurum}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty State: Barcode -->
                        <TextBlock Text="Kayıt bulunamadı"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,40"
                                   Opacity="0.5"
                                   FontSize="16"
                                   IsVisible="{Binding !WarehouseStocks.Count}" />
                    </Grid>
                </Border>

                <!-- Quick Stock Update Buttons -->
                <Border Background="White" CornerRadius="8" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Hizli Stok Guncelleme" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="-5" Command="{Binding QuickUpdateCommand}" CommandParameter="-5"
                                    Background="{DynamicResource MesRedBright}" Foreground="White" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="6" Width="56" HorizontalContentAlignment="Center" />
                            <Button Content="-1" Command="{Binding QuickUpdateCommand}" CommandParameter="-1"
                                    Background="#F87171" Foreground="White" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="6" Width="56" HorizontalContentAlignment="Center" />
                            <Button Content="+1" Command="{Binding QuickUpdateCommand}" CommandParameter="1"
                                    Background="#4ADE80" Foreground="White" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="6" Width="56" HorizontalContentAlignment="Center" />
                            <Button Content="+5" Command="{Binding QuickUpdateCommand}" CommandParameter="5"
                                    Background="{DynamicResource MesGreen}" Foreground="White" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="6" Width="56" HorizontalContentAlignment="Center" />
                            <Button Content="+10" Command="{Binding QuickUpdateCommand}" CommandParameter="10"
                                    Background="#15803D" Foreground="White" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="6" Width="56" HorizontalContentAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding QuickUpdateStatus}" FontSize="13"
                                   Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Barkod sorgusu yapiliyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State (no barcode scanned yet) -->
        <Border Grid.Row="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Barkod Okutun" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="USB barkod okuyucu ile tarayin veya manuel girin"
                           FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
