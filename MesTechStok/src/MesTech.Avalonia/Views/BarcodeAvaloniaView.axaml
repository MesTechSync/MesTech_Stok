<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.BarcodeAvaloniaView"
             x:Name="RootBarcodeAvaloniaView"
             x:DataType="vm:BarcodeAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-06 Gorev 4E: Barkod Islemleri — USB HID wedge + urun karti + stok breakdown + hizli guncelleme -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Barkod Islemleri" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} sorgu'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Barcode Scan Input (USB HID keyboard wedge) -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Barkod:" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource MesTextSlate}" FontWeight="SemiBold" />
                <TextBox Width="360" Watermark="Barkod okutun veya manuel girin (Enter ile sorgula)..." AutomationProperties.Name="Barkod okutun veya manuel girin (Enter ile sorgula)..."
                         Text="{Binding SearchText}"
                         FontSize="{StaticResource FontSizeBodyLg}" Padding="10,8"
                         Name="BarcodeInput" />
                <Button Content="Sorgula" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Sorgula"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="2" Padding="16">
            <StackPanel Spacing="16" IsVisible="{Binding HasProduct}">

                <!-- Product Card -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="{Binding ProductName}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{Binding ProductSku, StringFormat='SKU: {0}'}"
                                           FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBlock Text="{Binding ProductBarcode, StringFormat='Barkod: {0}'}"
                                           FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <TextBlock Text="{Binding ProductPrice, StringFormat='Fiyat: {0:N2} TL'}"
                                           FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <Border CornerRadius="{StaticResource MesRadiusSm}" Padding="8,2"
                                        Background="{Binding StokDurumRenk}">
                                    <TextBlock Text="{Binding StokDurum}" FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock Text="Toplam Stok" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding TotalStock}" FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Warehouse Breakdown -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Depo Bazli Stok Dagilimi" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding WarehouseStocks}"
                                  AutomationProperties.Name="Depo stok dagilimi"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource MesBgPrimary}"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Depo" Binding="{Binding WarehouseName}" Width="200" />
                                <DataGridTextColumn Header="Raf" Binding="{Binding ShelfCode}" Width="100" />
                                <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity}" Width="100" />
                                <DataGridTextColumn Header="Min Stok" Binding="{Binding MinStock}" Width="100" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding StokDurum}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty State: Barcode -->
                        <TextBlock Text="Stok verisi bulunamadi"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,40"
                                   Opacity="0.5"
                                   FontSize="{StaticResource FontSizeSubtitle}"
                                   IsVisible="{Binding !WarehouseStocks.Count}" />
                    </Grid>
                </Border>

                <!-- Quick Stock Update Buttons -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Hizli Stok Guncelleme" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="-5" Command="{Binding QuickUpdateCommand}" CommandParameter="-5"
                                    ToolTip.Tip="-5"
                                    Background="{DynamicResource MesRedBright}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" Width="56" HorizontalContentAlignment="Center" />
                            <Button Content="-1" Command="{Binding QuickUpdateCommand}" CommandParameter="-1"
                                    ToolTip.Tip="-1"
                                    Background="{DynamicResource MesRedBright}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" Width="56" HorizontalContentAlignment="Center" />
                            <Button Content="+1" Command="{Binding QuickUpdateCommand}" CommandParameter="1"
                                    ToolTip.Tip="+1"
                                    Background="{DynamicResource MesEmerald}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" Width="56" HorizontalContentAlignment="Center" />
                            <Button Content="+5" Command="{Binding QuickUpdateCommand}" CommandParameter="5"
                                    ToolTip.Tip="+5"
                                    Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" Width="56" HorizontalContentAlignment="Center" />
                            <Button Content="+10" Command="{Binding QuickUpdateCommand}" CommandParameter="10"
                                    ToolTip.Tip="+10"
                                    Background="{DynamicResource MesTeal}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                    Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" Width="56" HorizontalContentAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding QuickUpdateStatus}" FontSize="{StaticResource FontSizeCallout}"
                                   Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State (no barcode scanned yet) -->
        <Border Grid.Row="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Barkod Okutun" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="USB barkod okuyucu ile tarayin veya manuel girin"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
