<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StockTimelineAvaloniaView"
             x:DataType="vm:StockTimelineAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- I-06 Gorev 5: Stok Hareket Gecmisi Timeline — 5 tip x renk kodu -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Stok Hareket Gecmisi" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesOverlayLight}" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} hareket'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Son 7 Gun" Command="{Binding FilterWeekCommand}"
                            Background="{DynamicResource MesOverlayLight}" Foreground="{DynamicResource MesBgPrimary}" Padding="10,6" CornerRadius="6" />
                    <Button Content="Son 30 Gun" Command="{Binding FilterMonthCommand}"
                            Background="{DynamicResource MesOverlayLight}" Foreground="{DynamicResource MesBgPrimary}" Padding="10,6" CornerRadius="6" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="6" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Legend -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,8"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="6" Background="{DynamicResource MesGreen}" />
                    <TextBlock Text="Alim" FontSize="11" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="6" Background="{DynamicResource MesRedAlert}" />
                    <TextBlock Text="Satis" FontSize="11" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="6" Background="{DynamicResource MesPrimaryBlue}" />
                    <TextBlock Text="Transfer" FontSize="11" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="6" Background="{DynamicResource MesPurple}" />
                    <TextBlock Text="Iade" FontSize="11" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="6" Background="{DynamicResource MesCoolGray}" />
                    <TextBlock Text="Duzeltme" FontSize="11" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Timeline List -->
        <ScrollViewer Grid.Row="2" Padding="16">
            <ItemsControl ItemsSource="{Binding Movements}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:StockTimelineItemDto">
                        <Grid ColumnDefinitions="80,Auto,*,120" Margin="0,0,0,2">
                            <!-- Timestamp -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DateText}" FontSize="11" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBlock Text="{Binding TimeText}" FontSize="10" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>

                            <!-- Timeline Dot + Line -->
                            <Grid Grid.Column="1" Width="32" VerticalAlignment="Stretch">
                                <Border Width="2" Background="{DynamicResource MesBorderMedium}" HorizontalAlignment="Center" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{Binding TypeColor}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Movement Info -->
                            <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="6" Padding="12,8" Margin="8,2"
                                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding TypeIcon}" FontSize="13" Foreground="{Binding TypeColor}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding TypeText}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Reason}" FontSize="12" Foreground="{DynamicResource MesSlateGray}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Quantity Change -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding QuantityText}" FontSize="14" FontWeight="Bold"
                                           Foreground="{Binding QuantityColor}" HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding ResultStockText}" FontSize="11" Foreground="{DynamicResource MesMutedGray}"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Stok hareketleri yukleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Stok Hareketi Bulunamadi" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" />
                <TextBlock Text="Secilen tarih araliginda hareket yok"
                           FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
