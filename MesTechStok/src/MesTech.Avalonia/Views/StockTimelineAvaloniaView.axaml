<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StockTimelineAvaloniaView"
             x:DataType="vm:StockTimelineAvaloniaViewModel"
             AutomationProperties.Name="Stok Zaman Cizgisi">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- I-06 Gorev 5: Stok Hareket Gecmisi Timeline — 5 tip x renk kodu -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Stok Hareket Gecmisi" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesOverlayLight}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} hareket'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Son 7 Gun" Command="{Binding FilterWeekCommand}"
                            ToolTip.Tip="Son 7 Gun"
                            Background="{DynamicResource MesOverlayLight}" Foreground="{DynamicResource MesBgPrimary}" Padding="10,6" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Son 30 Gun" Command="{Binding FilterMonthCommand}"
                            ToolTip.Tip="Son 30 Gun"
                            Background="{DynamicResource MesOverlayLight}" Foreground="{DynamicResource MesBgPrimary}" Padding="10,6" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Legend -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,8"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="{StaticResource MesRadiusBase}" Background="{DynamicResource MesGreen}" />
                    <TextBlock Text="Alim" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="{StaticResource MesRadiusBase}" Background="{DynamicResource MesRedAlert}" />
                    <TextBlock Text="Satis" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="{StaticResource MesRadiusBase}" Background="{DynamicResource MesPrimaryBlue}" />
                    <TextBlock Text="Transfer" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="{StaticResource MesRadiusBase}" Background="{DynamicResource MesPurple}" />
                    <TextBlock Text="Iade" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Border Width="12" Height="12" CornerRadius="{StaticResource MesRadiusBase}" Background="{DynamicResource MesCoolGray}" />
                    <TextBlock Text="Duzeltme" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Timeline List -->        <ScrollViewer Grid.Row="2" Padding="16">
            <ItemsControl ItemsSource="{Binding Movements}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:StockTimelineItemDto">
                        <Grid ColumnDefinitions="80,Auto,*,120" Margin="0,0,0,2">
                            <!-- Timestamp -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DateText}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBlock Text="{Binding TimeText}" FontSize="{StaticResource FontSizeCaption1}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>

                            <!-- Timeline Dot + Line -->
                            <Grid Grid.Column="1" Width="32" VerticalAlignment="Stretch">
                                <Border Width="2" Background="{DynamicResource MesBorderMedium}" HorizontalAlignment="Center" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{Binding TypeColor}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>

                            <!-- Movement Info -->
                            <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusBase}" Padding="12,8" Margin="8,2"
                                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding TypeIcon}" FontSize="{StaticResource FontSizeCallout}" Foreground="{Binding TypeColor}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding TypeText}" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Reason}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Quantity Change -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding QuantityText}" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                                           Foreground="{Binding QuantityColor}" HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding ResultStockText}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}"
                                           HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Stok hareketleri yukleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Stok Hareketi Bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" />
                <TextBlock Text="Secilen tarih araliginda hareket yok"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>
    
        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
