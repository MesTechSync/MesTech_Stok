<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ShipmentAvaloniaView"
             x:DataType="vm:ShipmentAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-12: Kargo Takip — sevkiyat listesi DataGrid + durum badge -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Kargo Takip" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} gonderi'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- KPI Row -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="24">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource MesTeal}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DeliveredCount, StringFormat='Teslim Edildi: {0}'}"
                               FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesDarkSlate}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource MesPrimaryBlue}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding InTransitCount, StringFormat='Yolda: {0}'}"
                               FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesDarkSlate}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="10" Height="10" CornerRadius="5" Background="{DynamicResource MesAmber}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding PreparingCount, StringFormat='Hazirlaniyor: {0}'}"
                               FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesDarkSlate}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Shipments DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Shipments}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}"
                  Margin="16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Takip No" Binding="{Binding TrackingNumber}" Width="160" />
                <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderNumber}" Width="140" />
                <DataGridTextColumn Header="Kargo Firmasi" Binding="{Binding CarrierName}" Width="140" />
                <DataGridTextColumn Header="Alici" Binding="{Binding RecipientName}" Width="180" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120" />
                <DataGridTextColumn Header="Gonderim Tarihi" Binding="{Binding ShipDate}" Width="130" />
            </DataGrid.Columns>
        </DataGrid>
        <!-- Empty State -->
        <TextBlock Grid.Row="2" Text="Kayit bulunamadi"
                   FontSize="{StaticResource FontSizeTitle}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource MesMutedGray}"
                   IsVisible="{Binding !Shipments.Count}"
                   Opacity="0.5" />

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Gonderi bilgileri yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Gonderi Bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Henuz aktif gonderi bulunmuyor"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
