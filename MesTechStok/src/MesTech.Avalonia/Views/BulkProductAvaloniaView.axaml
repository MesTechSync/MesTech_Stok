<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.BulkProductAvaloniaView"
             x:Name="RootBulkProductAvaloniaView"
             x:DataType="vm:BulkProductAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Toplu Urun Islemleri — Import / Export / Toplu Guncelle -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Toplu Urun Islemleri" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBox Width="220" Watermark="Ara: urun adi, SKU..."
                             AutomationProperties.Name="Ara: urun adi, SKU..."
                             Text="{Binding SearchText}"
                             FontSize="{StaticResource FontSizeSmall}" Padding="8,6"
                             Background="{DynamicResource MesOverlayLight}" Foreground="{DynamicResource MesBgPrimary}"
                             CornerRadius="{StaticResource MesRadiusBase}" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="16" TabStripPlacement="Top">

            <!-- Tab 1: Import -->
            <TabItem Header="Import">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16">

                        <!-- File Selection -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Dosya Secimi" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding ImportFilePath}"
                                             Watermark="Excel dosya sec..." AutomationProperties.Name="Excel dosya sec..." IsReadOnly="True"
                                             Height="36" FontSize="{StaticResource FontSizeCallout}" CornerRadius="{StaticResource MesRadiusSm}" />
                                    <Button Grid.Column="1" Content="Dosya Sec..."
                                            ToolTip.Tip="Dosya Sec..."
                                            Command="{Binding SelectFileCommand}"
                                            Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                                            FontWeight="SemiBold" Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}"
                                            Margin="8,0,0,0" />
                                </Grid>
                                <TextBlock Text="{Binding ImportFileInfo}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}"
                                           IsVisible="{Binding HasImportFile}" />
                            </StackPanel>
                        </Border>

                        <!-- Column Mapping Preview -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasImportFile}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Kolon Eslestirme" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <DataGrid ItemsSource="{Binding ColumnMappings}"
                                          AutoGenerateColumns="False" IsReadOnly="False" CanUserResizeColumns="True" CanUserReorderColumns="True"
                                          GridLinesVisibility="Horizontal" BorderThickness="0"
                                          MaxHeight="200">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Excel Kolonu" Binding="{Binding ExcelColumn}" Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Ornek Veri" Binding="{Binding SampleData}" Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="MesTech Alani" Binding="{Binding MesTechField}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
<!-- Empty State -->        <TextBlock Text="Urun bulunamadi"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !ColumnMappings.Count}" />
                            </StackPanel>
                        </Border>

                        <!-- Data Preview -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasImportFile}">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Veri Onizleme (ilk 10 satir)" FontSize="{StaticResource FontSizeBody}"
                                               FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PreviewValidationSummary}"
                                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                                </Grid>
                                <DataGrid ItemsSource="{Binding PreviewRows}"
                                          AutoGenerateColumns="False" IsReadOnly="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                                          GridLinesVisibility="Horizontal" BorderThickness="0"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="50" />
                                        <DataGridTextColumn Header="Urun Adi" Binding="{Binding ProductName}" Width="*" />
                                        <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" />
                                        <DataGridTextColumn Header="Fiyat" Binding="{Binding Price, StringFormat='TL{0:N2}'}" Width="100" />
                                        <DataGridTextColumn Header="Stok" Binding="{Binding Stock}" Width="80" />
                                        <DataGridTextColumn Header="Durum" Binding="{Binding ValidationStatus}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <!-- Import Options -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasImportFile}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Import Secenekleri" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <StackPanel Orientation="Horizontal" Spacing="24">
                                    <CheckBox Content="Mevcut urunleri guncelle"
                                              IsChecked="{Binding UpdateExistingProducts}" />
                                    <CheckBox Content="Hatalari atla"
                                              IsChecked="{Binding SkipErrors}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Import Action -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasImportFile}">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <ProgressBar Minimum="0" Maximum="100"
                                                     Value="{Binding ImportProgress}" Height="8"
                                                     Foreground="{DynamicResource MesGreenMaterial}" Background="{DynamicResource MesBorderLight}" CornerRadius="{StaticResource MesRadiusSm}"
                                                     IsVisible="{Binding IsImporting}" />
                                        <TextBlock Text="{Binding ImportStatusText}" FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{DynamicResource MesSlateGray}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Iptal"
                                            ToolTip.Tip="Iptal"
                                            Command="{Binding CancelCommand}"
                                            IsVisible="{Binding IsImporting}"
                                            Background="{DynamicResource MesDanger}" Foreground="{DynamicResource MesBgPrimary}"
                                            FontWeight="SemiBold" Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}"
                                            Margin="12,0,8,0" />
                                    <Button Grid.Column="2" Content="Import Baslat"
                                            ToolTip.Tip="Import Baslat"
                                            Command="{Binding ImportCommand}"
                                            IsEnabled="{Binding CanImport}"
                                            Background="{DynamicResource MesGreenMaterial}" Foreground="{DynamicResource MesBgPrimary}"
                                            FontWeight="SemiBold" Padding="20,8" CornerRadius="{StaticResource MesRadiusBase}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Export -->
            <TabItem Header="Export">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16">

                        <!-- Export Filters -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Export Filtreleri" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                        <TextBlock Text="Platform" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                        <ComboBox ItemsSource="{Binding ExportPlatformList}"
                                                  SelectedItem="{Binding SelectedExportPlatform}"
                                                  HorizontalAlignment="Stretch"  AutomationProperties.Name="Platform"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,4,0">
                                        <TextBlock Text="Kategori" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                        <ComboBox ItemsSource="{Binding ExportCategoryList}"
                                                  SelectedItem="{Binding SelectedExportCategory}"
                                                  HorizontalAlignment="Stretch"  AutomationProperties.Name="Kategori"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4" Margin="8,0,0,0">
                                        <TextBlock Text="Stok Durumu" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                        <ComboBox ItemsSource="{Binding ExportStockFilterList}"
                                                  SelectedItem="{Binding SelectedExportStockFilter}"
                                                  HorizontalAlignment="Stretch"  AutomationProperties.Name="Stok Durumu"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Export Format & Action -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="Format:" FontSize="{StaticResource FontSizeCallout}"
                                           Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                    <RadioButton Content="XLSX" IsChecked="{Binding IsXlsxFormat}" GroupName="ExportFormat" />
                                    <RadioButton Content="CSV" IsChecked="{Binding IsCsvFormat}" GroupName="ExportFormat" />
                                </StackPanel>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding ExportProductCount, StringFormat='{}{0:N0} urun bulundu'}"
                                           FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesDarkSlate}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,16,0" />
                                <Button Grid.Column="4" Content="Indir"
                                        ToolTip.Tip="Indir"
                                        Command="{Binding ExportCommand}"
                                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                                        FontWeight="SemiBold" Padding="20,8" CornerRadius="{StaticResource MesRadiusBase}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Toplu Guncelle -->
            <TabItem Header="Toplu Guncelle">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16">

                        <!-- Selection Info -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Toplu Guncelleme" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{DynamicResource MesBgSecondary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="12,4">
                                        <TextBlock Text="{Binding SelectedProductCount, StringFormat='{}{0} urun secili'}"
                                                   FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold" />
                                    </Border>
                                    <Button Content="Tum Urunleri Sec"
                                            ToolTip.Tip="Tum Urunleri Sec"
                                            Command="{Binding SelectAllProductsCommand}"
                                            Background="Transparent" Foreground="{DynamicResource MesPrimaryBlue}"
                                            FontSize="{StaticResource FontSizeSmall}" Padding="8,4" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Action Selection -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Islem Sec" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                        <TextBlock Text="Islem Turu" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                        <ComboBox ItemsSource="{Binding BulkActionList}"
                                                  SelectedItem="{Binding SelectedBulkAction}"
                                                  HorizontalAlignment="Stretch"  AutomationProperties.Name="Islem Turu"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
                                        <TextBlock Text="Deger" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBox Text="{Binding BulkActionValue}"
                                                 Watermark="Deger giriniz..." AutomationProperties.Name="Deger giriniz..."
                                                 Height="36" FontSize="{StaticResource FontSizeCallout}" CornerRadius="{StaticResource MesRadiusSm}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Preview -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasBulkPreview}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Onizleme" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <DataGrid ItemsSource="{Binding BulkPreviewRows}"
                                          AutoGenerateColumns="False" IsReadOnly="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                                          GridLinesVisibility="Horizontal" BorderThickness="0"
                                          MaxHeight="250">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Urun" Binding="{Binding ProductName}" Width="*" />
                                        <DataGridTextColumn Header="Mevcut Deger" Binding="{Binding CurrentValue}" Width="140" />
                                        <DataGridTextColumn Header="Yeni Deger" Binding="{Binding NewValue}" Width="140" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <!-- Apply Action -->
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding BulkUpdateStatusText}"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Uygula"
                                        ToolTip.Tip="Uygula"
                                        Command="{Binding BulkUpdateCommand}"
                                        IsEnabled="{Binding CanBulkUpdate}"
                                        Background="{DynamicResource MesBrandAccent}" Foreground="{DynamicResource MesBgPrimary}"
                                        FontWeight="SemiBold" Padding="20,8" CornerRadius="{StaticResource MesRadiusBase}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Urun bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz urun bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

</Grid>
</UserControl>
