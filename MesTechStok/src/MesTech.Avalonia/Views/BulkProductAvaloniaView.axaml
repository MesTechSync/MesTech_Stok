<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.BulkProductAvaloniaView"
             x:DataType="vm:BulkProductAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Toplu Urun Islemleri — Import / Export / Toplu Guncelle -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Toplu Urun Islemleri" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="16" TabStripPlacement="Top">

            <!-- Tab 1: Import -->
            <TabItem Header="Import">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16">

                        <!-- File Selection -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Dosya Secimi" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding ImportFilePath}"
                                             Watermark="Excel dosya sec..." AutomationProperties.Name="Excel dosya sec..." IsReadOnly="True"
                                             Height="36" FontSize="13" CornerRadius="4" />
                                    <Button Grid.Column="1" Content="Dosya Sec..."
                                            Command="{Binding SelectFileCommand}"
                                            Background="{DynamicResource MesPrimaryBlue}" Foreground="White"
                                            FontWeight="SemiBold" Padding="16,8" CornerRadius="6"
                                            Margin="8,0,0,0" />
                                </Grid>
                                <TextBlock Text="{Binding ImportFileInfo}" FontSize="12" Foreground="{DynamicResource MesSlateGray}"
                                           IsVisible="{Binding HasImportFile}" />
                            </StackPanel>
                        </Border>

                        <!-- Column Mapping Preview -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasImportFile}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Kolon Eslestirme" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <DataGrid ItemsSource="{Binding ColumnMappings}"
                                          AutoGenerateColumns="False" IsReadOnly="False"
                                          GridLinesVisibility="Horizontal" BorderThickness="0"
                                          MaxHeight="200">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Excel Kolonu" Binding="{Binding ExcelColumn}" Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Ornek Veri" Binding="{Binding SampleData}" Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="MesTech Alani" Binding="{Binding MesTechField}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
<!-- Empty State -->        <TextBlock Text="Kayıt bulunamadı"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="16"                   IsVisible="{Binding !ColumnMappings.Count}" />
                            </StackPanel>
                        </Border>

                        <!-- Data Preview -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasImportFile}">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Veri Onizleme (ilk 10 satir)" FontSize="14"
                                               FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PreviewValidationSummary}"
                                               FontSize="12" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                                </Grid>
                                <DataGrid ItemsSource="{Binding PreviewRows}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          GridLinesVisibility="Horizontal" BorderThickness="0"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="50" />
                                        <DataGridTextColumn Header="Urun Adi" Binding="{Binding ProductName}" Width="*" />
                                        <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" />
                                        <DataGridTextColumn Header="Fiyat" Binding="{Binding Price, StringFormat='TL{0:N2}'}" Width="100" />
                                        <DataGridTextColumn Header="Stok" Binding="{Binding Stock}" Width="80" />
                                        <DataGridTextColumn Header="Durum" Binding="{Binding ValidationStatus}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <!-- Import Options -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasImportFile}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Import Secenekleri" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <StackPanel Orientation="Horizontal" Spacing="24">
                                    <CheckBox Content="Mevcut urunleri guncelle"
                                              IsChecked="{Binding UpdateExistingProducts}" />
                                    <CheckBox Content="Hatalari atla"
                                              IsChecked="{Binding SkipErrors}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Import Action -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasImportFile}">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <ProgressBar Minimum="0" Maximum="100"
                                                     Value="{Binding ImportProgress}" Height="8"
                                                     Foreground="{DynamicResource MesGreenMaterial}" Background="{DynamicResource MesBorderLight}" CornerRadius="4"
                                                     IsVisible="{Binding IsImporting}" />
                                        <TextBlock Text="{Binding ImportStatusText}" FontSize="12"
                                                   Foreground="{DynamicResource MesSlateGray}" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Iptal"
                                            Command="{Binding CancelCommand}"
                                            IsVisible="{Binding IsImporting}"
                                            Background="{DynamicResource MesDanger}" Foreground="White"
                                            FontWeight="SemiBold" Padding="16,8" CornerRadius="6"
                                            Margin="12,0,8,0" />
                                    <Button Grid.Column="2" Content="Import Baslat"
                                            Command="{Binding ImportCommand}"
                                            IsEnabled="{Binding CanImport}"
                                            Background="{DynamicResource MesGreenMaterial}" Foreground="White"
                                            FontWeight="SemiBold" Padding="20,8" CornerRadius="6" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Export -->
            <TabItem Header="Export">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16">

                        <!-- Export Filters -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Export Filtreleri" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                        <TextBlock Text="Platform" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <ComboBox ItemsSource="{Binding ExportPlatformList}"
                                                  SelectedItem="{Binding SelectedExportPlatform}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" Margin="4,0,4,0">
                                        <TextBlock Text="Kategori" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <ComboBox ItemsSource="{Binding ExportCategoryList}"
                                                  SelectedItem="{Binding SelectedExportCategory}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4" Margin="8,0,0,0">
                                        <TextBlock Text="Stok Durumu" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <ComboBox ItemsSource="{Binding ExportStockFilterList}"
                                                  SelectedItem="{Binding SelectedExportStockFilter}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Export Format & Action -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                <TextBlock Grid.Column="0" Text="Format:" FontSize="13"
                                           Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                    <RadioButton Content="XLSX" IsChecked="{Binding IsXlsxFormat}" GroupName="ExportFormat" />
                                    <RadioButton Content="CSV" IsChecked="{Binding IsCsvFormat}" GroupName="ExportFormat" />
                                </StackPanel>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding ExportProductCount, StringFormat='{}{0:N0} urun bulundu'}"
                                           FontSize="13" Foreground="{DynamicResource MesDarkSlate}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,0,16,0" />
                                <Button Grid.Column="4" Content="Indir"
                                        Command="{Binding ExportCommand}"
                                        Background="{DynamicResource MesPrimaryBlue}" Foreground="White"
                                        FontWeight="SemiBold" Padding="20,8" CornerRadius="6" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Toplu Guncelle -->
            <TabItem Header="Toplu Guncelle">
                <ScrollViewer Padding="16">
                    <StackPanel Spacing="16">

                        <!-- Selection Info -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Toplu Guncelleme" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="#E3F2FD" CornerRadius="12" Padding="12,4">
                                        <TextBlock Text="{Binding SelectedProductCount, StringFormat='{}{0} urun secili'}"
                                                   FontSize="13" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold" />
                                    </Border>
                                    <Button Content="Tum Urunleri Sec"
                                            Command="{Binding SelectAllProductsCommand}"
                                            Background="Transparent" Foreground="{DynamicResource MesPrimaryBlue}"
                                            FontSize="12" Padding="8,4" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Action Selection -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Islem Sec" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                        <TextBlock Text="Islem Turu" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <ComboBox ItemsSource="{Binding BulkActionList}"
                                                  SelectedItem="{Binding SelectedBulkAction}"
                                                  HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
                                        <TextBlock Text="Deger" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBox Text="{Binding BulkActionValue}"
                                                 Watermark="Deger giriniz..." AutomationProperties.Name="Deger giriniz..."
                                                 Height="36" FontSize="13" CornerRadius="4" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Preview -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                IsVisible="{Binding HasBulkPreview}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Onizleme" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                                <DataGrid ItemsSource="{Binding BulkPreviewRows}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          GridLinesVisibility="Horizontal" BorderThickness="0"
                                          MaxHeight="250">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Urun" Binding="{Binding ProductName}" Width="*" />
                                        <DataGridTextColumn Header="Mevcut Deger" Binding="{Binding CurrentValue}" Width="140" />
                                        <DataGridTextColumn Header="Yeni Deger" Binding="{Binding NewValue}" Width="140" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <!-- Apply Action -->
                        <Border Background="White" CornerRadius="8" Padding="16"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="{Binding BulkUpdateStatusText}"
                                           FontSize="12" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Uygula"
                                        Command="{Binding BulkUpdateCommand}"
                                        IsEnabled="{Binding CanBulkUpdate}"
                                        Background="{DynamicResource MesBrandAccent}" Foreground="White"
                                        FontWeight="SemiBold" Padding="20,8" CornerRadius="6" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Yukleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
