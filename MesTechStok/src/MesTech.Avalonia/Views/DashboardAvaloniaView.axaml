<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.DashboardAvaloniaView"
             x:DataType="vm:DashboardAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Premium Dashboard — 6 KPI + Tables + Platform Health + AI Insight -->

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Background="{DynamicResource MesBgPage}">

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 0: Header Bar                                           -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource MesBgPrimary}" Padding="20,12"
                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="0,0,0,1"
                BoxShadow="{DynamicResource MesElevation1}">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <PathIcon Data="{StaticResource IconDashboard}"
                              Width="24" Height="24" Foreground="{DynamicResource MesPrimaryBlue}" />
                    <TextBlock Text="Dashboard" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                               Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusLg}" Padding="10,4"
                            VerticalAlignment="Center">
                        <TextBlock Text="Canli" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesPrimaryBlue}" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding LastRefreshText}"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}"
                               VerticalAlignment="Center" />
                    <ToggleSwitch IsChecked="{Binding IsAutoRefreshEnabled}"
                                  OnContent="Canli" OffContent="Durdur"
                                  VerticalAlignment="Center" />
                    <Button Command="{Binding RefreshCommand}"
                            ToolTip.Tip="Yenile"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{DynamicResource MesBorderSoft}" CornerRadius="{StaticResource MesRadiusBase}"
                            Padding="8">
                        <PathIcon Data="{StaticResource IconRefresh}"
                                  Width="16" Height="16" Foreground="{DynamicResource MesSlateGray}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 1: 6 KPI Cards                                         -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <WrapPanel Grid.Row="1" Margin="20,16,20,4"
                   Orientation="Horizontal">

            <!-- KPI 1: Bugun Satis -->
            <controls:KpiCardControl DataContext="{Binding TodaySalesKpi}"
                                     Width="180" Margin="0,0,12,12" />

            <!-- KPI 2: Bu Hafta Ciro -->
            <controls:KpiCardControl DataContext="{Binding WeekRevenueKpi}"
                                     Width="180" Margin="0,0,12,12" />

            <!-- KPI 3: Urunler Toplam -->
            <controls:KpiCardControl DataContext="{Binding TotalProductsKpi}"
                                     Width="180" Margin="0,0,12,12" />

            <!-- KPI 4: Dusuk Stok -->
            <controls:KpiCardControl DataContext="{Binding LowStockKpi}"
                                     Width="180" Margin="0,0,12,12" />

            <!-- KPI 5: Bekleyen Siparis -->
            <controls:KpiCardControl DataContext="{Binding PendingOrdersKpi}"
                                     Width="180" Margin="0,0,12,12" />

            <!-- KPI 6: Iadeler -->
            <controls:KpiCardControl DataContext="{Binding ReturnsKpi}"
                                     Width="180" Margin="0,0,12,12" />
        </WrapPanel>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 2: Tables — Son Siparisler + Stok Uyarilari            -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*"
              Margin="20,8,20,8">

            <!-- Left: Son Siparisler -->
            <Border Grid.Column="0" Classes="mestech-card" Margin="0,0,8,0"
                    Padding="0" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <PathIcon Grid.Column="0"
                                      Data="{StaticResource IconShoppingCart}"
                                      Width="18" Height="18" Foreground="{DynamicResource MesPrimaryBlue}"
                                      Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="Son Siparisler"
                                       FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="10 kayit"
                                       FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                <Grid>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding RecentOrders}"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="{DynamicResource MesBgPrimary}"
                              MaxHeight="380">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Siparis No"
                                                Binding="{Binding OrderNo}"
                                                Width="130" />
                            <DataGridTextColumn Header="Tarih"
                                                Binding="{Binding Date}"
                                                Width="90" />
                            <DataGridTextColumn Header="Musteri"
                                                Binding="{Binding Customer}"
                                                Width="150" />
                            <DataGridTextColumn Header="Tutar"
                                                Binding="{Binding Amount}"
                                                Width="100" />
                            <DataGridTextColumn Header="Durum"
                                                Binding="{Binding Status}"
                                                Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               IsVisible="{Binding !RecentOrders.Count}" />
                </Grid>
                </Grid>
            </Border>

            <!-- Right: Stok Uyarilari -->
            <Border Grid.Column="1" Classes="mestech-card" Margin="8,0,0,0"
                    Padding="0" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <PathIcon Grid.Column="0"
                                      Data="{StaticResource IconWarning}"
                                      Width="18" Height="18" Foreground="{DynamicResource MesAmber}"
                                      Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="Stok Uyarilari"
                                       FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="2" Background="{DynamicResource MesBgSurface}"
                                    CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                                <TextBlock Text="{Binding CriticalStockCount}"
                                           FontSize="{StaticResource FontSizeCaption}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesAmber}"
                                           HorizontalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CriticalStockItems}"
                                      Margin="0,4,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="8,2" Padding="0"
                                            CornerRadius="{StaticResource MesRadiusBase}"
                                            Background="{DynamicResource MesBgSurface}"
                                            BorderBrush="{DynamicResource MesBorderSoft}"
                                            BorderThickness="1">
                                        <Grid ColumnDefinitions="4,*,Auto,Auto"
                                              MinHeight="48">
                                            <!-- Color severity bar -->
                                            <Border Grid.Column="0"
                                                    Background="{Binding SeverityColor}"
                                                    CornerRadius="6,0,0,6" />

                                            <!-- Product info -->
                                            <StackPanel Grid.Column="1"
                                                        Margin="12,6,8,6"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ProductName}"
                                                           FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MesDarkSlate}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="180" />
                                                <TextBlock Text="{Binding SKU}"
                                                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" />
                                            </StackPanel>

                                            <!-- Stock count -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StockText}"
                                                       FontSize="{StaticResource FontSizeCallout}" FontWeight="Bold"
                                                       Foreground="{Binding SeverityColor}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />

                                            <!-- Order button -->
                                            <Button Grid.Column="3"
                                                    Content="Siparis &#x2192;"
                                                    Command="{Binding OrderCommand}"
                                                    FontSize="{StaticResource FontSizeCaption}"
                                                    Padding="10,4"
                                                    CornerRadius="{StaticResource MesRadiusSm}"
                                                    Background="{DynamicResource MesPrimaryBlue}"
                                                    Foreground="{DynamicResource MesBgPrimary}"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 3: Platform Saglik Durumu                               -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Classes="mestech-card" Margin="20,4,20,8"
                Padding="16,12">
            <Grid RowDefinitions="Auto,Auto">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8"
                            Margin="0,0,0,10">
                    <PathIcon Data="{StaticResource IconChart}"
                              Width="16" Height="16" Foreground="{DynamicResource MesPrimaryBlue}" />
                    <TextBlock Text="Platform Saglik Durumu"
                               FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDarkSlate}" />
                </StackPanel>
                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding PlatformStatuses}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,16,6" Padding="8,4"
                                    CornerRadius="{StaticResource MesRadiusLg}"
                                    Background="{DynamicResource MesBgPage}"
                                    BorderBrush="{DynamicResource MesBorderSoft}"
                                    BorderThickness="1"
                                    ToolTip.Tip="{Binding TooltipText}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding StatusColor}" />
                                    <TextBlock Text="{Binding PlatformName}"
                                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesTextSlate}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Row 4: AI Onerisi (MESA OS — Mor/Purple)                    -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Margin="20,0,20,20"
                Background="{DynamicResource MesBgPurpleLight}" CornerRadius="{StaticResource MesRadiusLg}"
                Padding="20,16"
                BorderBrush="{DynamicResource MesBorderPurple}" BorderThickness="1"
                IsVisible="{Binding HasAIInsight}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- AI Icon + Title -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0"
                            VerticalAlignment="Center">
                    <Border Background="{DynamicResource MesPurple}" CornerRadius="{StaticResource MesRadiusMd}"
                            Width="40" Height="40"
                            HorizontalAlignment="Center">
                        <TextBlock Text="AI" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesBgPrimary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="MESA OS" FontSize="{StaticResource FontSizeCaption2}" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesPurple}" Margin="0,4,0,0"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- AI Content -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            Spacing="4">
                    <TextBlock Text="AI Onerisi" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                               Foreground="{DynamicResource MesPurple}" />
                    <TextBlock Text="{Binding AiInsightText}"
                               FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesPurpleDark}"
                               TextWrapping="Wrap"
                               MaxWidth="600" />
                </StackPanel>

                <!-- Action Button -->
                <Button Grid.Column="2"
                        Content="Detaylar &#x2192;"
                        Command="{Binding OpenAIInsightCommand}"
                        Background="{DynamicResource MesPurple}" Foreground="{DynamicResource MesBgPrimary}"
                        FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusMd}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Loading Overlay                                             -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4"
                             Margin="0,0,0,12" />
                <TextBlock Text="Dashboard verileri yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Empty State                                                 -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <PathIcon Data="{StaticResource IconDashboard}"
                          Width="48" Height="48" Foreground="{DynamicResource MesMutedGray}" />
                <TextBlock Text="Veri yok" FontSize="{StaticResource FontSizeTitle}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MesMutedGray}" Margin="0,12,0,4" />
                <TextBlock Text="Henuz veri bulunamadi"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
                <Button Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Margin="0,16,0,0" Padding="20,8" CornerRadius="{StaticResource MesRadiusBase}"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════ -->
        <!-- Error State                                                 -->
        <!-- ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="{StaticResource MesRadiusLg}" Padding="32"
                        HorizontalAlignment="Center"
                        BoxShadow="{DynamicResource MesElevation2}">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <PathIcon Data="{StaticResource IconError}"
                                  Width="32" Height="32" Foreground="{DynamicResource MesRedClassic}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="Hata Olustu" FontWeight="Bold"
                                   Foreground="{DynamicResource MesRedClassic}" FontSize="{StaticResource FontSizeSubtitle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                                   TextWrapping="Wrap" MaxWidth="400"
                                   HorizontalAlignment="Center" />
                        <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                                Command="{Binding RefreshCommand}"
                                Padding="20,8" Margin="0,8,0,0"
                                CornerRadius="{StaticResource MesRadiusBase}"
                                Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                                HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
