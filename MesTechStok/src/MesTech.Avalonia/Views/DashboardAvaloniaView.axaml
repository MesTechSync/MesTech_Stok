<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.DashboardAvaloniaView"
             x:DataType="vm:DashboardAvaloniaViewModel">

    <!-- Avalonia Dashboard — 4 KPI cards + recent orders DataGrid -->

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Row 0: Header / Refresh Bar -->
        <Border Grid.Row="0" Background="White" Padding="16,10"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Kontrol Paneli" FontSize="22" FontWeight="Bold"
                               Foreground="#0078D4" VerticalAlignment="Center" />
                    <TextBlock Text="Stok ve islem durum ozeti"
                               FontSize="14" Foreground="#64748B" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <Button Content="Yenile" Command="{Binding RefreshCommand}"
                            Background="#0078D4" Foreground="White"
                            Padding="16,8" CornerRadius="6" />
                    <TextBlock Text="{Binding LastUpdated, StringFormat='Son: {0}'}"
                               VerticalAlignment="Center" Foreground="#64748B" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: KPI Cards -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="16">

            <!-- Toplam Urun -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="6"
                    BorderBrush="#E0E6ED" BorderThickness="1" ClipToBounds="True">
                <Grid ColumnDefinitions="6,*">
                    <Border Grid.Column="0" Background="#0078D4" />
                    <StackPanel Grid.Column="1" Margin="16">
                        <TextBlock Text="Toplam Urun" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding TotalProducts}"
                                   FontSize="28" FontWeight="Bold" Foreground="#0078D4"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Sistemdeki aktif urun sayisi"
                                   FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Aktif Siparis -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="6"
                    BorderBrush="#E0E6ED" BorderThickness="1" ClipToBounds="True">
                <Grid ColumnDefinitions="6,*">
                    <Border Grid.Column="0" Background="#10B981" />
                    <StackPanel Grid.Column="1" Margin="16">
                        <TextBlock Text="Aktif Siparis" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding ActiveOrders}"
                                   FontSize="28" FontWeight="Bold" Foreground="#10B981"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Islemdeki siparis sayisi"
                                   FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Bugunku Gelir -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" Margin="6"
                    BorderBrush="#E0E6ED" BorderThickness="1" ClipToBounds="True">
                <Grid ColumnDefinitions="6,*">
                    <Border Grid.Column="0" Background="#F59E0B" />
                    <StackPanel Grid.Column="1" Margin="16">
                        <TextBlock Text="Bugunku Gelir" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding TodayRevenue}"
                                   FontSize="28" FontWeight="Bold" Foreground="#F59E0B"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Gunluk toplam gelir"
                                   FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Stok Alarm -->
            <Border Grid.Column="3" Background="White" CornerRadius="8" Margin="6"
                    BorderBrush="#E0E6ED" BorderThickness="1" ClipToBounds="True">
                <Grid ColumnDefinitions="6,*">
                    <Border Grid.Column="0" Background="#E74C3C" />
                    <StackPanel Grid.Column="1" Margin="16">
                        <TextBlock Text="Stok Alarm" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding StockAlerts}"
                                   FontSize="28" FontWeight="Bold" Foreground="#E74C3C"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Kritik stok seviyesi"
                                   FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 2: Recent Orders Table -->
        <Border Grid.Row="2" Background="White" CornerRadius="8" Margin="22,0,22,22"
                BorderBrush="#E0E6ED" BorderThickness="1">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Padding="20,14"
                        BorderBrush="#E0E6ED" BorderThickness="0,0,0,1">
                    <TextBlock Text="Son Siparisler" FontSize="16" FontWeight="SemiBold"
                               Foreground="#1E293B" />
                </Border>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding RecentOrders}"
                          AutoGenerateColumns="False"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderNo}" Width="160" />
                        <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="120" />
                        <DataGridTextColumn Header="Musteri" Binding="{Binding Customer}" Width="200" />
                        <DataGridTextColumn Header="Tutar" Binding="{Binding Amount}" Width="150" />
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="130" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Dashboard verileri yukleniyor..."
                           FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#F8FAFC"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Veri yok" FontSize="20"
                           HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,0,0,8" />
                <TextBlock Text="Henuz veri bulunamadi"
                           FontSize="16" Foreground="#64748B"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#F8FAFC"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="#FFF3F3" CornerRadius="8" Padding="24" HorizontalAlignment="Center">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Hata Olustu" FontWeight="Bold" Foreground="#E74C3C" FontSize="16" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="14" Foreground="#666"
                                   TextWrapping="Wrap" MaxWidth="400" />
                        <Button Content="Tekrar Dene"
                                Command="{Binding RefreshCommand}"
                                Padding="16,6" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
