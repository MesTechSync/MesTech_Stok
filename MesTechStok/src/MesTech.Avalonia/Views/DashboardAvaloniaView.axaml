<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.DashboardAvaloniaView"
             x:DataType="vm:DashboardAvaloniaViewModel">

    <!-- Avalonia port of WPF DashboardView.xaml -->
    <!-- Key changes: xmlns→avaloniaui, .axaml ext, Fluent theme, no MaterialDesign refs -->
    <!-- ViewModel: DashboardAvaloniaViewModel (MVVM-first, no code-behind logic) -->

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Row 0: Refresh Bar -->
        <Border Grid.Row="0" Background="White" Padding="16,10"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Stok ve islem durum ozeti"
                           FontSize="14" Foreground="#64748B" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <Button Content="Yenile" Command="{Binding RefreshCommand}"
                            Background="#3B82F6" Foreground="White"
                            Padding="16,8" CornerRadius="6" />
                    <TextBlock Text="{Binding LastUpdated, StringFormat='Son: {0}'}"
                               VerticalAlignment="Center" Foreground="#64748B" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: KPI Cards -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="16">

            <!-- Total Products -->
            <Border Grid.Column="0" Background="White" CornerRadius="12"
                    Padding="20" Margin="6"
                    BorderBrush="#E0E6ED" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Toplam Urun" FontSize="12" Foreground="#6B7280" />
                    <TextBlock Text="{Binding TotalProducts}"
                               FontSize="28" FontWeight="Bold" Foreground="#2563EB"
                               Margin="0,8,0,0" />
                    <TextBlock Text="Sistemdeki aktif urun sayisi"
                               FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Total Stock Value -->
            <Border Grid.Column="1" Background="White" CornerRadius="12"
                    Padding="20" Margin="6"
                    BorderBrush="#E0E6ED" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Toplam Stok Degeri" FontSize="12" Foreground="#6B7280" />
                    <TextBlock Text="{Binding TotalStockValue}"
                               FontSize="28" FontWeight="Bold" Foreground="#10B981"
                               Margin="0,8,0,0" />
                    <TextBlock Text="Toplam stok degeri"
                               FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Low Stock -->
            <Border Grid.Column="2" Background="White" CornerRadius="12"
                    Padding="20" Margin="6"
                    BorderBrush="#E0E6ED" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Dusuk Stok" FontSize="12" Foreground="#6B7280" />
                    <TextBlock Text="{Binding LowStockCount}"
                               FontSize="28" FontWeight="Bold" Foreground="#F59E0B"
                               Margin="0,8,0,0" />
                    <TextBlock Text="Kritik stok seviyesindeki urunler"
                               FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Active Categories -->
            <Border Grid.Column="3" Background="White" CornerRadius="12"
                    Padding="20" Margin="6"
                    BorderBrush="#E0E6ED" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Aktif Kategori" FontSize="12" Foreground="#6B7280" />
                    <TextBlock Text="{Binding ActiveCategories}"
                               FontSize="28" FontWeight="Bold" Foreground="#8B5CF6"
                               Margin="0,8,0,0" />
                    <TextBlock Text="Aktif urun kategorileri"
                               FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 2: Placeholder for chart area -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Margin="22,0,22,22"
                BorderBrush="#E0E6ED" BorderThickness="1" Padding="24">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Satis Analizi — Grafik Alani"
                           FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"
                           HorizontalAlignment="Center" />
                <TextBlock Text="LiveChartsCore.SkiaSharpView.Avalonia entegrasyonu — Dalga 10'da aktif"
                           FontSize="13" Foreground="#94A3B8"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
