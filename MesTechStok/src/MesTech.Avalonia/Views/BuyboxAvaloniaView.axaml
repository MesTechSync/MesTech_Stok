<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.BuyboxAvaloniaView"
             x:Name="RootBuyboxAvaloniaView"
             x:DataType="vm:BuyboxAvaloniaViewModel"
             AutomationProperties.Name="Buybox Analizi">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding LoadDataCommand}" />    </UserControl.KeyBindings>

    <!-- FIX-18 Gorev #13: Buybox Analizi View -->

    <Grid RowDefinitions="Auto,*">
        <!-- Loading Skeleton -->
        <Border Background="{DynamicResource BackgroundBrush}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader />
        </Border>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesBrandPrimary}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding PageTitle}" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding Items.Count, StringFormat='{}{0} ürün'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding LoadDataCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesBrandPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="24,16">

            <!-- Summary Cards -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16,12" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Kazanılan" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesEmerald}" FontWeight="SemiBold" />
                        <TextBlock Text="—" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold" Foreground="{DynamicResource MesGreen}" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16,12" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Kaybedilen" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesRedBright}" FontWeight="SemiBold" />
                        <TextBlock Text="—" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold" Foreground="{DynamicResource MesRedAlert}" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16,12" MinWidth="160">
                    <StackPanel>
                        <TextBlock Text="Toplam Ürün" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Items.Count}" FontSize="{StaticResource FontSizeHeader}" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- DataGrid -->
            <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                    BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserReorderColumns="True"
                          CanUserSortColumns="True" CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ürün Adı" Binding="{Binding ProductName}" Width="*" />
                        <DataGridTextColumn Header="Bizim Fiyat (₺)" Binding="{Binding OurPrice, StringFormat='{}{0:N2}'}" Width="140" />
                        <DataGridTextColumn Header="Rakip Fiyat (₺)" Binding="{Binding CompetitorPrice, StringFormat='{}{0:N2}'}" Width="140" />
                        <DataGridTemplateColumn Header="Durum" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="vm:BuyboxItemViewModel">
                                    <Border CornerRadius="{StaticResource MesRadiusSm}" Padding="8,4"
                                            HorizontalAlignment="Left"
                                            Background="{Binding StatusColor}">
                                        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource MesBgPrimary}"
                                                   FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <!-- Empty State -->
                <TextBlock Text="Urun bulunamadi"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,40"
                           Opacity="0.5"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           IsVisible="{Binding !Items.Count}" />
            </Grid>
            </Border>
        </Grid>

        <!-- Loading overlay -->
        <Border Grid.RowSpan="2" Background="{DynamicResource MesOverlayMedium}"
                IsVisible="{Binding IsLoading}">
            <TextBlock Text="Yükleniyor..." FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesSlateGray}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Platform verisi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz platform verisi bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

</Grid>
</UserControl>
