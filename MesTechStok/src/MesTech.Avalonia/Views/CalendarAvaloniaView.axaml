<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.CalendarAvaloniaView"
             x:Name="RootCalendarAvaloniaView"
             x:DataType="vm:CalendarAvaloniaViewModel"
             AutomationProperties.Name="Takvim">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">
        <!-- Loading Skeleton -->
        <Border Background="{DynamicResource BackgroundBrush}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader />
        </Border>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Takvim" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding CurrentMonth}" Foreground="{DynamicResource MesBgPrimary}"
                                   FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22" Spacing="0">

                <!-- Loading -->
                <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                           Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" Margin="0,20" />

                        <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

                <!-- Empty -->
                <TextBlock Text="Henuz etkinlik bulunmuyor."
                           IsVisible="{Binding IsEmpty}" Foreground="{DynamicResource MesMutedGray}"
                           HorizontalAlignment="Center" Margin="0,40" FontSize="{StaticResource FontSizeBody}" />

                <!-- Events List -->
                <ItemsControl ItemsSource="{Binding Events}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CalendarEventVm">
                            <Border Margin="0,0,0,10" Padding="16" Background="{DynamicResource MesBgPrimary}"
                                    CornerRadius="{StaticResource MesRadiusMd}" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Color bar -->
                                    <Border Grid.Column="0" Width="4" CornerRadius="2" Margin="0,0,14,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Color}" />
                                        </Border.Background>
                                    </Border>
                                    <!-- Content -->
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}" />
                                        <TextBlock Text="{Binding DateDisplay}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                    </StackPanel>
                                    <!-- Time + Type -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{Binding TimeRange}" FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{DynamicResource MesPrimaryBlue}" HorizontalAlignment="Right" />
                                        <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusSm}" Padding="6,2">
                                            <TextBlock Text="{Binding Type}" FontSize="{StaticResource FontSizeCaption1}" Foreground="{DynamicResource MesSlateGray}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
