<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MesTech.Avalonia.Views.CalendarAvaloniaView">

    <!-- Avalonia port — Takvim -->

    <Grid RowDefinitions="Auto,*" Background="#F8FAFC">
        <Border Grid.Row="0" Background="#2855AC" Padding="20,14">
            <TextBlock Text="Takvim" Foreground="White" FontSize="18" FontWeight="SemiBold" />
        </Border>
        <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="22" Padding="24"
                BorderBrush="#E0E6ED" BorderThickness="1">
            <TextBlock Text="Avalonia port — Takvim" FontSize="14" Foreground="#64748B"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
