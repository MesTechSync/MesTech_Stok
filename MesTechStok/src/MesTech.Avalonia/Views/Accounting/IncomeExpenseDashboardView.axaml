<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels.Accounting"
             x:Class="MesTech.Avalonia.Views.Accounting.IncomeExpenseDashboardView"
             x:Name="RootIncomeExpenseDashboardView"
             x:DataType="vm:IncomeExpenseDashboardViewModel"
             AutomationProperties.Name="Gelir Gider Dashboard">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesTeal}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Gelir / Gider Ozeti" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1" Content="Yeni Kayit" ToolTip.Tip="Yeni gelir/gider kaydi ekle"
                        Command="{Binding AddEntryCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Yenile" ToolTip.Tip="Verileri yenile (F5)"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- 4 KPI Cards -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPage}" Padding="16,12">
            <Grid ColumnDefinitions="*,*,*,*">
                <!-- Toplam Gelir -->
                <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Toplam Gelir" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding TotalIncomeFormatted}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesEmerald}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <!-- Toplam Gider -->
                <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Toplam Gider" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding TotalExpenseFormatted}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesDanger}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <!-- Net Kar -->
                <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Net Kar" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding NetProfitFormatted}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPrimaryBlue}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <!-- Kar Marji -->
                <Border Grid.Column="3" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Kar Marji" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding ProfitMarginFormatted}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPurple}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Recent Transactions DataGrid -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" Margin="16" CornerRadius="{StaticResource MesRadiusLg}"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
            <Grid>
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="Son 10 Islem" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDarkSlate}" Margin="16,12,16,8" />
                    <DataGrid Grid.Row="1" ItemsSource="{Binding RecentTransactions}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" BorderThickness="0"
                              CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="110" />
                            <DataGridTextColumn Header="Tur" Binding="{Binding Type}" Width="80" />
                            <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="140" />
                            <DataGridTextColumn Header="Tutar" Binding="{Binding AmountFormatted}" Width="130" />
                            <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="120" />
                            <DataGridTextColumn Header="Aciklama" Binding="{Binding Description}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsVisible="{Binding IsEmpty}">
                    <TextBlock Text="Henuz islem yok" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                    <TextBlock Text="Gelir veya gider kaydi ekleyerek baslayabilirsiniz"
                               FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                               HorizontalAlignment="Center" Opacity="0.7" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Gelir/gider ozeti yukleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
