<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels.Accounting"
             x:Class="MesTech.Avalonia.Views.Accounting.JournalEntryListView"
             x:DataType="vm:JournalEntryListViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding LoadDataCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*">
        <!-- Filtre bar -->
        <Border Grid.Row="0" Padding="12" Background="{DynamicResource SurfaceCardBrush}"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <DatePicker SelectedDate="{Binding FromDate}"  AutomationProperties.Name="Tarih seciniz"/>
                <TextBlock Text="-" VerticalAlignment="Center" Foreground="{DynamicResource MesSlateGray}" />
                <DatePicker SelectedDate="{Binding ToDate}"  AutomationProperties.Name="Tarih seciniz"/>
                <ComboBox ItemsSource="{Binding SourceTypes}"
                          SelectedItem="{Binding SelectedSourceType}"
                          PlaceholderText="Kaynak Tipi" Width="140"  AutomationProperties.Name="Kaynak Tipi"/>
                <Button Content="Filtrele" Command="{Binding FilterCommand}"
                        ToolTip.Tip="Filtrele"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                        Padding="12,6" CornerRadius="{StaticResource MesRadiusSm}" FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <TextBlock Grid.Row="1"
                   Text="Kayit bulunamadi"
                   FontSize="{StaticResource FontSizeTitle}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource MesMutedGray}"
                   IsVisible="{Binding IsEmpty}"
                   Opacity="0.5" />

        <!-- Yevmiye DataGrid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding JournalEntries}"
                  AutoGenerateColumns="False" CanUserSortColumns="True"
                  CanUserResizeColumns="True" CanUserReorderColumns="True" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Yevmiye No" Binding="{Binding EntryNumber}" Width="120" />
                <DataGridTextColumn Header="Tarih" Binding="{Binding EntryDateText}" Width="100" />
                <DataGridTextColumn Header="Aciklama" Binding="{Binding Description}" Width="*" />
                <DataGridTextColumn Header="Kaynak" Binding="{Binding SourceTypeText}" Width="100" />
                <DataGridTextColumn Header="Borc" Binding="{Binding TotalDebitText}" Width="120" />
                <DataGridTextColumn Header="Alacak" Binding="{Binding TotalCreditText}" Width="120" />
                <DataGridTextColumn Header="Denge" Binding="{Binding BalanceIcon}" Width="60" />
            </DataGrid.Columns>
        </DataGrid>
    
        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding LoadDataCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>


        <!-- Loading State -->
        <Border IsVisible="{Binding IsLoading}" Background="{DynamicResource MesOverlayLight}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" />
                <TextBlock Text="Veriler yukleniyor..." FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
