<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels.Accounting"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.Accounting.CommissionRatesView"
             x:Name="RootCommissionRatesView"
             x:DataType="vm:CommissionRatesViewModel"
             AutomationProperties.Name="Komisyon Oranlari">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding LoadDataCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Loading Skeleton -->
        <Border Background="{DynamicResource BackgroundBrush}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader />
        </Border>

        <!-- Aciklama -->
        <Border Grid.Row="0" Padding="12" Background="{DynamicResource MesBgSecondary}"
                CornerRadius="{StaticResource MesRadiusMd}" Margin="12,12,12,0">
            <TextBlock TextWrapping="Wrap" FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{DynamicResource MesSlateGray}">
                Platform komisyon oranlari burada yonetilir. Siparis tamamlandiginda
                komisyon otomatik olarak gider kaydi (GL 760.02) olusturur.
            </TextBlock>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Padding="12,8" Margin="12,8,12,0">
            <TextBox Text="{Binding SearchText}"
                     Watermark="Ara..." AutomationProperties.Name="Ara..."
                     Width="240" Padding="10,8" HorizontalAlignment="Left"
                     CornerRadius="{StaticResource MesRadiusMd}"
                     FontSize="{StaticResource FontSizeBody}" />
        </Border>

        <!-- Empty State -->
        <TextBlock Grid.Row="2"
                   Text="Kayit bulunamadi"
                   FontSize="{StaticResource FontSizeTitle}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource MesMutedGray}"
                   IsVisible="{Binding !CommissionRates.Count}"
                   Opacity="0.5" />

        <!-- Komisyon tablosu -->
        <DataGrid Grid.Row="2" Margin="12" ItemsSource="{Binding CommissionRates}"
                  AutoGenerateColumns="False" CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                  BorderThickness="0" Background="{DynamicResource MesBgPrimary}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Platform" Binding="{Binding PlatformName}" Width="140" />
                <DataGridTextColumn Header="Komisyon %" Binding="{Binding RateText}" Width="100" />
                <DataGridTextColumn Header="Sabit Tutar" Binding="{Binding FixedAmountText}" Width="120" />
                <DataGridTextColumn Header="Gecerlilik" Binding="{Binding EffectivePeriod}" Width="180" />
                <DataGridTextColumn Header="Ornek Hesaplama" Binding="{Binding ExampleCalculation}" Width="200" />
            </DataGrid.Columns>
        </DataGrid>
    
        <!-- Empty State -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <TextBlock Text="Komisyon orani bulunamadi" FontSize="{StaticResource FontSizeSubtitle}"
                           HorizontalAlignment="Center" Opacity="0.6" />
            </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding LoadDataCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>


        <!-- Loading State -->
        <Border IsVisible="{Binding IsLoading}" Background="{DynamicResource MesOverlayLight}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" />
                <TextBlock Text="Veriler yukleniyor..." FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
