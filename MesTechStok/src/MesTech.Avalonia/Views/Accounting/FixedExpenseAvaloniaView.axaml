<base:BaseView xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels.Accounting"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:base="using:MesTech.Avalonia.Views.Base"
             x:Class="MesTech.Avalonia.Views.Accounting.FixedExpenseAvaloniaView"
             x:Name="RootFixedExpenseAvaloniaView"
             x:DataType="vm:FixedExpenseAvaloniaViewModel">
<base:BaseView.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </base:BaseView.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesTeal}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Sabit Giderler" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayit'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile (F5)"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- KPI Row -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPage}" Padding="16,12">
            <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Aylik Toplam" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding MonthlyTotal}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPrimaryBlue}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Yillik Toplam" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding YearlyTotal}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesDanger}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16" Margin="4"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Aktif Gider" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding ActiveExpenseCount}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesEmerald}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                          Width="160" AutomationProperties.Name="Kategori filtresi" />
                <TextBox Width="260" Watermark="Gider adi ara..."
                         AutomationProperties.Name="Sabit gider ara"
                         Text="{Binding SearchText}" />
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="3" Background="{DynamicResource MesBgPrimary}" Margin="16" CornerRadius="{StaticResource MesRadiusLg}"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
            <Grid>
                <DataGrid ItemsSource="{Binding Items}"
                          AutomationProperties.Name="Sabit gider listesi"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" BorderThickness="0"
                          CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Gider Adi" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="110" />
                        <DataGridTextColumn Header="Aylik Tutar" Binding="{Binding MonthlyFormatted}" Width="130" />
                        <DataGridTextColumn Header="Periyot" Binding="{Binding Frequency}" Width="90" />
                        <DataGridTextColumn Header="Sonraki Odeme" Binding="{Binding NextPayment}" Width="120" />
                        <DataGridTextColumn Header="Durum" Binding="{Binding StatusText}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="Kayit bulunamadi"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="0,40" Opacity="0.5"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           IsVisible="{Binding !Items.Count}" />
            </Grid>
        </Border>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="4" Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="3" Background="{DynamicResource MesBgSurface}" IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Sabit gider bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Henuz sabit gider kaydi eklenmemis"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="1" Grid.RowSpan="3" Background="{DynamicResource MesBgSurface}" IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</base:BaseView>
