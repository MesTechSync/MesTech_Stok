<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.TenantAvaloniaView"
             x:DataType="vm:TenantAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-12: Tenant Yonetimi — tenant listesi + secim -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Tenant Yonetimi" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="16">

                <!-- Current Tenant Info -->
                <Border Background="White" CornerRadius="8" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Aktif Tenant" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                        <TextBlock Text="{Binding TenantName}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{Binding TenantCode, StringFormat='Kod: {0}'}"
                                       FontSize="13" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Text="{Binding TenantPlan, StringFormat='Plan: {0}'}"
                                       FontSize="13" Foreground="{DynamicResource MesSlateGray}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tenant Config -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Tenant Ayarlari" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                        <StackPanel Grid.Row="1" Margin="16" Spacing="12">
                            <Grid ColumnDefinitions="160,*">
                                <TextBlock Grid.Column="0" Text="Veritabani:" FontSize="14"
                                           Foreground="{DynamicResource MesTextSlate}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding DatabaseName}" FontSize="14"
                                           Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="160,*">
                                <TextBlock Grid.Column="0" Text="Max Kullanici:" FontSize="14"
                                           Foreground="{DynamicResource MesTextSlate}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding MaxUsers}" FontSize="14"
                                           Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="160,*">
                                <TextBlock Grid.Column="0" Text="Depolama:" FontSize="14"
                                           Foreground="{DynamicResource MesTextSlate}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding StorageUsed, StringFormat='{}{0} GB'}" FontSize="14"
                                           Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Tenant bilgileri yukleniyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
