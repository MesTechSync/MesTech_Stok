<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.DocumentManagerAvaloniaView"
             x:Name="RootDocumentManagerAvaloniaView"
             x:DataType="vm:DocumentManagerAvaloniaViewModel">

    <UserControl.KeyBindings>
        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Belge Yoneticisi" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} belge'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Belge Yukle" Command="{Binding UploadCommand}"
                        ToolTip.Tip="Yeni belge yukle"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="260" Watermark="Belge ara..." AutomationProperties.Name="Belge ara..."
                         Text="{Binding SearchText}" />
                <ComboBox Width="120" PlaceholderText="Tip"
                          ItemsSource="{Binding TypeOptions}"
                          SelectedItem="{Binding SelectedType}"  AutomationProperties.Name="Tip"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Loading -->
            <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>

            <!-- Empty -->
            <TextBlock Text="Henuz belge bulunmuyor."
                       IsVisible="{Binding IsEmpty}" Foreground="{DynamicResource MesMutedGray}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBody}" />

            <!-- Data Grid -->
                <Grid>
            <DataGrid ItemsSource="{Binding Documents}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource MesBgPrimary}"
                     >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Belge Adi" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="Klasor" Binding="{Binding Folder}" Width="130" />
                    <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="80" />
                    <DataGridTextColumn Header="Boyut" Binding="{Binding Size}" Width="90" />
                    <DataGridTextColumn Header="Yukleyen" Binding="{Binding UploadedBy}" Width="120" />
                    <DataGridTextColumn Header="Tarih" Binding="{Binding UploadedDisplay}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Belge bulunamadi"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               IsVisible="{Binding !Documents.Count}" />
                </Grid>
        </Grid>
${skeleton}
<!-- Loading Skeleton -->        <Border Grid.Row="0" Grid.RowSpan="3"                Background="{DynamicResource MesBgPage}"                IsVisible="{Binding IsLoading}"                ZIndex="100">            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />        </Border>
    </Grid>
</UserControl>
