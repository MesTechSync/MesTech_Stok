<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MesTech.Avalonia.ViewModels"
        x:Class="MesTech.Avalonia.Views.LoginWindow"
        x:DataType="vm:LoginAvaloniaViewModel"
        Title="MesTech — Giriş"
        Width="420" Height="520"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="{DynamicResource BackgroundBrush}">

  <Border Background="{DynamicResource SurfaceBrush}"
          CornerRadius="{StaticResource CornerRadiusLarge}"
          Margin="32"
          Padding="32"
          VerticalAlignment="Center"
          BoxShadow="{DynamicResource MesElevation3}">
    <StackPanel Spacing="16">

      <!-- Logo / Baslik -->
      <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,0,0,8">
        <TextBlock Text="MesTech"
                   FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryBlueBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Entegratör Stok Yönetimi"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Kullanici adi -->
      <StackPanel Spacing="4">
        <TextBlock Text="Kullanıcı Adı"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <TextBox x:Name="UsernameBox"
                 Text="admin"
                 Watermark="Kullanıcı adınızı girin" AutomationProperties.Name="Kullanıcı adınızı girin"
                 FontSize="{StaticResource FontSizeBody}"/>
      </StackPanel>

      <!-- Sifre -->
      <StackPanel Spacing="4">
        <TextBlock Text="Şifre"
                   FontSize="{StaticResource FontSizeSmall}"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <Grid>
          <TextBox x:Name="PasswordBox"
                   PasswordChar="●"
                   Watermark="Şifrenizi girin" AutomationProperties.Name="Şifrenizi girin"
                   FontSize="{StaticResource FontSizeBody}"/>
          <Button x:Name="TogglePasswordBtn"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"
                  Background="Transparent"
                  Padding="4"
                  Cursor="Hand"
                  Click="OnTogglePassword">
            <TextBlock x:Name="PasswordToggleIcon" Text="👁" FontSize="{StaticResource FontSizeBody}"/>
          </Button>
        </Grid>
      </StackPanel>

      <!-- Beni Hatirla -->
      <CheckBox x:Name="RememberMeCheck"
                Content="Beni Hatırla"
                FontSize="{StaticResource FontSizeSmall}"
                Foreground="{DynamicResource TextSecondaryBrush}"/>

      <!-- Giris butonu -->
      <Button x:Name="LoginButton"
              ToolTip.Tip="GIRIS YAP"
              Content="GİRİŞ YAP"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Height="44"
              FontSize="{StaticResource FontSizeBody}"
              FontWeight="SemiBold"
              Background="{DynamicResource PrimaryBlueBrush}"
              Foreground="{DynamicResource MesBgPrimary}"
              CornerRadius="{StaticResource CornerRadiusMedium}"
              Click="OnLoginClick"/>

      <!-- Hata mesaji (varsayilan gizli) -->
      <Border x:Name="ErrorPanel"
              Background="{DynamicResource MesBgDangerLight}"
              CornerRadius="{StaticResource CornerRadiusLarge}"
              Padding="12,8"
              IsVisible="False">
        <TextBlock x:Name="ErrorText"
                   Foreground="{DynamicResource ErrorRedBrush}"
                   FontSize="{StaticResource FontSizeSmall}"
                   TextWrapping="Wrap"/>
      </Border>

      <!-- Lockout panel (brute-force kilitleme) -->
      <Border x:Name="LockoutPanel"
              Background="{DynamicResource MesBgSurface}"
              CornerRadius="{StaticResource CornerRadiusLarge}"
              Padding="12,8"
              IsVisible="False">
        <StackPanel Spacing="4">
          <TextBlock x:Name="LockoutText"
                     Foreground="{DynamicResource MesAmber}"
                     FontSize="{StaticResource FontSizeSmall}"
                     FontWeight="SemiBold"/>
          <TextBlock x:Name="LockoutCountdown"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="{StaticResource FontSizeCaption}"/>
        </StackPanel>
      </Border>

      <!-- Demo giriş bilgisi (WPF ile aynı) -->
      <TextBlock Text="Demo Giriş: admin / Admin123!"
                 FontSize="{StaticResource FontSizeCaption}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 HorizontalAlignment="Center"
                 Opacity="0.7"/>

    </StackPanel>
  </Border>
</Window>
