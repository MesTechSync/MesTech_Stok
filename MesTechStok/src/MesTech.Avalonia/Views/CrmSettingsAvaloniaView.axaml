<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.CrmSettingsAvaloniaView"
             x:Name="RootCrmSettingsAvaloniaView"
             x:DataType="vm:CrmSettingsAvaloniaViewModel">

    <UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding LoadDataCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Loading State -->
        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="3" Grid.Row="0" />

        <!-- Header -->
        <Border Grid.Row="1" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="CRM Ayarlari" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center"
                           Grid.Column="0" />
                <Button Grid.Column="1" Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet" Command="{Binding SaveSettingsCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}"
                        IsEnabled="{Binding !IsSaving}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22" Spacing="20" MaxWidth="700" HorizontalAlignment="Left">

                <!-- MESA AI Settings -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <TextBlock Text="MESA AI Ayarlari" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBodyLg}" />

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MESA AI Otomatik Yanit" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" />
                                <TextBlock Text="Gelen mesajlar icin AI yanit onerisi olusturur"
                                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsMesaAiEnabled}"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Message Check Interval -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Mesaj Kontrol Araligi" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBodyLg}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <NumericUpDown Value="{Binding MessageCheckIntervalMinutes}"
                                           Minimum="1" Maximum="60" Increment="1"
                                           Width="120"  AutomationProperties.Name="Mesaj Kontrol Araligi"/>
                            <TextBlock Text="dakika" VerticalAlignment="Center"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" />
                        </StackPanel>
                        <TextBlock Text="Platformlardan yeni mesaj kontrolu bu aralikta yapilir."
                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}" />
                    </StackPanel>
                </Border>

                <!-- Quick Reply Templates -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="20"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Hizli Yanit Sablonlari" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBodyLg}" />

                        <TextBlock Text="Kayit bulunamadi"
                                   FontSize="{StaticResource FontSizeTitle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource MesMutedGray}"
                                   IsVisible="{Binding !QuickReplyTemplates.Count}"
                                   Opacity="0.5" Margin="0,12" />

                        <ListBox ItemsSource="{Binding QuickReplyTemplates}"
                                 SelectedItem="{Binding SelectedTemplate}"
                                 MinHeight="120" MaxHeight="280"
                                 Background="{DynamicResource MesBgPage}"
                                 CornerRadius="{StaticResource MesRadiusBase}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                               FontSize="{StaticResource FontSizeSmall}" Padding="4,6" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Add template -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <TextBox Grid.Column="0" Text="{Binding NewTemplateText}"
                                     Watermark="Yeni sablon metni..." AutomationProperties.Name="Yeni sablon metni..."
                                     Margin="0,0,8,0" />
                            <Button Grid.Column="1" Content="Ekle" Command="{Binding AddTemplateCommand}"
                                    ToolTip.Tip="Ekle"
                                    Background="{DynamicResource MesEmerald}" Foreground="{DynamicResource MesBgPrimary}" Padding="14,8"
                                    CornerRadius="{StaticResource MesRadiusBase}" FontWeight="SemiBold" />
                        </Grid>

                        <!-- Remove selected -->
                        <Button Content="Secili Sablonu Kaldir" Command="{Binding RemoveTemplateCommand}"
                                ToolTip.Tip="Secili Sablonu Kaldir"
                                Background="{DynamicResource MesRedBright}" Foreground="{DynamicResource MesBgPrimary}" Padding="14,8"
                                CornerRadius="{StaticResource MesRadiusBase}" FontSize="{StaticResource FontSizeSmall}"
                                HorizontalAlignment="Left"
                                IsEnabled="{Binding SelectedTemplate, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    
        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding LoadDataCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
