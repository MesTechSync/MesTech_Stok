<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.InvoiceSettingsAvaloniaView"
             x:Name="RootInvoiceSettingsAvaloniaView"
             x:DataType="vm:InvoiceSettingsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Fatura Ayarlari" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet"
                        Command="{Binding SaveCommand}"
                        Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Settings Form -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Left">

                <!-- E-Fatura Entegrasyonu -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="E-Fatura Entegrasyonu" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="E-Fatura Saglayici" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <ComboBox ItemsSource="{Binding InvoiceProviders}"
                                      SelectedItem="{Binding SelectedProvider}" Width="300"  AutomationProperties.Name="E-Fatura Saglayici"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="E-Fatura mukellefiyeti aktif"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEInvoiceActive}"
                                          OnContent="Evet" OffContent="Hayir"  AutomationProperties.Name="E-Fatura mukellefiyeti aktif"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="E-Arsiv fatura otomatik olustur"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoCreateEArchive}"
                                          OnContent="Acik" OffContent="Kapali"  AutomationProperties.Name="E-Arsiv fatura otomatik olustur"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Firma Bilgileri -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Firma Bilgileri" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Firma Unvani" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding CompanyName}" Watermark="Orn: MesTech Yazilim A.S." AutomationProperties.Name="Orn: MesTech Yazilim A.S." />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Vergi Dairesi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding TaxOffice}" Watermark="Orn: Mecidiyekoy" AutomationProperties.Name="Orn: Mecidiyekoy" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Vergi No" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding TaxNumber}" Watermark="Orn: 1234567890" AutomationProperties.Name="Orn: 1234567890" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Adres" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding CompanyAddress}" Watermark="Firma adresi" AutomationProperties.Name="Firma adresi"
                                     AcceptsReturn="True" Height="60" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Fatura Numaralama -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Fatura Numaralama" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Seri Oneki:"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding InvoicePrefix}"
                                     Watermark="Orn: MES" AutomationProperties.Name="Orn: MES" Width="160" HorizontalAlignment="Left" />
                        </Grid>
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Sonraki Numara:"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="1" Value="{Binding NextInvoiceNumber}"
                                          Minimum="1" FormatString="N0" Width="160"
                                          HorizontalAlignment="Left"  AutomationProperties.Name="Sonraki Numara:"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- KDV Ayarlari -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="KDV Ayarlari" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Varsayilan KDV Orani (%):"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="1" Value="{Binding DefaultVatRate}"
                                          Minimum="0" Maximum="100" FormatString="N0" Width="160"
                                          HorizontalAlignment="Left"  AutomationProperties.Name="Varsayilan KDV Orani (%):"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Fiyatlar KDV dahil gosterilsin"
                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding PricesIncludeVat}"
                                          OnContent="Evet" OffContent="Hayir"  AutomationProperties.Name="Fiyatlar KDV dahil gosterilsin"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Fatura ayarlari yukleniyor..." FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <TextBlock Text="Fatura ayari bulunamadi" FontSize="{StaticResource FontSizeSubtitle}"
                           HorizontalAlignment="Center" Opacity="0.6" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
