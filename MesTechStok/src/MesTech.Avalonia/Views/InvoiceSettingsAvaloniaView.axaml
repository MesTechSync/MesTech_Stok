<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.InvoiceSettingsAvaloniaView"
             x:DataType="vm:InvoiceSettingsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Fatura Ayarlari" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet"
                        Command="{Binding SaveCommand}"
                        Background="{DynamicResource MesGreen}" Foreground="White" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Settings Form -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Left">

                <!-- E-Fatura Entegrasyonu -->
                <Border Background="White" CornerRadius="12" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="0 2 8 0 #14000000">
                    <StackPanel Spacing="16">
                        <TextBlock Text="E-Fatura Entegrasyonu" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="E-Fatura Saglayici" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <ComboBox ItemsSource="{Binding InvoiceProviders}"
                                      SelectedItem="{Binding SelectedProvider}" Width="300" />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="E-Fatura mukellefiyeti aktif"
                                       FontSize="13" Foreground="{DynamicResource MesTextSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEInvoiceActive}"
                                          OnContent="Evet" OffContent="Hayir" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="E-Arsiv fatura otomatik olustur"
                                       FontSize="13" Foreground="{DynamicResource MesTextSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoCreateEArchive}"
                                          OnContent="Acik" OffContent="Kapali" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Firma Bilgileri -->
                <Border Background="White" CornerRadius="12" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="0 2 8 0 #14000000">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Firma Bilgileri" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <StackPanel Spacing="4">
                            <TextBlock Text="Firma Unvani" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding CompanyName}" Watermark="Orn: MesTech Yazilim A.S." AutomationProperties.Name="Orn: MesTech Yazilim A.S." />
                        </StackPanel>
                        <Grid ColumnDefinitions="*,16,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Vergi Dairesi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding TaxOffice}" Watermark="Orn: Mecidiyekoy" AutomationProperties.Name="Orn: Mecidiyekoy" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Vergi No" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding TaxNumber}" Watermark="Orn: 1234567890" AutomationProperties.Name="Orn: 1234567890" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Adres" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding CompanyAddress}" Watermark="Firma adresi" AutomationProperties.Name="Firma adresi"
                                     AcceptsReturn="True" Height="60" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Fatura Numaralama -->
                <Border Background="White" CornerRadius="12" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="0 2 8 0 #14000000">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Fatura Numaralama" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Seri Oneki:"
                                       FontSize="13" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding InvoicePrefix}"
                                     Watermark="Orn: MES" AutomationProperties.Name="Orn: MES" Width="160" HorizontalAlignment="Left" />
                        </Grid>
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Sonraki Numara:"
                                       FontSize="13" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="1" Value="{Binding NextInvoiceNumber}"
                                          Minimum="1" FormatString="N0" Width="160"
                                          HorizontalAlignment="Left" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- KDV Ayarlari -->
                <Border Background="White" CornerRadius="12" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" BoxShadow="0 2 8 0 #14000000">
                    <StackPanel Spacing="16">
                        <TextBlock Text="KDV Ayarlari" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <Grid ColumnDefinitions="200,*">
                            <TextBlock Grid.Column="0" Text="Varsayilan KDV Orani (%):"
                                       FontSize="13" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="1" Value="{Binding DefaultVatRate}"
                                          Minimum="0" Maximum="100" FormatString="N0" Width="160"
                                          HorizontalAlignment="Left" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Fiyatlar KDV dahil gosterilsin"
                                       FontSize="13" Foreground="{DynamicResource MesTextSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding PricesIncludeVat}"
                                          OnContent="Evet" OffContent="Hayir" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Fatura ayarlari yukleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
