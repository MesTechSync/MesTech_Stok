<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.LabelPreviewAvaloniaView"
             x:Name="RootLabelPreviewAvaloniaView"
             x:DataType="vm:LabelPreviewAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Etiket Onizleme — I-05 -->

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Kargo Etiketi Onizleme" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TrackingNumber}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <ComboBox Grid.Column="1" Width="100" Margin="0,0,8,0"
                          ItemsSource="{Binding Formats}"
                          SelectedItem="{Binding SelectedFormat}"  AutomationProperties.Name="Format seciniz"/>
                <Button Grid.Column="2" Content="Yazdir"
                        ToolTip.Tip="Yazdir"
                        Command="{Binding PrintCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <Button Grid.Column="3" Content="Indir"
                        ToolTip.Tip="Indir"
                        Command="{Binding DownloadCommand}"
                        Background="{DynamicResource MesBadgeOverlay}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Label Preview Content -->
        <ScrollViewer Grid.Row="1" Background="{DynamicResource MesBgMist}" HorizontalScrollBarVisibility="Disabled">
            <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Margin="40,24" Padding="0"
                    MaxWidth="500" HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="2">

                <StackPanel>
                    <!-- Label Header -->
                    <Border Background="{DynamicResource MesDarkSlate}" Padding="16,12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding CargoProvider}"
                                       Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding TrackingNumber}"
                                       Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Barcode Area -->
                    <Border Background="{DynamicResource MesBgPage}" Padding="20,16"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="0,0,0,1">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <Border Background="{DynamicResource MesDarkSlate}" Height="60" Width="300" CornerRadius="2" />
                            <TextBlock Text="{Binding BarcodeText}" FontSize="{StaticResource FontSizeSmall}"
                                       HorizontalAlignment="Center" Foreground="{DynamicResource MesSlateGray}"
                                       FontFamily="Consolas" />
                        </StackPanel>
                    </Border>

                    <!-- Sender -->
                    <Border Padding="16,12" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="0,0,0,1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="GONDEREN" FontSize="{StaticResource FontSizeCaption1}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesMutedGray}" />
                            <TextBlock Text="{Binding SenderName}" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding SenderAddress}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding SenderPhone}" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesTextSlate}" />
                        </StackPanel>
                    </Border>

                    <!-- Recipient -->
                    <Border Padding="16,12" BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="0,0,0,1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="ALICI" FontSize="{StaticResource FontSizeCaption1}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesMutedGray}" />
                            <TextBlock Text="{Binding RecipientName}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding RecipientAddress}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                            <TextBlock Text="{Binding RecipientCity}" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding RecipientPhone}" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesTextSlate}" />
                        </StackPanel>
                    </Border>

                    <!-- Parcel Info -->
                    <Border Padding="16,12">
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="KOLI SAYISI" FontSize="{StaticResource FontSizeCaption1}" FontWeight="Bold" Foreground="{DynamicResource MesMutedGray}" />
                                <TextBlock Text="{Binding ParcelCount}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesDarkSlate}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="AGIRLIK" FontSize="{StaticResource FontSizeCaption1}" FontWeight="Bold" Foreground="{DynamicResource MesMutedGray}" />
                                <TextBlock Text="{Binding Weight, StringFormat='{}{0:N1} kg'}" FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold" Foreground="{DynamicResource MesDarkSlate}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Etiket hazirlaniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Etiket bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz etiket bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
