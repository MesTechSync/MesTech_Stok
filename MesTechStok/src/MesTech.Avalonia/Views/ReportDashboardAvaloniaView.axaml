<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="MesTech.Avalonia.Views.ReportDashboardAvaloniaView"
             x:Name="RootReportDashboardAvaloniaView"
             x:DataType="vm:ReportDashboardAvaloniaViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
    </UserControl.KeyBindings>

    <!-- WPF019: Raporlar — LiveCharts2 grafik + TreeView + filtreler [ENT-DEV2] -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- ═══ HEADER ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Raporlar"
                           Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Excel Aktar" ToolTip.Tip="Raporu Excel olarak dışa aktar"
                        Command="{Binding ExportExcelCommand}"
                        Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}"
                        FontWeight="SemiBold" Padding="16,8"
                        CornerRadius="{StaticResource MesRadiusBase}"
                        Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}"
                        FontWeight="SemiBold" Padding="16,8"
                        CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="260,*">

            <!-- ── LEFT PANEL: Report Type TreeView ───────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource MesBgPrimary}"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,1,0"
                    Padding="0">
                <Grid RowDefinitions="Auto,*">

                    <!-- Panel header -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Rapor Tipi"
                                   FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                    </Border>

                    <!-- Category + children list -->
                    <ScrollViewer Grid.Row="1">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding ReportCategories}" Padding="8,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ReportCategoryItem">
                                        <StackPanel Spacing="2" Margin="0,0,0,8">
                                            <!-- Category header -->
                                            <Border Padding="10,8" CornerRadius="{StaticResource MesRadiusBase}"
                                                    Background="{DynamicResource MesBgSurface}">
                                                <TextBlock Text="{Binding CategoryName}"
                                                           FontSize="{StaticResource FontSizeSmall}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MesSlateGray}" />
                                            </Border>
                                            <!-- Child items -->
                                            <ItemsControl ItemsSource="{Binding Children}" Margin="8,2,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <Button Content="{Binding}"
                                                                HorizontalAlignment="Stretch"
                                                                HorizontalContentAlignment="Left"
                                                                Padding="10,7"
                                                                CornerRadius="{StaticResource MesRadiusBase}"
                                                                Background="Transparent"
                                                                Foreground="{DynamicResource MesDarkSlate}"
                                                                FontSize="{StaticResource FontSizeBody}"
                                                                Margin="0,1" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="Rapor kategorisi bulunamadı"
                                       HorizontalAlignment="Center" Margin="0,24"
                                       Opacity="0.5" FontSize="{StaticResource FontSizeSubtitle}"
                                       IsVisible="{Binding !ReportCategories.Count}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── RIGHT PANEL: Filters + Chart + Table ───────────────────── -->
            <ScrollViewer Grid.Column="1" Padding="16">
                <StackPanel Spacing="16">

                    <!-- Generating progress overlay -->
                    <Border Background="{DynamicResource MesBgSurface}"
                            CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                            BorderBrush="{DynamicResource MesBorderAmberLight}" BorderThickness="1"
                            IsVisible="{Binding IsGenerating}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                             VerticalAlignment="Center" />
                                <TextBlock Text="{Binding GeneratingMessage}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{DynamicResource MesAmber}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                         Height="6" CornerRadius="3" />
                        </StackPanel>
                    </Border>

                    <!-- ── FILTER BAR ──────────────────────────────────────── -->
                    <Border Background="{DynamicResource MesBgPrimary}"
                            CornerRadius="{StaticResource MesRadiusLg}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Filtreler"
                                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <WrapPanel Orientation="Horizontal">

                                <!-- DateFrom -->
                                <StackPanel Spacing="4" Margin="0,0,16,8">
                                    <TextBlock Text="Başlangıç"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource MesSlateGray}" />
                                    <DatePicker SelectedDate="{Binding DateFrom}"
                                                Width="160"
                                                AutomationProperties.Name="Başlangıç Tarihi" />
                                </StackPanel>

                                <!-- DateTo -->
                                <StackPanel Spacing="4" Margin="0,0,16,8">
                                    <TextBlock Text="Bitiş"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource MesSlateGray}" />
                                    <DatePicker SelectedDate="{Binding DateTo}"
                                                Width="160"
                                                AutomationProperties.Name="Bitiş Tarihi" />
                                </StackPanel>

                                <!-- Platform -->
                                <StackPanel Spacing="4" Margin="0,0,16,8">
                                    <TextBlock Text="Platform"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{DynamicResource MesSlateGray}" />
                                    <ComboBox ItemsSource="{Binding Platforms}"
                                              SelectedItem="{Binding SelectedPlatform}"
                                              Width="160"
                                              AutomationProperties.Name="Platform Seçimi" />
                                </StackPanel>

                                <!-- Raporu Getir -->
                                <StackPanel Spacing="4" Margin="0,0,0,8">
                                    <TextBlock Text=" " FontSize="{StaticResource FontSizeCaption}" />
                                    <Button Content="Raporu Getir"
                                            ToolTip.Tip="Seçilen filtrelere göre raporu oluştur"
                                            Command="{Binding GenerateReportCommand}"
                                            Background="{DynamicResource MesPrimaryBlue}"
                                            Foreground="{DynamicResource MesBgPrimary}"
                                            FontWeight="SemiBold"
                                            Padding="20,10"
                                            CornerRadius="{StaticResource MesRadiusBase}" />
                                </StackPanel>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── KPI SUMMARY CARDS ───────────────────────────────── -->
                    <Grid ColumnDefinitions="*,*,*">
                        <!-- Satış -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource MesBgPrimary}"
                                CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1"
                                Margin="0,0,6,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Toplam Satış"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesSlateGray}" />
                                <TextBlock Text="{Binding TotalSales}"
                                           FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesPrimaryBlue}" />
                                <TextBlock Text="{Binding TotalOrders, StringFormat='{}{0} sipariş'}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                        </Border>

                        <!-- Stok -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource MesBgPrimary}"
                                CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1"
                                Margin="3,0,3,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Toplam Ürün"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesSlateGray}" />
                                <TextBlock Text="{Binding TotalProducts}"
                                           FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesGreen}" />
                                <TextBlock Text="{Binding LowStockCount, StringFormat='{}{0} düşük stok'}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesAmber}" />
                            </StackPanel>
                        </Border>

                        <!-- Karlılık -->
                        <Border Grid.Column="2"
                                Background="{DynamicResource MesBgPrimary}"
                                CornerRadius="{StaticResource MesRadiusMdLg}" Padding="16"
                                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1"
                                Margin="6,0,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Net Kâr"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesSlateGray}" />
                                <TextBlock Text="{Binding NetProfit}"
                                           FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesTeal}" />
                                <TextBlock Text="{Binding TotalExpenses, StringFormat='Gider: {0}'}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── LIVECHARTS2 CHART ───────────────────────────────── -->
                    <Border Background="{DynamicResource MesBgPrimary}"
                            CornerRadius="{StaticResource MesRadiusLg}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Satış &amp; Sipariş Trendi"
                                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Son 7 gün — ColumnSeries: Satış (TL) · LineSeries: Sipariş adedi"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <lvc:CartesianChart Series="{Binding ChartSeries}"
                                               XAxes="{Binding XAxes}"
                                               YAxes="{Binding YAxes}"
                                               Height="280"
                                               LegendPosition="Bottom" />
                        </StackPanel>
                    </Border>

                    <!-- ── SUMMARY TABLE ───────────────────────────────────── -->
                    <Border Background="{DynamicResource MesBgPrimary}"
                            CornerRadius="{StaticResource MesRadiusLg}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Rapor Detayı"
                                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Excel Aktar"
                                        ToolTip.Tip="Tabloyu Excel olarak dışa aktar"
                                        Command="{Binding ExportExcelCommand}"
                                        Background="{DynamicResource MesGreen}"
                                        Foreground="{DynamicResource MesBgPrimary}"
                                        FontWeight="SemiBold" Padding="14,8"
                                        CornerRadius="{StaticResource MesRadiusBase}" />
                            </Grid>

                            <DataGrid ItemsSource="{Binding ReportRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      CanUserSortColumns="True"
                                      CanUserResizeColumns="True"
                                      CanUserReorderColumns="True"
                                      MaxHeight="320">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tarih"
                                                        Binding="{Binding Tarih}"
                                                        Width="110" />
                                    <DataGridTextColumn Header="Platform"
                                                        Binding="{Binding Platform}"
                                                        Width="130" />
                                    <DataGridTextColumn Header="Dönem"
                                                        Binding="{Binding DonemTipi}"
                                                        Width="100" />
                                    <DataGridTextColumn Header="Sipariş"
                                                        Binding="{Binding SiparisSayisi}"
                                                        Width="90" />
                                    <DataGridTextColumn Header="Satış (TL)"
                                                        Binding="{Binding SatisTL}"
                                                        Width="130" />
                                    <DataGridTextColumn Header="Kâr (TL)"
                                                        Binding="{Binding KarTL}"
                                                        Width="130" />
                                    <DataGridTextColumn Header="Marjin %"
                                                        Binding="{Binding MarjinYuzde}"
                                                        Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Empty State -->
                            <TextBlock Text="Henüz rapor oluşturulmadı — yukarıdan filtre seçip 'Raporu Getir'e tıklayın."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,24"
                                       Opacity="0.55"
                                       FontSize="{StaticResource FontSizeBody}"
                                       IsVisible="{Binding !ReportRows.Count}" />
                        </StackPanel>
                    </Border>

                    <!-- ── QUICK REPORTS ───────────────────────────────────── -->
                    <Border Background="{DynamicResource MesBgPrimary}"
                            CornerRadius="{StaticResource MesRadiusLg}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Hızlı Raporlar"
                                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="Stok Değerleme"
                                        ToolTip.Tip="Stok Değerleme"
                                        Command="{Binding GenerateQuickReportCommand}"
                                        CommandParameter="Stok Değerleme"
                                        Background="{DynamicResource MesPrimaryBlue}"
                                        Foreground="{DynamicResource MesBgPrimary}"
                                        FontWeight="SemiBold" Padding="14,9"
                                        CornerRadius="{StaticResource MesRadiusBase}"
                                        Margin="0,0,8,8" />
                                <Button Content="Platform Performans"
                                        ToolTip.Tip="Platform Performans"
                                        Command="{Binding GenerateQuickReportCommand}"
                                        CommandParameter="Platform Performans"
                                        Background="{DynamicResource MesGreen}"
                                        Foreground="{DynamicResource MesBgPrimary}"
                                        FontWeight="SemiBold" Padding="14,9"
                                        CornerRadius="{StaticResource MesRadiusBase}"
                                        Margin="0,0,8,8" />
                                <Button Content="Ürün Karlılığı"
                                        ToolTip.Tip="Ürün Karlılığı"
                                        Command="{Binding GenerateQuickReportCommand}"
                                        CommandParameter="Ürün Karlılığı"
                                        Background="{DynamicResource MesPurple}"
                                        Foreground="{DynamicResource MesBgPrimary}"
                                        FontWeight="SemiBold" Padding="14,9"
                                        CornerRadius="{StaticResource MesRadiusBase}"
                                        Margin="0,0,8,8" />
                                <Button Content="Gönderim Raporu"
                                        ToolTip.Tip="Gönderim Raporu"
                                        Command="{Binding GenerateQuickReportCommand}"
                                        CommandParameter="Gönderim Raporu"
                                        Background="{DynamicResource MesWarning}"
                                        Foreground="{DynamicResource MesBgPrimary}"
                                        FontWeight="SemiBold" Padding="14,9"
                                        CornerRadius="{StaticResource MesRadiusBase}"
                                        Margin="0,0,8,8" />
                                <Button Content="Vergi Özeti"
                                        ToolTip.Tip="Vergi Özeti"
                                        Command="{Binding GenerateQuickReportCommand}"
                                        CommandParameter="Vergi Özeti"
                                        Background="{DynamicResource MesRedAlert}"
                                        Foreground="{DynamicResource MesBgPrimary}"
                                        FontWeight="SemiBold" Padding="14,9"
                                        CornerRadius="{StaticResource MesRadiusBase}"
                                        Margin="0,0,0,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── RECENT REPORTS ──────────────────────────────────── -->
                    <Border Background="{DynamicResource MesBgPrimary}"
                            CornerRadius="{StaticResource MesRadiusLg}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Son Raporlar"
                                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="En son oluşturulan raporlar"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding RecentReports}"
                                      AutoGenerateColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserReorderColumns="True"
                                      CanUserSortColumns="True"
                                      IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"
                                      BorderThickness="0"
                                      MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tarih"
                                                        Binding="{Binding Date}"
                                                        Width="120" />
                                    <DataGridTextColumn Header="Rapor Adı"
                                                        Binding="{Binding ReportName}"
                                                        Width="*" />
                                    <DataGridTextColumn Header="Format"
                                                        Binding="{Binding Format}"
                                                        Width="90" />
                                    <DataGridTextColumn Header="Boyut"
                                                        Binding="{Binding Size}"
                                                        Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="Kayıt bulunamadı"
                                       FontSize="{StaticResource FontSizeTitle}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MesMutedGray}"
                                       IsVisible="{Binding !RecentReports.Count}"
                                       Opacity="0.5" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ LOADING OVERLAY ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Rapor paneli yükleniyor..."
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ═══ ERROR STATE ════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="İşlemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
