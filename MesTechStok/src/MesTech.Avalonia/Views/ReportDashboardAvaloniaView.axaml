<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ReportDashboardAvaloniaView"
             x:DataType="vm:ReportDashboardAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Rapor Paneli — İ-11 Görev 4B -->
    <!-- Quick reports, parameters, scheduled & recent reports -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Rapor Paneli"
                           Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="24" MaxWidth="900">

                <!-- Generating Overlay -->
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16"
                        BorderBrush="{DynamicResource MesBorderAmberLight}" BorderThickness="1"
                        IsVisible="{Binding IsGenerating}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                                         VerticalAlignment="Center" />
                            <TextBlock Text="{Binding GeneratingMessage}" FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource MesAmber}" VerticalAlignment="Center" />
                        </StackPanel>
                        <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                                     Height="6" CornerRadius="3" />
                    </StackPanel>
                </Border>

                <!-- Quick Report Buttons -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Hizli Raporlar" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                        <WrapPanel Orientation="Horizontal">
                            <Button Content="Stok Degerleme"
                                    ToolTip.Tip="Stok Degerleme"
                                    Command="{Binding GenerateQuickReportCommand}"
                                    CommandParameter="Stok Degerleme"
                                    Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                    Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,8" />
                            <Button Content="Platform Performans"
                                    ToolTip.Tip="Platform Performans"
                                    Command="{Binding GenerateQuickReportCommand}"
                                    CommandParameter="Platform Performans"
                                    Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                    Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,8" />
                            <Button Content="Musteri Yasam Boyu"
                                    ToolTip.Tip="Musteri Yasam Boyu"
                                    Command="{Binding GenerateQuickReportCommand}"
                                    CommandParameter="CLV Analizi"
                                    Background="{DynamicResource MesPurple}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                    Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,8" />
                            <Button Content="Gonderim Raporu"
                                    ToolTip.Tip="Gonderim Raporu"
                                    Command="{Binding GenerateQuickReportCommand}"
                                    CommandParameter="Gonderim Raporu"
                                    Background="{DynamicResource MesWarning}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                    Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,8" />
                            <Button Content="Vergi Ozeti"
                                    ToolTip.Tip="Vergi Ozeti"
                                    Command="{Binding GenerateQuickReportCommand}"
                                    CommandParameter="Vergi Ozeti"
                                    Background="{DynamicResource MesRedAlert}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                    Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,8" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Report Parameters -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Rapor Parametreleri" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Ozel rapor olusturmak icin parametreleri ayarlayin"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,4">
                            <!-- Report Type -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,8,12">
                                <TextBlock Text="Rapor Turu" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <ComboBox ItemsSource="{Binding ReportTypes}"
                                          SelectedItem="{Binding SelectedReportType}"
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Platform Filter -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="8,0,0,12">
                                <TextBlock Text="Platform" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <ComboBox ItemsSource="{Binding Platforms}"
                                          SelectedItem="{Binding SelectedPlatform}"
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Start Date -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,0,8,12">
                                <TextBlock Text="Baslangic Tarihi" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <DatePicker SelectedDate="{Binding StartDate}" HorizontalAlignment="Stretch"  AutomationProperties.Name="Baslangic Tarihi" />
                            </StackPanel>

                            <!-- End Date -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="8,0,0,12">
                                <TextBlock Text="Bitis Tarihi" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <DatePicker SelectedDate="{Binding EndDate}" HorizontalAlignment="Stretch"  AutomationProperties.Name="Bitis Tarihi" />
                            </StackPanel>

                            <!-- Export Format -->
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="8" Margin="0,0,0,12">
                                <TextBlock Text="Disari Aktarma Formati" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesDarkSlate}" />
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <RadioButton GroupName="ExportFmt" Content="Excel"
                                                 IsChecked="{Binding SelectedExportFormat,
                                                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                 FontSize="{StaticResource FontSizeBody}" />
                                    <RadioButton GroupName="ExportFmt" Content="PDF" FontSize="{StaticResource FontSizeBody}" />
                                    <RadioButton GroupName="ExportFmt" Content="CSV" FontSize="{StaticResource FontSizeBody}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Generate Button -->
                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2">
                                <Button Content="Rapor Olustur" ToolTip.Tip="Rapor olustur ve indir"
                                        Command="{Binding GenerateReportCommand}"
                                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                                        Padding="24,12" CornerRadius="{StaticResource MesRadiusBase}"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Scheduled Reports -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Zamanlanmis Raporlar" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Otomatik olarak olusturulan periyodik raporlar"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding ScheduledReports}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="True" CanUserReorderColumns="True"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  MaxHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Rapor Adi" Binding="{Binding Name}" Width="200" />
                                <DataGridTextColumn Header="Periyot" Binding="{Binding Period}" Width="100" />
                                <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="80" />
                                <DataGridTextColumn Header="Son Calisma" Binding="{Binding LastRun}" Width="120" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <!-- Empty State -->
                        <TextBlock Text="Kayit bulunamadi"
                                   FontSize="{StaticResource FontSizeTitle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource MesMutedGray}"
                                   IsVisible="{Binding !ScheduledReports.Count}"
                                   Opacity="0.5" />
                    </StackPanel>
                </Border>

                <!-- Recent Reports -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Son Raporlar" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="En son olusturulan raporlar"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding RecentReports}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="True" CanUserReorderColumns="True"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="120" />
                                <DataGridTextColumn Header="Rapor Adi" Binding="{Binding ReportName}" Width="220" />
                                <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="80" />
                                <DataGridTextColumn Header="Boyut" Binding="{Binding Size}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <!-- Empty State -->
                        <TextBlock Text="Kayit bulunamadi"
                                   FontSize="{StaticResource FontSizeTitle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource MesMutedGray}"
                                   IsVisible="{Binding !RecentReports.Count}"
                                   Opacity="0.5" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Rapor paneli yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Rapor bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz rapor bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
