<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.InventoryAvaloniaView"
             x:DataType="vm:InventoryAvaloniaViewModel">

    <!-- Avalonia port — Envanter (DataGrid + stok alarm gostergesi) -->

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#2855AC" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Envanter" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} urun'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                    <Border Background="#EF4444" CornerRadius="10" Padding="8,2"
                            IsVisible="{Binding AlarmCount}">
                        <TextBlock Text="{Binding AlarmCount, StringFormat='{}{0} alarm'}"
                                   Foreground="White" FontSize="12" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#2855AC" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <TextBox Width="320" Watermark="SKU, urun adi veya depo ara..."
                     Text="{Binding SearchText}"
                     HorizontalAlignment="Left" />
        </Border>

        <!-- Inventory DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="White">

            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" />
                <DataGridTextColumn Header="Ad" Binding="{Binding Ad}" Width="250" />
                <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar}" Width="90" />
                <DataGridTextColumn Header="Min Stok" Binding="{Binding MinStok}" Width="90" />
                <DataGridTextColumn Header="Max Stok" Binding="{Binding MaxStok}" Width="90" />
                <DataGridTextColumn Header="Depo" Binding="{Binding Depo}" Width="140" />
            </DataGrid.Columns>

            <DataGrid.Styles>
                <!-- Red row highlight for items below minimum stock -->
                <Style Selector="DataGridRow" x:DataType="vm:InventoryItemDto">
                    <Style Selector="^[Tag=alarm]">
                        <Setter Property="Background" Value="#FEE2E2" />
                        <Setter Property="Foreground" Value="#B91C1C" />
                    </Style>
                </Style>
            </DataGrid.Styles>
        </DataGrid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Envanter verileri yukleniyor..."
                           FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#F7F9FC"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Envanter bos" FontSize="48"
                           HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8" />
                <TextBlock Text="Henuz envanter verisi bulunamadi"
                           FontSize="16" Foreground="#64748B"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#F7F9FC"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#E53935"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="#E53935"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
