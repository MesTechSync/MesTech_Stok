<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.InventoryAvaloniaView"
             x:DataType="vm:InventoryAvaloniaViewModel">

    <!-- EMR-06 Gorev 4E: Envanter — 4 seviye stok badge + depo filtre + KPI kartlari + sayfalama -->

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Envanter" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} urun'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                    <Border Background="{DynamicResource MesRedBright}" CornerRadius="10" Padding="8,2"
                            IsVisible="{Binding AlarmCount}">
                        <TextBlock Text="{Binding AlarmCount, StringFormat='{}{0} alarm'}"
                                   Foreground="White" FontSize="12" FontWeight="Bold"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- KPI Cards -->
        <Border Grid.Row="1" Background="White" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <!-- Toplam Urun -->
                <Border Background="#EFF6FF" CornerRadius="8" Padding="16,10" MinWidth="140">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Toplam Urun" FontSize="11" Foreground="#3B82F6" />
                        <TextBlock Text="{Binding KpiTotal}" FontSize="22" FontWeight="Bold" Foreground="#1E40AF" />
                    </StackPanel>
                </Border>
                <!-- Kritik Stok -->
                <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="8" Padding="16,10" MinWidth="140">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Kritik Stok" FontSize="11" Foreground="{DynamicResource MesRedBright}" />
                        <TextBlock Text="{Binding KpiCritical}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource MesRedAlert}" />
                    </StackPanel>
                </Border>
                <!-- Stok Degeri -->
                <Border Background="#F0FDF4" CornerRadius="8" Padding="16,10" MinWidth="160">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Stok Degeri" FontSize="11" Foreground="#22C55E" />
                        <TextBlock Text="{Binding KpiStockValue, StringFormat='{}{0:N0} TL'}"
                                   FontSize="22" FontWeight="Bold" Foreground="#15803D" />
                    </StackPanel>
                </Border>
                <!-- Tukenen -->
                <Border Background="#FFF7ED" CornerRadius="8" Padding="16,10" MinWidth="140">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Tukenen" FontSize="11" Foreground="#F97316" />
                        <TextBlock Text="{Binding KpiOutOfStock}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource MesAmber}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Search Bar + Warehouse Filter -->
        <Border Grid.Row="2" Background="White" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBox Width="320" Watermark="SKU, urun adi veya depo ara..." AutomationProperties.Name="SKU, urun adi veya depo ara..."
                         Text="{Binding SearchText}"
                         HorizontalAlignment="Left" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Depo:" VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource MesTextSlate}" />
                    <ComboBox Width="180" ItemsSource="{Binding WarehouseFilter}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              PlaceholderText="Tum Depolar" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Inventory DataGrid -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="White">

            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" />
                <DataGridTextColumn Header="Ad" Binding="{Binding Ad}" Width="250" />
                <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar}" Width="90" />
                <DataGridTextColumn Header="Min Stok" Binding="{Binding MinStok}" Width="90" />
                <DataGridTextColumn Header="Max Stok" Binding="{Binding MaxStok}" Width="90" />
                <DataGridTextColumn Header="Depo" Binding="{Binding Depo}" Width="140" />
                <DataGridTextColumn Header="Durum" Binding="{Binding StokDurum}" Width="100" />
            </DataGrid.Columns>

            <DataGrid.Styles>
                <!-- EMR-06 renk tablosu — 4 seviye stok durumu satir renklendirme -->
                <Style Selector="DataGridRow" x:DataType="vm:InventoryItemDto">
                    <Style Selector="^[Tag=TUKENDI]">
                        <Setter Property="Background" Value="#D32F2F" />
                        <Setter Property="Foreground" Value="White" />
                    </Style>
                    <Style Selector="^[Tag=KRITIK]">
                        <Setter Property="Background" Value="#D32F2F" />
                        <Setter Property="Foreground" Value="White" />
                    </Style>
                    <Style Selector="^[Tag=DUSUK]">
                        <Setter Property="Background" Value="#F57C00" />
                        <Setter Property="Foreground" Value="White" />
                    </Style>
                    <Style Selector="^[Tag=YETERLI]">
                        <Setter Property="Background" Value="#E8F5E9" />
                    </Style>
                </Style>
            </DataGrid.Styles>
        </DataGrid>
<!-- Empty State -->        <TextBlock Grid.Row="3" Text="Kayıt bulunamadı"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="16"                   IsVisible="{Binding !Items.Count}" />

        <!-- Pagination -->
        <Border Grid.Row="4" Background="White" Padding="12,8"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding PaginationInfo}"
                           FontSize="12" Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Content="Onceki" Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding CanGoPrevious}"
                            Padding="12,6" CornerRadius="4" FontSize="12" />
                    <TextBlock Text="{Binding CurrentPage, StringFormat='Sayfa {0}'}"
                               FontSize="12" Foreground="{DynamicResource MesDarkSlate}" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="8,0" />
                    <Button Content="Sonraki" Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            Padding="12,6" CornerRadius="4" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Envanter verileri yukleniyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Envanter bos" FontSize="48"
                           HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8" />
                <TextBlock Text="Henuz envanter verisi bulunamadi"
                           FontSize="16" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
