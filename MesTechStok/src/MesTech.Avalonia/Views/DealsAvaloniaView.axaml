<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.DealsAvaloniaView"
             x:DataType="vm:DealsAvaloniaViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Firsatlar" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} firsat'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalAmount}" Foreground="White"
                                   FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Firsat"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBox Width="220" Watermark="Firsat ara..."
                         Text="{Binding SearchText}" />
                <ComboBox Width="160" PlaceholderText="Asama"
                          ItemsSource="{Binding StageOptions}"
                          SelectedItem="{Binding SelectedStage}" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Loading -->
            <TextBlock Text="Yukleniyor..." IsVisible="{Binding IsLoading}"
                       Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Error -->
            <Border IsVisible="{Binding HasError}" Background="#FEF2F2" Margin="22"
                    CornerRadius="8" Padding="16" BorderBrush="#FECACA" BorderThickness="1"
                    VerticalAlignment="Top">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap" />
            </Border>

            <!-- Empty -->
            <TextBlock Text="Henuz firsat bulunmuyor."
                       IsVisible="{Binding IsEmpty}" Foreground="#94A3B8"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />

            <!-- Data Grid -->
            <DataGrid ItemsSource="{Binding Deals}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="White"
                      IsVisible="{Binding !IsLoading}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Firsat Adi" Binding="{Binding Title}" Width="200" />
                    <DataGridTextColumn Header="Kisi" Binding="{Binding ContactName}" Width="150" />
                    <DataGridTextColumn Header="Tutar" Binding="{Binding AmountDisplay}" Width="120" />
                    <DataGridTextColumn Header="Asama" Binding="{Binding Stage}" Width="130" />
                    <DataGridTextColumn Header="Olasilik" Binding="{Binding ProbabilityDisplay}" Width="90" />
                    <DataGridTextColumn Header="Tarih" Binding="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
