<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.ProductsAvaloniaView"
             x:DataType="vm:ProductsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Avalonia Products — DataGrid with SKU, Ad, Fiyat, Stok, Platform, Durum -->
    <!-- GOREV 4: Smart Search + GOREV 5: Grid/List Toggle -->

    <Grid RowDefinitions="Auto,Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Urun Yonetimi" Foreground="White"
                               FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="10,4">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} urun'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <!-- GOREV 5: Grid/List Toggle Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Command="{Binding SetListViewCommand}"
                            Background="#FFFFFF88"
                            Padding="8,6" CornerRadius="4,0,0,4"
                            ToolTip.Tip="Liste Gorunumu">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="#FFFFFF44" />
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                        </Button.Styles>
                        <TextBlock Text="&#x2630;" FontSize="16" />
                    </Button>
                    <Button Command="{Binding SetGridViewCommand}"
                            Padding="8,6" CornerRadius="0,4,4,0"
                            ToolTip.Tip="Kart Gorunumu">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="#FFFFFF44" />
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                        </Button.Styles>
                        <TextBlock Text="&#x25A6;" FontSize="16" />
                    </Button>
                </StackPanel>

                <Button Grid.Column="2" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Row 1: Enhanced Search Bar (GOREV 4) -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBox Width="380" Watermark="Ad, SKU, Barkod veya Aciklama ile arayin..." AutomationProperties.Name="Ad, SKU, Barkod veya Aciklama ile arayin..."
                             Text="{Binding SearchText}" />
                    <!-- Barcode quick-search button -->
                    <Button Command="{Binding BarcodeSearchCommand}"
                            ToolTip.Tip="Barkod ile Hizli Ara"
                            Padding="10,8" CornerRadius="6"
                            Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesPrimaryBlue}">
                        <TextBlock Text="&#x2B1C;" FontSize="14" />
                    </Button>
                    <ComboBox Width="180"
                              ItemsSource="{Binding Platforms}"
                              SelectedItem="{Binding SelectedPlatform}" />
                    <!-- Search match indicator -->
                    <TextBlock Text="{Binding SearchMatchInfo}"
                               VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource MesSlateGray}"
                               IsVisible="{Binding SearchMatchInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 2: Quick Filter Chips (GOREV 4) -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPage}" Padding="16,8"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Filtreler:" FontSize="12" Foreground="{DynamicResource MesMutedGray}"
                           VerticalAlignment="Center" Margin="0,0,4,0" />
                <ToggleButton IsChecked="{Binding FilterOutOfStock}"
                              Padding="10,5" CornerRadius="12" FontSize="12">
                    <ToggleButton.Styles>
                        <Style Selector="ToggleButton">
                            <Setter Property="Background" Value="{DynamicResource MesBgMist}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesSlateGray}" />
                        </Style>
                        <Style Selector="ToggleButton:checked">
                            <Setter Property="Background" Value="{DynamicResource MesBgDangerLight}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesRedAlert}" />
                        </Style>
                    </ToggleButton.Styles>
                    <TextBlock Text="Stokta Yok" />
                </ToggleButton>
                <ToggleButton IsChecked="{Binding FilterLowStock}"
                              Padding="10,5" CornerRadius="12" FontSize="12">
                    <ToggleButton.Styles>
                        <Style Selector="ToggleButton">
                            <Setter Property="Background" Value="{DynamicResource MesBgMist}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesSlateGray}" />
                        </Style>
                        <Style Selector="ToggleButton:checked">
                            <Setter Property="Background" Value="#FEF3C7" />
                            <Setter Property="Foreground" Value="#D97706" />
                        </Style>
                    </ToggleButton.Styles>
                    <TextBlock Text="Dusuk Stok" />
                </ToggleButton>
                <ToggleButton IsChecked="{Binding FilterDiscounted}"
                              Padding="10,5" CornerRadius="12" FontSize="12">
                    <ToggleButton.Styles>
                        <Style Selector="ToggleButton">
                            <Setter Property="Background" Value="{DynamicResource MesBgMist}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesSlateGray}" />
                        </Style>
                        <Style Selector="ToggleButton:checked">
                            <Setter Property="Background" Value="#DBEAFE" />
                            <Setter Property="Foreground" Value="#2563EB" />
                        </Style>
                    </ToggleButton.Styles>
                    <TextBlock Text="Indirimli" />
                </ToggleButton>

                <!-- Recent Searches -->
                <Border Margin="12,0,0,0" IsVisible="{Binding RecentSearches.Count}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Son:" FontSize="11" Foreground="{DynamicResource MesMutedGray}"
                                   VerticalAlignment="Center" />
                        <ItemsControl ItemsSource="{Binding RecentSearches}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Command="{Binding $parent[UserControl].((vm:ProductsAvaloniaViewModel)DataContext).ApplyRecentSearchCommand}"
                                            CommandParameter="{Binding}"
                                            FontSize="11" Padding="6,2" CornerRadius="8"
                                            Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesSlateGray}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Row 3: Products - List View (DataGrid) -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="White"
                  Margin="0"
                  IsVisible="{Binding IsListView}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="140" />
                <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="280" />
                <DataGridTextColumn Header="Fiyat (TL)" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="130" />
                <DataGridTextColumn Header="Stok" Binding="{Binding Stock}" Width="80" />
                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="130" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State: Products -->
        <TextBlock Grid.Row="3"
                   Text="Kayıt bulunamadı"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,40"
                   Opacity="0.5"
                   FontSize="16"
                   IsVisible="{Binding !Products.Count}" />

        <!-- Row 3: Products - Grid View (GOREV 5) -->
        <ScrollViewer Grid.Row="3"
                      IsVisible="{Binding IsGridView}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Products}" Margin="16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProductItemDto">
                        <Border Width="220" Height="280" Margin="8"
                                Background="White" CornerRadius="10"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                BoxShadow="0 2 8 0 #14000000"
                                ClipToBounds="True">
                            <Grid RowDefinitions="140,*">
                                <!-- Product Image Placeholder -->
                                <Border Grid.Row="0" Background="{DynamicResource MesBgMist}" CornerRadius="10,10,0,0">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="&#x1F4E6;" FontSize="36"
                                                       HorizontalAlignment="Center" Opacity="0.4" />
                                            <TextBlock Text="{Binding SKU}" FontSize="10"
                                                       Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                        <!-- Discount badge -->
                                        <Border IsVisible="{Binding HasDiscount}"
                                                Background="{DynamicResource MesRedClassic}" CornerRadius="0,0,0,8"
                                                Padding="8,3" HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <TextBlock Text="INDIRIM" FontSize="10"
                                                       Foreground="White" FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Product Info -->
                                <StackPanel Grid.Row="1" Margin="12,10,12,10" Spacing="4">
                                    <!-- Product Name (2 lines max) -->
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MesDarkSlate}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2" TextWrapping="Wrap"
                                               Height="36" />

                                    <!-- Price -->
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding PriceDisplay}"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{DynamicResource MesPrimaryBlue}" />
                                        <TextBlock Text="{Binding OriginalPriceDisplay}"
                                                   FontSize="12" Foreground="{DynamicResource MesMutedGray}"
                                                   IsVisible="{Binding HasDiscount}"
                                                   TextDecorations="Strikethrough"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Stock -->
                                    <TextBlock Text="{Binding StockDisplay}"
                                               FontSize="12"
                                               Foreground="{Binding StockColor}" />

                                    <!-- Platform Badge -->
                                    <Border Background="{DynamicResource MesBgMist}" CornerRadius="4"
                                            Padding="6,2" HorizontalAlignment="Left"
                                            Margin="0,2,0,0">
                                        <TextBlock Text="{Binding PlatformBadge}"
                                                   FontSize="10" Foreground="{DynamicResource MesPrimaryBlue}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Urunler yukleniyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Kayit bulunamadi" FontSize="20"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesMutedGray}" Margin="0,0,0,8" />
                <TextBlock Text="Arama kriterlerine uygun urun bulunamadi"
                           FontSize="16" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="8" Padding="24" HorizontalAlignment="Center">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Hata Olustu" FontWeight="Bold" Foreground="{DynamicResource MesRedClassic}" FontSize="16" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="14" Foreground="#666"
                                   TextWrapping="Wrap" MaxWidth="400" />
                        <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                                Command="{Binding RefreshCommand}"
                                Padding="16,6" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
