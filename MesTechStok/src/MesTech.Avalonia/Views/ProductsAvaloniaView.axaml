<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:converters="using:MesTech.Avalonia.Converters"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:asyncImage="using:AsyncImageLoader"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.ProductsAvaloniaView"
             x:DataType="vm:ProductsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />        <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />    </UserControl.KeyBindings>

    <!-- Urun Yonetimi — DataGrid + Smart Search + Grid/List Toggle -->

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Background="{DynamicResource MesBgPage}">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Urun Yonetimi" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH2}" FontWeight="Bold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="10,4">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} urun'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <!-- Grid/List Toggle Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Command="{Binding SetListViewCommand}"
                            Background="{DynamicResource MesOverlayMedium}"
                            Padding="8,6" CornerRadius="4,0,0,4"
                            ToolTip.Tip="Liste Gorunumu">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="{DynamicResource MesBadgeOverlay}" />
                                <Setter Property="Foreground" Value="{DynamicResource MesBgPrimary}" />
                            </Style>
                        </Button.Styles>
                        <TextBlock Text="&#x2630;" FontSize="{StaticResource FontSizeSubtitle}" />
                    </Button>
                    <Button Command="{Binding SetGridViewCommand}"
                            Padding="8,6" CornerRadius="0,4,4,0"
                            ToolTip.Tip="Kart Gorunumu">
                        <Button.Styles>
                            <Style Selector="Button">
                                <Setter Property="Background" Value="{DynamicResource MesBadgeOverlay}" />
                                <Setter Property="Foreground" Value="{DynamicResource MesBgPrimary}" />
                            </Style>
                        </Button.Styles>
                        <TextBlock Text="&#x25A6;" FontSize="{StaticResource FontSizeSubtitle}" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Content="+ Yeni Urun" ToolTip.Tip="Yeni urun ekle"
                            Command="{Binding AddProductCommand}"
                            Background="{DynamicResource MesSuccessGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Enhanced Search Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBox x:Name="SearchBox" Width="380" Watermark="Ad, SKU, Barkod veya Aciklama ile arayin..." AutomationProperties.Name="Ad, SKU, Barkod veya Aciklama ile arayin..."
                             Text="{Binding SearchText}" />
                    <!-- Barcode quick-search button -->
                    <Button Command="{Binding BarcodeSearchCommand}"
                            ToolTip.Tip="Barkod ile Hizli Ara"
                            Padding="10,8" CornerRadius="{StaticResource MesRadiusBase}"
                            Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesPrimaryBlue}">
                        <TextBlock Text="&#x2B1C;" FontSize="{StaticResource FontSizeBody}" />
                    </Button>
                    <ComboBox Width="180"
                              ItemsSource="{Binding Platforms}"
                              SelectedItem="{Binding SelectedPlatform}"  AutomationProperties.Name="&#x2B1C;"/>
                    <!-- Search match indicator -->
                    <TextBlock Text="{Binding SearchMatchInfo}"
                               VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}"
                               IsVisible="{Binding SearchMatchInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Row 2: Quick Filter Chips -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPage}" Padding="16,8"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Filtreler:" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}"
                           VerticalAlignment="Center" Margin="0,0,4,0" />
                <ToggleButton IsChecked="{Binding FilterOutOfStock}"
                              Padding="10,5" CornerRadius="{StaticResource MesRadiusLg}" FontSize="{StaticResource FontSizeSmall}">
                    <ToggleButton.Styles>
                        <Style Selector="ToggleButton">
                            <Setter Property="Background" Value="{DynamicResource MesBgMist}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesSlateGray}" />
                        </Style>
                        <Style Selector="ToggleButton:checked">
                            <Setter Property="Background" Value="{DynamicResource MesBgDangerLight}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesRedAlert}" />
                        </Style>
                    </ToggleButton.Styles>
                    <TextBlock Text="Stokta Yok" />
                </ToggleButton>
                <ToggleButton IsChecked="{Binding FilterLowStock}"
                              Padding="10,5" CornerRadius="{StaticResource MesRadiusLg}" FontSize="{StaticResource FontSizeSmall}">
                    <ToggleButton.Styles>
                        <Style Selector="ToggleButton">
                            <Setter Property="Background" Value="{DynamicResource MesBgMist}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesSlateGray}" />
                        </Style>
                        <Style Selector="ToggleButton:checked">
                            <Setter Property="Background" Value="{DynamicResource MesBgAmberLight}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesAmberDark}" />
                        </Style>
                    </ToggleButton.Styles>
                    <TextBlock Text="Dusuk Stok" />
                </ToggleButton>
                <ToggleButton IsChecked="{Binding FilterDiscounted}"
                              Padding="10,5" CornerRadius="{StaticResource MesRadiusLg}" FontSize="{StaticResource FontSizeSmall}">
                    <ToggleButton.Styles>
                        <Style Selector="ToggleButton">
                            <Setter Property="Background" Value="{DynamicResource MesBgMist}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesSlateGray}" />
                        </Style>
                        <Style Selector="ToggleButton:checked">
                            <Setter Property="Background" Value="{DynamicResource MesBgSecondary}" />
                            <Setter Property="Foreground" Value="{DynamicResource MesPrimaryBlue}" />
                        </Style>
                    </ToggleButton.Styles>
                    <TextBlock Text="Indirimli" />
                </ToggleButton>

                <!-- Recent Searches -->
                <Border Margin="12,0,0,0" IsVisible="{Binding RecentSearches.Count}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Son:" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}"
                                   VerticalAlignment="Center" />
                        <ItemsControl ItemsSource="{Binding RecentSearches}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            ToolTip.Tip="{Binding}"
                                            Command="{Binding $parent[UserControl].((vm:ProductsAvaloniaViewModel)DataContext).ApplyRecentSearchCommand}"
                                            CommandParameter="{Binding}"
                                            FontSize="{StaticResource FontSizeCaption}" Padding="6,2" CornerRadius="{StaticResource MesRadiusMd}"
                                            Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesSlateGray}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Row 3: Products - List View (DataGrid) -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}"
                  Margin="0"
                  IsVisible="{Binding IsListView}"
                  DoubleTapped="OnDataGridDoubleTapped">
            <!-- WPF014: Row background by stock level (Red=out, Yellow=low, Transparent=ok) -->
            <DataGrid.Styles>
                <Style Selector="DataGridRow" x:DataType="vm:ProductItemDto">
                    <Setter Property="Background"
                            Value="{Binding RowBackground,
                                Converter={StaticResource StockLevelToBrushConverter},
                                FallbackValue=Transparent}" />
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="140" />
                <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="280" />
                <DataGridTextColumn Header="Fiyat (TL)" Binding="{Binding Price, StringFormat='{}{0:N2}'}" Width="130" />
                <DataGridTextColumn Header="Stok" Binding="{Binding Stock}" Width="80" />
                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="130" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State: Products -->
        <TextBlock Grid.Row="3"
                   Text="Kayıt bulunamadı"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,40"
                   Opacity="0.5"
                   FontSize="{StaticResource FontSizeSubtitle}"
                   IsVisible="{Binding !Products.Count}" />

        <!-- Row 3: Products - Grid View -->
        <ScrollViewer Grid.Row="3"
                      IsVisible="{Binding IsGridView}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Products}" Margin="16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProductItemDto">
                        <Border Width="220" Height="280" Margin="8"
                                Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMdLg}"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                BoxShadow="{DynamicResource MesElevationCard}"
                                ClipToBounds="True">
                            <Grid RowDefinitions="140,*">
                                <!-- Product Image (AsyncImageLoader lazy load) -->
                                <Border Grid.Row="0" Background="{DynamicResource MesBgMist}" CornerRadius="10,10,0,0">
                                    <Grid>
                                        <!-- Placeholder (görsel yoksa veya yüklenirken) -->
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    IsVisible="{Binding ImageUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}">
                                            <TextBlock Text="&#x1F4E6;" FontSize="{StaticResource FontSizeXL}"
                                                       HorizontalAlignment="Center" Opacity="0.4" />
                                            <TextBlock Text="{Binding SKU}" FontSize="{StaticResource FontSizeCaption1}"
                                                       Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                        <!-- Lazy-loaded product image -->
                                        <asyncImage:AdvancedImage
                                            IsVisible="{Binding ImageUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            Source="{Binding ImageUrl}"
                                            Stretch="UniformToFill"
                                            VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        <!-- Discount badge -->
                                        <Border IsVisible="{Binding HasDiscount}"
                                                Background="{DynamicResource MesRedClassic}" CornerRadius="0,0,0,8"
                                                Padding="8,3" HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <TextBlock Text="INDIRIM" FontSize="{StaticResource FontSizeCaption1}"
                                                       Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Product Info -->
                                <StackPanel Grid.Row="1" Margin="12,10,12,10" Spacing="4">
                                    <!-- Product Name (2 lines max) -->
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MesDarkSlate}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2" TextWrapping="Wrap"
                                               Height="36" />

                                    <!-- Price -->
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding PriceDisplay}"
                                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                                   Foreground="{DynamicResource MesPrimaryBlue}" />
                                        <TextBlock Text="{Binding OriginalPriceDisplay}"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}"
                                                   IsVisible="{Binding HasDiscount}"
                                                   TextDecorations="Strikethrough"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Stock -->
                                    <TextBlock Text="{Binding StockDisplay}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{Binding StockColor}" />

                                    <!-- Platform Badge -->
                                    <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusSm}"
                                            Padding="6,2" HorizontalAlignment="Left"
                                            Margin="0,2,0,0">
                                        <TextBlock Text="{Binding PlatformBadge}"
                                                   FontSize="{StaticResource FontSizeCaption1}" Foreground="{DynamicResource MesPrimaryBlue}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Row 4: HH-DEV2-001 Pagination Controls -->
        <Border Grid.Row="4" Background="{DynamicResource MesBgPrimary}" Padding="12,8"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Page size selector -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Sayfa boyutu:" FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{DynamicResource MesSlateGray}" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding PageSizeOptions}" SelectedItem="{Binding PageSize}"
                              Width="80" AutomationProperties.Name="Sayfa boyutu" />
                </StackPanel>

                <!-- Pagination info -->
                <TextBlock Grid.Column="1" Text="{Binding PaginationInfo}"
                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />

                <!-- Navigation buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Content="&#x00AB;" ToolTip.Tip="Ilk sayfa"
                            Command="{Binding FirstPageCommand}" Padding="10,6"
                            Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusSm}" />
                    <Button Content="&#x2039;" ToolTip.Tip="Onceki sayfa"
                            Command="{Binding PrevPageCommand}" Padding="10,6"
                            Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusSm}" />
                    <Border Background="{DynamicResource MesBgSecondary}" CornerRadius="{StaticResource MesRadiusSm}" Padding="12,6">
                        <TextBlock FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} / {1}">
                                    <Binding Path="CurrentPage" />
                                    <Binding Path="TotalPages" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                    <Button Content="&#x203A;" ToolTip.Tip="Sonraki sayfa"
                            Command="{Binding NextPageCommand}" Padding="10,6"
                            Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusSm}" />
                    <Button Content="&#x00BB;" ToolTip.Tip="Son sayfa"
                            Command="{Binding LastPageCommand}" Padding="10,6"
                            Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusSm}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State (Lottie + EmptyStateControl) -->
        <Border Grid.Row="1" Grid.RowSpan="4"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <controls:EmptyStateControl
                Title="Urun bulunamadi"
                Subtitle="Arama kriterlerine uygun urun bulunamadi. Filtreleri degistirmeyi deneyin."
                LottieSource="avares://MesTech.Avalonia/Assets/Animations/empty-box.json"
                ActionText="Yenile"
                ActionCommand="{Binding RefreshCommand}" />
        </Border>

        <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Grid.Row="0"
                    Title="Bir sorun oluştu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>
    </Grid>
</UserControl>
