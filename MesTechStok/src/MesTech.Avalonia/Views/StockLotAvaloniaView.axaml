<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StockLotAvaloniaView"
             x:DataType="vm:StockLotAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-06 Gorev 4A: Lot Ekleme — urun lot kaydi formu + son lotlar tablosu -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Lot Ekleme" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content: Form + Recent Lots -->
        <Grid Grid.Row="1" ColumnDefinitions="400,*" Margin="16">

            <!-- Left: Lot Entry Form -->
            <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="0,0,8,0">
                <StackPanel Spacing="14">
                    <TextBlock Text="Yeni Lot Kaydi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,4" />

                    <!-- Urun Arama -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Urun" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                        <TextBox Watermark="SKU veya urun adi ile ara..." AutomationProperties.Name="SKU veya urun adi ile ara..."
                                 Text="{Binding ProductSearchText}" />
                        <ListBox ItemsSource="{Binding ProductSuggestions}"
                                 SelectedItem="{Binding SelectedProduct}"
                                 MaxHeight="120"
                                 IsVisible="{Binding ProductSuggestions.Count}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LotProductDto">
                                    <TextBlock Text="{Binding Ad}" FontSize="{StaticResource FontSizeCallout}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- Lot Numarasi -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Lot Numarasi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                        <TextBox Watermark="LOT-2026-001" AutomationProperties.Name="LOT-2026-001"
                                 Text="{Binding LotNumber}" />
                    </StackPanel>

                    <!-- Miktar + Birim Maliyet -->
                    <Grid ColumnDefinitions="*,12,*">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Miktar" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <NumericUpDown Value="{Binding Quantity}" Minimum="0"
                                           FormatString="N0"  AutomationProperties.Name="Miktar"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Birim Maliyet (TL)" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                            <NumericUpDown Value="{Binding UnitCost}" Minimum="0"
                                           FormatString="N2" Increment="0.01"  AutomationProperties.Name="Birim Maliyet (TL)"/>
                        </StackPanel>
                    </Grid>

                    <!-- Tedarikci -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Tedarikci" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                        <ComboBox ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding SelectedSupplier}"
                                  PlaceholderText="Tedarikci secin..."
                                  HorizontalAlignment="Stretch"  AutomationProperties.Name="Tedarikci secin..."/>
                    </StackPanel>

                    <!-- Son Kullanma Tarihi -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Son Kullanma Tarihi (opsiyonel)" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                        <DatePicker SelectedDate="{Binding ExpiryDate}"
                                    HorizontalAlignment="Stretch"  AutomationProperties.Name="Son Kullanma Tarihi (opsiyonel)"/>
                    </StackPanel>

                    <!-- Depo -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Depo" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                        <ComboBox ItemsSource="{Binding Warehouses}"
                                  SelectedItem="{Binding SelectedWarehouse}"
                                  PlaceholderText="Depo secin..."
                                  HorizontalAlignment="Stretch"  AutomationProperties.Name="Depo secin..."/>
                    </StackPanel>

                    <!-- Kaydet -->
                    <Button Content="Lot Kaydet" Command="{Binding SaveLotCommand}"
                            ToolTip.Tip="Lot Kaydet"
                            Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="16,10" CornerRadius="{StaticResource MesRadiusBase}"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Margin="0,8,0,0" />

                    <!-- Status -->
                    <TextBlock Text="{Binding SaveStatus}" FontSize="{StaticResource FontSizeCallout}"
                               Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Right: Recent Lots Table -->
            <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                    BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Margin="8,0,0,0">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Son Lot Kayitlari" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDarkSlate}" />
                    </Border>
                <Grid>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding RecentLots}"
                              AutoGenerateColumns="False"
                              CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="{DynamicResource MesBgPrimary}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Lot No" Binding="{Binding LotNo}" Width="140" />
                            <DataGridTextColumn Header="Urun" Binding="{Binding ProductName}" Width="200" />
                            <DataGridTextColumn Header="Miktar" Binding="{Binding Quantity}" Width="80" />
                            <DataGridTextColumn Header="B.Maliyet" Binding="{Binding UnitCost, StringFormat='{}{0:N2} TL'}" Width="110" />
                            <DataGridTextColumn Header="Tedarikci" Binding="{Binding Supplier}" Width="160" />
                            <DataGridTextColumn Header="Depo" Binding="{Binding Warehouse}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Empty State -->
                    <!-- Empty State -->
                    <TextBlock Text="Stok verisi bulunamadi" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,40" Opacity="0.5" FontSize="{StaticResource FontSizeBody}"
                               IsVisible="{Binding !IsLoading}" />
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Lot verileri yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Stok verisi bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz urun bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
