<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.InvoiceCreateAvaloniaView"
             x:Name="InvoiceCreateAvaloniaView"
             x:DataType="vm:InvoiceCreateAvaloniaViewModel">

    <UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding LoadDataCommand}" />    </UserControl.KeyBindings>

    <!-- Fatura Olustur — 3 Adimli Sihirbaz -->

    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource BackgroundBrush}">

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBlueBrush}" Padding="20,14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource IconAdd}" Width="22" Height="22" Foreground="{DynamicResource MesBgPrimary}"/>
                <TextBlock Text="Fatura Olustur" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeHeader}" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Row 1: Step Indicator -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Padding="24,14"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
                <!-- Step 1 -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Width="28" Height="28" CornerRadius="{StaticResource MesRadiusLgXl}"
                            Background="{DynamicResource PrimaryBlueBrush}">
                        <TextBlock Text="1" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Siparis Sec" VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="—" Foreground="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                <!-- Step 2 -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Width="28" Height="28" CornerRadius="{StaticResource MesRadiusLgXl}"
                            Background="{DynamicResource BorderBrush}">
                        <TextBlock Text="2" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Fatura Detay" VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <TextBlock Text="—" Foreground="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>
                <!-- Step 3 -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Width="28" Height="28" CornerRadius="{StaticResource MesRadiusLgXl}"
                            Background="{DynamicResource BorderBrush}">
                        <TextBlock Text="3" Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Onizleme ve Onay" VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Fatura verileri yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesMutedGray}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Fatura olusturulacak siparis bulunamadi" FontSize="{StaticResource FontSizeTitle}"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesMutedGray}" Margin="0,0,0,8" />
                <TextBlock Text="Oncelikle siparis olusturun veya mevcut siparisleri kontrol edin"
                           FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="{StaticResource MesRadiusMd}" Padding="24" HorizontalAlignment="Center">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                                   Foreground="{DynamicResource MesDanger}" HorizontalAlignment="Center" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Row 2: Step Content -->
        <ScrollViewer Grid.Row="2" Padding="24">
          <Panel>
            <!-- Step 1: Order Selection -->
            <StackPanel IsVisible="{Binding CurrentStep, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=1}"
                        Spacing="12">
                <TextBlock Text="Fatura kesilecek siparisleri secin"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <DataGrid ItemsSource="{Binding Orders}"
                          AutoGenerateColumns="False"
                          CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                          IsReadOnly="False"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource BorderBrush}"
                          CornerRadius="{StaticResource CornerRadiusLarge}"
                          Background="{DynamicResource SurfaceBrush}"
                          MinHeight="300">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Sec" Binding="{Binding IsSelected}" Width="60"/>
                        <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderId}" Width="150"/>
                        <DataGridTextColumn Header="Musteri" Binding="{Binding CustomerName}" Width="240"/>
                        <DataGridTextColumn Header="Tutar (TL)" Binding="{Binding Amount, StringFormat='{}{0:N2}'}" Width="140"/>
                        <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="120"/>
                        <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
<!-- Empty State -->        <TextBlock Text="Siparis bulunamadi"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !Orders.Count}" />
            </StackPanel>

            <!-- Step 2: Invoice Details -->
            <StackPanel IsVisible="{Binding CurrentStep, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=2}"
                        Spacing="16" MaxWidth="600">
                <TextBlock Text="Fatura Detaylari"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Fatura Tipi" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ComboBox ItemsSource="{Binding InvoiceTypes}"
                                      SelectedItem="{Binding SelectedType}"
                                      HorizontalAlignment="Stretch" AutomationProperties.Name="Fatura Tipi"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Provider" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ComboBox ItemsSource="{Binding Providers}"
                                      SelectedItem="{Binding SelectedProvider}"
                                      HorizontalAlignment="Stretch" AutomationProperties.Name="Provider"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="KDV Orani (%)" FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ComboBox ItemsSource="{Binding KdvRates}"
                                      SelectedItem="{Binding KdvRate}"
                                      HorizontalAlignment="Stretch" AutomationProperties.Name="KDV Orani (%)"/>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>

                        <TextBlock Text="Alici Bilgileri" FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox Watermark="Alici Adi / Unvani" AutomationProperties.Name="Alici Adi / Unvani" Text="{Binding RecipientName}"/>
                        <TextBox Watermark="VKN / TCKN" AutomationProperties.Name="VKN / TCKN" Text="{Binding RecipientVkn}"/>
                        <TextBox Watermark="Adres" AutomationProperties.Name="Adres" Text="{Binding RecipientAddress}"
                                 AcceptsReturn="True" MinHeight="60"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Step 3: Preview -->
            <StackPanel IsVisible="{Binding CurrentStep, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=3}"
                        Spacing="16" MaxWidth="700">
                <TextBlock Text="Onizleme ve Onay"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="{StaticResource CornerRadiusLarge}"
                        Padding="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <!-- Provider + Type info -->
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Fatura Tipi" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedType}" FontWeight="SemiBold"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Provider" FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedProvider}" FontWeight="SemiBold"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>

                        <!-- Line items -->
                        <TextBlock Text="Kalemler" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"/>
                        <ItemsControl ItemsSource="{Binding PreviewLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:InvoiceLinePreviewDto">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                                        <TextBlock Grid.Column="0" Text="{Binding Description}"
                                                   FontSize="{StaticResource FontSizeBody}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Amount, StringFormat='{}{0:N2} TL'}"
                                                   FontWeight="SemiBold"
                                                   FontSize="{StaticResource FontSizeBody}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4"/>

                        <!-- Totals -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="Ara Toplam" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PreviewSubtotal, StringFormat='{}{0:N2} TL'}"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                            <TextBlock Text="{Binding KdvRate, StringFormat='KDV (%{0})'}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PreviewKdv, StringFormat='{}{0:N2} TL'}"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <TextBlock Text="Genel Toplam" FontWeight="Bold"
                                       FontSize="{StaticResource FontSizeSubtitle}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PreviewTotal, StringFormat='{}{0:N2} TL'}"
                                       FontWeight="Bold"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       Foreground="{DynamicResource PrimaryBlueBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
          </Panel>
        </ScrollViewer>

        <!-- Row 3: Navigation Buttons -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" Padding="24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Content="Geri"
                        ToolTip.Tip="Geri"
                        Command="{Binding GoBackCommand}"
                        IsVisible="{Binding CanGoBack}"
                        Padding="16,8" CornerRadius="{StaticResource CornerRadiusMedium}"
                        FontSize="{StaticResource FontSizeBody}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button Content="Ileri"
                            ToolTip.Tip="Ileri"
                            Command="{Binding GoNextCommand}"
                            IsVisible="{Binding CanGoNext}"
                            Background="{DynamicResource PrimaryBlueBrush}" Foreground="{DynamicResource MesBgPrimary}"
                            Padding="16,8" CornerRadius="{StaticResource CornerRadiusMedium}"
                            FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"/>
                    <Button Content="Fatura Olustur"
                            ToolTip.Tip="Fatura Olustur"
                            Command="{Binding ConfirmCommand}"
                            IsVisible="{Binding IsConfirmStep}"
                            Background="{DynamicResource MesGreen}" Foreground="{DynamicResource MesBgPrimary}"
                            Padding="20,8" CornerRadius="{StaticResource CornerRadiusMedium}"
                            FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12"/>
                <TextBlock Text="Islem yapiliyor..."
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    
        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding LoadDataCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
