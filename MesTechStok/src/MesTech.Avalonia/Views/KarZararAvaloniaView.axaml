<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.KarZararAvaloniaView"
             x:DataType="vm:KarZararAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header with period navigation -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Kar / Zarar Raporu" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <Button Content="&#x25C0;" Command="{Binding PrevMonthCommand}"
                            Background="Transparent" Foreground="{DynamicResource MesBgPrimary}"
                            BorderThickness="0" FontSize="16" Padding="8,4" />
                    <TextBlock Text="{Binding PeriodLabel}" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Content="&#x25B6;" Command="{Binding NextMonthCommand}"
                            Background="Transparent" Foreground="{DynamicResource MesBgPrimary}"
                            BorderThickness="0" FontSize="16" Padding="8,4" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile" Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" Margin="12,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- KPI Cards -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPage}" Padding="16">
            <Grid ColumnDefinitions="*,*,*,*">
                <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="20" Margin="6"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Gelir" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding TotalRevenue}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource MesEmerald}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="20" Margin="6"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Gider" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding TotalExpenses}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource MesRedBright}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="20" Margin="6"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Net Kar" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding NetProfit}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPrimaryBlue}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="20" Margin="6"
                        BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Kar Marji" FontSize="12" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding ProfitMarginText}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPurple}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Detail Table -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" Margin="16" CornerRadius="{StaticResource MesRadiusLg}"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Kalem Detayi" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                </Border>
                <Grid>
                <DataGrid Grid.Row="1" ItemsSource="{Binding LineItems}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kalem" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="100" />
                        <DataGridTextColumn Header="Tutar" Binding="{Binding AmountFormatted}" Width="140" />
                        <DataGridTextColumn Header="Oran (%)" Binding="{Binding PercentFormatted}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="16"
                               IsVisible="{Binding !LineItems.Count}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Kar/Zarar raporu yukleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Veri bulunamadi" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Secilen donem icin kar/zarar verisi yok"
                           FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
