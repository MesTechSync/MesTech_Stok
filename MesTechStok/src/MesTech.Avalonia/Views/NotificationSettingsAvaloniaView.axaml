<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.NotificationSettingsAvaloniaView"
             x:DataType="vm:NotificationSettingsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Bildirim Ayarlari — İ-11 Görev 4A -->
    <!-- Channels, category matrix, quiet hours, digest mode -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Bildirim Ayarlari"
                           Foreground="{DynamicResource MesBgPrimary}" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Test Gonder"
                        Command="{Binding SendTestNotificationCommand}"
                        Background="{DynamicResource MesBadgeOverlay}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet"
                        Command="{Binding SaveCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="24" MaxWidth="720">

                <!-- Save Success -->
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="8" Padding="14,10"
                        IsVisible="{Binding IsSaved}"
                        BorderBrush="{DynamicResource MesBorderSuccess}" BorderThickness="1">
                    <TextBlock Text="Bildirim ayarlari basariyla kaydedildi."
                               Foreground="{DynamicResource MesTeal}" FontSize="13" FontWeight="SemiBold" />
                </Border>

                <!-- Test Result -->
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="8" Padding="14,10"
                        IsVisible="{Binding IsTestSent}"
                        BorderBrush="{DynamicResource MesInfo}" BorderThickness="1">
                    <TextBlock Text="{Binding TestResult}"
                               Foreground="{DynamicResource MesPrimaryBlue}" FontSize="13" FontWeight="SemiBold" />
                </Border>

                <!-- Section 1: Bildirim Kanallari -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="12" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Bildirim Kanallari" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Bildirimlerin gonderilecegi kanallari secin"
                                       FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <!-- InApp Channel -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Uygulama Ici" FontSize="14" Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Anlık bildirimler uygulama icerisinde gosterilir"
                                           FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsInAppEnabled}"
                                          OnContent="" OffContent="" IsEnabled="False" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource MesBgMist}" />

                        <!-- Email Channel -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="E-posta" FontSize="14" Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Onemli bildirimler e-posta adresinize gonderilir"
                                           FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEmailEnabled}"
                                          OnContent="" OffContent="" />
                        </Grid>

                        <!-- Email Address (shown when email enabled) -->
                        <StackPanel Spacing="6" IsVisible="{Binding IsEmailEnabled}" Margin="16,0,0,0">
                            <TextBlock Text="E-posta Adresi" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBox Text="{Binding EmailAddress}"
                                     Watermark="ornek@sirket.com" AutomationProperties.Name="ornek@sirket.com"
                                     Padding="12,10" CornerRadius="8" FontSize="14" />
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource MesBgMist}" />

                        <!-- Telegram Channel -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Telegram" FontSize="14" Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Telegram bot uzerinden anlık bildirimler"
                                           FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsTelegramEnabled}"
                                          OnContent="" OffContent="" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource MesBgMist}" />

                        <!-- WhatsApp Channel -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="WhatsApp" FontSize="14" Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="WhatsApp Business API ile bildirimler"
                                           FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsWhatsAppEnabled}"
                                          OnContent="" OffContent="" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section 2: Kategori Matrisi -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="12" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Bildirim Kategorileri" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Her kategori icin hangi kanallardan bildirim alacaginizi secin"
                                       FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <!-- Column Headers -->
                        <Grid ColumnDefinitions="2*,*,*,*,*" Margin="0,4">
                            <TextBlock Grid.Column="0" Text="Kategori" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Grid.Column="1" Text="Uygulama" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="E-posta" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Telegram" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="WhatsApp" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource MesBorderLight}" />

                        <!-- Category rows -->
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:NotificationCategoryItem">
                                    <StackPanel Spacing="0">
                                        <Grid ColumnDefinitions="2*,*,*,*,*" Margin="0,6">
                                            <TextBlock Grid.Column="0" Text="{Binding CategoryName}"
                                                       FontSize="13" Foreground="{DynamicResource MesDarkSlate}"
                                                       VerticalAlignment="Center" />
                                            <CheckBox Grid.Column="1" IsChecked="{Binding InApp}"
                                                      HorizontalAlignment="Center" />
                                            <CheckBox Grid.Column="2" IsChecked="{Binding Email}"
                                                      HorizontalAlignment="Center" />
                                            <CheckBox Grid.Column="3" IsChecked="{Binding Telegram}"
                                                      HorizontalAlignment="Center" />
                                            <CheckBox Grid.Column="4" IsChecked="{Binding WhatsApp}"
                                                      HorizontalAlignment="Center" />
                                        </Grid>
                                        <Border Height="1" Background="{DynamicResource MesBgMist}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Section 3: Sessiz Saatler -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="12" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Sessiz Saatler" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Belirtilen saatler arasinda bildirim gonderilmez"
                                       FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <TextBlock Grid.Column="0" Text="Sessiz saatleri etkinlestir" FontSize="14"
                                       Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsQuietHoursEnabled}"
                                          OnContent="" OffContent="" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="16"
                                    IsVisible="{Binding IsQuietHoursEnabled}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Baslangic" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <TimePicker SelectedTime="{Binding QuietStart}" Width="140" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Bitis" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <TimePicker SelectedTime="{Binding QuietEnd}" Width="140" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section 4: Ozet Modu -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="12" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Bildirim Gonderim Modu" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Bildirimlerin anlık mi yoksa gunluk ozet olarak mi gonderilecegini secin"
                                       FontSize="12" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <RadioButton GroupName="DigestMode"
                                         IsChecked="{Binding IsInstantMode}"
                                         Content="Anlık Bildirim — Her olay aninda gonderilir"
                                         FontSize="14" />
                            <RadioButton GroupName="DigestMode"
                                         IsChecked="{Binding IsDailyDigestMode}"
                                         Content="Gunluk Ozet — Tum bildirimler tek e-postada"
                                         FontSize="14" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12"
                                    IsVisible="{Binding IsDailyDigestMode}">
                            <TextBlock Text="Ozet gonderim saati:" FontSize="13" Foreground="{DynamicResource MesDarkSlate}"
                                       VerticalAlignment="Center" />
                            <TimePicker SelectedTime="{Binding DigestTime}" Width="140" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Bildirim ayarlari yukleniyor..."
                           FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="14" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
