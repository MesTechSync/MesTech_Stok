<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.NotificationSettingsAvaloniaView"
             x:Name="RootNotificationSettingsAvaloniaView"
             x:DataType="vm:NotificationSettingsAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Bildirim Ayarlari — İ-11 Görev 4A -->
    <!-- Channels, category matrix, quiet hours, digest mode -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Bildirim Ayarlari"
                           Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Test Gonder"
                        ToolTip.Tip="Test Gonder"
                        Command="{Binding SendTestNotificationCommand}"
                        Background="{DynamicResource MesBadgeOverlay}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet"
                        Command="{Binding SaveCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="24" MaxWidth="720">

                <!-- Save Success -->
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="14,10"
                        IsVisible="{Binding IsSaved}"
                        BorderBrush="{DynamicResource MesBorderSuccess}" BorderThickness="1">
                    <TextBlock Text="Bildirim ayarlari basariyla kaydedildi."
                               Foreground="{DynamicResource MesTeal}" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" />
                </Border>

                <!-- Test Result -->
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="14,10"
                        IsVisible="{Binding IsTestSent}"
                        BorderBrush="{DynamicResource MesInfo}" BorderThickness="1">
                    <TextBlock Text="{Binding TestResult}"
                               Foreground="{DynamicResource MesPrimaryBlue}" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold" />
                </Border>

                <!-- Section 1: Bildirim Kanallari -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Bildirim Kanallari" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Bildirimlerin gonderilecegi kanallari secin"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <!-- InApp Channel -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Uygulama Ici" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Anlık bildirimler uygulama icerisinde gosterilir"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsInAppEnabled}"
                                          OnContent="" OffContent="" IsEnabled="False"  AutomationProperties.Name="Anlık bildirimler uygulama icerisinde gosterilir"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource MesBgMist}" />

                        <!-- Email Channel -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="E-posta" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Onemli bildirimler e-posta adresinize gonderilir"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEmailEnabled}"
                                          OnContent="" OffContent=""  AutomationProperties.Name="Onemli bildirimler e-posta adresinize gonderilir"/>
                        </Grid>

                        <!-- Email Address (shown when email enabled) -->
                        <StackPanel Spacing="6" IsVisible="{Binding IsEmailEnabled}" Margin="16,0,0,0">
                            <TextBlock Text="E-posta Adresi" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBox Text="{Binding EmailAddress}"
                                     Watermark="ornek@sirket.com" AutomationProperties.Name="ornek@sirket.com"
                                     Padding="12,10" CornerRadius="{StaticResource MesRadiusMd}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource MesBgMist}" />

                        <!-- Telegram Channel -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Telegram" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="Telegram bot uzerinden anlık bildirimler"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsTelegramEnabled}"
                                          OnContent="" OffContent=""  AutomationProperties.Name="Telegram bot uzerinden anlık bildirimler"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource MesBgMist}" />

                        <!-- WhatsApp Channel -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="WhatsApp" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDarkSlate}" />
                                <TextBlock Text="WhatsApp Business API ile bildirimler"
                                           FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsWhatsAppEnabled}"
                                          OnContent="" OffContent=""  AutomationProperties.Name="WhatsApp Business API ile bildirimler"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Section 2: Kategori Matrisi -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Bildirim Kategorileri" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Her kategori icin hangi kanallardan bildirim alacaginizi secin"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <!-- Column Headers -->
                        <Grid ColumnDefinitions="2*,*,*,*,*" Margin="0,4">
                            <TextBlock Grid.Column="0" Text="Kategori" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" />
                            <TextBlock Grid.Column="1" Text="Uygulama" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="E-posta" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Telegram" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="WhatsApp" FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource MesBorderLight}" />

                        <!-- Category rows -->
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:NotificationCategoryItem">
                                    <StackPanel Spacing="0">
                                        <Grid ColumnDefinitions="2*,*,*,*,*" Margin="0,6">
                                            <TextBlock Grid.Column="0" Text="{Binding CategoryName}"
                                                       FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesDarkSlate}"
                                                       VerticalAlignment="Center" />
                                            <CheckBox Grid.Column="1" IsChecked="{Binding InApp}"
                                                      HorizontalAlignment="Center" />
                                            <CheckBox Grid.Column="2" IsChecked="{Binding Email}"
                                                      HorizontalAlignment="Center" />
                                            <CheckBox Grid.Column="3" IsChecked="{Binding Telegram}"
                                                      HorizontalAlignment="Center" />
                                            <CheckBox Grid.Column="4" IsChecked="{Binding WhatsApp}"
                                                      HorizontalAlignment="Center" />
                                        </Grid>
                                        <Border Height="1" Background="{DynamicResource MesBgMist}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Kayit bulunamadi"
                                   FontSize="{StaticResource FontSizeTitle}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource MesMutedGray}"
                                   IsVisible="{Binding !Categories.Count}"
                                   Opacity="0.5" />
                    </StackPanel>
                </Border>

                <!-- Section 3: Sessiz Saatler -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Sessiz Saatler" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Belirtilen saatler arasinda bildirim gonderilmez"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
                            <TextBlock Grid.Column="0" Text="Sessiz saatleri etkinlestir" FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsQuietHoursEnabled}"
                                          OnContent="" OffContent=""  AutomationProperties.Name="Sessiz saatleri etkinlestir"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="16"
                                    IsVisible="{Binding IsQuietHoursEnabled}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Baslangic" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <TimePicker SelectedTime="{Binding QuietStart}" Width="140" />
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Bitis" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                <TimePicker SelectedTime="{Binding QuietEnd}" Width="140" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Section 4: Ozet Modu -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}" Padding="24"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Bildirim Gonderim Modu" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="Bildirimlerin anlık mi yoksa gunluk ozet olarak mi gonderilecegini secin"
                                       FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" />
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <RadioButton GroupName="DigestMode"
                                         IsChecked="{Binding IsInstantMode}"
                                         Content="Anlık Bildirim — Her olay aninda gonderilir"
                                         FontSize="{StaticResource FontSizeBody}" />
                            <RadioButton GroupName="DigestMode"
                                         IsChecked="{Binding IsDailyDigestMode}"
                                         Content="Gunluk Ozet — Tum bildirimler tek e-postada"
                                         FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12"
                                    IsVisible="{Binding IsDailyDigestMode}">
                            <TextBlock Text="Ozet gonderim saati:" FontSize="{StaticResource FontSizeCallout}" Foreground="{DynamicResource MesDarkSlate}"
                                       VerticalAlignment="Center" />
                            <TimePicker SelectedTime="{Binding DigestTime}" Width="140" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="1" Grid.RowSpan="1"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="40">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <TextBlock Text="Bildirim ayari bulunamadi" FontSize="{StaticResource FontSizeSubtitle}"
                           HorizontalAlignment="Center" Opacity="0.6" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
