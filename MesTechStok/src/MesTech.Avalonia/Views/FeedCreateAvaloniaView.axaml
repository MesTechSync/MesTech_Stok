<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.FeedCreateAvaloniaView"
             x:DataType="vm:FeedCreateAvaloniaViewModel">

    <!-- Feed Olusturma — URL, format, sync araligi, fiyat markup, kolon eslestirme -->

    <Grid RowDefinitions="Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <TextBlock Text="Yeni Feed Oluştur" Foreground="White"
                       FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel MaxWidth="600" Spacing="16">

                <!-- Basic Info -->
                <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E5E9F2" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Feed Bilgileri" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Feed Adı" FontSize="12" Foreground="#64748B" />
                            <TextBox Text="{Binding FeedName}" Watermark="Örn: ABC Elektronik XML" Padding="10,8" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Feed URL" FontSize="12" Foreground="#64748B" />
                            <TextBox Text="{Binding FeedUrl}" Watermark="https://tedarikci.com/feed.xml" Padding="10,8" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Format" FontSize="12" Foreground="#64748B" />
                            <ComboBox ItemsSource="{Binding FormatOptions}"
                                      SelectedItem="{Binding SelectedFormat}" Width="160" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding SyncIntervalMinutes, StringFormat='Senkronizasyon Aralığı: {0} dakika'}"
                                       FontSize="12" Foreground="#64748B" />
                            <Slider Minimum="15" Maximum="1440" Value="{Binding SyncIntervalMinutes}"
                                    TickFrequency="15" IsSnapToTickEnabled="True" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Pricing -->
                <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E5E9F2" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Fiyatlandırma" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" />

                        <Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                <TextBlock Text="Fiyat Artış %" FontSize="12" Foreground="#64748B" />
                                <TextBox Text="{Binding PriceMarkupPercent}" Padding="10,8" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
                                <TextBlock Text="Minimum Marj %" FontSize="12" Foreground="#64748B" />
                                <TextBox Text="{Binding MinimumMarginPercent}" Padding="10,8" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Column Mapping -->
                <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E5E9F2" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Kolon Eşleştirme" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" />
                            <Button Grid.Column="1" Content="+ Ekle" Command="{Binding AddMappingCommand}"
                                    Background="#0078D4" Foreground="White" Padding="10,4" CornerRadius="4" FontSize="12" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ColumnMappings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:FeedColumnMappingDto">
                                    <Grid ColumnDefinitions="*,Auto,*,Auto" Margin="0,4">
                                        <TextBox Grid.Column="0" Text="{Binding SourceColumn}" Watermark="Kaynak kolon"
                                                 Padding="8,6" Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1" Text="→" FontSize="16" VerticalAlignment="Center"
                                                   Foreground="#94A3B8" Margin="4,0" />
                                        <TextBox Grid.Column="2" Text="{Binding TargetField}" Watermark="Hedef alan"
                                                 Padding="8,6" Margin="0,0,8,0" />
                                        <Button Grid.Column="3" Content="X" FontSize="11"
                                                Command="{Binding $parent[ItemsControl].((vm:FeedCreateAvaloniaViewModel)DataContext).RemoveMappingCommand}"
                                                CommandParameter="{Binding}"
                                                Background="#FFEBEE" Foreground="#C62828"
                                                Padding="6,2" CornerRadius="4" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet" Command="{Binding SaveFeedCommand}"
                            Background="#4CAF50" Foreground="White" FontWeight="SemiBold"
                            Padding="20,10" CornerRadius="6" IsEnabled="{Binding !IsSaving}" />
                    <Button Content="Temizle" Command="{Binding ResetCommand}"
                            Background="#94A3B8" Foreground="White" Padding="16,10" CornerRadius="6" />
                </StackPanel>

                <Border Background="#E8F5E9" CornerRadius="8" Padding="12" IsVisible="{Binding SaveCompleted}">
                    <TextBlock Text="Feed başarıyla kaydedildi!" Foreground="#2E7D32" FontWeight="SemiBold" />
                </Border>

                <Border Background="#FFEBEE" CornerRadius="8" Padding="12" IsVisible="{Binding HasError}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#99FFFFFF" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Isleniyor..." FontSize="14" Foreground="#555555" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
