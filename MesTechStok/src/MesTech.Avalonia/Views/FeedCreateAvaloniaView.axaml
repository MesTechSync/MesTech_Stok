<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.FeedCreateAvaloniaView"
             x:DataType="vm:FeedCreateAvaloniaViewModel">

    <!-- Feed Olusturma — URL, format, sync araligi, fiyat markup, kolon eslestirme -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <TextBlock Text="Yeni Feed Oluştur" Foreground="{DynamicResource MesBgPrimary}"
                       FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel MaxWidth="600" Spacing="16">

                <!-- Basic Info -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="8" Padding="20" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Feed Bilgileri" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Feed Adı" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding FeedName}" Watermark="Örn: ABC Elektronik XML" AutomationProperties.Name="Örn: ABC Elektronik XML" Padding="10,8" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Feed URL" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <TextBox Text="{Binding FeedUrl}" Watermark="https://tedarikci.com/feed.xml" AutomationProperties.Name="https://tedarikci.com/feed.xml" Padding="10,8" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Format" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <ComboBox ItemsSource="{Binding FormatOptions}"
                                      SelectedItem="{Binding SelectedFormat}" Width="160" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding SyncIntervalMinutes, StringFormat='Senkronizasyon Aralığı: {0} dakika'}"
                                       FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            <Slider Minimum="15" Maximum="1440" Value="{Binding SyncIntervalMinutes}"
                                    TickFrequency="15" IsSnapToTickEnabled="True" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Pricing -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="8" Padding="20" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Fiyatlandırma" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />

                        <Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                <TextBlock Text="Fiyat Artış %" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding PriceMarkupPercent}" Padding="10,8" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
                                <TextBlock Text="Minimum Marj %" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                <TextBox Text="{Binding MinimumMarginPercent}" Padding="10,8" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Column Mapping -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="8" Padding="20" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Kolon Eşleştirme" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                            <Button Grid.Column="1" Content="+ Ekle" Command="{Binding AddMappingCommand}"
                                    Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" Padding="10,4" CornerRadius="4" FontSize="12" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ColumnMappings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:FeedColumnMappingDto">
                                    <Grid ColumnDefinitions="*,Auto,*,Auto" Margin="0,4">
                                        <TextBox Grid.Column="0" Text="{Binding SourceColumn}" Watermark="Kaynak kolon" AutomationProperties.Name="Kaynak kolon"
                                                 Padding="8,6" Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1" Text="→" FontSize="16" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MesMutedGray}" Margin="4,0" />
                                        <TextBox Grid.Column="2" Text="{Binding TargetField}" Watermark="Hedef alan" AutomationProperties.Name="Hedef alan"
                                                 Padding="8,6" Margin="0,0,8,0" />
                                        <Button Grid.Column="3" Content="X" FontSize="11"
                                                Command="{Binding $parent[ItemsControl].((vm:FeedCreateAvaloniaViewModel)DataContext).RemoveMappingCommand}"
                                                CommandParameter="{Binding}"
                                                Background="{DynamicResource MesBgDangerLight}" Foreground="{DynamicResource MesRedAlert}"
                                                Padding="6,2" CornerRadius="4" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet" Command="{Binding SaveFeedCommand}"
                            Background="{DynamicResource MesGreenMaterial}" Foreground="{DynamicResource MesBgPrimary}" FontWeight="SemiBold"
                            Padding="20,10" CornerRadius="6" IsEnabled="{Binding !IsSaving}" />
                    <Button Content="Temizle" Command="{Binding ResetCommand}"
                            Background="{DynamicResource MesMutedGray}" Foreground="{DynamicResource MesBgPrimary}" Padding="16,10" CornerRadius="6" />
                </StackPanel>

                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="8" Padding="12" IsVisible="{Binding SaveCompleted}">
                    <TextBlock Text="Feed başarıyla kaydedildi!" Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold" />
                </Border>

                <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="8" Padding="12" IsVisible="{Binding HasError}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesRedAlert}" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Isleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
