<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.WorkScheduleAvaloniaView"
             x:DataType="vm:WorkScheduleAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- EMR-12: Calisma Takvimi — haftalik plan + vardiya listesi -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Calisma Takvimi" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} vardiya'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="16">

                <!-- Week Overview -->
                <WrapPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Pazartesi" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Sali" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Carsamba" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Persembe" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Cuma" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Schedule DataGrid -->
                <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Vardiya Plani" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                <Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Schedules}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="{DynamicResource MesBgPrimary}"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Calisan" Binding="{Binding EmployeeName}" Width="180" />
                                <DataGridTextColumn Header="Gun" Binding="{Binding DayOfWeek}" Width="120" />
                                <DataGridTextColumn Header="Baslangic" Binding="{Binding StartTime}" Width="100" />
                                <DataGridTextColumn Header="Bitis" Binding="{Binding EndTime}" Width="100" />
                                <DataGridTextColumn Header="Vardiya" Binding="{Binding ShiftType}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayit bulunamadi" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,40" Opacity="0.5" FontSize="{StaticResource FontSizeTitle}"
                               Foreground="{DynamicResource MesMutedGray}"
                               IsVisible="{Binding !Schedules.Count}" />
                </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Takvim yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    
        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
