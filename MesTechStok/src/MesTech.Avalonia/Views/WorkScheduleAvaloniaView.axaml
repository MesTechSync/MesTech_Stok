<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.WorkScheduleAvaloniaView"
             x:DataType="vm:WorkScheduleAvaloniaViewModel">

    <!-- EMR-12: Calisma Takvimi — haftalik plan + vardiya listesi -->

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Calisma Takvimi" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} vardiya'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="16">

                <!-- Week Overview -->
                <WrapPanel Orientation="Horizontal">
                    <Border Background="White" CornerRadius="8" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Pazartesi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Sali" FontSize="12" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Carsamba" FontSize="12" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Persembe" FontSize="12" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="8" Padding="16,14" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" MinWidth="120">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="Cuma" FontSize="12" Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="09:00-18:00" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Schedule DataGrid -->
                <Border Background="White" CornerRadius="8"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Vardiya Plani" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                        </Border>
                <Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Schedules}"
                                  AutoGenerateColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="White"
                                  MaxHeight="300">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Calisan" Binding="{Binding EmployeeName}" Width="180" />
                                <DataGridTextColumn Header="Gun" Binding="{Binding DayOfWeek}" Width="120" />
                                <DataGridTextColumn Header="Baslangic" Binding="{Binding StartTime}" Width="100" />
                                <DataGridTextColumn Header="Bitis" Binding="{Binding EndTime}" Width="100" />
                                <DataGridTextColumn Header="Vardiya" Binding="{Binding ShiftType}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="16"
                               IsVisible="{Binding !Schedules.Count}" />
                </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Takvim yukleniyor..."
                           FontSize="14" Foreground="#555555" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
