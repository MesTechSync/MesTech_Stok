<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.EmployeesAvaloniaView"
             x:DataType="vm:EmployeesAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesTeal}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Calisanlar" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} calisan'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Watermark="Calisan ara..." AutomationProperties.Name="Calisan ara..." Width="250" HorizontalAlignment="Left" />
                <ComboBox Grid.Column="1" PlaceholderText="Departman" Width="140" Margin="8,0" />
                <Button Grid.Column="2" Content="+ Calisan Ekle" Background="{DynamicResource MesTeal}" Foreground="{DynamicResource MesBgPrimary}"
                        FontWeight="SemiBold" Padding="12,6" CornerRadius="{StaticResource MesRadiusSm}" />
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2" Margin="16">
            <!-- Loading Overlay -->
            <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsLoading}"
                    CornerRadius="{StaticResource MesRadiusMd}" ZIndex="10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" />
                    <TextBlock Text="Calisan verileri yukleniyor..." FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Main Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" IsVisible="{Binding !IsLoading}">
                <StackPanel Spacing="16">

                    <!-- Summary Card -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="20"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Calisan Yonetimi" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" />
                            <TextBlock Text="{Binding Summary}" FontSize="13" Foreground="{DynamicResource MesSlateGray}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Department Cards -->
                    <Grid ColumnDefinitions="*,*,*,*" Margin="0,4,0,0">
                        <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="0,0,8,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="PERSONEL KAYDI" FontSize="11" FontWeight="DemiBold" Foreground="{DynamicResource MesTeal}" />
                                <TextBlock Text="Calisan bilgileri ve ozluk dosyalari" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="4,0,4,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="DEPARTMAN" FontSize="11" FontWeight="DemiBold" Foreground="{DynamicResource MesPrimaryBlue}" />
                                <TextBlock Text="Departman atama ve yonetimi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="4,0,4,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="ORGANIZASYON" FontSize="11" FontWeight="DemiBold" Foreground="{DynamicResource MesPurple}" />
                                <TextBlock Text="Organizasyon semasi ve hiyerarsi" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="8,0,0,0"
                                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1">
                            <StackPanel Spacing="4">
                                <TextBlock Text="PERFORMANS" FontSize="11" FontWeight="DemiBold" Foreground="{DynamicResource MesAmber}" />
                                <TextBlock Text="Performans degerlendirme ve takip" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Empty Table Placeholder -->
                    <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="24"
                            BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1" MinHeight="200">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="Calisan listesi bos" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center" />
                            <TextBlock Text="Calisan verileri yuklendiginde burada listelenecek" FontSize="13"
                                       Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
