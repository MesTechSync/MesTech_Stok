<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StockAlertAvaloniaView"
             x:DataType="vm:StockAlertAvaloniaViewModel">

    <!-- I-06 Gorev 3: Kritik Stok Alarm Paneli — 3 seviye renk kodlu + aksiyon butonlari -->

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#DC2626" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Stok Uyarilari" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding AlertSummary}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#DC2626" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Tumunu Goster" Command="{Binding FilterAllCommand}"
                        Background="#F1F5F9" Foreground="#475569" Padding="12,6" CornerRadius="6" />
                <Button Content="Tukendi" Command="{Binding FilterOutOfStockCommand}"
                        Background="#FEE2E2" Foreground="#DC2626" Padding="12,6" CornerRadius="6" />
                <Button Content="Kritik" Command="{Binding FilterCriticalCommand}"
                        Background="#FEF3C7" Foreground="#D97706" Padding="12,6" CornerRadius="6" />
                <Button Content="Dusuk" Command="{Binding FilterLowCommand}"
                        Background="#FED7AA" Foreground="#EA580C" Padding="12,6" CornerRadius="6" />
            </StackPanel>
        </Border>

        <!-- Alert List -->
        <ScrollViewer Grid.Row="2" Padding="16">
            <ItemsControl ItemsSource="{Binding FilteredAlerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:StockAlertItemDto">
                        <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                                BorderBrush="{Binding AlertBorderColor}" BorderThickness="2,2,2,2">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Severity Icon -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                        Background="{Binding AlertColor}" Margin="0,0,14,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SeverityIcon}" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White" FontWeight="Bold" />
                                </Border>

                                <!-- Alert Details -->
                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding LevelText}" FontSize="12" FontWeight="Bold"
                                                   Foreground="{Binding AlertColor}" />
                                        <TextBlock Text="{Binding Sku, StringFormat='SKU: {0}'}" FontSize="12"
                                                   Foreground="#64748B" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding ProductName}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="#1E293B" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{Binding StockInfo}" FontSize="12" Foreground="#64748B" />
                                        <TextBlock Text="{Binding WarehouseName}" FontSize="12" Foreground="#64748B" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Action Buttons -->
                                <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                    <Button Content="Siparis Ver" Padding="10,4" CornerRadius="4"
                                            Background="#0078D4" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                    <Button Content="{Binding SecondaryAction}" Padding="10,4" CornerRadius="4"
                                            Background="#F1F5F9" Foreground="#475569" FontSize="11" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Stok uyarilari yukleniyor..." FontSize="14" Foreground="#555555"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" Background="#F7F9FC"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Tum Stoklar Saglikli" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#16A34A" />
                <TextBlock Text="Kritik seviyede urun bulunmuyor"
                           FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
