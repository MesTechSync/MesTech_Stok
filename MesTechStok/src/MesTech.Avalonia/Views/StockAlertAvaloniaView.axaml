<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StockAlertAvaloniaView"
             x:DataType="vm:StockAlertAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- I-06 Gorev 3: Kritik Stok Alarm Paneli — 3 seviye renk kodlu + aksiyon butonlari -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesRedAlert}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Stok Uyarilari" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding AlertSummary}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesRedAlert}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Tumunu Goster" Command="{Binding FilterAllCommand}"
                        Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesTextSlate}" Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" />
                <Button Content="Tukendi" Command="{Binding FilterOutOfStockCommand}"
                        Background="{DynamicResource MesBgDangerLight}" Foreground="{DynamicResource MesRedAlert}" Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" />
                <Button Content="Kritik" Command="{Binding FilterCriticalCommand}"
                        Background="{DynamicResource MesBgSurface}" Foreground="{DynamicResource MesAmber}" Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" />
                <Button Content="Dusuk" Command="{Binding FilterLowCommand}"
                        Background="{DynamicResource MesBorderAmberLight}" Foreground="{DynamicResource MesAmber}" Padding="12,6" CornerRadius="{StaticResource MesRadiusBase}" />
            </StackPanel>
        </Border>

        <!-- Alert List -->
        <ScrollViewer Grid.Row="2" Padding="16">
            <ItemsControl ItemsSource="{Binding FilteredAlerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:StockAlertItemDto">
                        <Border Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}" Padding="16" Margin="0,0,0,8"
                                BorderBrush="{Binding AlertBorderColor}" BorderThickness="2,2,2,2">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <!-- Severity Icon -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                        Background="{Binding AlertColor}" Margin="0,0,14,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SeverityIcon}" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource MesBgPrimary}" FontWeight="Bold" />
                                </Border>

                                <!-- Alert Details -->
                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding LevelText}" FontSize="12" FontWeight="Bold"
                                                   Foreground="{Binding AlertColor}" />
                                        <TextBlock Text="{Binding Sku, StringFormat='SKU: {0}'}" FontSize="12"
                                                   Foreground="{DynamicResource MesSlateGray}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding ProductName}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MesDarkSlate}" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{Binding StockInfo}" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBlock Text="{Binding WarehouseName}" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Action Buttons -->
                                <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                    <Button Content="Siparis Ver" Padding="10,4" CornerRadius="{StaticResource MesRadiusSm}"
                                            Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}" FontSize="11" FontWeight="SemiBold" />
                                    <Button Content="{Binding SecondaryAction}" Padding="10,4" CornerRadius="{StaticResource MesRadiusSm}"
                                            Background="{DynamicResource MesBgMist}" Foreground="{DynamicResource MesTextSlate}" FontSize="11" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Stok uyarilari yukleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}" ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Tum Stoklar Saglikli" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesGreen}" />
                <TextBlock Text="Kritik seviyede urun bulunmuyor"
                           FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
