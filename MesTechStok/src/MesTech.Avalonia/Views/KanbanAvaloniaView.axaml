<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.KanbanAvaloniaView"
             x:DataType="vm:KanbanAvaloniaViewModel"
             AutomationProperties.Name="Firsatlar Kanban">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding LoadDataCommand}" />    </UserControl.KeyBindings>

    <!-- Avalonia port of WPF Views/Crm/DealsView.xaml -->
    <!-- Key changes:
         - xmlns → avaloniaui
         - DropShadowEffect → BoxShadow (Avalonia uses CSS-like shadows)
         - Cursor="Hand" → Cursor="Hand" (same)
         - ViewModel: KanbanAvaloniaViewModel (97% identical to WPF DealsViewModel) -->

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Loading State -->
        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="3" Grid.Row="0" />

        <!-- Header -->
        <Border Grid.Row="1" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Firsatlar — Kanban" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center"
                           Grid.Column="0" />
                <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="8">
                    <Button Content="+ Yeni Firsat" Command="{Binding CreateDealCommand}"
                            ToolTip.Tip="+ Yeni Firsat"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="14,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Liste" Command="{Binding SwitchToListCommand}"
                            ToolTip.Tip="Liste"
                            Background="Transparent" Foreground="{DynamicResource MesBgPrimary}"
                            BorderBrush="{DynamicResource MesBgPrimary}" BorderThickness="1" Padding="12,8"
                            CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Empty State -->
        <TextBlock Grid.Row="2"
                   Text="Kayit bulunamadi"
                   FontSize="{StaticResource FontSizeTitle}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{DynamicResource MesMutedGray}"
                   IsVisible="{Binding !Stages.Count}"
                   Opacity="0.5" />

        <!-- Kanban Columns -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Background="{DynamicResource MesBgSecondary}">
            <ItemsControl ItemsSource="{Binding Stages}" Margin="16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:KanbanStageVm">
                        <!-- Single Kanban Column -->
                        <Border Width="260" VerticalAlignment="Top"
                                Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                                BoxShadow="{DynamicResource MesElevationCard}">
                            <DockPanel>
                                <!-- Column Header — uses stage Color property -->
                                <Border DockPanel.Dock="Top" CornerRadius="8,8,0,0"
                                        Padding="14,10">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Color}" />
                                    </Border.Background>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource MesBgPrimary}"
                                                   FontWeight="SemiBold" FontSize="{StaticResource FontSizeCallout}"
                                                   Grid.Column="0" />
                                        <Border Grid.Column="1" Background="{DynamicResource MesBadgeOverlay}"
                                                CornerRadius="{StaticResource MesRadiusMdLg}" Padding="6,2">
                                            <TextBlock Text="{Binding DealCount}" Foreground="{DynamicResource MesBgPrimary}"
                                                       FontSize="{StaticResource FontSizeCaption}" FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Deal Cards -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                                    <ItemsControl ItemsSource="{Binding Deals}" Margin="8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:DealCardVm">
                                                <Border Margin="0,0,0,8" Padding="12"
                                                        Background="{DynamicResource MesBgPage}" CornerRadius="{StaticResource MesRadiusBase}"
                                                        BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="1"
                                                        Cursor="Hand">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontWeight="SemiBold" FontSize="{StaticResource FontSizeCallout}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding ContactName}"
                                                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesSlateGray}" />
                                                        <TextBlock Text="{Binding Amount, StringFormat='TL {0:N0}'}"
                                                                   FontSize="{StaticResource FontSizeCallout}" FontWeight="Bold"
                                                                   Foreground="{DynamicResource MesPrimaryBlue}" Margin="0,2,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    
<!-- Empty state -->
        <Border Background="{DynamicResource MesBgPrimary}" IsVisible="{Binding IsEmpty}" CornerRadius="{StaticResource MesRadiusMd}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Gorev bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="DemiBold" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
            <TextBlock Text="Henuz gorev bulunmuyor" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesMutedGray}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Error State -->
        <Border IsVisible="{Binding HasError}" VerticalAlignment="Center" HorizontalAlignment="Center" ZIndex="90">
            <StackPanel HorizontalAlignment="Center" Spacing="8" MaxWidth="400">
                <TextBlock Text="Hata olustu" FontSize="{StaticResource FontSizeTitle}"
                           Foreground="{DynamicResource StatusDangerBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Tekrar Dene" Command="{Binding LoadDataCommand}"
                        ToolTip.Tip="Verileri tekrar yukle"
                        Classes="mestech-raised" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

</Grid>
</UserControl>
