<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             x:Class="MesTech.Avalonia.Views.CariHesaplarAvaloniaView"
             x:Name="RootCariHesaplarAvaloniaView"
             x:DataType="vm:CariHesaplarAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <!-- Cari Hesaplar — customer/supplier accounts with balance summary -->

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Cari Hesaplar" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} hesap'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Tip:" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextSlate}"
                           VerticalAlignment="Center" />
                <ComboBox Width="180"
                          ItemsSource="{Binding TypeOptions}"
                          SelectedItem="{Binding SelectedType}"  AutomationProperties.Name="Tip:"/>
            </StackPanel>
        </Border>

        <!-- Cari DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredItems}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Hesap Adi" Binding="{Binding HesapAdi}" Width="280" />
                <DataGridTextColumn Header="Tip" Binding="{Binding Tip}" Width="120" />
                <DataGridTextColumn Header="Borc (TL)" Binding="{Binding Borc, StringFormat='{}{0:N2}'}" Width="140" />
                <DataGridTextColumn Header="Alacak (TL)" Binding="{Binding Alacak, StringFormat='{}{0:N2}'}" Width="140" />
                <DataGridTextColumn Header="Bakiye (TL)" Binding="{Binding Bakiye, StringFormat='{}{0:N2}'}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>
<!-- Empty State -->        <TextBlock Grid.Row="2" Text="Kayıt bulunamadı"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="{StaticResource FontSizeSubtitle}"                   IsVisible="{Binding !FilteredItems.Count}" />

        <!-- Balance Summary Footer -->
        <Border Grid.Row="3" Background="{DynamicResource MesBgMist}" Padding="20,12"
                BorderBrush="{DynamicResource MesBorderSoft}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Ozet" FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="14,8" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="Toplam Borc" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesPrimaryBlue}" />
                        <TextBlock Text="{Binding TotalDebit, StringFormat='{}{0:N2} TL'}"
                                   FontSize="{StaticResource FontSizeBodyLg}" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="14,8" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="Toplam Alacak" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesGreen}" />
                        <TextBlock Text="{Binding TotalCredit, StringFormat='{}{0:N2} TL'}"
                                   FontSize="{StaticResource FontSizeBodyLg}" FontWeight="Bold" Foreground="{DynamicResource MesGreen}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusMd}" Padding="14,8" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="Net Bakiye" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesAmber}" />
                        <TextBlock Text="{Binding NetBalance, StringFormat='{}{0:N2} TL'}"
                                   FontSize="{StaticResource FontSizeBodyLg}" FontWeight="Bold" Foreground="{DynamicResource MesAmber}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Cari hesap bulunamadi" FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}"
                           Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}"
                        Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
