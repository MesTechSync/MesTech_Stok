<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StoreWizardAvaloniaView"
             x:DataType="vm:StoreWizardAvaloniaViewModel">

    <!-- Magaza Ekleme Sihirbazi — 3 adim: Platform Sec → Kimlik → Test + Kaydet -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Yeni Mağaza Ekle" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                    <TextBlock Text="{Binding CurrentStep, StringFormat='Adım {0}/3'}"
                               Foreground="White" FontSize="12" VerticalAlignment="Center" />
                </Border>
            </StackPanel>
        </Border>

        <!-- Step Indicator -->
        <Border Grid.Row="1" Background="White" Padding="20,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource MesPrimaryBlue}">
                        <TextBlock Text="1" Foreground="White" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Platform Seç" VerticalAlignment="Center" FontSize="13" />
                </StackPanel>
                <TextBlock Text="—" Foreground="#CBD5E1" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource MesMutedGray}">
                        <TextBlock Text="2" Foreground="White" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Kimlik Bilgileri" VerticalAlignment="Center" FontSize="13" />
                </StackPanel>
                <TextBlock Text="—" Foreground="#CBD5E1" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource MesMutedGray}">
                        <TextBlock Text="3" Foreground="White" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Test ve Kaydet" VerticalAlignment="Center" FontSize="13" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Step Content -->
        <ScrollViewer Grid.Row="2" Padding="24">
          <Panel>

            <!-- STEP 1: Platform Select -->
            <StackPanel IsVisible="{Binding IsStep1Visible}">
                <TextBlock Text="Platform Seçin" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"
                           Foreground="{DynamicResource MesDarkSlate}" />
                <ItemsControl ItemsSource="{Binding AvailablePlatforms}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WizardPlatformDto">
                            <Button Margin="6" Padding="0" Background="White" CornerRadius="8"
                                    BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1"
                                    Command="{Binding $parent[ItemsControl].((vm:StoreWizardAvaloniaViewModel)DataContext).SelectPlatformCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Width="160">
                                    <Border Height="6" CornerRadius="8,8,0,0" Background="{Binding Color}" />
                                    <Border Padding="16,12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource MesDarkSlate}" />
                                            <TextBlock Text="Seç" FontSize="12" Foreground="{DynamicResource MesPrimaryBlue}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- STEP 2: Credential Form -->
            <StackPanel IsVisible="{Binding IsStep2Visible}" MaxWidth="500" Spacing="16">
                <TextBlock Text="{Binding SelectedPlatform, StringFormat='{}{0} — Kimlik Bilgileri'}"
                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Mağaza Adı" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBox Text="{Binding StoreName}" Watermark="Örn: Ana Mağaza" AutomationProperties.Name="Örn: Ana Mağaza" Padding="10,8" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Field1Label}" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBox Text="{Binding Field1Value}" Watermark="{Binding Field1Label}" AutomationProperties.Name="{Binding Field1Label}" Padding="10,8" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Field2Label}" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBox Text="{Binding Field2Value}" Watermark="{Binding Field2Label}" AutomationProperties.Name="{Binding Field2Label}"
                             PasswordChar="*" Padding="10,8" />
                </StackPanel>

                <StackPanel Spacing="4" IsVisible="{Binding Field3Visible}">
                    <TextBlock Text="{Binding Field3Label}" FontSize="12" Foreground="{DynamicResource MesSlateGray}" />
                    <TextBox Text="{Binding Field3Value}" Watermark="{Binding Field3Label}" AutomationProperties.Name="{Binding Field3Label}" Padding="10,8" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                    <Button Content="Geri" Command="{Binding GoBackCommand}"
                            Background="{DynamicResource MesMutedGray}" Foreground="White" Padding="16,8" CornerRadius="6" />
                    <Button Content="İleri" Command="{Binding GoNextCommand}"
                            Background="{DynamicResource MesPrimaryBlue}" Foreground="White" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="6" />
                </StackPanel>
            </StackPanel>

            <!-- STEP 3: Test + Save -->
            <StackPanel IsVisible="{Binding IsStep3Visible}" MaxWidth="500" Spacing="16">
                <TextBlock Text="Bağlantı Testi ve Kayıt" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesDarkSlate}" />

                <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding SelectedPlatform, StringFormat='Platform: {0}'}" FontSize="14" />
                        <TextBlock Text="{Binding StoreName, StringFormat='Mağaza: {0}'}" FontSize="14" />

                        <Button Content="Bağlantı Test" Command="{Binding TestConnectionCommand}"
                                Background="{DynamicResource MesPrimaryBlue}" Foreground="White" FontWeight="SemiBold"
                                Padding="16,8" CornerRadius="6"
                                IsEnabled="{Binding !IsTesting}" />

                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsTesting}" Height="4" />

                        <Border Background="{DynamicResource MesBgSurface}" CornerRadius="6" Padding="12"
                                IsVisible="{Binding TestPassed}">
                            <TextBlock Text="{Binding TestResultMessage}" Foreground="{DynamicResource MesGreen}" FontWeight="SemiBold" />
                        </Border>

                        <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="6" Padding="12"
                                IsVisible="{Binding TestFailed}">
                            <TextBlock Text="{Binding TestResultMessage}" Foreground="{DynamicResource MesRedAlert}" />
                        </Border>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Geri" Command="{Binding GoBackCommand}"
                            Background="{DynamicResource MesMutedGray}" Foreground="White" Padding="16,8" CornerRadius="6" />
                    <Button Content="Kaydet" ToolTip.Tip="Degisiklikleri kaydet" Command="{Binding SaveStoreCommand}"
                            Background="{DynamicResource MesGreenMaterial}" Foreground="White" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="6"
                            IsEnabled="{Binding TestPassed}" />
                </StackPanel>

                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="8" Padding="16"
                        IsVisible="{Binding SaveCompleted}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Mağaza başarıyla kaydedildi!" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesGreen}" />
                        <Button Content="Yeni Mağaza Ekle" Command="{Binding ResetCommand}"
                                Background="{DynamicResource MesPrimaryBlue}" Foreground="White" Padding="16,8" CornerRadius="6" />
                    </StackPanel>
                </Border>
            </StackPanel>
          </Panel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="İşleniyor..." FontSize="14" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
