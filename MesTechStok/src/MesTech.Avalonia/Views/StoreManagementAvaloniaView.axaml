<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.StoreManagementAvaloniaView"
             x:DataType="vm:StoreManagementAvaloniaViewModel">

    <!-- EMR-12: Magaza Yonetimi — magaza listesi + ayarlar -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Magaza Yonetimi" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} magaza'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,12"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <TextBox Width="360" Watermark="Magaza adi ile arama..."
                     Text="{Binding SearchText}"
                     FontSize="14" Padding="10,8" HorizontalAlignment="Left" />
        </Border>

        <!-- Store DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Stores}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="White"
                  Margin="16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Magaza Adi" Binding="{Binding StoreName}" Width="200" />
                <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="140" />
                <DataGridTextColumn Header="API Durumu" Binding="{Binding ApiStatus}" Width="120" />
                <DataGridTextColumn Header="Urun Sayisi" Binding="{Binding ProductCount}" Width="120" />
                <DataGridTextColumn Header="Son Senkronizasyon" Binding="{Binding LastSync}" Width="160" />
            </DataGrid.Columns>
        </DataGrid>
<!-- Empty State -->        <TextBlock Grid.Row="2" Text="Kayıt bulunamadı"                   HorizontalAlignment="Center"                   VerticalAlignment="Center"                   Margin="0,40"                   Opacity="0.5"                   FontSize="16"                   IsVisible="{Binding !Stores.Count}" />

        <!-- Empty State -->
        <Border Grid.Row="2"
                Background="#F7F9FC"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Magaza Bulunamadi" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Henuz magaza tanimlanmamis"
                           FontSize="14" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Magaza bilgileri yukleniyor..."
                           FontSize="14" Foreground="#555555" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
