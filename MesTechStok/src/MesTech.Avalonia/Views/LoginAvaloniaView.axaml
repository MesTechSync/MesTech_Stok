<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.LoginAvaloniaView"
             x:Name="LoginAvaloniaView"
             x:DataType="vm:LoginAvaloniaViewModel">

    <!-- Avalonia port — Giris Ekrani (Login) -->
    <!-- Centered card: logo area, username, password (masked), login button -->
    <!-- Brand color #0078D4, error message display for failed login -->

    <Grid Background="{DynamicResource MesBgPage}">

        <!-- Login Form (visible when NOT authenticated) -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusXl}"
                Padding="48,40" Width="420"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1"
                BoxShadow="{DynamicResource MesElevation3}"
                IsVisible="{Binding !IsAuthenticated}">
            <StackPanel Spacing="20">

                <!-- Logo Area -->
                <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,8">
                    <Border Background="{DynamicResource MesBgMist}" CornerRadius="{StaticResource MesRadiusFull}" Width="72" Height="72"
                            HorizontalAlignment="Center">
                        <TextBlock Text="M" FontSize="{StaticResource FontSizeDisplay}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPrimaryBlue}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="MesTech Stok" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                               Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                    <TextBlock Text="Hesabiniza giris yapin" FontSize="{StaticResource FontSizeCallout}"
                               Foreground="{DynamicResource MesSlateGray}" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Username -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Kullanici Adi" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDarkSlate}" />
                    <TextBox Text="{Binding Username}"
                             Watermark="Kullanici adinizi giriniz" AutomationProperties.Name="Kullanici adinizi giriniz"
                             Padding="12,10" CornerRadius="{StaticResource MesRadiusMd}" FontSize="{StaticResource FontSizeBody}" />
                </StackPanel>

                <!-- Password -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Sifre" FontSize="{StaticResource FontSizeCallout}" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDarkSlate}" />
                    <TextBox Text="{Binding Password}"
                             PasswordChar="●"
                             Watermark="Sifrenizi giriniz" AutomationProperties.Name="Sifrenizi giriniz"
                             Padding="12,10" CornerRadius="{StaticResource MesRadiusMd}" FontSize="{StaticResource FontSizeBody}" />
                </StackPanel>

                <!-- Error Message -->
                <Border Background="{DynamicResource MesBgDangerLight}" CornerRadius="{StaticResource MesRadiusMd}" Padding="12,10"
                        IsVisible="{Binding HasError}"
                        BorderBrush="{DynamicResource MesBorderDanger}" BorderThickness="1">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource MesRedAlert}" FontSize="{StaticResource FontSizeCallout}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Login Button -->
                <Button Content="Giris Yap"
                        ToolTip.Tip="Giris Yap"
                        Command="{Binding LoginCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="{DynamicResource MesPrimaryBlue}" Foreground="{DynamicResource MesBgPrimary}"
                        FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                        Padding="16,12" CornerRadius="{StaticResource MesRadiusMd}" />

                <!-- Version Info -->
                <TextBlock Text="MesTech Stok v10.0 — Avalonia PoC"
                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource MesMutedGray}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Welcome State (visible when authenticated) -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusXl}"
                Padding="48,40" Width="420"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1"
                BoxShadow="{DynamicResource MesElevation3}"
                IsVisible="{Binding IsAuthenticated}">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="{StaticResource MesRadiusFull}" Width="72" Height="72"
                        HorizontalAlignment="Center">
                    <TextBlock Text="&#x2713;" FontSize="{StaticResource FontSizeXL}" FontWeight="Bold"
                               Foreground="{DynamicResource MesTeal}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding WelcomeMessage}"
                           FontSize="{StaticResource FontSizeTitle}" FontWeight="Bold"
                           Foreground="{DynamicResource MesDarkSlate}" HorizontalAlignment="Center" />
                <TextBlock Text="Sisteme basariyla giris yaptiniz."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Giris yapiliyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
