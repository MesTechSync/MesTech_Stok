<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.AccountingDashboardAvaloniaView"
             x:DataType="vm:AccountingDashboardAvaloniaViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Background="#F8FAFC">

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Muhasebe Ozeti" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2">
                        <TextBlock Text="{Binding LastUpdated, StringFormat='Son: {0}'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile"
                        Command="{Binding RefreshCommand}"
                        Background="White" Foreground="#0078D4" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="6" />
            </Grid>
        </Border>

        <!-- KPI Cards Row -->
        <Border Grid.Row="1" Background="#F8FAFC" Padding="16">
            <Grid ColumnDefinitions="*,*,*,*">

                <!-- Toplam Gelir -->
                <Border Grid.Column="0" Background="White" CornerRadius="12"
                        Padding="20" Margin="6" BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Toplam Gelir" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding TotalRevenue}" FontSize="22" FontWeight="Bold"
                                   Foreground="#10B981" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Toplam Gider -->
                <Border Grid.Column="1" Background="White" CornerRadius="12"
                        Padding="20" Margin="6" BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Toplam Gider" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding TotalExpense}" FontSize="22" FontWeight="Bold"
                                   Foreground="#EF4444" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Net Kar -->
                <Border Grid.Column="2" Background="White" CornerRadius="12"
                        Padding="20" Margin="6" BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Net Kar" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding NetProfit}" FontSize="22" FontWeight="Bold"
                                   Foreground="#2563EB" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Bakiye -->
                <Border Grid.Column="3" Background="White" CornerRadius="12"
                        Padding="20" Margin="6" BoxShadow="0 2 8 0 #14000000">
                    <StackPanel>
                        <TextBlock Text="Bakiye" FontSize="12" Foreground="#6B7280" />
                        <TextBlock Text="{Binding Balance}" FontSize="22" FontWeight="Bold"
                                   Foreground="#8B5CF6" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- Recent Transactions DataGrid -->
        <Border Grid.Row="2" Background="White" Margin="16" CornerRadius="12"
                BorderBrush="#E0E6ED" BorderThickness="1" Padding="0">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Padding="16,12" BorderBrush="#E0E6ED" BorderThickness="0,0,0,1">
                    <TextBlock Text="Son Islemler" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" />
                </Border>
                <Grid>
                <DataGrid Grid.Row="1" ItemsSource="{Binding RecentTransactions}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="120" />
                        <DataGridTextColumn Header="Aciklama" Binding="{Binding Description}" Width="*" />
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="140" />
                        <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="80" />
                        <DataGridTextColumn Header="Tutar" Binding="{Binding AmountFormatted}" Width="130" />
                    </DataGrid.Columns>
                </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="16"
                               IsVisible="{Binding !RecentTransactions.Count}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#99FFFFFF"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Muhasebe verileri yukleniyor..."
                           FontSize="14" Foreground="#555555" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2"
                Background="#F7F9FC"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Veri bulunamadi" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#1E293B" Margin="0,0,0,8" />
                <TextBlock Text="Henuz muhasebe kaydi girilmemis"
                           FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#F7F9FC"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="#E53935" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="#E53935"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
