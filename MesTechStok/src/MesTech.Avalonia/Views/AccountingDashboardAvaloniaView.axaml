<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             x:Class="MesTech.Avalonia.Views.AccountingDashboardAvaloniaView"
             x:Name="AccountingDashboardAvaloniaView"
             x:DataType="vm:AccountingDashboardAvaloniaViewModel"
             AutomationProperties.Name="Muhasebe Paneli">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Muhasebe Ozeti" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding LastUpdated, StringFormat='Son: {0}'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" ToolTip.Tip="Verileri yenile"
                        Command="{Binding RefreshCommand}"
                        Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                        Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
            </Grid>
        </Border>

        <!-- KPI Cards Row -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPage}" Padding="16">
            <Grid ColumnDefinitions="*,*,*,*">

                <!-- Toplam Gelir -->
                <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}"
                        Padding="20" Margin="6" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Toplam Gelir" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding TotalRevenue}" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesEmerald}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Toplam Gider -->
                <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}"
                        Padding="20" Margin="6" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Toplam Gider" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding TotalExpense}" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesRedBright}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Net Kar -->
                <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}"
                        Padding="20" Margin="6" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Net Kar" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding NetProfit}" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPrimaryBlue}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Bakiye -->
                <Border Grid.Column="3" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusLg}"
                        Padding="20" Margin="6" BoxShadow="{DynamicResource MesElevationCard}">
                    <StackPanel>
                        <TextBlock Text="Bakiye" FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesCoolGray}" />
                        <TextBlock Text="{Binding Balance}" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                                   Foreground="{DynamicResource MesPurple}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- Recent Transactions DataGrid -->
        <Border Grid.Row="2" Background="{DynamicResource MesBgPrimary}" Margin="16" CornerRadius="{StaticResource MesRadiusLg}"
                BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1" Padding="0">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Son Islemler" FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold" Foreground="{DynamicResource MesDarkSlate}" />
                </Border>
                <Grid>
                <DataGrid Grid.Row="1" ItemsSource="{Binding RecentTransactions}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True" CanUserReorderColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tarih" Binding="{Binding Date}" Width="120" />
                        <DataGridTextColumn Header="Aciklama" Binding="{Binding Description}" Width="*" />
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="140" />
                        <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="80" />
                        <DataGridTextColumn Header="Tutar" Binding="{Binding AmountFormatted}" Width="130" />
                    </DataGrid.Columns>
                </DataGrid>
                    <!-- Empty State -->
                    <TextBlock Text="Kayıt bulunamadı"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40"
                               Opacity="0.5"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               IsVisible="{Binding !RecentTransactions.Count}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesOverlayLight}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12" />
                <TextBlock Text="Muhasebe verileri yukleniyor..."
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesTextMuted}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Veri bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Henuz muhasebe kaydi girilmemis"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding HasError}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="!" FontSize="{StaticResource FontSizeHero}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDanger}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ErrorMessage}" FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesDanger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"
                           TextWrapping="Wrap" MaxWidth="400" />
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene" Command="{Binding RefreshCommand}" Padding="16,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
