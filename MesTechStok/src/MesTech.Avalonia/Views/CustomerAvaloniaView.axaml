<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.CustomerAvaloniaView"
             x:DataType="vm:CustomerAvaloniaViewModel">
<UserControl.KeyBindings>        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />        <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}" />    </UserControl.KeyBindings>

    <!-- WPF018: Musteriler CRM — segment filtreleme, detay paneli, sag-tik menu -->

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Müşteriler" Foreground="{DynamicResource MesBgPrimary}"
                               FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Background="{DynamicResource MesBadgeOverlay}" CornerRadius="{StaticResource MesRadiusMdLg}" Padding="8,2">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} müşteri'}"
                                   Foreground="{DynamicResource MesBgPrimary}" FontSize="{StaticResource FontSizeSmall}" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <!-- KD-DEV2-008: Export Excel button -->
                    <Button Content="Excel Aktar" ToolTip.Tip="Musteri listesini Excel olarak disari aktar"
                            Command="{Binding ExportExcelCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesTeal}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search + Segment Filter Bar -->
        <Border Grid.Row="1" Background="{DynamicResource MesBgPrimary}" Padding="16,10"
                BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Segment Filter Buttons -->
                <ItemsControl Grid.Column="0" ItemsSource="{x:Static vm:CustomerAvaloniaViewModel.SegmentFilters}"
                              Margin="0,0,16,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SegmentFilterItem">
                            <Button Content="{Binding Label}"
                                    Command="{Binding $parent[UserControl].((vm:CustomerAvaloniaViewModel)DataContext).FilterSegmentCommand}"
                                    CommandParameter="{Binding Key}"
                                    ToolTip.Tip="{Binding Label}"
                                    Padding="12,6"
                                    CornerRadius="{StaticResource MesRadiusSm}"
                                    FontSize="{StaticResource FontSizeSmall}"
                                    FontWeight="SemiBold" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Search Box -->
                <TextBox x:Name="SearchBox" Grid.Column="2" Width="320"
                         Watermark="Ad, soyad, email veya telefon ara..."
                         AutomationProperties.Name="Müşteri ara"
                         Text="{Binding SearchText}"
                         HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Main Content: DataGrid + Detail Panel -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">

            <!-- Customers DataGrid -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedCustomer}"
                      AutomationProperties.Name="Musteri listesi"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{DynamicResource MesBgPrimary}">

                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Detay"
                                  Command="{Binding OpenDetailCommand}"
                                  CommandParameter="{Binding SelectedCustomer}" />
                        <MenuItem Header="Siparişler"
                                  Command="{Binding ShowOrdersCommand}"
                                  CommandParameter="{Binding SelectedCustomer}" />
                        <MenuItem Header="Not Ekle"
                                  Command="{Binding AddNoteCommand}"
                                  CommandParameter="{Binding SelectedCustomer}" />
                        <Separator />
                        <MenuItem Header="Segment Değiştir →">
                            <MenuItem Header="VIP"    Command="{Binding ChangeSegmentCommand}" CommandParameter="VIP" />
                            <MenuItem Header="Normal" Command="{Binding ChangeSegmentCommand}" CommandParameter="Normal" />
                            <MenuItem Header="Pasif"  Command="{Binding ChangeSegmentCommand}" CommandParameter="Pasif" />
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ad Soyad"        Binding="{Binding AdSoyad}"          Width="180" />
                    <DataGridTextColumn Header="Telefon"         Binding="{Binding Telefon}"          Width="150" />
                    <DataGridTextColumn Header="Email"           Binding="{Binding Email}"            Width="220" />
                    <DataGridTextColumn Header="Şehir"           Binding="{Binding Sehir}"            Width="110" />
                    <DataGridTextColumn Header="Sipariş Sayısı"  Binding="{Binding SiparisSayisi}"    Width="110" />
                    <DataGridTextColumn Header="Toplam Harcama"  Binding="{Binding ToplamHarcamaStr}" Width="130" />
                    <DataGridTextColumn Header="Son Sipariş"     Binding="{Binding SonSiparis}"       Width="110" />
                    <DataGridTemplateColumn Header="Segment" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:CustomerItemDto">
                                <Border Background="{Binding SegmentRenk}" CornerRadius="{StaticResource MesRadiusSm}"
                                        Padding="8,2" HorizontalAlignment="Left" Margin="4,2">
                                    <TextBlock Text="{Binding Segment}"
                                               Foreground="White" FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Customer Detail Side Panel -->
            <Border Grid.Column="1"
                    IsVisible="{Binding IsDetailOpen}"
                    Width="320"
                    Background="{DynamicResource MesBgPrimary}"
                    BorderBrush="{DynamicResource MesBorderMedium}"
                    BorderThickness="1,0,0,0">
                <Grid RowDefinitions="Auto,*">
                    <!-- Detail Header -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource MesBorderMedium}" BorderThickness="0,0,0,1"
                            Background="{DynamicResource MesBgSurface}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Müşteri Detayı"
                                       FontSize="{StaticResource FontSizeBodyLg}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDarkSlate}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="✕"
                                    Command="{Binding CloseDetailCommand}"
                                    ToolTip.Tip="Detay panelini kapat"
                                    Background="Transparent"
                                    Padding="8,4"
                                    FontSize="{StaticResource FontSizeBody}" />
                        </Grid>
                    </Border>

                    <!-- Detail Content -->
                    <ScrollViewer Grid.Row="1" Padding="16">
                        <StackPanel Spacing="16" IsVisible="{Binding SelectedCustomer, Converter={x:Static ObjectConverters.IsNotNull}}">

                            <!-- Segment Badge -->
                            <Border Background="{Binding SelectedCustomer.SegmentRenk}"
                                    CornerRadius="6" Padding="12,6" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding SelectedCustomer.Segment}"
                                           Foreground="White" FontWeight="Bold" FontSize="{StaticResource FontSizeCallout}" />
                            </Border>

                            <!-- Personal Info -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="KİŞİSEL BİLGİLER" FontSize="{StaticResource FontSizeCaption1}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesSlateGray}"
                                           LetterSpacing="1" />
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*" >
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ad Soyad:" Margin="0,0,8,4"
                                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedCustomer.AdSoyad}"
                                               FontSize="{StaticResource FontSizeSmall}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MesDarkSlate}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:" Margin="0,0,8,4"
                                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedCustomer.Email}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource MesDarkSlate}" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Telefon:" Margin="0,0,8,4"
                                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedCustomer.Telefon}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource MesDarkSlate}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Şehir:" Margin="0,0,8,4"
                                               FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedCustomer.Sehir}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource MesDarkSlate}" />
                                </Grid>
                            </StackPanel>

                            <!-- Order Summary -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="SİPARİŞ ÖZETİ" FontSize="{StaticResource FontSizeCaption1}" FontWeight="Bold"
                                           Foreground="{DynamicResource MesSlateGray}"
                                           LetterSpacing="1" />
                                <Border Background="{DynamicResource MesBgSurface}" CornerRadius="6" Padding="12">
                                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Sipariş Sayısı"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding SelectedCustomer.SiparisSayisi}"
                                                   FontSize="{StaticResource FontSizeSmall}" FontWeight="Bold"
                                                   Foreground="{DynamicResource MesDarkSlate}" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Toplam Harcama" Margin="0,6,0,0"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"
                                                   Text="{Binding SelectedCustomer.ToplamHarcamaStr}"
                                                   FontSize="{StaticResource FontSizeSmall}" FontWeight="Bold"
                                                   Foreground="{DynamicResource MesPrimaryBlue}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Son Sipariş" Margin="0,6,0,0"
                                                   FontSize="{StaticResource FontSizeSmall}" Foreground="{DynamicResource MesSlateGray}" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0"
                                                   Text="{Binding SelectedCustomer.SonSiparis}"
                                                   FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{DynamicResource MesDarkSlate}" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Action Buttons -->
                            <StackPanel Spacing="6">
                                <Button Content="Siparişleri Göster"
                                        Command="{Binding ShowOrdersCommand}"
                                        CommandParameter="{Binding SelectedCustomer}"
                                        ToolTip.Tip="Secili musterinin siparislerini goster"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Padding="12,8" />
                                <Button Content="Not Ekle"
                                        Command="{Binding AddNoteCommand}"
                                        CommandParameter="{Binding SelectedCustomer}"
                                        ToolTip.Tip="Musteriye not ekle"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Padding="12,8" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>

        <!-- Empty State: Customers -->
        <TextBlock Grid.Row="2"
                   Text="Kayıt bulunamadı"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,40"
                   Opacity="0.5"
                   FontSize="{StaticResource FontSizeSubtitle}"
                   IsVisible="{Binding !Items.Count}" />

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="False" ShowChart="False" />
        </Border>

        <!-- Empty State (no data at all) -->
        <Border Grid.Row="1" Grid.RowSpan="2"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Müşteri bulunamadı" FontSize="{StaticResource FontSizeHero}"
                           HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8" />
                <TextBlock Text="Henüz müşteri kaydedilmemiş"
                           FontSize="{StaticResource FontSizeSubtitle}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

        <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Grid.Row="0"
                    Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>
    </Grid>
</UserControl>
