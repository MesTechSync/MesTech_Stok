<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MesTech.Avalonia.ViewModels"
             xmlns:controls="using:MesTech.Avalonia.Controls"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             x:Class="MesTech.Avalonia.Views.Reports.StockValueReportView"
             x:Name="RootStockValueReportView"
             x:DataType="vm:StockValueReportViewModel"
             AutomationProperties.Name="Stok Deger Raporu">
<UserControl.KeyBindings>
    <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
</UserControl.KeyBindings>

    <!-- R-03: Stok Deger Raporu -->

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Background="{DynamicResource MesBgPage}">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource MesPrimaryBlue}" Padding="20,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Stok Deger Raporu" Foreground="{DynamicResource MesBgPrimary}"
                           FontSize="{StaticResource FontSizeH3}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Excel" ToolTip.Tip="Excel olarak disari aktar"
                            Command="{Binding ExportExcelCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}"
                            BorderBrush="{DynamicResource MesPrimaryBlue}" BorderThickness="1"
                            Padding="12,6" CornerRadius="{StaticResource MesRadiusSm}" FontWeight="SemiBold" />
                    <Button Content="PDF" ToolTip.Tip="PDF olarak disari aktar"
                            Command="{Binding ExportPdfCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}"
                            BorderBrush="{DynamicResource MesPrimaryBlue}" BorderThickness="1"
                            Padding="12,6" CornerRadius="{StaticResource MesRadiusSm}" FontWeight="SemiBold" />
                    <Button Content="Yenile" ToolTip.Tip="Verileri yenile (F5)"
                            Command="{Binding RefreshCommand}"
                            Background="{DynamicResource MesBgPrimary}" Foreground="{DynamicResource MesPrimaryBlue}" FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="{StaticResource MesRadiusBase}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- KPI Cards -->
        <Border Grid.Row="1" Padding="16,12" Background="{DynamicResource MesBgSurface}">
            <Grid ColumnDefinitions="*,*,*" Margin="0">
                <!-- Toplam Stok Degeri -->
                <Border Grid.Column="0" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        Padding="16,12" Margin="0,0,8,0"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Toplam Stok Degeri" FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource MesSlateGray}" />
                        <TextBlock Text="{Binding TotalStockValueText}" FontSize="{StaticResource FontSizeH2}"
                                   FontWeight="Bold" Foreground="{DynamicResource StatusSuccessBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <!-- Toplam SKU -->
                <Border Grid.Column="1" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        Padding="16,12" Margin="4,0"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Toplam SKU" FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource MesSlateGray}" />
                        <TextBlock Text="{Binding TotalSkuText}" FontSize="{StaticResource FontSizeH2}"
                                   FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBlue}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <!-- Ortalama Devir Hizi -->
                <Border Grid.Column="2" Background="{DynamicResource MesBgPrimary}" CornerRadius="{StaticResource MesRadiusMd}"
                        Padding="16,12" Margin="8,0,0,0"
                        BorderBrush="{DynamicResource MesBorderLight}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Ortalama Devir Hizi" FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource MesSlateGray}" />
                        <TextBlock Text="{Binding AverageTurnoverText}" FontSize="{StaticResource FontSizeH2}"
                                   FontWeight="Bold" Foreground="{DynamicResource MesDarkSlate}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Warehouse Breakdown DataGrid -->
        <DataGrid Grid.Row="2" Margin="12"
                  ItemsSource="{Binding WarehouseStocks}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Depo" Binding="{Binding WarehouseName}" Width="180" />
                <DataGridTextColumn Header="SKU Sayisi" Binding="{Binding SkuCount}" Width="110" />
                <DataGridTextColumn Header="Toplam Adet" Binding="{Binding TotalQuantity}" Width="120" />
                <DataGridTextColumn Header="Toplam Deger" Binding="{Binding TotalValueText}" Width="150" />
                <DataGridTextColumn Header="Devir Hizi (gun)" Binding="{Binding TurnoverDaysText}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Aging Analysis Header -->
        <TextBlock Grid.Row="3" Text="Stok Yaslandirma Analizi" Margin="16,8,16,4"
                   FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold"
                   Foreground="{DynamicResource MesDarkSlate}" />

        <!-- Aging Analysis DataGrid -->
        <DataGrid Grid.Row="4" Margin="12" Height="200"
                  ItemsSource="{Binding AgingBuckets}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True" CanUserResizeColumns="True" CanUserReorderColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0"
                  Background="{DynamicResource MesBgPrimary}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Yaslandirma Dilimi" Binding="{Binding BucketName}" Width="180" />
                <DataGridTextColumn Header="SKU Sayisi" Binding="{Binding SkuCount}" Width="110" />
                <DataGridTextColumn Header="Toplam Adet" Binding="{Binding TotalQuantity}" Width="120" />
                <DataGridTextColumn Header="Deger" Binding="{Binding ValueText}" Width="150" />
                <DataGridTextColumn Header="Yuzde %" Binding="{Binding PercentageText}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Loading Skeleton -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{DynamicResource MesBgPage}"
                IsVisible="{Binding IsLoading}"
                ZIndex="100">
            <controls:SkeletonLoader ShowKpi="True" ShowChart="True" />
        </Border>

        <!-- Empty State -->
        <Border Grid.Row="1" Grid.RowSpan="4"
                Background="{DynamicResource MesBgSurface}"
                IsVisible="{Binding IsEmpty}"
                ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Stok verisi bulunamadi" FontSize="{StaticResource FontSizeH2}" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{DynamicResource MesDarkSlate}" Margin="0,0,0,8" />
                <TextBlock Text="Depolarinizda kayitli stok bulunmuyor"
                           FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource MesSlateGray}"
                           HorizontalAlignment="Center" Opacity="0.7" />
            </StackPanel>
        </Border>

                <!-- Error State — FluentAvalonia InfoBar -->
        <fa:InfoBar Title="Bir sorun olustu"
                    Message="{Binding ErrorMessage}"
                    Severity="Error"
                    IsOpen="{Binding HasError}"
                    IsClosable="True"
                    Margin="16,8"
                    ZIndex="50">
            <fa:InfoBar.ActionButton>
                <Button Content="Tekrar Dene" ToolTip.Tip="Islemi tekrar dene"
                        Command="{Binding RefreshCommand}" />
            </fa:InfoBar.ActionButton>
        </fa:InfoBar>
    </Grid>
</UserControl>
