<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ MesTech Dark Theme Override — İ-16 ═══ -->
    <!-- Brand, Status, Typography, Spacing → AYNI KALIR -->
    <!-- Sadece background, text, separator renkleri değişir -->

    <Color x:Key="MesBgPrimary">#1C1C1E</Color>
    <Color x:Key="MesBgSecondary">#2C2C2E</Color>
    <Color x:Key="MesBgTertiary">#3A3A3C</Color>
    <Color x:Key="MesBgElevated">#2C2C2E</Color>
    <Color x:Key="MesTextPrimary">#F5F5F7</Color>
    <Color x:Key="MesTextSecondary">#98989D</Color>
    <Color x:Key="MesTextTertiary">#636366</Color>
    <Color x:Key="MesSeparator">#38383A</Color>
    <Color x:Key="MesSeparatorOpaque">#545456</Color>

    <!-- ═══ UI PALETTE (Dark Override) ═══ -->
    <Color x:Key="MesSlateGray">#98989D</Color>
    <Color x:Key="MesPrimaryBlue">#0A84FF</Color>
    <Color x:Key="MesDarkSlate">#E5E5EA</Color>
    <Color x:Key="MesBorderLight">#38383A</Color>
    <Color x:Key="MesMutedGray">#636366</Color>
    <Color x:Key="MesBgPage">#1C1C1E</Color>
    <Color x:Key="MesBorderMedium">#48484A</Color>
    <Color x:Key="MesDanger">#FF453A</Color>
    <Color x:Key="MesGreen">#30D158</Color>
    <Color x:Key="MesTextMuted">#98989D</Color>
    <Color x:Key="MesCoolGray">#8E8E93</Color>
    <Color x:Key="MesBgSurface">#2C2C2E</Color>
    <Color x:Key="MesTextSlate">#AEAEB2</Color>
    <Color x:Key="MesRedAlert">#FF453A</Color>
    <Color x:Key="MesEmerald">#30D158</Color>
    <Color x:Key="MesBgMist">#2C2C2E</Color>
    <Color x:Key="MesAmber">#FFD60A</Color>
    <Color x:Key="MesBorderSoft">#48484A</Color>
    <Color x:Key="MesGreenMaterial">#30D158</Color>
    <Color x:Key="MesTeal">#64D2FF</Color>
    <Color x:Key="MesBgDangerLight">#3A2020</Color>
    <Color x:Key="MesRedBright">#FF6961</Color>
    <Color x:Key="MesPurple">#BF5AF2</Color>
    <Color x:Key="MesRedClassic">#FF453A</Color>
    <Color x:Key="MesRedDark">#FF6961</Color>

    <!-- ═══ PURPLE / VIOLET (Dark) ═══ -->
    <Color x:Key="MesPurpleDark">#C4B5FD</Color>
    <Color x:Key="MesBgPurpleLight">#2D2042</Color>
    <Color x:Key="MesBorderPurple">#4C3575</Color>

    <!-- ═══ AMBER / WARNING EXTENDED (Dark) ═══ -->
    <Color x:Key="MesAmberDark">#FCD34D</Color>
    <Color x:Key="MesAmberMuted">#FBBF24</Color>
    <Color x:Key="MesAmberText">#FDE68A</Color>
    <Color x:Key="MesBgAmberLight">#3A2E1A</Color>
    <Color x:Key="MesBorderAmber">#92400E</Color>

    <!-- ═══ BORDER SEMANTIC (Dark) ═══ -->
    <Color x:Key="MesBorderDanger">#7F1D1D</Color>
    <Color x:Key="MesBorderSuccess">#064E3B</Color>
    <Color x:Key="MesBorderMuted">#475569</Color>

    <!-- ═══ BORDER AMBER (Dark) ═══ -->
    <Color x:Key="MesBorderAmberLight">#92400E</Color>

    <!-- ═══ G041 ALIAS OVERRIDES (Dark) ═══ -->
    <Color x:Key="MesErrorRed">#FF453A</Color>
    <Color x:Key="MesSuccessGreen">#30D158</Color>
    <Color x:Key="MesBorderDefault">#48484A</Color>
    <Color x:Key="MesBgSuccessLight">#0D3320</Color>
    <Color x:Key="MesBrandHB">#FF6000</Color>

    <!-- ═══ STATUS COLORS (Dark — iOS HIG) ═══ -->
    <Color x:Key="MesSuccess">#30D158</Color>
    <Color x:Key="MesWarning">#FFD60A</Color>
    <Color x:Key="MesError">#FF453A</Color>
    <Color x:Key="MesInfo">#0A84FF</Color>

    <!-- ═══ ELEVATION (Dark — softer shadows) ═══ -->
    <BoxShadows x:Key="MesElevationCard">0 2 8 0 #28000000</BoxShadows>

    <!-- ═══ OVERLAY (Dark) ═══ -->
    <Color x:Key="MesBadgeOverlay">#00000033</Color>
    <Color x:Key="MesOverlayLight">#99000000</Color>
    <Color x:Key="MesOverlayMedium">#80000000</Color>

    <!-- ═══ MISSING DARK OVERRIDES — G155 DEV2 Tur 11 ═══ -->
    <!-- Stock status backgrounds (light→dark BG) -->
    <Color x:Key="MesStockLowBg">#332B00</Color>
    <Color x:Key="MesStockOutBg">#3B1010</Color>

    <!-- Timeline (dark variants) -->
    <Color x:Key="MesTimelineTrack">#48484A</Color>
    <Color x:Key="MesTimelineInactive">#636366</Color>
    <Color x:Key="MesTimelineActive">#0A84FF</Color>
    <Color x:Key="MesTimelineText">#EBEBF5</Color>

    <!-- Badge/neutral (dark variants) -->
    <Color x:Key="MesBadgeLightBg">#3A3A3C</Color>
    <Color x:Key="MesGrayLight">#636366</Color>
    <Color x:Key="MesNeutralGray">#8E8E93</Color>

    <!-- ═══ ACCENT + GRADIENT (Dark Override) ═══ -->
    <Color x:Key="MesAccentOrange">#FF8C00</Color>
    <Color x:Key="MesAccentOrangeDark">#FF6F00</Color>
    <Color x:Key="MesPrimaryBlueDark">#1565C0</Color>
    <Color x:Key="MesTealDark">#00897B</Color>
    <Color x:Key="MesTealMaterial">#26A69A</Color>
    <Color x:Key="MesMesaGlow">#1040C05C</Color>
    <Color x:Key="MesGradientDark">#0A0F1A</Color>
    <Color x:Key="MesGradientMid">#121E2E</Color>

    <!-- ═══ ELEVATION (Dark — all levels) ═══ -->
    <BoxShadows x:Key="MesElevation0">0 0 0 0 #00000000</BoxShadows>
    <BoxShadows x:Key="MesElevation1">0 1 3 0 #00000033</BoxShadows>
    <BoxShadows x:Key="MesElevation2">0 4 12 0 #0000004D</BoxShadows>
    <BoxShadows x:Key="MesElevation3">0 8 24 0 #00000066</BoxShadows>
    <BoxShadows x:Key="MesElevation4">0 16 48 0 #00000080</BoxShadows>

</ResourceDictionary>
