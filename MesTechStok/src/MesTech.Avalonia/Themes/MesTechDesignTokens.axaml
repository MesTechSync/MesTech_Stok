<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ MesTech Design System (MDS) — İ-16 ═══ -->
    <!-- Tek kaynak: Tüm renk, tipografi, spacing, elevation token'ları -->
    <!-- macOS HIG + Material Design 3 hibrit yaklaşım -->

    <!-- ═══ BRAND COLORS ═══ -->
    <Color x:Key="MesBrandPrimary">#2855AC</Color>
    <Color x:Key="MesBrandSecondary">#1a2332</Color>
    <Color x:Key="MesBrandAccent">#f27a1a</Color>

    <!-- ═══ SEMANTIC COLORS (Light) ═══ -->
    <Color x:Key="MesBgPrimary">#FFFFFF</Color>
    <Color x:Key="MesBgSecondary">#F5F7FA</Color>
    <Color x:Key="MesBgTertiary">#EDF0F5</Color>
    <Color x:Key="MesBgElevated">#FFFFFF</Color>
    <Color x:Key="MesTextPrimary">#1D1D1F</Color>
    <Color x:Key="MesTextSecondary">#6E6E73</Color>
    <Color x:Key="MesTextTertiary">#AEAEB2</Color>
    <Color x:Key="MesSeparator">#E5E5EA</Color>
    <Color x:Key="MesSeparatorOpaque">#C6C6C8</Color>

    <!-- ═══ UI PALETTE (View'larda en sık kullanılan) ═══ -->
    <Color x:Key="MesSlateGray">#64748B</Color>
    <Color x:Key="MesPrimaryBlue">#0078D4</Color>
    <Color x:Key="MesDarkSlate">#1E293B</Color>
    <Color x:Key="MesBorderLight">#E0E6ED</Color>
    <Color x:Key="MesMutedGray">#94A3B8</Color>
    <Color x:Key="MesBgPage">#F8FAFC</Color>
    <Color x:Key="MesBorderMedium">#E5E9F2</Color>
    <Color x:Key="MesDanger">#E53935</Color>
    <Color x:Key="MesGreen">#16A34A</Color>
    <Color x:Key="MesTextMuted">#555555</Color>
    <Color x:Key="MesCoolGray">#6B7280</Color>
    <Color x:Key="MesBgSurface">#F7F9FC</Color>
    <Color x:Key="MesTextSlate">#475569</Color>
    <Color x:Key="MesRedAlert">#DC2626</Color>
    <Color x:Key="MesEmerald">#10B981</Color>
    <Color x:Key="MesBgMist">#F1F5F9</Color>
    <Color x:Key="MesAmber">#F59E0B</Color>
    <Color x:Key="MesBorderSoft">#E2E8F0</Color>
    <Color x:Key="MesGreenMaterial">#4CAF50</Color>
    <Color x:Key="MesTeal">#059669</Color>
    <Color x:Key="MesBgDangerLight">#FEF2F2</Color>
    <Color x:Key="MesRedBright">#EF4444</Color>
    <Color x:Key="MesPurple">#7C3AED</Color>
    <Color x:Key="MesRedClassic">#E74C3C</Color>
    <Color x:Key="MesRedDark">#991B1B</Color>

    <!-- ═══ PURPLE / VIOLET ═══ -->
    <Color x:Key="MesPurpleDark">#4C1D95</Color>
    <Color x:Key="MesBgPurpleLight">#EDE9FE</Color>
    <Color x:Key="MesBorderPurple">#DDD6FE</Color>

    <!-- ═══ AMBER / WARNING EXTENDED ═══ -->
    <Color x:Key="MesAmberDark">#92400E</Color>
    <Color x:Key="MesAmberMuted">#CA8A04</Color>
    <Color x:Key="MesAmberText">#A16207</Color>
    <Color x:Key="MesBgAmberLight">#FFFBEB</Color>
    <Color x:Key="MesBorderAmber">#FDE68A</Color>

    <!-- ═══ BORDER SEMANTIC ═══ -->
    <Color x:Key="MesBorderDanger">#FECACA</Color>
    <Color x:Key="MesBorderSuccess">#A7F3D0</Color>
    <Color x:Key="MesBorderMuted">#CBD5E1</Color>

    <!-- ═══ BORDER AMBER ═══ -->
    <Color x:Key="MesBorderAmberLight">#FDBA74</Color>

    <!-- ═══ OVERLAY ═══ -->
    <Color x:Key="MesBadgeOverlay">#FFFFFF22</Color>
    <Color x:Key="MesOverlayLight">#99FFFFFF</Color>
    <Color x:Key="MesOverlayMedium">#80FFFFFF</Color>

    <!-- ═══ PLATFORM BRAND COLORS ═══ -->
    <Color x:Key="MesBrandAmazon">#FF9900</Color>
    <Color x:Key="MesBrandAmazonEu">#232F3E</Color>
    <Color x:Key="MesBrandCiceksepeti">#E91E63</Color>
    <Color x:Key="MesBrandCiceksepetiAlt">#6c3f99</Color>
    <Color x:Key="MesBrandEbay">#E53238</Color>
    <Color x:Key="MesBrandHepsiburada">#FF6000</Color>
    <Color x:Key="MesBrandN11">#6B21A8</Color>
    <Color x:Key="MesBrandN11Alt">#6610f2</Color>
    <Color x:Key="MesBrandOpenCart">#2496E8</Color>
    <Color x:Key="MesBrandOzon">#005BFF</Color>
    <Color x:Key="MesBrandPazarama">#FF5722</Color>
    <Color x:Key="MesBrandPttAvm">#FFD100</Color>
    <Color x:Key="MesBrandPttAvmDark">#D4A800</Color>

    <!-- ═══ GRADIENT / SPECIAL ═══ -->
    <Color x:Key="MesGradientDark">#0D1B2A</Color>
    <Color x:Key="MesGradientMid">#1B2838</Color>
    <Color x:Key="MesMesaGlow">#10B98144</Color>
    <Color x:Key="MesPrimaryBlueDark">#1E3D7A</Color>
    <Color x:Key="MesAccentOrange">#FF6F00</Color>
    <Color x:Key="MesAccentOrangeDark">#E65100</Color>
    <Color x:Key="MesTealMaterial">#00897B</Color>
    <Color x:Key="MesTealDark">#00695C</Color>

    <!-- ═══ SEMANTIC STATUS (C# code-behind) ═══ -->
    <Color x:Key="MesDangerDark">#D32F2F</Color>
    <Color x:Key="MesGreenForest">#388E3C</Color>
    <Color x:Key="MesGreenDark">#2E7D32</Color>
    <Color x:Key="MesWarningOrange">#FF9800</Color>
    <Color x:Key="MesWarningDark">#F57C00</Color>
    <Color x:Key="MesBlueMaterial">#2196F3</Color>
    <Color x:Key="MesSuccessVivid">#22C55E</Color>
    <Color x:Key="MesDarkNavy">#1A1A2E</Color>
    <Color x:Key="MesDarkCharcoal">#1F2937</Color>
    <Color x:Key="MesGrayLight">#9CA3AF</Color>

    <!-- ═══ CARGO BRAND COLORS ═══ -->
    <Color x:Key="MesBrandYurtici">#E31E24</Color>
    <Color x:Key="MesBrandAras">#00A651</Color>
    <Color x:Key="MesBrandSurat">#ED1C24</Color>
    <Color x:Key="MesBrandMng">#E30613</Color>
    <Color x:Key="MesBrandPttKargo">#FFC107</Color>
    <Color x:Key="MesBrandHepsijet">#FF6000</Color>
    <Color x:Key="MesBrandSendeo">#00BCD4</Color>
    <Color x:Key="MesNeutralGray">#9E9E9E</Color>

    <!-- ═══ CONNECTION STATUS ═══ -->
    <Color x:Key="MesConnectedGreen">#4CAF50</Color>
    <Color x:Key="MesDisconnectedRed">#F44336</Color>

    <!-- ═══ TIMELINE STEP ═══ -->
    <Color x:Key="MesTimelineActive">#2196F3</Color>
    <Color x:Key="MesTimelineInactive">#BDBDBD</Color>
    <Color x:Key="MesTimelineTrack">#E0E0E0</Color>
    <Color x:Key="MesTimelineText">#212121</Color>

    <!-- ═══ STOCK LEVEL BACKGROUNDS ═══ -->
    <Color x:Key="MesStockOutBg">#FFEBEE</Color>
    <Color x:Key="MesStockLowBg">#FFF8E1</Color>

    <!-- ═══ PLAN BADGE COLORS ═══ -->
    <Color x:Key="MesBadgeLightBg">#E5E7EB</Color>
    <Color x:Key="MesBadgeProStart">#3B82F6</Color>
    <Color x:Key="MesBadgeProEnd">#2563EB</Color>
    <Color x:Key="MesBadgeUltraEnd">#D97706</Color>

    <!-- ═══ STATUS COLORS ═══ -->
    <Color x:Key="MesSuccess">#34C759</Color>
    <Color x:Key="MesWarning">#FF9500</Color>
    <Color x:Key="MesError">#FF3B30</Color>
    <Color x:Key="MesInfo">#007AFF</Color>

    <!-- G041: Missing color aliases used by views -->
    <Color x:Key="MesErrorRed">#FF3B30</Color>
    <Color x:Key="MesSuccessGreen">#34C759</Color>
    <Color x:Key="MesBorderDefault">#E0E6ED</Color>
    <Color x:Key="MesBgSuccessLight">#F0FDF4</Color>
    <Color x:Key="MesBrandHB">#FF6000</Color>

    <!-- ═══ ELEVATION (BoxShadow) ═══ -->
    <BoxShadows x:Key="MesElevation0">0 0 0 0 #00000000</BoxShadows>
    <BoxShadows x:Key="MesElevation1">0 1 3 0 #0000001A</BoxShadows>
    <BoxShadows x:Key="MesElevationCard">0 2 8 0 #14000000</BoxShadows>
    <BoxShadows x:Key="MesElevation2">0 4 12 0 #00000026</BoxShadows>
    <BoxShadows x:Key="MesElevation3">0 8 24 0 #00000033</BoxShadows>
    <BoxShadows x:Key="MesElevation4">0 16 48 0 #0000003D</BoxShadows>

    <!-- ═══ TYPOGRAPHY (macOS SF Pro esinlenmesi) ═══ -->
    <!-- FIX-18 #14: Inter font primary — fallback to Segoe UI until .ttf embedded in Assets/Fonts/ -->
    <FontFamily x:Key="MesFontFamily">Inter, Segoe UI, SF Pro Display, system-ui</FontFamily>
    <FontFamily x:Key="InterFont">Inter, Segoe UI, sans-serif</FontFamily>

    <x:Double x:Key="MesFontLargeTitle">28</x:Double>
    <x:Double x:Key="MesFontTitle1">22</x:Double>
    <x:Double x:Key="MesFontTitle2">18</x:Double>
    <x:Double x:Key="MesFontTitle3">16</x:Double>
    <x:Double x:Key="MesFontHeadline">14</x:Double>
    <x:Double x:Key="MesFontBody">14</x:Double>
    <x:Double x:Key="MesFontCallout">13</x:Double>
    <x:Double x:Key="MesFontSubhead">12</x:Double>
    <x:Double x:Key="MesFontFootnote">11</x:Double>
    <x:Double x:Key="MesFontCaption1">10</x:Double>
    <x:Double x:Key="MesFontCaption2">9</x:Double>

    <!-- ═══ SPACING (4px grid) ═══ -->
    <Thickness x:Key="MesSpaceXxs">2</Thickness>
    <Thickness x:Key="MesSpaceXs">4</Thickness>
    <Thickness x:Key="MesSpaceSm">8</Thickness>
    <Thickness x:Key="MesSpaceMd">12</Thickness>
    <Thickness x:Key="MesSpaceLg">16</Thickness>
    <Thickness x:Key="MesSpaceXl">24</Thickness>
    <Thickness x:Key="MesSpaceXxl">32</Thickness>
    <Thickness x:Key="MesSpace3xl">48</Thickness>

    <!-- ═══ BORDER RADIUS ═══ -->
    <CornerRadius x:Key="MesRadiusNone">0</CornerRadius>
    <CornerRadius x:Key="MesRadiusSm">4</CornerRadius>
    <CornerRadius x:Key="MesRadiusBase">6</CornerRadius>
    <CornerRadius x:Key="MesRadiusMd">8</CornerRadius>
    <CornerRadius x:Key="MesRadiusMdLg">10</CornerRadius>
    <CornerRadius x:Key="MesRadiusLg">12</CornerRadius>
    <CornerRadius x:Key="MesRadiusLgXl">14</CornerRadius>
    <CornerRadius x:Key="MesRadiusXl">16</CornerRadius>
    <CornerRadius x:Key="MesRadiusFull">9999</CornerRadius>

    <!-- ═══ ANIMATION DURATIONS ═══ -->
    <x:String x:Key="MesDurationFast">0:0:0.08</x:String>
    <x:String x:Key="MesDurationNormal">0:0:0.15</x:String>
    <x:String x:Key="MesDurationMedium">0:0:0.25</x:String>
    <x:String x:Key="MesDurationSlow">0:0:0.3</x:String>

</ResourceDictionary>
