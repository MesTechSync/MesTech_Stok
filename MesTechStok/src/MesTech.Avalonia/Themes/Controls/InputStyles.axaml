<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ============================================================ -->
  <!-- MesTech Input Styles                                         -->
  <!-- TextBox, ComboBox, SearchBox                                 -->
  <!-- ============================================================ -->

  <!-- Standard TextBox -->
  <Style Selector="TextBox.mestech">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}"/>
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}"/>
    <Setter Property="MinHeight" Value="{StaticResource InputMinHeight}"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="TextBox.mestech:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}"/>
    <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessMedium}"/>
  </Style>
  <Style Selector="TextBox.mestech:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}"/>
  </Style>
  <Style Selector="TextBox.mestech:disabled">
    <Setter Property="Background" Value="{DynamicResource MesBgSecondary}"/>
    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}"/>
  </Style>

  <!-- Watermark / Placeholder styling -->
  <Style Selector="TextBox.mestech /template/ TextBlock#PART_Watermark">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="FontStyle" Value="Italic"/>
  </Style>

  <!-- ComboBox -->
  <Style Selector="ComboBox.mestech">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}"/>
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}"/>
    <Setter Property="MinHeight" Value="{StaticResource InputMinHeight}"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
  </Style>
  <Style Selector="ComboBox.mestech:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}"/>
  </Style>
  <Style Selector="ComboBox.mestech:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource TextSecondaryBrush}"/>
  </Style>

  <!-- SearchBox (TextBox variant with search icon styling) -->
  <Style Selector="TextBox.mestech-search">
    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}"/>
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusLarge}"/>
    <Setter Property="MinHeight" Value="{StaticResource InputMinHeight}"/>
    <Setter Property="Padding" Value="36,8,12,8"/>
    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
    <Setter Property="Watermark" Value="Ara..."/>
  </Style>
  <Style Selector="TextBox.mestech-search:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}"/>
    <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessMedium}"/>
  </Style>

</Styles>
