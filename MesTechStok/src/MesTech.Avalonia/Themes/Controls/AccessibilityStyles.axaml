<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ============================================================ -->
  <!-- Erişilebilirlik Stilleri — Focus Ring + Keyboard Navigation   -->
  <!-- WCAG 2.2 AA: Keyboard kullanıcılar için görünür focus ring    -->
  <!-- 3px mavi outline — evrensel erişilebilirlik standardı         -->
  <!-- ============================================================ -->

  <!-- Button focus ring -->
  <Style Selector="Button:focus-visible">
    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

  <!-- TextBox focus ring -->
  <Style Selector="TextBox:focus-visible">
    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

  <!-- ComboBox focus ring -->
  <Style Selector="ComboBox:focus-visible">
    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

  <!-- CheckBox focus ring -->
  <Style Selector="CheckBox:focus-visible">
    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
  </Style>

  <!-- RadioButton focus ring -->
  <Style Selector="RadioButton:focus-visible">
    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
  </Style>

  <!-- ListBoxItem focus ring -->
  <Style Selector="ListBoxItem:focus-visible">
    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

</Styles>
