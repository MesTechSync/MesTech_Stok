<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ============================================================ -->
  <!-- MesTech Button Styles                                        -->
  <!-- Raised, Accent, Outline, Flat, Danger, Icon Button           -->
  <!-- ============================================================ -->

  <!-- Base Button Style (Raised) -->
  <Style Selector="Button.mestech-raised">
    <Setter Property="Background" Value="{DynamicResource PrimaryBlueBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="MinWidth" Value="{StaticResource ButtonMinWidth}"/>
    <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeight}"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}"/>
    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button.mestech-raised:pointerover">
    <Setter Property="Background" Value="{DynamicResource SecondaryBlueBrush}"/>
  </Style>
  <Style Selector="Button.mestech-raised:pressed">
    <Setter Property="Background" Value="{DynamicResource SecondaryBlueBrush}"/>
    <Setter Property="RenderTransform" Value="scale(0.98)"/>
  </Style>
  <Style Selector="Button.mestech-raised:disabled">
    <Setter Property="Background" Value="{DynamicResource DisabledBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}"/>
  </Style>

  <!-- Accent Button (Green) -->
  <Style Selector="Button.mestech-accent">
    <Setter Property="Background" Value="{DynamicResource AccentGreenBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="MinWidth" Value="{StaticResource ButtonMinWidth}"/>
    <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeight}"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}"/>
    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.mestech-accent:pointerover">
    <Setter Property="Background" Value="{DynamicResource MesGreenMaterial}"/>
  </Style>
  <Style Selector="Button.mestech-accent:pressed">
    <Setter Property="Background" Value="{DynamicResource MesGreenMaterial}"/>
  </Style>

  <!-- Outline Button -->
  <Style Selector="Button.mestech-outline">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{DynamicResource PrimaryBlueBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBlueBrush}"/>
    <Setter Property="BorderThickness" Value="{StaticResource BorderThicknessThin}"/>
    <Setter Property="MinWidth" Value="{StaticResource ButtonMinWidth}"/>
    <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeight}"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}"/>
    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.mestech-outline:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
  </Style>

  <!-- Flat Button -->
  <Style Selector="Button.mestech-flat">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{DynamicResource PrimaryBlueBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeight}"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.mestech-flat:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
  </Style>

  <!-- Danger Button -->
  <Style Selector="Button.mestech-danger">
    <Setter Property="Background" Value="{DynamicResource ErrorRedBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="MinWidth" Value="{StaticResource ButtonMinWidth}"/>
    <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeight}"/>
    <Setter Property="Padding" Value="16,8"/>
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusMedium}"/>
    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    <Setter Property="FontFamily" Value="{StaticResource DefaultFontFamily}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.mestech-danger:pointerover">
    <Setter Property="Background" Value="{DynamicResource MesDanger}"/>
  </Style>
  <Style Selector="Button.mestech-danger:pressed">
    <Setter Property="Background" Value="{DynamicResource MesRedAlert}"/>
  </Style>

  <!-- Icon Button -->
  <Style Selector="Button.mestech-icon-btn">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Width" Value="36"/>
    <Setter Property="Height" Value="36"/>
    <Setter Property="Padding" Value="6"/>
    <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusLarge}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>
  <Style Selector="Button.mestech-icon-btn:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverOverlayBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
  </Style>

</Styles>
