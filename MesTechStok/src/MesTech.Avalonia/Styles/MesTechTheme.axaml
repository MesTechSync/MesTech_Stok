<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- MesTech Antigravity - Canonical Brand Colors (Avalonia) -->
  <SolidColorBrush x:Key="MesTechPrimary" Color="#0078D4"/>
  <SolidColorBrush x:Key="MesTechSecondary" Color="#00897B"/>
  <SolidColorBrush x:Key="MesTechAccent" Color="#FF6F00"/>
  <SolidColorBrush x:Key="MesTechBackground" Color="#FAFAFA"/>
  <SolidColorBrush x:Key="MesTechSurface" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="MesTechError" Color="#D32F2F"/>
  <SolidColorBrush x:Key="MesTechSuccess" Color="#2E7D32"/>
  <SolidColorBrush x:Key="MesTechWarning" Color="#F57F17"/>

  <!-- Primary Gradient -->
  <LinearGradientBrush x:Key="MesTechPrimaryGradient" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Color="#0078D4" Offset="0"/>
    <GradientStop Color="#1E3D7A" Offset="1"/>
  </LinearGradientBrush>

  <!-- Accent Gradient -->
  <LinearGradientBrush x:Key="MesTechAccentGradient" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Color="#FF6F00" Offset="0"/>
    <GradientStop Color="#E65100" Offset="1"/>
  </LinearGradientBrush>

  <!-- Teal Gradient -->
  <LinearGradientBrush x:Key="MesTechTealGradient" StartPoint="0%,0%" EndPoint="100%,100%">
    <GradientStop Color="#00897B" Offset="0"/>
    <GradientStop Color="#00695C" Offset="1"/>
  </LinearGradientBrush>

  <!-- ============================================================ -->
  <!-- WPF-Aligned Color Definitions (Colors.xaml birebir)          -->
  <!-- ============================================================ -->

  <!-- Primary Colors -->
  <Color x:Key="PrimaryBlueColor">#2196F3</Color>
  <Color x:Key="SecondaryBlueColor">#1976D2</Color>
  <Color x:Key="AccentGreenColor">#4CAF50</Color>
  <Color x:Key="OrangePrimaryColor">#FB8C00</Color>
  <Color x:Key="OrangeHoverColor">#F57C00</Color>
  <Color x:Key="OrangeDarkColor">#EF6C00</Color>
  <Color x:Key="WarningOrangeColor">#FF9800</Color>
  <Color x:Key="ErrorRedColor">#F44336</Color>
  <Color x:Key="TextPrimaryColor">#212121</Color>
  <Color x:Key="TextSecondaryColor">#757575</Color>
  <Color x:Key="BackgroundColor">#F5F7FA</Color>
  <Color x:Key="SurfaceColor">#FFFFFF</Color>
  <Color x:Key="BorderColor">#E0E0E0</Color>

  <!-- Sidebar Colors -->
  <Color x:Key="SidebarBackgroundColor">#1B2838</Color>
  <Color x:Key="SidebarHoverColor">#263850</Color>
  <Color x:Key="SidebarActiveColor">#2196F3</Color>
  <Color x:Key="SidebarTextColor">#B0BEC5</Color>
  <Color x:Key="SidebarTextActiveColor">#FFFFFF</Color>
  <Color x:Key="SidebarBorderColor">#37474F</Color>

  <!-- State Colors -->
  <Color x:Key="SuccessColor">#4CAF50</Color>
  <Color x:Key="InfoColor">#2196F3</Color>
  <Color x:Key="DisabledColor">#BDBDBD</Color>
  <Color x:Key="DisabledTextColor">#9E9E9E</Color>
  <Color x:Key="HoverOverlayColor">#0A000000</Color>
  <Color x:Key="PressedOverlayColor">#1A000000</Color>
  <Color x:Key="FocusBorderColor">#2196F3</Color>

  <!-- ============================================================ -->
  <!-- SolidColorBrush Definitions (WPF-Aligned)                    -->
  <!-- ============================================================ -->

  <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{DynamicResource PrimaryBlueColor}"/>
  <SolidColorBrush x:Key="SecondaryBlueBrush" Color="{DynamicResource SecondaryBlueColor}"/>
  <SolidColorBrush x:Key="AccentGreenBrush" Color="{DynamicResource AccentGreenColor}"/>
  <SolidColorBrush x:Key="OrangePrimaryBrush" Color="{DynamicResource OrangePrimaryColor}"/>
  <SolidColorBrush x:Key="OrangeHoverBrush" Color="{DynamicResource OrangeHoverColor}"/>
  <SolidColorBrush x:Key="OrangeDarkBrush" Color="{DynamicResource OrangeDarkColor}"/>
  <SolidColorBrush x:Key="WarningOrangeBrush" Color="{DynamicResource WarningOrangeColor}"/>
  <SolidColorBrush x:Key="ErrorRedBrush" Color="{DynamicResource ErrorRedColor}"/>
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}"/>
  <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>

  <!-- Sidebar Brushes -->
  <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{DynamicResource SidebarBackgroundColor}"/>
  <SolidColorBrush x:Key="SidebarHoverBrush" Color="{DynamicResource SidebarHoverColor}"/>
  <SolidColorBrush x:Key="SidebarActiveBrush" Color="{DynamicResource SidebarActiveColor}"/>
  <SolidColorBrush x:Key="SidebarTextBrush" Color="{DynamicResource SidebarTextColor}"/>
  <SolidColorBrush x:Key="SidebarTextActiveBrush" Color="{DynamicResource SidebarTextActiveColor}"/>
  <SolidColorBrush x:Key="SidebarBorderBrush" Color="{DynamicResource SidebarBorderColor}"/>

  <!-- State Brushes -->
  <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}"/>
  <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}"/>
  <SolidColorBrush x:Key="DisabledBrush" Color="{DynamicResource DisabledColor}"/>
  <SolidColorBrush x:Key="DisabledTextBrush" Color="{DynamicResource DisabledTextColor}"/>
  <SolidColorBrush x:Key="HoverOverlayBrush" Color="{DynamicResource HoverOverlayColor}"/>
  <SolidColorBrush x:Key="PressedOverlayBrush" Color="{DynamicResource PressedOverlayColor}"/>
  <SolidColorBrush x:Key="FocusBorderBrush" Color="{DynamicResource FocusBorderColor}"/>

  <!-- ============================================================ -->
  <!-- Status Palette — Tüm modüllerde tutarlı durum renkleri       -->
  <!-- ============================================================ -->

  <!-- Platform Status -->
  <Color x:Key="PlatformActiveColor">#388E3C</Color>
  <Color x:Key="PlatformInactiveColor">#9CA3AF</Color>
  <Color x:Key="PlatformErrorColor">#D32F2F</Color>
  <Color x:Key="PlatformSyncingColor">#0078D4</Color>
  <SolidColorBrush x:Key="PlatformActiveBrush" Color="{DynamicResource PlatformActiveColor}"/>
  <SolidColorBrush x:Key="PlatformInactiveBrush" Color="{DynamicResource PlatformInactiveColor}"/>
  <SolidColorBrush x:Key="PlatformErrorBrush" Color="{DynamicResource PlatformErrorColor}"/>
  <SolidColorBrush x:Key="PlatformSyncingBrush" Color="{DynamicResource PlatformSyncingColor}"/>

  <!-- Order Status -->
  <Color x:Key="OrderNewColor">#0078D4</Color>
  <Color x:Key="OrderProcessingColor">#F57C00</Color>
  <Color x:Key="OrderShippedColor">#7B1FA2</Color>
  <Color x:Key="OrderDeliveredColor">#388E3C</Color>
  <Color x:Key="OrderCancelledColor">#D32F2F</Color>
  <Color x:Key="OrderReturnedColor">#E91E63</Color>
  <SolidColorBrush x:Key="OrderNewBrush" Color="{DynamicResource OrderNewColor}"/>
  <SolidColorBrush x:Key="OrderProcessingBrush" Color="{DynamicResource OrderProcessingColor}"/>
  <SolidColorBrush x:Key="OrderShippedBrush" Color="{DynamicResource OrderShippedColor}"/>
  <SolidColorBrush x:Key="OrderDeliveredBrush" Color="{DynamicResource OrderDeliveredColor}"/>
  <SolidColorBrush x:Key="OrderCancelledBrush" Color="{DynamicResource OrderCancelledColor}"/>
  <SolidColorBrush x:Key="OrderReturnedBrush" Color="{DynamicResource OrderReturnedColor}"/>

  <!-- Cargo Status -->
  <Color x:Key="CargoPickedUpColor">#0078D4</Color>
  <Color x:Key="CargoInTransitColor">#F57C00</Color>
  <Color x:Key="CargoAtBranchColor">#7B1FA2</Color>
  <Color x:Key="CargoDeliveredColor">#388E3C</Color>
  <Color x:Key="CargoFailedColor">#D32F2F</Color>
  <SolidColorBrush x:Key="CargoPickedUpBrush" Color="{DynamicResource CargoPickedUpColor}"/>
  <SolidColorBrush x:Key="CargoInTransitBrush" Color="{DynamicResource CargoInTransitColor}"/>
  <SolidColorBrush x:Key="CargoAtBranchBrush" Color="{DynamicResource CargoAtBranchColor}"/>
  <SolidColorBrush x:Key="CargoDeliveredBrush" Color="{DynamicResource CargoDeliveredColor}"/>
  <SolidColorBrush x:Key="CargoFailedBrush" Color="{DynamicResource CargoFailedColor}"/>

  <!-- Invoice Status -->
  <Color x:Key="InvoiceDraftColor">#9CA3AF</Color>
  <Color x:Key="InvoiceSentColor">#0078D4</Color>
  <Color x:Key="InvoiceAcceptedColor">#388E3C</Color>
  <Color x:Key="InvoiceRejectedColor">#D32F2F</Color>
  <SolidColorBrush x:Key="InvoiceDraftBrush" Color="{DynamicResource InvoiceDraftColor}"/>
  <SolidColorBrush x:Key="InvoiceSentBrush" Color="{DynamicResource InvoiceSentColor}"/>
  <SolidColorBrush x:Key="InvoiceAcceptedBrush" Color="{DynamicResource InvoiceAcceptedColor}"/>
  <SolidColorBrush x:Key="InvoiceRejectedBrush" Color="{DynamicResource InvoiceRejectedColor}"/>

  <!-- Stock Level -->
  <Color x:Key="StockNormalColor">#388E3C</Color>
  <Color x:Key="StockLowColor">#F57C00</Color>
  <Color x:Key="StockCriticalColor">#D32F2F</Color>
  <Color x:Key="StockOutColor">#1A1A1A</Color>
  <SolidColorBrush x:Key="StockNormalBrush" Color="{DynamicResource StockNormalColor}"/>
  <SolidColorBrush x:Key="StockLowBrush" Color="{DynamicResource StockLowColor}"/>
  <SolidColorBrush x:Key="StockCriticalBrush" Color="{DynamicResource StockCriticalColor}"/>
  <SolidColorBrush x:Key="StockOutBrush" Color="{DynamicResource StockOutColor}"/>

  <!-- ============================================================ -->
  <!-- MESA OS Renk Token'ları — AI/Bot/RAG ayrı renk ailesi        -->
  <!-- ============================================================ -->

  <Color x:Key="AIInsightColor">#7C3AED</Color>
  <Color x:Key="AIInsightBgColor">#EDE9FE</Color>
  <Color x:Key="BotNotificationColor">#059669</Color>
  <Color x:Key="BotNotificationBgColor">#D1FAE5</Color>
  <Color x:Key="RagSearchColor">#0891B2</Color>
  <Color x:Key="RagSearchBgColor">#CFFAFE</Color>
  <SolidColorBrush x:Key="AIInsightBrush" Color="{DynamicResource AIInsightColor}"/>
  <SolidColorBrush x:Key="AIInsightBgBrush" Color="{DynamicResource AIInsightBgColor}"/>
  <SolidColorBrush x:Key="BotNotificationBrush" Color="{DynamicResource BotNotificationColor}"/>
  <SolidColorBrush x:Key="BotNotificationBgBrush" Color="{DynamicResource BotNotificationBgColor}"/>
  <SolidColorBrush x:Key="RagSearchBrush" Color="{DynamicResource RagSearchColor}"/>
  <SolidColorBrush x:Key="RagSearchBgBrush" Color="{DynamicResource RagSearchBgColor}"/>

  <!-- ============================================================ -->
  <!-- Platform Marka Renkleri (resmi)                               -->
  <!-- ============================================================ -->

  <Color x:Key="TrendyolColor">#F27A1A</Color>
  <Color x:Key="HepsiburadaColor">#FF6000</Color>
  <Color x:Key="N11Color">#6610F2</Color>
  <Color x:Key="CiceksepetiColor">#6C3F99</Color>
  <Color x:Key="AmazonColor">#FF9900</Color>
  <Color x:Key="PazaramaColor">#0095D9</Color>
  <Color x:Key="EbayColor">#E53238</Color>
  <Color x:Key="OpenCartColor">#2D9FD9</Color>
  <Color x:Key="OzonColor">#005BFF</Color>
  <Color x:Key="PttAvmColor">#FFD100</Color>
  <Color x:Key="ShopifyColor">#96BF48</Color>
  <Color x:Key="WooCommerceColor">#9B5C8F</Color>
  <Color x:Key="EtsyColor">#F16521</Color>
  <Color x:Key="BitrixColor">#2FC6F6</Color>
  <SolidColorBrush x:Key="TrendyolBrush" Color="{DynamicResource TrendyolColor}"/>
  <SolidColorBrush x:Key="HepsiburadaBrush" Color="{DynamicResource HepsiburadaColor}"/>
  <SolidColorBrush x:Key="N11Brush" Color="{StaticResource N11Color}"/>
  <SolidColorBrush x:Key="CiceksepetiBrush" Color="{DynamicResource CiceksepetiColor}"/>
  <SolidColorBrush x:Key="AmazonBrush" Color="{DynamicResource AmazonColor}"/>
  <SolidColorBrush x:Key="PazaramaBrush" Color="{DynamicResource PazaramaColor}"/>
  <SolidColorBrush x:Key="EbayBrush" Color="{DynamicResource EbayColor}"/>
  <SolidColorBrush x:Key="OpenCartBrush" Color="{DynamicResource OpenCartColor}"/>
  <SolidColorBrush x:Key="OzonBrush" Color="{DynamicResource OzonColor}"/>
  <SolidColorBrush x:Key="PttAvmBrush" Color="{DynamicResource PttAvmColor}"/>
  <SolidColorBrush x:Key="ShopifyBrush" Color="{DynamicResource ShopifyColor}"/>
  <SolidColorBrush x:Key="WooCommerceBrush" Color="{DynamicResource WooCommerceColor}"/>
  <SolidColorBrush x:Key="EtsyBrush" Color="{DynamicResource EtsyColor}"/>
  <SolidColorBrush x:Key="BitrixBrush" Color="{DynamicResource BitrixColor}"/>

  <!-- ============================================================ -->
  <!-- Semantik Light Backgrounds (alert/badge arka planları)       -->
  <!-- ============================================================ -->

  <Color x:Key="ErrorLightColor">#FFEBEE</Color>
  <Color x:Key="SuccessLightColor">#E8F5E9</Color>
  <Color x:Key="WarningLightColor">#FFF3E0</Color>
  <Color x:Key="InfoLightColor">#E3F2FD</Color>
  <SolidColorBrush x:Key="ErrorLightBrush" Color="{DynamicResource ErrorLightColor}"/>
  <SolidColorBrush x:Key="SuccessLightBrush" Color="{DynamicResource SuccessLightColor}"/>
  <SolidColorBrush x:Key="WarningLightBrush" Color="{DynamicResource WarningLightColor}"/>
  <SolidColorBrush x:Key="InfoLightBrush" Color="{DynamicResource InfoLightColor}"/>

  <!-- ============================================================ -->
  <!-- Typography                                                    -->
  <!-- ============================================================ -->

  <FontFamily x:Key="DefaultFontFamily">Segoe UI, San Francisco, Helvetica Neue, Arial</FontFamily>
  <FontFamily x:Key="MonoFontFamily">Cascadia Code, Consolas, monospace</FontFamily>

  <x:Double x:Key="FontSizeCaption">11</x:Double>
  <x:Double x:Key="FontSizeSmall">12</x:Double>
  <x:Double x:Key="FontSizeBody">14</x:Double>
  <x:Double x:Key="FontSizeSubtitle">16</x:Double>
  <x:Double x:Key="FontSizeTitle">20</x:Double>
  <x:Double x:Key="FontSizeHeader">24</x:Double>
  <x:Double x:Key="FontSizeDisplay">32</x:Double>

  <!-- ============================================================ -->
  <!-- Dimensions                                                    -->
  <!-- ============================================================ -->

  <CornerRadius x:Key="CornerRadiusSmall">2</CornerRadius>
  <CornerRadius x:Key="CornerRadiusMedium">4</CornerRadius>
  <CornerRadius x:Key="CornerRadiusLarge">8</CornerRadius>
  <CornerRadius x:Key="CornerRadiusRound">12</CornerRadius>

  <Thickness x:Key="PaddingSmall">4</Thickness>
  <Thickness x:Key="PaddingMedium">8</Thickness>
  <Thickness x:Key="PaddingLarge">16</Thickness>
  <Thickness x:Key="PaddingXLarge">24</Thickness>

  <Thickness x:Key="BorderThicknessThin">1</Thickness>
  <Thickness x:Key="BorderThicknessMedium">2</Thickness>

  <x:Double x:Key="SidebarWidth">240</x:Double>
  <x:Double x:Key="SidebarCollapsedWidth">60</x:Double>
  <x:Double x:Key="ButtonMinWidth">80</x:Double>
  <x:Double x:Key="ButtonMinHeight">36</x:Double>
  <x:Double x:Key="InputMinHeight">36</x:Double>
  <x:Double x:Key="IconSizeSmall">16</x:Double>
  <x:Double x:Key="IconSizeMedium">24</x:Double>
  <x:Double x:Key="IconSizeLarge">32</x:Double>

  <!-- ============================================================ -->
  <!-- Dark Mode Color Overrides                                     -->
  <!-- Avalonia ThemeDictionaries: Light = yukarıdaki default'lar    -->
  <!-- Dark = aşağıdaki override'lar                                -->
  <!-- RequestedThemeVariant="Dark" yapıldığında otomatik swap olur  -->
  <!-- WCAG 2.2 AA kontrast oranları doğrulanmış                    -->
  <!-- ============================================================ -->

  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Dark">
      <!-- Arka plan — koyu yüzeyler -->
      <Color x:Key="BackgroundColor">#0F1419</Color>
      <Color x:Key="SurfaceColor">#1A2332</Color>
      <Color x:Key="BorderColor">#2D3748</Color>

      <!-- Metin — açık renkler koyu zemin üzerinde -->
      <Color x:Key="TextPrimaryColor">#E2E8F0</Color>
      <Color x:Key="TextSecondaryColor">#A0AEC0</Color>

      <!-- Sidebar (dark'ta daha koyu) -->
      <Color x:Key="SidebarBackgroundColor">#0D1520</Color>
      <Color x:Key="SidebarHoverColor">#162233</Color>
      <Color x:Key="SidebarBorderColor">#1E2D3D</Color>
      <Color x:Key="SidebarTextColor">#94A3B8</Color>

      <!-- State renkler (dark'ta biraz yumuşak) -->
      <Color x:Key="DisabledColor">#4A5568</Color>
      <Color x:Key="DisabledTextColor">#718096</Color>
      <Color x:Key="HoverOverlayColor">#0AFFFFFF</Color>
      <Color x:Key="PressedOverlayColor">#1AFFFFFF</Color>

      <!-- Semantik arka planlar (dark variant) -->
      <Color x:Key="ErrorLightColor">#331A1A</Color>
      <Color x:Key="SuccessLightColor">#1A332A</Color>
      <Color x:Key="WarningLightColor">#332A1A</Color>
      <Color x:Key="InfoLightColor">#1A2633</Color>

      <!-- MESA OS arka planlar (dark variant) -->
      <Color x:Key="AIInsightBgColor">#2D1B69</Color>
      <Color x:Key="BotNotificationBgColor">#1A332A</Color>
      <Color x:Key="RagSearchBgColor">#1A2C33</Color>

      <!-- Stok tükendi (dark'ta görünür olsun) -->
      <Color x:Key="StockOutColor">#718096</Color>

      <!-- Dark Brush'lar -->
      <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E2E8F0"/>
      <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0AEC0"/>
      <SolidColorBrush x:Key="BackgroundBrush" Color="#0F1419"/>
      <SolidColorBrush x:Key="SurfaceBrush" Color="#1A2332"/>
      <SolidColorBrush x:Key="BorderBrush" Color="#2D3748"/>
      <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0D1520"/>
      <SolidColorBrush x:Key="SidebarHoverBrush" Color="#162233"/>
      <SolidColorBrush x:Key="SidebarBorderBrush" Color="#1E2D3D"/>
      <SolidColorBrush x:Key="SidebarTextBrush" Color="#94A3B8"/>
      <SolidColorBrush x:Key="DisabledBrush" Color="#4A5568"/>
      <SolidColorBrush x:Key="DisabledTextBrush" Color="#718096"/>
      <SolidColorBrush x:Key="HoverOverlayBrush" Color="#0AFFFFFF"/>
      <SolidColorBrush x:Key="PressedOverlayBrush" Color="#1AFFFFFF"/>
      <SolidColorBrush x:Key="ErrorLightBrush" Color="#331A1A"/>
      <SolidColorBrush x:Key="SuccessLightBrush" Color="#1A332A"/>
      <SolidColorBrush x:Key="WarningLightBrush" Color="#332A1A"/>
      <SolidColorBrush x:Key="InfoLightBrush" Color="#1A2633"/>
      <SolidColorBrush x:Key="AIInsightBgBrush" Color="#2D1B69"/>
      <SolidColorBrush x:Key="BotNotificationBgBrush" Color="#1A332A"/>
      <SolidColorBrush x:Key="RagSearchBgBrush" Color="#1A2C33"/>
      <SolidColorBrush x:Key="StockOutBrush" Color="#718096"/>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
