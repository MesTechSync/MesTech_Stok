<Application x:Class="MesTechStok.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MesTechStok.Desktop"
             xmlns:converters="clr-namespace:MesTechStok.Desktop.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <!-- 🎨 MesTech Antigravity Theme System -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- ═══ Material Design 3 Temel Kaynakları ═══ -->
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Blue"
                    SecondaryColor="Teal"
                    ColorAdjustment="{materialDesign:ColorAdjustment}"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>

                <!-- ═══ BRAVO TİMİ Modern Styles (korunuyor) ═══ -->
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/Typography.xaml"/>
                <ResourceDictionary Source="Styles/Animations.xaml"/>
                <ResourceDictionary Source="Styles/ModernControls.xaml"/>
                <ResourceDictionary Source="Styles/NavigationStyles.xaml"/>
                <!-- Modern input bileşenleri (TextBox/PasswordBox vb.) -->
                <ResourceDictionary Source="Themes/ModernInputs.xaml"/>

                <!-- ═══ MesTech Antigravity Tema Kaynakları ═══ -->
                <ResourceDictionary Source="Resources/Themes/MesTechTheme.xaml"/>

                <!-- ═══ Bitrix24 Marka Renkleri (mestech-tokens.css sync) ═══ -->
                <ResourceDictionary Source="Resources/Themes/Bitrix24Theme.xaml"/>

                <!-- ═══ DPI FIX: Render ayarlari (PerMonitorV2 destegi) ═══ -->
                <ResourceDictionary Source="Resources/Themes/DpiRenderSettings.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <!-- BRAVO TİMİ Custom Converters -->
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <converters:StockStatusToColorConverter x:Key="StockStatusToColorConverter"/>

            <!-- Global Font Definitions -->
            <FontFamily x:Key="PrimaryFont">Segoe UI</FontFamily>
            <FontFamily x:Key="MonoFont">Consolas</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
