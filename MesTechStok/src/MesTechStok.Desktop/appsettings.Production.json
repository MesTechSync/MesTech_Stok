{
  "Database": {
    "Provider": "PostgreSQL"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "Authentication": {
    "SkipLogin": false
  },
  "Platforms": {
    "Trendyol": {
      "BaseUrl": "https://apigw.trendyol.com/integration",
      "Enabled": true
    },
    "OpenCart": {
      "BaseUrl": "https://allmes.store",
      "Enabled": true
    },
    "Ciceksepeti": {
      "BaseUrl": "https://apis.ciceksepeti.com/api/v1/",
      "Enabled": true
    },
    "Hepsiburada": {
      "BaseUrl": "https://mpop-sit.hepsiburada.com/",
      "Enabled": true
    },
    "Pazarama": {
      "BaseUrl": "https://api.pazarama.com/api/v1/",
      "Enabled": true
    }
  },
  "Invoice": {
    "ActiveProvider": "Sovos",
    "Sovos": {
      "BaseUrl": "https://edonusum.sovos.com.tr"
    }
  },
  "Features": {
    "UseMockInvoice": false
  }
}
