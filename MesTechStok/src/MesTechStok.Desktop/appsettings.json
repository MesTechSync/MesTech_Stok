{
  "Database": {
    "Provider": "PostgreSQL"
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mestech_stok;Username=mestech_user;Password=mestech_postgres_dev"
  },
  "Authentication": {
    "SkipLogin": false,
    "AllowedUsernames": ["admin"],
    "AcceptedPasswords": []
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Application": {
    "Name": "MesTech Stok Takip Sistemi",
    "Version": "2.0 Professional",
    "DatabasePath": "MesTechStok.db",
    "BackupPath": "Backups",
    "LogPath": "Logs"
  },
  "BarcodeView": {
    "Reader": {
      "FormatPreset": "RetailPlus2D_NoUPCE",
      "UseROI": false,
      "RoiTopPercent": 0.25,
      "RoiHeightPercent": 0.5,
      "RoiLeftPercent": 0.05,
      "RoiWidthPercent": 0.9,
      "DecodeCooldownMs": 250,
      "TryHarder": true,
      "TryInverted": false,
      "Priority2D": true,
      "UseClahe": true,
      "Thresholding": "Adaptive",
      "QrFallbackOpenCV": true
    },
    "Scan": {
      "BaseTimeoutMs": 12000,
      "AbsoluteTimeoutMs": 30000
    },
    "PreviewEnabled": true
  },
  "BarcodeSettings": {
    "AutoScanEnabled": true,
    "ScanTimeout": 5000,
    "SupportedFormats": ["Code128", "Code39", "EAN13", "EAN8", "UPC", "QR"],
    "CameraIndex": 0
  },
  "OpenCartSettings": {
    "ApiUrl": "https://allmes.store",
    "ApiKey": "** USER SECRETS **",
    "AutoSyncEnabled": true,
    "SyncIntervalMinutes": 30
  },
  "Resilience": {
    "CircuitBreaker": {
      "FailRateThreshold": 0.2,
      "SlidingWindowSeconds": 60,
      "OpenStateDurationSeconds": 120,
      "HalfOpenMaxCalls": 10,
      "MinimumThroughput": 20
    },
    "Retry": {
      "BackoffSeconds": [1, 2, 4, 8, 16]
    },
    "QueueRetentionHours": 24
  },
  "UISettings": {
    "Theme": "Light",
    "Language": "tr-TR",
    "ShowAnimations": true,
    "AutoRefreshInterval": 30
  },
  "WeatherApiSettings": {
    "OpenWeatherMapApiKey": "** USER SECRETS **",
    "DefaultCity": "Istanbul",
    "DefaultCountryCode": "TR",
    "Language": "tr",
    "Units": "metric",
    "CacheExpirationMinutes": 30,
    "EnableForecast": true
  },
  "BarcodeValidationSettings": {
    "EnableGS1Validation": true,
    "EnableOnlineLookup": true,
    "UpcDatabaseApiKey": "trial",
    "BarcodeLookupApiKey": "",
    "ValidationTimeoutSeconds": 10,
    "StrictValidation": false,
    "CacheResults": true,
    "CacheExpirationHours": 24,
    "AllowedCountryCodes": [],
    "RestrictedPrefixes": []
  },
  "Platforms": {
    "Trendyol": {
      "BaseUrl": "https://api.trendyol.com/sapigw",
      "Enabled": true
    },
    "OpenCart": {
      "BaseUrl": "https://allmes.store",
      "Enabled": true
    },
    "Ciceksepeti": {
      "BaseUrl": "https://sandbox-apis.ciceksepeti.com/api/v1/",
      "Enabled": false
    },
    "Hepsiburada": {
      "BaseUrl": "https://sandbox-api.hepsiburada.com/",
      "Enabled": false
    }
  },
  "Cargo": {
    "Yurtici": {
      "BaseUrl": "http://testwebservices.yurticikargo.com:9090",
      "UserName": "** USER SECRETS **",
      "Password": "** USER SECRETS **"
    },
    "Aras": {
      "BaseUrl": "https://customerservicestest.araskargo.com.tr",
      "ApiKey": "** USER SECRETS **"
    },
    "Surat": {
      "BaseUrl": "https://testapi.suratkargo.com.tr",
      "ApiKey": "** USER SECRETS **"
    }
  },
  "Features": {
    "UseMockInvoice": true
  }
} 
