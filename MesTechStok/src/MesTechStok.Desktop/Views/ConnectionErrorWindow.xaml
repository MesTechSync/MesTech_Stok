<Window x:Class="MesTechStok.Desktop.Views.ConnectionErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="MesTech - Baglanti Hatasi"
        Height="400" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Bitrix24PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource Bitrix24ButtonRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"
                                        Value="{StaticResource Bitrix24PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Outline Button Style -->
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Bitrix24TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Bitrix24InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource Bitrix24ButtonRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"
                                        Value="{StaticResource Bitrix24PrimaryLightBrush}"/>
                                <Setter Property="BorderBrush"
                                        Value="{StaticResource Bitrix24PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Bitrix24DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource Bitrix24ButtonRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#c82333"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Connection Info Label Style -->
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Bitrix24TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>

        <!-- Connection Info Value Style -->
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="{StaticResource Bitrix24TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <!-- Outer Border with drop shadow -->
    <Border CornerRadius="12"
            Background="{StaticResource Bitrix24CardBgBrush}"
            BorderBrush="{StaticResource Bitrix24DividerBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="4"
                              Color="Black"
                              Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar (draggable) -->
            <Border Grid.Row="0"
                    Background="{StaticResource Bitrix24PrimaryGradient}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <TextBlock Text="MesTech Stok Sistemi"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <TextBlock Text="Baglanti Hatasi"
                               FontSize="11"
                               Foreground="#B0C4DE"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Center Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0">
                <StackPanel Margin="28,20,28,12"
                            HorizontalAlignment="Stretch">

                    <!-- Alert Icon -->
                    <materialDesign:PackIcon Kind="AlertCircle"
                                             Width="64" Height="64"
                                             Foreground="{StaticResource Bitrix24DangerBrush}"
                                             HorizontalAlignment="Center"
                                             Margin="0,0,0,12"/>

                    <!-- Title -->
                    <TextBlock Text="Veritabani Baglanti Hatasi"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource Bitrix24TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- Error Message (scrollable) -->
                    <Border Background="{StaticResource Bitrix24ContentBgBrush}"
                            CornerRadius="{StaticResource Bitrix24CardRadius}"
                            BorderBrush="{StaticResource Bitrix24DividerBrush}"
                            BorderThickness="1"
                            Padding="12"
                            MaxHeight="120"
                            Margin="0,0,0,16">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock x:Name="ErrorMessageText"
                                       Text="Veritabani sunucusuna baglanilamadi."
                                       FontSize="13"
                                       Foreground="{StaticResource Bitrix24TextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Connection Info Grid -->
                    <Border Background="{StaticResource Bitrix24ContentBgBrush}"
                            CornerRadius="{StaticResource Bitrix24CardRadius}"
                            BorderBrush="{StaticResource Bitrix24DividerBrush}"
                            BorderThickness="1"
                            Padding="14,10"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Sunucu -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Sunucu:"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="HostText"
                                       Grid.Row="0" Grid.Column="1"
                                       Text="localhost"
                                       Style="{StaticResource InfoValue}"/>

                            <!-- Port -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Port:"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="PortText"
                                       Grid.Row="1" Grid.Column="1"
                                       Text="5432"
                                       Style="{StaticResource InfoValue}"/>

                            <!-- Veritabani -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Veritabani:"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="DatabaseText"
                                       Grid.Row="2" Grid.Column="1"
                                       Text="mestech_stok"
                                       Style="{StaticResource InfoValue}"/>

                            <!-- Sifre (masked) -->
                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Sifre:"
                                       Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="****"
                                       Style="{StaticResource InfoValue}"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Buttons -->
            <Border Grid.Row="2"
                    BorderBrush="{StaticResource Bitrix24DividerBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="28,16">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <!-- Tekrar Dene -->
                    <Button x:Name="RetryButton"
                            Style="{StaticResource PrimaryButton}"
                            Click="RetryButton_Click"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh"
                                                     Width="16" Height="16"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0"/>
                            <TextBlock x:Name="RetryButtonText"
                                       Text="Tekrar Dene"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Ayarlar -->
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource OutlineButton}"
                            Click="SettingsButton_Click"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog"
                                                     Width="16" Height="16"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0"/>
                            <TextBlock Text="Ayarlar"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Cikis -->
                    <Button x:Name="ExitButton"
                            Style="{StaticResource DangerButton}"
                            Click="ExitButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ExitToApp"
                                                     Width="16" Height="16"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0"/>
                            <TextBlock Text="Cikis"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
