<UserControl x:Class="MesTechStok.Desktop.Views.MesaAIToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Modern Card Style -->
        <Style x:Key="AICard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#6366F1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4F46E5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A5B4FC"/>
                                <Setter Property="Foreground" Value="#E0E7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#10B981"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EF4444"/>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="#212529"/>
        </Style>

        <Style x:Key="InfoButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#06B6D4"/>
        </Style>

        <!-- Status Badge Styles -->
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F3F4"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- AI Tool Card Style -->
        <Style x:Key="AIToolCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E7FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#6366F1" BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat Card Style -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F7FA" Padding="0,0,0,10">
            <Grid Margin="15" SnapsToDevicePixels="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Header -->
                <Border Grid.Row="0" Style="{StaticResource AICard}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#EEF2FF" Offset="0"/>
                            <GradientStop Color="#E0E7FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#x1F916;" FontSize="32" Margin="0,0,14,0" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="MESA AI Araclari"
                                          FontSize="24"
                                          FontWeight="Bold"
                                          Foreground="#312E81"/>
                                <TextBlock Text="Yapay zeka destekli stok optimizasyonu ve tahminleme"
                                          FontSize="13"
                                          Foreground="#6366F1"
                                          Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="&#x1F504; Yenile"
                                Style="{StaticResource PrimaryButton}"
                                Click="Refresh_Click"
                                Margin="5,0"/>
                    </Grid>
                </Border>

                <!-- Row 1: AI Status + Stats -->
                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: MESA Connection Status -->
                    <Border Grid.Column="0" Style="{StaticResource AICard}">
                        <StackPanel>
                            <TextBlock Text="&#x1F4E1; MESA Baglanti Durumu"
                                      FontSize="14" FontWeight="Bold" Foreground="#312E81"
                                      Margin="0,0,0,14"/>

                            <!-- Connection indicator -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Ellipse x:Name="ConnectionIndicator"
                                        Width="12" Height="12"
                                        Fill="#10B981"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"/>
                                <TextBlock x:Name="ConnectionStatusText"
                                          Text="MESA Baglantisi Aktif"
                                          FontSize="14" FontWeight="SemiBold"
                                          Foreground="#10B981"
                                          VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Model version -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Model:"
                                          FontSize="12" Foreground="#6C757D"
                                          Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ModelVersionText"
                                          Text="MESA v2.1 — GPT-4 Tabanli"
                                          FontSize="12" FontWeight="Medium"
                                          Foreground="#4338CA"
                                          VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Last sync -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Son Senkronizasyon:"
                                          FontSize="12" Foreground="#6C757D"
                                          Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LastSyncText"
                                          Text="--"
                                          FontSize="12" Foreground="#6C757D"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Right: AI Stats -->
                    <Border Grid.Column="2" Style="{StaticResource AICard}">
                        <StackPanel>
                            <TextBlock Text="&#x1F4CA; AI Performans Istatistikleri"
                                      FontSize="14" FontWeight="Bold" Foreground="#312E81"
                                      Margin="0,0,0,14"/>
                            <UniformGrid Columns="3">
                                <!-- Tahmin Dogrulugu -->
                                <Border Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F3AF;" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="Tahmin Dogrulugu" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="PredictionAccuracyText"
                                                  Text="%94.2"
                                                  FontSize="22" FontWeight="Bold" Foreground="#10B981"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Islenen Urun -->
                                <Border Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F4E6;" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="Islenen Urun" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="ProcessedProductsText"
                                                  Text="1,423"
                                                  FontSize="22" FontWeight="Bold" Foreground="#6366F1"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Otomatik Siparis -->
                                <Border Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F6D2;" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="Otomatik Siparis" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="AutoOrdersText"
                                                  Text="234"
                                                  FontSize="22" FontWeight="Bold" Foreground="#F59E0B"
                                                  HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Row 2: AI Tools Cards (3-column grid) -->
                <Border Grid.Row="2" Style="{StaticResource AICard}" Margin="8,6,8,6">
                    <StackPanel>
                        <TextBlock Text="&#x1F9E0; AI Araclari"
                                  FontSize="16" FontWeight="Bold" Foreground="#312E81"
                                  Margin="0,0,0,14"/>

                        <UniformGrid Columns="3" Rows="2">
                            <!-- Card 1: Stok Tahminleme -->
                            <Border Style="{StaticResource AIToolCard}">
                                <StackPanel>
                                    <TextBlock Text="&#x1F4CA;" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="Stok Tahminleme" FontSize="15" FontWeight="Bold" Foreground="#312E81"/>
                                    <TextBlock Text="AI tabanli stok ihtiyac tahmini. Gecmis verilere dayanarak gelecek donem stok gereksinimlerini hesaplar."
                                              FontSize="12" Foreground="#6C757D"
                                              TextWrapping="Wrap" Margin="0,6,0,12"/>
                                    <Button Content="&#x25B6; Calistir"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="RunStockPrediction_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 2: AI Urun Aciklamasi -->
                            <Border Style="{StaticResource AIToolCard}">
                                <StackPanel>
                                    <TextBlock Text="&#x1F4DD;" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="AI Urun Aciklamasi" FontSize="15" FontWeight="Bold" Foreground="#312E81"/>
                                    <TextBlock Text="Urun bilgilerinden otomatik SEO uyumlu aciklama olusturma. Kategori bazli sablonlar kullanir."
                                              FontSize="12" Foreground="#6C757D"
                                              TextWrapping="Wrap" Margin="0,6,0,12"/>
                                    <Button Content="&#x25B6; Calistir"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="RunDescriptionGenerator_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 3: Fiyat Optimizasyonu -->
                            <Border Style="{StaticResource AIToolCard}">
                                <StackPanel>
                                    <TextBlock Text="&#x1F4B0;" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="Fiyat Optimizasyonu" FontSize="15" FontWeight="Bold" Foreground="#312E81"/>
                                    <TextBlock Text="Rekabet analizi ve talep verilerine gore AI destekli fiyatlandirma onerileri olusturur."
                                              FontSize="12" Foreground="#6C757D"
                                              TextWrapping="Wrap" Margin="0,6,0,12"/>
                                    <Button Content="&#x25B6; Calistir"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="RunPriceOptimization_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 4: Anomali Tespiti -->
                            <Border Style="{StaticResource AIToolCard}">
                                <StackPanel>
                                    <TextBlock Text="&#x1F514;" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="Anomali Tespiti" FontSize="15" FontWeight="Bold" Foreground="#312E81"/>
                                    <TextBlock Text="Stok hareketlerinde olagan disi kaliplari tespit eder. Hirsizlik, kayip ve veri bozulmasini algilar."
                                              FontSize="12" Foreground="#6C757D"
                                              TextWrapping="Wrap" Margin="0,6,0,12"/>
                                    <Button Content="&#x25B6; Calistir"
                                            Style="{StaticResource WarningButton}"
                                            Click="RunAnomalyDetection_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 5: Talep Tahmini -->
                            <Border Style="{StaticResource AIToolCard}">
                                <StackPanel>
                                    <TextBlock Text="&#x1F4C8;" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="Talep Tahmini" FontSize="15" FontWeight="Bold" Foreground="#312E81"/>
                                    <TextBlock Text="Mevsimsellik, trend ve kampanya verilerine gore gelecek donem talep tahminlemesi yapar."
                                              FontSize="12" Foreground="#6C757D"
                                              TextWrapping="Wrap" Margin="0,6,0,12"/>
                                    <Button Content="&#x25B6; Calistir"
                                            Style="{StaticResource SuccessButton}"
                                            Click="RunDemandForecast_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 6: Bot Yonetimi -->
                            <Border Style="{StaticResource AIToolCard}">
                                <StackPanel>
                                    <TextBlock Text="&#x1F916;" FontSize="28" Margin="0,0,0,8"/>
                                    <TextBlock Text="Bot Yonetimi" FontSize="15" FontWeight="Bold" Foreground="#312E81"/>
                                    <TextBlock Text="MESA bot yapilandirmasi ve yonetimi. Otomatik siparis, bildirim ve raporlama botlarini kontrol eder."
                                              FontSize="12" Foreground="#6C757D"
                                              TextWrapping="Wrap" Margin="0,6,0,12"/>
                                    <Button Content="&#x2699; Yapilandir"
                                            Style="{StaticResource InfoButton}"
                                            Click="ConfigureBot_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Row 3: AI Activity Log -->
                <Border Grid.Row="3" Style="{StaticResource AICard}" Margin="8,6,8,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="200"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#x1F4CB;" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="AI Aktivite Gunlugu"
                                      FontSize="16" FontWeight="Bold" Foreground="#312E81"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="ActivityCountText"
                                      Text="(0 islem)"
                                      FontSize="13" Foreground="#6C757D"
                                      Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  x:Name="ActivityDataGrid"
                                  Style="{StaticResource ModernDataGrid}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  EnableRowVirtualization="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tarih"
                                                   Binding="{Binding FormattedDate}"
                                                   Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Islem"
                                                   Binding="{Binding Operation}"
                                                   Width="200" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Durum" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource StatusBadge}" x:Name="StatusBorder">
                                                <TextBlock x:Name="StatusText"
                                                          Text="{Binding Status}"
                                                          FontSize="11" FontWeight="Bold"
                                                          HorizontalAlignment="Center"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Basarili">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#D1FAE5"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#065F46"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Devam Ediyor">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#E0E7FF"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#3730A3"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Basarisiz">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#FEE2E2"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#991B1B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Uyari">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#FEF3C7"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#92400E"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Sonuc"
                                                   Binding="{Binding Result}"
                                                   Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Sure"
                                                   Binding="{Binding Duration}"
                                                   Width="100" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Error State -->
        <Border x:Name="MesaErrorState" Visibility="Collapsed" Background="#FFFBFE" Panel.ZIndex="50" Padding="32">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400">
                <TextBlock Text="&#x26A0;" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock x:Name="MesaErrorText" Text="Bir hata oluştu." TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,12,0,16" FontSize="14" Foreground="#B00020" />
                <Button Content="Tekrar Dene" HorizontalAlignment="Center" Padding="24,8" Style="{StaticResource PrimaryButton}" Click="Refresh_Click" />
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="MesaEmptyState" Visibility="Collapsed" Background="#FFFBFE" Panel.ZIndex="50" Padding="32">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x1F4AD;" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock Text="Henüz veri bulunmuyor." HorizontalAlignment="Center" FontSize="16" Foreground="#999" Margin="0,12,0,0" />
            </StackPanel>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay"
                Background="#80FFFFFF"
                Visibility="Collapsed"
                Panel.ZIndex="999">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#x23F3;" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock.RenderTransform>
                        <RotateTransform CenterX="18" CenterY="18"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                    From="0" To="360" Duration="0:0:2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock Text="MESA AI isleniyor..."
                          FontSize="15" FontWeight="Medium"
                          Foreground="#6366F1"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Yapay zeka modeli calistiriliyor, lutfen bekleyin..."
                          FontSize="12" Foreground="#6C757D"
                          HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
