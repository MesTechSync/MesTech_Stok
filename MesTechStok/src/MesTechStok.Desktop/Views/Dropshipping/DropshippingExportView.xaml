<UserControl x:Class="MesTechStok.Desktop.Views.Dropshipping.DropshippingExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:MesTechStok.Desktop.Converters">

    <UserControl.Resources>
        <conv:ReliabilityColorConverter x:Key="ScoreColor" ConvertMode="Foreground"/>
        <conv:ReliabilityColorConverter x:Key="ScoreBg"    ConvertMode="Background"/>
        <conv:ReliabilityLabelConverter x:Key="ScoreLabel"/>
        <BooleanToVisibilityConverter  x:Key="BoolVis"/>

        <!-- Platform renkleri -->
        <SolidColorBrush x:Key="TrendyolColor" Color="#F27A1A"/>
        <SolidColorBrush x:Key="HepsiColor"    Color="#FF6000"/>
        <SolidColorBrush x:Key="N11Color"      Color="#6C2D97"/>
        <SolidColorBrush x:Key="CicekColor"    Color="#2E7D32"/>
        <SolidColorBrush x:Key="PazaramaColor" Color="#1976D2"/>
        <SolidColorBrush x:Key="AmazonColor"   Color="#FF9900"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Başlık -->
            <RowDefinition Height="Auto"/>  <!-- Adım göstergesi -->
            <RowDefinition Height="*"/>     <!-- İçerik -->
            <RowDefinition Height="Auto"/>  <!-- Alt navigasyon -->
        </Grid.RowDefinitions>

        <!-- ── Başlık ── -->
        <Border Grid.Row="0" Background="#2855AC" Padding="16,10">
            <TextBlock Text="Dropshipping İhracat" Foreground="White"
                       FontSize="15" FontWeight="SemiBold"/>
        </Border>

        <!-- ── Adım Göstergesi ── -->
        <Border Grid.Row="1" Background="#f8fafc"
                BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <!-- Adım 1 -->
                <Border x:Name="Step1Indicator" CornerRadius="14"
                        Width="28" Height="28"
                        Background="#2855AC">
                    <TextBlock Text="1" Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="Step1Label" Text=" Ürün Seçimi "
                           VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="#2855AC"/>
                <Rectangle Width="60" Height="2" Fill="#e2e8f0" VerticalAlignment="Center" Margin="4,0"/>

                <!-- Adım 2 -->
                <Border x:Name="Step2Indicator" CornerRadius="14"
                        Width="28" Height="28"
                        Background="#cbd5e1">
                    <TextBlock Text="2" Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="Step2Label" Text=" Hedef &amp; Fiyat "
                           VerticalAlignment="Center"
                           Foreground="#94a3b8"/>
                <Rectangle Width="60" Height="2" Fill="#e2e8f0" VerticalAlignment="Center" Margin="4,0"/>

                <!-- Adım 3 -->
                <Border x:Name="Step3Indicator" CornerRadius="14"
                        Width="28" Height="28"
                        Background="#cbd5e1">
                    <TextBlock Text="3" Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="Step3Label" Text=" Gönder "
                           VerticalAlignment="Center"
                           Foreground="#94a3b8"/>
            </StackPanel>
        </Border>

        <!-- ── İçerik Alanı (3 panel, biri görünür) ── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="16">

                <!-- ADIM 1: Ürün Seçimi -->
                <Border x:Name="Panel1" Background="White" CornerRadius="8"
                        Padding="16"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="İhracat Edilecek Ürünleri Seçin"
                                       FontWeight="Bold" FontSize="14"
                                       Foreground="#1e293b"/>
                            <TextBox x:Name="TxtExportSearch"
                                     DockPanel.Dock="Right" Width="220"
                                     md:HintAssist.Hint="SKU, ürün adı..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     TextChanged="TxtExportSearch_TextChanged"/>
                        </DockPanel>

                        <DataGrid x:Name="ExportGrid"
                                  Height="350"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  SelectionMode="Extended"
                                  GridLinesVisibility="Horizontal"
                                  Style="{StaticResource MaterialDesignDataGrid}">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow"
                                       BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                    <Setter Property="BorderBrush"
                                            Value="{Binding ReliabilityScore,
                                                   Converter={StaticResource ScoreColor}}"/>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="&#x2713;" Width="36"
                                    Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"/>
                                <DataGridTextColumn Header="Ürün Adı"
                                    Binding="{Binding ProductName}" Width="*" MinWidth="150"/>
                                <DataGridTextColumn Header="SKU"
                                    Binding="{Binding Sku}" Width="110"/>
                                <DataGridTextColumn Header="Fiyat"
                                    Binding="{Binding CurrentPrice, StringFormat='{}{0:N2} ₺'}"
                                    Width="90"/>
                                <DataGridTextColumn Header="Stok"
                                    Binding="{Binding CurrentStock}" Width="60"/>
                                <DataGridTemplateColumn Header="Skor" Width="90"
                                    SortMemberPath="ReliabilityScore">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10"
                                                    Background="{Binding ReliabilityScore,
                                                                 Converter={StaticResource ScoreBg}}"
                                                    Padding="5,2">
                                                <TextBlock
                                                    Text="{Binding ReliabilityScore,
                                                           Converter={StaticResource ScoreLabel}}"
                                                    FontWeight="Bold" FontSize="11"
                                                    Foreground="{Binding ReliabilityScore,
                                                                 Converter={StaticResource ScoreColor}}"
                                                    HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="TxtSelectedCount"
                                   Text="0 ürün seçildi"
                                   Foreground="#64748b" FontSize="12"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ADIM 2: Platform + Fiyat -->
                <Border x:Name="Panel2" Visibility="Collapsed"
                        Background="White" CornerRadius="8" Padding="16"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <!-- Platform Seçimi -->
                        <TextBlock Text="Hedef Platform(lar)"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#1e293b" Margin="0,0,0,12"/>

                        <ItemsControl x:Name="PlatformList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="135" Height="80" Margin="4"
                                            CornerRadius="8" Cursor="Hand"
                                            BorderThickness="2"
                                            BorderBrush="{Binding BorderColor}"
                                            Background="{Binding BackgroundColor}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                Command="{Binding ToggleCommand}"/>
                                        </Border.InputBindings>
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="22"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#64748b"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Fiyat Markup -->
                        <Separator Margin="0,16"/>
                        <TextBlock Text="Fiyat Markup Kuralı"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#1e293b" Margin="0,0,0,12"/>

                        <Border Background="#f8fafc" CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="Yöntem:" VerticalAlignment="Center"
                                           Foreground="#64748b" Margin="0,0,8,0"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          x:Name="CmbMarkupMethod"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          SelectionChanged="CmbMarkupMethod_SelectionChanged">
                                    <ComboBoxItem Content="Yüzde (%)" Tag="percent" IsSelected="True"/>
                                    <ComboBoxItem Content="Sabit Tutar (₺)" Tag="fixed"/>
                                    <ComboBoxItem Content="Markup yok" Tag="none"/>
                                </ComboBox>

                                <TextBlock Grid.Row="0" Grid.Column="2"
                                           x:Name="TxtMarkupValueLabel"
                                           Text="   Oran (%):" VerticalAlignment="Center"
                                           Foreground="#64748b"/>
                                <TextBox Grid.Row="0" Grid.Column="3"
                                         x:Name="TxtMarkupValue" Text="15"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         TextChanged="TxtMarkupValue_TextChanged"/>

                                <TextBlock Grid.Row="2" Grid.ColumnSpan="5"
                                           x:Name="TxtMarkupPreview"
                                           Text="Örnek: 100 ₺ → 115.00 ₺"
                                           Foreground="#64748b" FontSize="11"
                                           Margin="0,4,0,0"/>
                            </Grid>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <CheckBox x:Name="ChkKdv" IsChecked="True"
                                      Content="KDV dahil fiyat kullan"
                                      Style="{StaticResource MaterialDesignCheckBox}"
                                      Margin="0,0,16,0"/>
                            <CheckBox x:Name="ChkHideSupplier" IsChecked="True"
                                      Content="Tedarikçi bilgisini gizle"
                                      Style="{StaticResource MaterialDesignCheckBox}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ADIM 3: Özet + Gönder -->
                <Border x:Name="Panel3" Visibility="Collapsed"
                        Background="White" CornerRadius="8" Padding="16"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <StackPanel>
                        <TextBlock Text="İhracat Özeti"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#1e293b" Margin="0,0,0,12"/>

                        <!-- Özet satırları -->
                        <Border Background="#f8fafc" CornerRadius="6" Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Seçilen Ürün:"
                                               Foreground="#64748b" Width="150"/>
                                    <TextBlock x:Name="SumProducts" FontWeight="SemiBold"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Hedef Platform(lar):"
                                               Foreground="#64748b" Width="150"/>
                                    <TextBlock x:Name="SumPlatforms" FontWeight="SemiBold"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="Markup:" Foreground="#64748b" Width="150"/>
                                    <TextBlock x:Name="SumMarkup" FontWeight="SemiBold"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="KDV:" Foreground="#64748b" Width="150"/>
                                    <TextBlock x:Name="SumKdv" FontWeight="SemiBold"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Aksiyon butonları -->
                        <TextBlock Text="Aksiyonu Seçin:"
                                   FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Button x:Name="BtnSendToPlatform"
                                Content="Platforma Gönder"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#2855AC" Foreground="White"
                                HorizontalAlignment="Left" Margin="0,0,0,8"
                                Click="BtnSendToPlatform_Click"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Dosya olarak indir: "
                                       VerticalAlignment="Center"
                                       Foreground="#64748b" FontSize="12"
                                       Margin="0,0,8,0"/>
                            <Button x:Name="BtnDownloadXml"
                                    Content="XML"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#f97316" BorderBrush="#f97316"
                                    Margin="0,0,6,0" Click="BtnDownloadXml_Click"/>
                            <Button x:Name="BtnDownloadCsv"
                                    Content="CSV"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#10b981" BorderBrush="#10b981"
                                    Margin="0,0,6,0" Click="BtnDownloadCsv_Click"/>
                            <Button x:Name="BtnDownloadExcel"
                                    Content="Excel"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#1d6f42" BorderBrush="#1d6f42"
                                    Click="BtnDownloadExcel_Click"/>
                        </StackPanel>

                        <!-- İlerleme -->
                        <Border x:Name="ProgressSection" Visibility="Collapsed"
                                Background="#f0f7ff" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock x:Name="TxtProgressMsg"
                                               FontWeight="SemiBold"
                                               Foreground="#2855AC"/>
                                    <TextBlock x:Name="TxtProgressPct"
                                               DockPanel.Dock="Right"
                                               FontWeight="Bold"
                                               Foreground="#2855AC"/>
                                </DockPanel>
                                <ProgressBar x:Name="ExportProgress" Value="0" Maximum="100"
                                             Height="8"
                                             Style="{StaticResource MaterialDesignLinearProgressBar}"
                                             Foreground="#2855AC"/>
                                <TextBlock x:Name="TxtProgressDetail"
                                           FontSize="11" Foreground="#64748b"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- ── Alt Navigasyon ── -->
        <Border Grid.Row="3" Background="#f8fafc"
                BorderBrush="#e2e8f0" BorderThickness="0,1,0,0" Padding="16,8">
            <DockPanel>
                <Button x:Name="BtnBack" Content="&#x2190; Geri"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        IsEnabled="False" Click="BtnBack_Click"/>
                <Button x:Name="BtnNext"
                        Content="Devam &#x2192;"
                        DockPanel.Dock="Right"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#2855AC" Foreground="White"
                        Click="BtnNext_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
