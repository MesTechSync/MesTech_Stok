<UserControl x:Class="MesTechStok.Desktop.Views.Dropshipping.DropshippingPoolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:MesTechStok.Desktop.Converters">

    <UserControl.Resources>
        <conv:ReliabilityColorConverter x:Key="ScoreColor" ConvertMode="Foreground"/>
        <conv:ReliabilityColorConverter x:Key="ScoreBg"    ConvertMode="Background"/>
        <conv:ReliabilityLabelConverter x:Key="ScoreLabel"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2855AC" Padding="16,10">
            <DockPanel>
                <md:PackIcon Kind="LayersTriple" Foreground="White"
                             Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="Ürün Havuzu" Foreground="White"
                           FontSize="15" FontWeight="SemiBold"
                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <TextBox x:Name="TxtSearch" Width="200" Margin="0,0,8,0"
                             md:HintAssist.Hint="Ürün adı, SKU..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Foreground="White" BorderBrush="White"
                             TextChanged="TxtSearch_TextChanged"/>
                    <Button x:Name="BtnRefresh" Content="&#x21BB; Yenile"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="White" BorderBrush="White"
                            Click="BtnRefresh_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Filtre Chip'leri -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    Margin="16,8,16,4" Background="Transparent">
            <Button x:Name="BtnAll"    Content="Tümü"
                    Tag="ALL"   Click="FilterChip_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,4,0"/>
            <Button x:Name="BtnGreen"  Content="Yeşil"
                    Tag="GREEN"  Click="FilterChip_Click"
                    Foreground="#065f46" Margin="0,0,4,0"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
            <Button x:Name="BtnYellow" Content="Sarı"
                    Tag="YELLOW" Click="FilterChip_Click"
                    Foreground="#92400e" Margin="0,0,4,0"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
            <Button x:Name="BtnOrange" Content="Turuncu"
                    Tag="ORANGE" Click="FilterChip_Click"
                    Foreground="#9a3412" Margin="0,0,4,0"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
            <Button x:Name="BtnRed"    Content="Kırmızı"
                    Tag="RED"    Click="FilterChip_Click"
                    Foreground="#991b1b"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
            <Separator Margin="8,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
            <Button x:Name="BtnBulkExport" Content="Seçilenleri Gönder"
                    IsEnabled="False" Click="BtnBulkExport_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="#2855AC"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  x:Name="PoolGrid"
                  Margin="16,0,16,0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionChanged="PoolGrid_SelectionChanged"
                  MouseRightButtonUp="PoolGrid_RightClick"
                  Style="{StaticResource MaterialDesignDataGrid}">

            <DataGrid.ContextMenu>
                <ContextMenu x:Name="PoolContextMenu">
                    <MenuItem Header="Stoğuma Çek"      Click="CtxPull_Click"/>
                    <MenuItem Header="Platforma Gönder" Click="CtxExport_Click"/>
                    <MenuItem Header="Tedarikçi Profili" Click="CtxSupplier_Click"/>
                    <Separator/>
                    <MenuItem Header="Havuzdan Kaldır"
                              Foreground="#ef4444" Click="CtxRemove_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow"
                       BasedOn="{StaticResource MaterialDesignDataGridRow}">
                    <Setter Property="BorderThickness" Value="3,0,0,0"/>
                    <Setter Property="BorderBrush"
                            Value="{Binding ReliabilityScore,
                                   Converter={StaticResource ScoreColor}}"/>
                    <Setter Property="ToolTip"
                            Value="{Binding ReliabilityTooltip}"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Ürün Adı"
                                    Binding="{Binding ProductName}"
                                    Width="*"
                                    MinWidth="150"/>
                <DataGridTextColumn Header="SKU"
                                    Binding="{Binding Sku}"
                                    Width="110"/>
                <DataGridTextColumn Header="Fiyat"
                                    Binding="{Binding CurrentPrice, StringFormat='{}{0:N2} ₺'}"
                                    Width="90"/>
                <DataGridTextColumn Header="Stok"
                                    Binding="{Binding CurrentStock}"
                                    Width="60"/>
                <DataGridTemplateColumn Header="Skor" Width="90" SortMemberPath="ReliabilityScore">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10"
                                    Background="{Binding ReliabilityScore,
                                                 Converter={StaticResource ScoreBg}}"
                                    Padding="6,2" HorizontalAlignment="Center">
                                <TextBlock
                                    Text="{Binding ReliabilityScore,
                                           Converter={StaticResource ScoreLabel}}"
                                    FontWeight="Bold" FontSize="11"
                                    Foreground="{Binding ReliabilityScore,
                                                 Converter={StaticResource ScoreColor}}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Tedarikçi"
                                    Binding="{Binding SupplierName}"
                                    Width="110"/>
                <DataGridTemplateColumn Header="" Width="60" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Çek" FontSize="11"
                                    Padding="6,2"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Click="BtnPull_Click"
                                    Tag="{Binding Id}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Alt Bar -->
        <Border Grid.Row="3" Background="#f8fafc"
                BorderBrush="#e2e8f0" BorderThickness="0,1,0,0">
            <DockPanel Margin="16,8">
                <TextBlock x:Name="TxtPageInfo"
                           Text="— ürün gösteriliyor"
                           VerticalAlignment="Center"
                           Foreground="#64748b" FontSize="12"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="BtnPrev" Content="Önceki"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            IsEnabled="False" Click="BtnPrev_Click"/>
                    <TextBlock x:Name="TxtPage" Text="Sayfa 1"
                               VerticalAlignment="Center" Margin="8,0"
                               Foreground="#64748b" FontSize="12"/>
                    <Button x:Name="BtnNext" Content="Sonraki"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="BtnNext_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
