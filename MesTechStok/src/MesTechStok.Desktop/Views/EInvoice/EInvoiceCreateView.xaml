<UserControl x:Class="MesTechStok.Desktop.Views.EInvoice.EInvoiceCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

  <UserControl.Resources>

    <!-- Converters -->
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- Card container -->
    <Style x:Key="SectionCard" TargetType="Border">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="#E9ECEF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="20"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Section heading -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#2C3E50"/>
      <Setter Property="Margin" Value="0,0,0,14"/>
    </Style>

    <!-- Field label -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#495057"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- Standard text input -->
    <Style x:Key="FormTextBox" TargetType="TextBox"
           BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Margin" Value="0,0,0,12"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- Standard combo -->
    <Style x:Key="FormComboBox" TargetType="ComboBox"
           BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Margin" Value="0,0,0,12"/>
      <Setter Property="Height" Value="36"/>
    </Style>

    <!-- Read-only total row -->
    <Style x:Key="TotalLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#6C757D"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TotalValue" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#2C3E50"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <!-- Action button styles -->
    <Style x:Key="PrimaryBtn" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignRaisedButton}">
      <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Padding" Value="20,0"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <Style x:Key="OutlinedBtn" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignOutlinedButton}">
      <Setter Property="Height" Value="40"/>
      <Setter Property="Padding" Value="20,0"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <Style x:Key="FlatBtn" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignFlatButton}">
      <Setter Property="Height" Value="40"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- DataGrid column header -->
    <Style x:Key="ColHeader" TargetType="DataGridColumnHeader"
           BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#495057"/>
    </Style>

    <!-- Status badge converters handled inline via triggers on the badge border -->
    <Style x:Key="StatusBadge" TargetType="Border">
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="8,3"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="24,20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <!-- Page header -->
        <RowDefinition Height="Auto"/>
        <!-- Section 1: Alici Bilgileri -->
        <RowDefinition Height="Auto"/>
        <!-- Section 2: Fatura Satirlari -->
        <RowDefinition Height="Auto"/>
        <!-- Section 3: Secenekler -->
        <RowDefinition Height="Auto"/>
        <!-- Bottom Button Bar -->
      </Grid.RowDefinitions>

      <!-- ═══════════════════════════════════════════
           PAGE HEADER
      ═══════════════════════════════════════════ -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
        <materialDesign:PackIcon Kind="FileDocumentOutline"
                                 Width="28" Height="28"
                                 Foreground="{DynamicResource PrimaryHueMidBrush}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"/>
        <StackPanel>
          <TextBlock Text="Yeni e-Fatura Oluştur"
                     FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
          <TextBlock Text="e-Fatura / e-Arşiv düzenleme formu"
                     FontSize="13" Foreground="#6C757D" Margin="0,2,0,0"/>
        </StackPanel>
      </StackPanel>

      <!-- ═══════════════════════════════════════════
           SECTION 1 — ALICI BİLGİLERİ
      ═══════════════════════════════════════════ -->
      <Border Grid.Row="1" Style="{StaticResource SectionCard}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionTitle}" Text="1. Alıcı Bilgileri"/>

          <!-- VKN / TCKN row -->
          <Grid Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
              <TextBlock Style="{StaticResource FieldLabel}" Text="VKN / TCKN *"/>
              <TextBox x:Name="TxtVkn"
                       Style="{StaticResource FormTextBox}"
                       Text="{Binding Vkn, UpdateSourceTrigger=PropertyChanged}"
                       materialDesign:HintAssist.Hint="10 veya 11 haneli numara"
                       MaxLength="11"
                       PreviewTextInput="Vkn_PreviewTextInput"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,0,12">
              <Button x:Name="BtnSorgula"
                      Style="{StaticResource OutlinedBtn}"
                      Content="Sorgula"
                      Margin="0"
                      Command="{Binding SorgulaCommand}"
                      ToolTip="GIB'den mükellef bilgilerini sorgula"/>
            </StackPanel>
          </Grid>

          <!-- Mükellefiyet durumu badge -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Style="{StaticResource FieldLabel}"
                       Text="Mükellefiyet Durumu:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <!-- e-Fatura Mukellef -->
            <Border Style="{StaticResource StatusBadge}"
                    Visibility="{Binding IsEFaturaMukellef, Converter={StaticResource BoolToVis}}">
              <Border.Background>
                <SolidColorBrush Color="#D4EDDA"/>
              </Border.Background>
              <TextBlock Text="e-Fatura Mükellefi"
                         Foreground="#155724" FontSize="12" FontWeight="SemiBold"/>
            </Border>
            <!-- e-Arsiv -->
            <Border Style="{StaticResource StatusBadge}"
                    Visibility="{Binding IsEArsiv, Converter={StaticResource BoolToVis}}"
                    Margin="4,0,0,0">
              <Border.Background>
                <SolidColorBrush Color="#CCE5FF"/>
              </Border.Background>
              <TextBlock Text="e-Arşiv"
                         Foreground="#004085" FontSize="12" FontWeight="SemiBold"/>
            </Border>
            <!-- Değil -->
            <Border Style="{StaticResource StatusBadge}"
                    Visibility="{Binding IsNotRegistered, Converter={StaticResource BoolToVis}}"
                    Margin="4,0,0,0">
              <Border.Background>
                <SolidColorBrush Color="#F8D7DA"/>
              </Border.Background>
              <TextBlock Text="Kayıtlı Değil"
                         Foreground="#721C24" FontSize="12" FontWeight="SemiBold"/>
            </Border>
          </StackPanel>

          <!-- Alici Unvani -->
          <TextBlock Style="{StaticResource FieldLabel}" Text="Alıcı Ünvanı *"/>
          <TextBox Style="{StaticResource FormTextBox}"
                   Text="{Binding AliciUnvani, UpdateSourceTrigger=PropertyChanged}"
                   materialDesign:HintAssist.Hint="GIB sorgusundan otomatik dolar veya elle girin"/>

          <!-- E-posta -->
          <TextBlock Style="{StaticResource FieldLabel}" Text="E-posta (isteğe bağlı)"/>
          <TextBox Style="{StaticResource FormTextBox}"
                   Text="{Binding Eposta, UpdateSourceTrigger=PropertyChanged}"
                   materialDesign:HintAssist.Hint="ornek@firma.com"/>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════
           SECTION 2 — FATURA SATIRLARI
      ═══════════════════════════════════════════ -->
      <Border Grid.Row="2" Style="{StaticResource SectionCard}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionTitle}" Text="2. Fatura Satırları"/>

          <!-- Satir action buttons -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="+ Satır Ekle"
                    Style="{StaticResource OutlinedBtn}"
                    Margin="0"
                    Command="{Binding SatirEkleCommand}"
                    ToolTip="Yeni fatura satırı ekle"/>
            <Button Content="Satır Sil"
                    Style="{StaticResource FlatBtn}"
                    Foreground="#DC3545"
                    Margin="8,0,0,0"
                    Command="{Binding SatirSilCommand}"
                    CommandParameter="{Binding ElementName=InvoiceLinesGrid, Path=SelectedItem}"
                    ToolTip="Seçili satırı sil"/>
          </StackPanel>

          <!-- Invoice Lines DataGrid -->
          <DataGrid x:Name="InvoiceLinesGrid"
                    ItemsSource="{Binding InvoiceLines}"
                    SelectedItem="{Binding SelectedLine}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeRows="False"
                    HeadersVisibility="Column"
                    SelectionMode="Single"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="#F0F0F0"
                    BorderThickness="1"
                    BorderBrush="#E9ECEF"
                    Background="White"
                    RowBackground="White"
                    AlternatingRowBackground="#FAFAFA"
                    MinHeight="120"
                    MaxHeight="360"
                    Style="{StaticResource MaterialDesignDataGrid}"
                    ColumnHeaderStyle="{StaticResource ColHeader}"
                    materialDesign:DataGridAssist.CellPadding="8 4 8 4"
                    materialDesign:DataGridAssist.ColumnHeaderPadding="8 6 8 6">
            <DataGrid.Columns>

              <!-- Aciklama -->
              <DataGridTextColumn Header="Açıklama"
                                  Binding="{Binding Aciklama, UpdateSourceTrigger=PropertyChanged}"
                                  Width="*"
                                  MinWidth="180">
                <DataGridTextColumn.EditingElementStyle>
                  <Style TargetType="TextBox">
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="FontSize" Value="13"/>
                  </Style>
                </DataGridTextColumn.EditingElementStyle>
              </DataGridTextColumn>

              <!-- Miktar -->
              <DataGridTextColumn Header="Miktar"
                                  Binding="{Binding Miktar, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                  Width="80">
                <DataGridTextColumn.EditingElementStyle>
                  <Style TargetType="TextBox">
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="TextAlignment" Value="Right"/>
                  </Style>
                </DataGridTextColumn.EditingElementStyle>
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Right"/>
                    <Setter Property="Padding" Value="4,2"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- Birim ComboBox -->
              <DataGridTemplateColumn Header="Birim" Width="80">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Birim}" Padding="4,2" FontSize="13"
                               VerticalAlignment="Center"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                  <DataTemplate>
                    <ComboBox SelectedItem="{Binding Birim, UpdateSourceTrigger=PropertyChanged}"
                              FontSize="13"
                              BorderThickness="0">
                      <ComboBoxItem Content="Adet"/>
                      <ComboBoxItem Content="Kg"/>
                      <ComboBoxItem Content="Lt"/>
                      <ComboBoxItem Content="M"/>
                    </ComboBox>
                  </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
              </DataGridTemplateColumn>

              <!-- Birim Fiyat -->
              <DataGridTextColumn Header="Birim Fiyat"
                                  Binding="{Binding BirimFiyat, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                  Width="100">
                <DataGridTextColumn.EditingElementStyle>
                  <Style TargetType="TextBox">
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="TextAlignment" Value="Right"/>
                  </Style>
                </DataGridTextColumn.EditingElementStyle>
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Right"/>
                    <Setter Property="Padding" Value="4,2"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- KDV % ComboBox -->
              <DataGridTemplateColumn Header="KDV %" Width="75">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding KdvOrani, StringFormat='{}{0}%'}"
                               Padding="4,2" FontSize="13"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
                <DataGridTemplateColumn.CellEditingTemplate>
                  <DataTemplate>
                    <ComboBox SelectedItem="{Binding KdvOrani, UpdateSourceTrigger=PropertyChanged}"
                              FontSize="13" BorderThickness="0"
                              HorizontalAlignment="Right">
                      <ComboBoxItem Content="0"/>
                      <ComboBoxItem Content="1"/>
                      <ComboBoxItem Content="8"/>
                      <ComboBoxItem Content="10"/>
                      <ComboBoxItem Content="18"/>
                      <ComboBoxItem Content="20"/>
                    </ComboBox>
                  </DataTemplate>
                </DataGridTemplateColumn.CellEditingTemplate>
              </DataGridTemplateColumn>

              <!-- İskonto -->
              <DataGridTextColumn Header="İskonto %"
                                  Binding="{Binding IskontoOrani, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                  Width="85">
                <DataGridTextColumn.EditingElementStyle>
                  <Style TargetType="TextBox">
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="TextAlignment" Value="Right"/>
                  </Style>
                </DataGridTextColumn.EditingElementStyle>
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Right"/>
                    <Setter Property="Padding" Value="4,2"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

              <!-- Tutar (read-only) -->
              <DataGridTextColumn Header="Tutar"
                                  Binding="{Binding Tutar, Mode=OneWay, StringFormat=N2}"
                                  Width="110"
                                  IsReadOnly="True">
                <DataGridTextColumn.ElementStyle>
                  <Style TargetType="TextBlock">
                    <Setter Property="TextAlignment" Value="Right"/>
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                  </Style>
                </DataGridTextColumn.ElementStyle>
              </DataGridTextColumn>

            </DataGrid.Columns>
          </DataGrid>

          <!-- Totals panel -->
          <Border BorderBrush="#E9ECEF" BorderThickness="0,1,0,0" Margin="0,16,0,0" Padding="0,12,0,0">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="1">
                <!-- KDV Haric -->
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource TotalLabel}"
                             Text="KDV Hariç Toplam:"/>
                  <TextBlock Grid.Column="1" Style="{StaticResource TotalValue}"
                             Text="{Binding KdvHaricToplam, StringFormat='{}{0:N2} ₺'}"/>
                </Grid>
                <!-- KDV Tutari -->
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Style="{StaticResource TotalLabel}"
                             Text="KDV Tutarı:"/>
                  <TextBlock Grid.Column="1" Style="{StaticResource TotalValue}"
                             Text="{Binding KdvTutari, StringFormat='{}{0:N2} ₺'}"/>
                </Grid>
                <!-- Separator -->
                <Separator Margin="0,4,0,8" Background="#E9ECEF"/>
                <!-- Genel Toplam -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0"
                             FontSize="14" FontWeight="Bold" Foreground="#2C3E50"
                             Text="Genel Toplam:" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1"
                             FontSize="16" FontWeight="Bold"
                             Foreground="{DynamicResource PrimaryHueMidBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"
                             Text="{Binding GenelToplam, StringFormat='{}{0:N2} ₺'}"/>
                </Grid>
              </StackPanel>
            </Grid>
          </Border>

        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════
           SECTION 3 — SEÇENEKLER
      ═══════════════════════════════════════════ -->
      <Border Grid.Row="3" Style="{StaticResource SectionCard}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionTitle}" Text="3. Fatura Seçenekleri"/>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: Senaryo + Tip -->
            <StackPanel Grid.Column="0">
              <TextBlock Style="{StaticResource FieldLabel}" Text="Senaryo *"/>
              <ComboBox Style="{StaticResource FormComboBox}"
                        SelectedItem="{Binding Senaryo, UpdateSourceTrigger=PropertyChanged}"
                        materialDesign:HintAssist.Hint="Senaryo seçin">
                <ComboBoxItem Content="TEMELFATURA"/>
                <ComboBoxItem Content="TICARIFATURA"/>
              </ComboBox>

              <TextBlock Style="{StaticResource FieldLabel}" Text="Fatura Tipi *"/>
              <ComboBox Style="{StaticResource FormComboBox}"
                        SelectedItem="{Binding FaturaTipi, UpdateSourceTrigger=PropertyChanged}"
                        materialDesign:HintAssist.Hint="Tip seçin">
                <ComboBoxItem Content="SATIS"/>
                <ComboBoxItem Content="IADE"/>
                <ComboBoxItem Content="TEVKIFAT"/>
              </ComboBox>
            </StackPanel>

            <!-- Divider -->
            <Separator Grid.Column="1" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                       Width="1" HorizontalAlignment="Center"/>

            <!-- Column 2: Entegratör + Para Birimi -->
            <StackPanel Grid.Column="2">
              <TextBlock Style="{StaticResource FieldLabel}" Text="Entegratör *"/>
              <ComboBox Style="{StaticResource FormComboBox}"
                        SelectedItem="{Binding Entegrator, UpdateSourceTrigger=PropertyChanged}"
                        materialDesign:HintAssist.Hint="Entegratör seçin">
                <ComboBoxItem Content="Sovos"/>
                <ComboBoxItem Content="GIB Portal"/>
              </ComboBox>

              <TextBlock Style="{StaticResource FieldLabel}" Text="Para Birimi"/>
              <ComboBox Style="{StaticResource FormComboBox}"
                        SelectedItem="{Binding ParaBirimi, UpdateSourceTrigger=PropertyChanged}"
                        materialDesign:HintAssist.Hint="Para birimi">
                <ComboBoxItem Content="TRY"/>
                <ComboBoxItem Content="USD"/>
                <ComboBoxItem Content="EUR"/>
              </ComboBox>
            </StackPanel>

            <!-- Divider -->
            <Separator Grid.Column="3" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                       Width="1" HorizontalAlignment="Center"/>

            <!-- Column 3: Düzenleme Tarihi -->
            <StackPanel Grid.Column="4">
              <TextBlock Style="{StaticResource FieldLabel}" Text="Düzenleme Tarihi *"/>
              <DatePicker x:Name="DpDuzenleme"
                          SelectedDate="{Binding DuzenlenmeTarihi}"
                          FontSize="13"
                          Margin="0,0,0,12"
                          Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                          materialDesign:HintAssist.Hint="gg.aa.yyyy"/>
            </StackPanel>

          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════════
           BOTTOM BUTTON BAR
      ═══════════════════════════════════════════ -->
      <Border Grid.Row="4"
              Background="White"
              BorderBrush="#E9ECEF"
              BorderThickness="0,1,0,0"
              Padding="0,16,0,4">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Left: Cancel -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Content="İptal"
                    Style="{StaticResource FlatBtn}"
                    Command="{Binding IptalCommand}"
                    ToolTip="Formu kapat, değişiklikleri kaydetme"/>
          </StackPanel>

          <!-- Right: Save Draft + Send -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Content="Taslak Kaydet"
                    Style="{StaticResource OutlinedBtn}"
                    Command="{Binding TaslakKaydetCommand}"
                    ToolTip="Faturayı taslak olarak kaydet, göndermeden sakla"/>
            <Button Content="Gönder"
                    Style="{StaticResource PrimaryBtn}"
                    Command="{Binding GonderCommand}"
                    ToolTip="Faturayı entegratör üzerinden GIB'e gönder"/>
          </StackPanel>
        </Grid>
      </Border>

    </Grid>
  </ScrollViewer>

</UserControl>
