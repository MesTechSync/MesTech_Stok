<UserControl x:Class="MesTechStok.Desktop.Views.Crm.PlatformMessagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Bar -->
        <Border Grid.Row="0" Background="{DynamicResource MesTechPrimary}" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Platform Mesajlari" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} mesaj'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Yenile" Command="{Binding RefreshCommand}"
                        Background="White" Foreground="{DynamicResource MesTechPrimary}" FontWeight="SemiBold"
                        Padding="16,8" BorderThickness="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </Grid>
        </Border>

        <!-- Filter Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <ComboBox Width="160" md:HintAssist.Hint="Platform"
                          ItemsSource="{Binding PlatformOptions}"
                          SelectedItem="{Binding SelectedPlatform}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,12,0"/>
                <ComboBox Width="140" md:HintAssist.Hint="Durum"
                          ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,12,0"/>
                <TextBox Width="220" md:HintAssist.Hint="Gonderici veya konu ara..."
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            </StackPanel>
        </Border>

        <!-- Master-Detail Layout -->
        <Grid Grid.Row="2" Background="#F4F6F9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Message List -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E5E9F2" BorderThickness="0,0,1,0">
                <ListBox ItemsSource="{Binding Messages}"
                         SelectedItem="{Binding SelectedMessage}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Platform Badge -->
                                <Border Grid.Column="0" Grid.RowSpan="3"
                                        Width="36" Height="36" CornerRadius="18"
                                        Background="{Binding PlatformColor}"
                                        Margin="0,0,10,0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding PlatformInitial}"
                                               Foreground="White" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Sender -->
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding SenderName}" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#1E293B"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Time -->
                                <TextBlock Grid.Column="2" Grid.Row="0"
                                           Text="{Binding ReceivedAtFormatted}"
                                           FontSize="10" Foreground="#94A3B8"
                                           VerticalAlignment="Center"/>

                                <!-- Subject -->
                                <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                           Text="{Binding Subject}" FontSize="12"
                                           Foreground="#475569" Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Preview + Status indicators -->
                                <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2"
                                            Orientation="Horizontal" Margin="0,4,0,0">
                                    <Border CornerRadius="8" Padding="6,2"
                                            Background="{Binding StatusColor}" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Status}" FontSize="10"
                                                   Foreground="White" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border CornerRadius="8" Padding="6,2"
                                            Background="#EEF2FF"
                                            Visibility="{Binding AiSuggestionVisibility}">
                                        <TextBlock Text="AI" FontSize="10"
                                                   Foreground="{DynamicResource MesTechPrimary}" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Right: Message Detail -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="20">
                    <!-- No Selection State -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding NoSelectionVisibility}">
                        <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bir mesaj secin" FontSize="15" Foreground="#6C757D"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>

                    <!-- Detail Panel -->
                    <StackPanel Visibility="{Binding DetailVisibility}">
                        <!-- Message Header -->
                        <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding SelectedMessage.Subject}"
                                               FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"
                                               TextWrapping="Wrap"/>
                                    <Border Grid.Column="1" CornerRadius="8" Padding="8,4"
                                            Background="{Binding SelectedMessage.PlatformColor}">
                                        <TextBlock Text="{Binding SelectedMessage.Platform}"
                                                   Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding SelectedMessage.SenderName}"
                                               FontSize="13" Foreground="#475569" FontWeight="SemiBold"/>
                                    <TextBlock Text=" — " Foreground="#94A3B8"/>
                                    <TextBlock Text="{Binding SelectedMessage.ReceivedAtFormatted}"
                                               FontSize="13" Foreground="#94A3B8"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedMessage.BodyPreview}"
                                           FontSize="13" Foreground="#334155" Margin="0,12,0,0"
                                           TextWrapping="Wrap" LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- AI Suggestion Box -->
                        <Border Background="#FFF7ED" CornerRadius="8" Padding="16" Margin="0,0,0,12"
                                BorderBrush="#FDBA74" BorderThickness="1"
                                Visibility="{Binding AiSuggestionPanelVisibility}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#F57C00" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="AI Oneri" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="MESA AI tarafindan olusturuldu" FontSize="11"
                                               Foreground="#92400E" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedMessage.AiSuggestedReply}"
                                           FontSize="13" Foreground="#78350F" TextWrapping="Wrap"
                                           LineHeight="20" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Kullan" Padding="12,6" Margin="0,0,8,0"
                                            Background="#F57C00" Foreground="White" BorderThickness="0"
                                            Command="{Binding UseAiSuggestionCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                                    <Button Content="Duzenle" Padding="12,6" Margin="0,0,8,0"
                                            Background="Transparent" Foreground="#F57C00"
                                            BorderBrush="#F57C00" BorderThickness="1"
                                            Command="{Binding EditAiSuggestionCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                    <Button Content="Yoksay" Padding="12,6"
                                            Background="Transparent" Foreground="#94A3B8"
                                            BorderBrush="#D1D5DB" BorderThickness="1"
                                            Command="{Binding IgnoreAiSuggestionCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Reply Form -->
                        <Border Background="White" CornerRadius="8" Padding="16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Yanit Yaz" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#1E293B" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding ReplyText, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="100" AcceptsReturn="True" TextWrapping="Wrap"
                                         md:HintAssist.Hint="Yanitinizi buraya yazin..."
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Gonder" Padding="20,8"
                                            Background="{DynamicResource MesTechPrimary}" Foreground="White"
                                            BorderThickness="0" FontWeight="SemiBold"
                                            Command="{Binding SendReplyCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource MesTechPrimary}"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.RowSpan="3" Background="White" Visibility="Collapsed" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Platform mesaji bulunamadi" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Henuz platform mesaji yok" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="3" Background="White" Visibility="Collapsed" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#F44336" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="14" Foreground="#F44336" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap" MaxWidth="400"/>
                <Button x:Name="RetryButton" Content="Tekrar Dene" Margin="0,12,0,0" Padding="16,8" Background="{DynamicResource MesTechPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand" Click="RetryButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
