<UserControl x:Class="MesTechStok.Desktop.Views.Crm.LeadsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Başlık Bar -->
        <Border Grid.Row="0" Background="{DynamicResource MesTechPrimary}" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Potansiyel Müşteriler" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#FFFFFF22" CornerRadius="10" Padding="8,2" Margin="12,0,0,0">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} kayıt'}"
                                   Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Lead" Command="{Binding CreateLeadCommand}"
                        Background="White" Foreground="{DynamicResource MesTechPrimary}" FontWeight="SemiBold"
                        Padding="16,8" BorderThickness="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </Grid>
        </Border>

        <!-- Filtre Bar -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E5E9F2" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="220" md:HintAssist.Hint="İsim, e-posta veya telefon ara..."
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,12,0"/>
                <ComboBox Width="140" md:HintAssist.Hint="Durum"
                          ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding SelectedStatus}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,12,0"/>
                <ComboBox Width="160" md:HintAssist.Hint="Kaynak"
                          ItemsSource="{Binding SourceOptions}"
                          SelectedItem="{Binding SelectedSource}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
            </StackPanel>
        </Border>

        <!-- Lead Listesi -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Leads}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="48"
                  BorderThickness="0"
                  Background="White">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Ad Soyad" Binding="{Binding FullName}" Width="180"/>
                <DataGridTextColumn Header="Şirket" Binding="{Binding Company}" Width="150"/>
                <DataGridTextColumn Header="E-posta" Binding="{Binding Email}" Width="200"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="130"/>

                <DataGridTemplateColumn Header="Durum" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,3" Background="{DynamicResource MesTechPrimary}">
                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Kaynak" Binding="{Binding Source}" Width="110"/>
                <DataGridTextColumn Header="Tarih" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy}" Width="100"/>

                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Detay" FontSize="11" Padding="8,3"
                                    Command="{Binding DataContext.OpenDetailCommand,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Id}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource MesTechPrimary}"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.RowSpan="3" Background="White" Visibility="Collapsed" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="CRM kaydi bulunamadi" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Henuz potansiyel musteri eklenmemis" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="3" Background="White" Visibility="Collapsed" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#F44336" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="14" Foreground="#F44336" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap" MaxWidth="400"/>
                <Button x:Name="RetryButton" Content="Tekrar Dene" Margin="0,12,0,0" Padding="16,8" Background="{DynamicResource MesTechPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand" Click="RetryButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
