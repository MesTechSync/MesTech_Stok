<UserControl x:Class="MesTechStok.Desktop.Views.Accounting.GelirGiderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource MesTechPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e3f80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#DC3545"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: SMMM Disclaimer -->
        <Border Grid.Row="0" Background="#FFF3CD" CornerRadius="4" Padding="10" Margin="8,8,8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x26A0;" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#856404" FontSize="14"/>
                <TextBlock TextWrapping="Wrap" Foreground="#856404">
                    <Run FontWeight="Bold">On Muhasebe Verisi</Run>
                    <Run> — Kesin beyanname ve resmi mali kayitlar SMMM tarafindan hazirlanmalidir.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Row 1: Header -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="8,8,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Gelir / Gider" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                    <TextBlock Text="Gelir ve gider kayitlarinin yonetimi" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <DatePicker x:Name="DateFrom" Width="120" Margin="0,0,4,0"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker x:Name="DateTo" Width="120" Margin="0,0,8,0"/>
                    <Button Content="Filtrele" Style="{StaticResource ActionBtn}" Click="ApplyFilter_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Summary Cards -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12" Margin="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Gelir" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalIncomeText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Gider" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalExpenseText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Net" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="NetText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 3: Split — Form + DataGrid -->
        <Grid Grid.Row="3" Margin="8,4,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Entry Form -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Yeni Kayit" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,8"/>

                    <TextBlock Text="Baslik" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="EntryTitle" Padding="8,6" FontSize="12"/>

                    <TextBlock Text="Tutar (TL)" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="EntryAmount" Padding="8,6" FontSize="12"/>

                    <TextBlock Text="Kategori" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="EntryCategory" SelectedIndex="0" FontSize="12">
                        <ComboBoxItem Content="Marketplace Satis"/>
                        <ComboBoxItem Content="Direkt Satis"/>
                        <ComboBoxItem Content="Kira"/>
                        <ComboBoxItem Content="Lojistik"/>
                        <ComboBoxItem Content="Komisyon"/>
                        <ComboBoxItem Content="Insan Kaynaklari"/>
                        <ComboBoxItem Content="Diger"/>
                    </ComboBox>

                    <TextBlock Text="Tarih" Style="{StaticResource FormLabel}"/>
                    <DatePicker x:Name="EntryDate" FontSize="12"/>

                    <TextBlock Text="Kaynak" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="EntrySource" SelectedIndex="0" FontSize="12">
                        <ComboBoxItem Content="Trendyol"/>
                        <ComboBoxItem Content="Hepsiburada"/>
                        <ComboBoxItem Content="N11"/>
                        <ComboBoxItem Content="OpenCart"/>
                        <ComboBoxItem Content="Manuel"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="Gelir Ekle" Style="{StaticResource SuccessBtn}" Click="AddIncome_Click" Margin="0,0,8,0"/>
                        <Button Content="Gider Ekle" Style="{StaticResource DangerBtn}" Click="AddExpense_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Right: DataGrid -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="12" Padding="16">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Kayitlar" FontSize="16" FontWeight="Bold" Foreground="#212529" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Content="Sil" Style="{StaticResource DangerBtn}" Click="DeleteEntry_Click"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" x:Name="EntriesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" SelectionMode="Single"
                              AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" FontSize="12" RowHeight="34" ColumnHeaderHeight="36">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Tur" Binding="{Binding EntryType}" Width="70"/>
                            <DataGridTextColumn Header="Baslik" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="130"/>
                            <DataGridTextColumn Header="Kaynak" Binding="{Binding Source}" Width="100"/>
                            <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat='{}{0:N2} TL'}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="4" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource MesTechPrimary}"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="3" Visibility="Collapsed" Background="White" CornerRadius="12" Margin="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Gelir/gider kaydi yok" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Sol panelden yeni kayit ekleyebilirsiniz" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="4" Visibility="Collapsed" Background="White" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#DC3545" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="Tekrar Dene" Click="RetryButton_Click" Margin="0,12,0,0" Padding="16,8" Background="{DynamicResource MesTechPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
