<UserControl x:Class="MesTechStok.Desktop.Views.Accounting.BankaHesaplariView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2855AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e3f80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="8,8,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Banka Hesaplari" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                    <TextBlock Text="Banka hesaplari ve islem hareketleri" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Hesap:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="#495057"/>
                    <ComboBox x:Name="AccountSelector" Width="240" SelectedIndex="0" SelectionChanged="AccountSelector_Changed">
                        <ComboBoxItem Content="Garanti BBVA - Ticari Hesap"/>
                        <ComboBoxItem Content="Is Bankasi - Vadesiz TL"/>
                    </ComboBox>
                    <Button Content="Ekstre Aktar" Style="{StaticResource SuccessBtn}" Margin="8,0,0,0" Click="ImportStatement_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Account Summary -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Hesap Bakiyesi" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="BalanceText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#2855AC" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="IBAN" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="IbanText" Text="TR** **** **** **** **** **" FontSize="14" FontWeight="Bold" Foreground="#495057" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Bu Ay Giren" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="MonthInText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Bu Ay Cikan" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="MonthOutText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 2: Transactions DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="8,4,8,8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Hesap Hareketleri" FontSize="16" FontWeight="Bold" Foreground="#212529" VerticalAlignment="Center"/>
                </StackPanel>
                <DataGrid Grid.Row="1" x:Name="TransactionsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserSortColumns="True" SelectionMode="Single"
                          AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          BorderThickness="0" FontSize="12" RowHeight="34" ColumnHeaderHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Aciklama" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Islem Turu" Binding="{Binding TransactionType}" Width="100"/>
                        <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat='{}{0:N2} TL'}" Width="120"/>
                        <DataGridTextColumn Header="Bakiye" Binding="{Binding RunningBalance, StringFormat='{}{0:N2} TL'}" Width="120"/>
                        <DataGridCheckBoxColumn Header="Mutabik" Binding="{Binding IsReconciled}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#2855AC"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="2" Visibility="Collapsed" Background="White" CornerRadius="12" Margin="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Banka hesabi bulunamadi" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Ekstre aktararak islemleri yukleyebilirsiniz" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="3" Visibility="Collapsed" Background="White" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#DC3545" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="Tekrar Dene" Click="RetryButton_Click" Margin="0,12,0,0" Padding="16,8" Background="#2855AC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
