<UserControl x:Class="MesTechStok.Desktop.Views.Accounting.CariHesaplarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2855AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e3f80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <!-- Alternating row style -->
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="8,8,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Cari Hesaplar" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                    <TextBlock Text="Platform, musteri ve tedarikci cari hesap yonetimi" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}" Width="200" Margin="0,0,8,0"
                             TextChanged="SearchBox_TextChanged">
                        <TextBox.Tag>Ara...</TextBox.Tag>
                    </TextBox>
                    <ComboBox x:Name="FilterCombo" Width="140" Margin="0,0,8,0" SelectedIndex="0"
                              SelectionChanged="FilterCombo_SelectionChanged">
                        <ComboBoxItem Content="Tumu"/>
                        <ComboBoxItem Content="Platform"/>
                        <ComboBoxItem Content="Musteri"/>
                        <ComboBoxItem Content="Tedarikci"/>
                    </ComboBox>
                    <Button Content="Yenile" Style="{StaticResource ActionBtn}" Click="Refresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Summary Cards -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Hesap" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalAccountsText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#2855AC" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Platform Bakiye" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PlatformBalanceText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#FF6600" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Musteri Bakiye" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CustomerBalanceText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Tedarikci Bakiye" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="SupplierBalanceText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 2: TabControl -->
        <TabControl Grid.Row="2" Margin="8,4,8,8" Background="White">

            <!-- TAB 1: Platformlar -->
            <TabItem Header="  Platformlar  ">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="PlatformGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" SelectionMode="Single"
                              AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" FontSize="12" RowHeight="34" ColumnHeaderHeight="36">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Platform" Binding="{Binding AccountName}" Width="*"/>
                            <DataGridTextColumn Header="VKN/TCKN" Binding="{Binding TaxNumber}" Width="120"/>
                            <DataGridTextColumn Header="Tur" Binding="{Binding AccountType}" Width="100"/>
                            <DataGridTextColumn Header="Borc" Binding="{Binding Debt, StringFormat='{}{0:N2}'}" Width="110"/>
                            <DataGridTextColumn Header="Alacak" Binding="{Binding Credit, StringFormat='{}{0:N2}'}" Width="110"/>
                            <DataGridTextColumn Header="Bakiye" Binding="{Binding Balance, StringFormat='{}{0:N2} TL'}" Width="120"/>
                            <DataGridTextColumn Header="Son Islem" Binding="{Binding LastTransaction, StringFormat=dd.MM.yyyy}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- TAB 2: Musteriler -->
            <TabItem Header="  Musteriler  ">
                <Grid Margin="0,8,0,0">
                    <DataGrid x:Name="CustomerGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" SelectionMode="Single"
                              AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" FontSize="12" RowHeight="34" ColumnHeaderHeight="36">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Musteri Adi" Binding="{Binding AccountName}" Width="*"/>
                            <DataGridTextColumn Header="VKN/TCKN" Binding="{Binding TaxNumber}" Width="120"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Borc" Binding="{Binding Debt, StringFormat='{}{0:N2}'}" Width="110"/>
                            <DataGridTextColumn Header="Alacak" Binding="{Binding Credit, StringFormat='{}{0:N2}'}" Width="110"/>
                            <DataGridTextColumn Header="Bakiye" Binding="{Binding Balance, StringFormat='{}{0:N2} TL'}" Width="120"/>
                            <DataGridTextColumn Header="Son Islem" Binding="{Binding LastTransaction, StringFormat=dd.MM.yyyy}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- TAB 3: Tedarikciler -->
            <TabItem Header="  Tedarikciler  ">
                <Grid Margin="0,8,0,0">
                    <DataGrid x:Name="SupplierGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" SelectionMode="Single"
                              AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" FontSize="12" RowHeight="34" ColumnHeaderHeight="36">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tedarikci Adi" Binding="{Binding AccountName}" Width="*"/>
                            <DataGridTextColumn Header="VKN/TCKN" Binding="{Binding TaxNumber}" Width="120"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Borc" Binding="{Binding Debt, StringFormat='{}{0:N2}'}" Width="110"/>
                            <DataGridTextColumn Header="Alacak" Binding="{Binding Credit, StringFormat='{}{0:N2}'}" Width="110"/>
                            <DataGridTextColumn Header="Bakiye" Binding="{Binding Balance, StringFormat='{}{0:N2} TL'}" Width="120"/>
                            <DataGridTextColumn Header="Son Islem" Binding="{Binding LastTransaction, StringFormat=dd.MM.yyyy}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#2855AC"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="2" Visibility="Collapsed" Background="White" CornerRadius="12" Margin="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Cari hesap bulunamadi" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Yeni hesap eklemek icin yukaridaki butonu kullanin" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="3" Visibility="Collapsed" Background="White" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#DC3545" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="Tekrar Dene" Click="RetryButton_Click" Margin="0,12,0,0" Padding="16,8" Background="#2855AC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
