<UserControl x:Class="MesTechStok.Desktop.Views.Accounting.JournalEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2855AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e3f80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: SMMM Disclaimer -->
        <Border Grid.Row="0" Background="#FFF3CD" CornerRadius="4" Padding="10" Margin="8,8,8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x26A0;" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#856404" FontSize="14"/>
                <TextBlock TextWrapping="Wrap" Foreground="#856404">
                    <Run FontWeight="Bold">On Muhasebe Verisi</Run>
                    <Run> — Yevmiye kayitlari on muhasebe amaclidir, resmi defterler SMMM tarafindan tutulmalidir.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Row 1: Header -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="8,8,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Yevmiye Kayitlari" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                    <TextBlock Text="Muhasebe fisi giris ve yevmiye defteri goruntuleme" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Donem:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="#495057"/>
                    <ComboBox x:Name="PeriodFilter" Width="120" SelectedIndex="0" SelectionChanged="PeriodFilter_Changed">
                        <ComboBoxItem Content="Mart 2026"/>
                        <ComboBoxItem Content="Subat 2026"/>
                        <ComboBoxItem Content="Ocak 2026"/>
                    </ComboBox>
                    <Button Content="Yeni Fis" Style="{StaticResource SuccessBtn}" Click="NewEntry_Click" Margin="12,0,0,0"/>
                    <Button Content="Yenile" Style="{StaticResource ActionBtn}" Click="Refresh_Click" Margin="8,0,0,0"/>
                    <Button Content="Disa Aktar" Style="{StaticResource ActionBtn}" Click="Export_Click" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: KPI Cards -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12" Margin="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Fis" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalEntriesText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#2855AC" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Borc" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalDebitText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Alacak" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalCreditText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Bakiye Fark" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="BalanceDiffText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#FFC107" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Taslak" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="DraftCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#17A2B8" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 3: Journal Entries DataGrid -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="8,4,8,8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Yevmiye Defteri" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="JournalGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserSortColumns="True" SelectionMode="Single"
                          AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          BorderThickness="0" FontSize="12" RowHeight="34" ColumnHeaderHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fis No" Binding="{Binding VoucherNo}" Width="100"/>
                        <DataGridTextColumn Header="Tarih" Binding="{Binding EntryDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Hesap Kodu" Binding="{Binding AccountCode}" Width="110"/>
                        <DataGridTextColumn Header="Hesap Adi" Binding="{Binding AccountName}" Width="*"/>
                        <DataGridTextColumn Header="Aciklama" Binding="{Binding Description}" Width="200"/>
                        <DataGridTextColumn Header="Borc" Binding="{Binding Debit, StringFormat='{}{0:N2} TL'}" Width="120"/>
                        <DataGridTextColumn Header="Alacak" Binding="{Binding Credit, StringFormat='{}{0:N2} TL'}" Width="120"/>
                        <DataGridTextColumn Header="Kaynak" Binding="{Binding Source}" Width="100"/>
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="4" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#2855AC"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="3" Visibility="Collapsed" Background="White" CornerRadius="12" Margin="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Yevmiye kaydi bulunamadi" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Yeni fis olusturarak yevmiye kaydi girebilirsiniz" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="4" Visibility="Collapsed" Background="White" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#DC3545" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="Tekrar Dene" Click="RetryButton_Click" Margin="0,12,0,0" Padding="16,8" Background="#2855AC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
