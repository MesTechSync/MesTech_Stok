<UserControl x:Class="MesTechStok.Desktop.Views.Accounting.BelgelerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2855AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e3f80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="8,8,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Belgeler" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                    <TextBlock Text="Fatura, irsaliye ve diger belgelerin yonetimi" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox x:Name="TypeFilter" Width="140" SelectedIndex="0" SelectionChanged="TypeFilter_Changed" Margin="0,0,8,0">
                        <ComboBoxItem Content="Tum Turleri"/>
                        <ComboBoxItem Content="Fatura"/>
                        <ComboBoxItem Content="Irsaliye"/>
                        <ComboBoxItem Content="Dekont"/>
                        <ComboBoxItem Content="Sozlesme"/>
                        <ComboBoxItem Content="Diger"/>
                    </ComboBox>
                    <ComboBox x:Name="SourceFilter" Width="120" SelectedIndex="0" SelectionChanged="SourceFilter_Changed">
                        <ComboBoxItem Content="Tum Kaynaklar"/>
                        <ComboBoxItem Content="Trendyol"/>
                        <ComboBoxItem Content="Hepsiburada"/>
                        <ComboBoxItem Content="N11"/>
                        <ComboBoxItem Content="Manuel"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Drag-Drop Upload Area -->
        <Border Grid.Row="1" Margin="16,4,16,4"
                Background="#F0F4FF" BorderBrush="#2855AC" BorderThickness="2"
                CornerRadius="12" Padding="24" AllowDrop="True"
                Drop="UploadArea_Drop" DragOver="UploadArea_DragOver">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <!-- Dashed border effect via visual brush -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="#2855AC" HorizontalAlignment="Center"/>
                <TextBlock Text="Belge yuklemek icin surukleyin veya tiklayin" FontSize="14" Foreground="#2855AC" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="PDF, JPG, PNG, XLSX (maks. 10 MB)" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <Button Content="Dosya Sec" Style="{StaticResource ActionBtn}" HorizontalAlignment="Center" Margin="0,12,0,0" Click="SelectFile_Click"/>
            </StackPanel>
        </Border>

        <!-- Row 2: Split — DataGrid + Preview -->
        <Grid Grid.Row="2" Margin="8,4,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Document List -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Belge Listesi" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="1" x:Name="DocumentsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" SelectionMode="Single"
                              AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" FontSize="12" RowHeight="34" ColumnHeaderHeight="36"
                              SelectionChanged="DocumentsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dosya Adi" Binding="{Binding FileName}" Width="*"/>
                            <DataGridTextColumn Header="Tur" Binding="{Binding DocumentType}" Width="80"/>
                            <DataGridTextColumn Header="Kaynak" Binding="{Binding Source}" Width="100"/>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding UploadDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Boyut" Binding="{Binding FileSize}" Width="80"/>
                            <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right: Preview Panel -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="12" Padding="16">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Onizleme" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,8"/>
                    <Border Grid.Row="1" Background="#F8F9FA" CornerRadius="8" Padding="16">
                        <StackPanel x:Name="PreviewPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="PreviewFileName" Text="Belge seciniz" FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock x:Name="PreviewDetails" Text="" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#2855AC"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="2" Visibility="Collapsed" Background="White" CornerRadius="12" Margin="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Henuz belge yuklenmedi" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Yuklemek icin yukaridaki alani kullanin" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
