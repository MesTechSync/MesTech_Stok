<UserControl x:Class="MesTechStok.Desktop.Views.Accounting.ChartOfAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2855AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e3f80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="8,8,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Hesap Plani" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                    <TextBlock Text="Tekduzen hesap plani ve hesap kodu yonetimi" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Ara:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="#495057"/>
                    <TextBox x:Name="SearchBox" Width="180" Padding="6,4" FontSize="12" TextChanged="SearchBox_TextChanged"/>
                    <TextBlock Text="Grup:" VerticalAlignment="Center" Margin="16,0,8,0" FontSize="12" Foreground="#495057"/>
                    <ComboBox x:Name="GroupFilter" Width="140" SelectedIndex="0" SelectionChanged="GroupFilter_Changed">
                        <ComboBoxItem Content="Tumu"/>
                        <ComboBoxItem Content="1 - Donen Varliklar"/>
                        <ComboBoxItem Content="2 - Duran Varliklar"/>
                        <ComboBoxItem Content="3 - Kisa Vade Borclar"/>
                        <ComboBoxItem Content="4 - Uzun Vade Borclar"/>
                        <ComboBoxItem Content="5 - Ozkaynaklar"/>
                        <ComboBoxItem Content="6 - Gelir Tablosu"/>
                        <ComboBoxItem Content="7 - Maliyet"/>
                    </ComboBox>
                    <Button Content="Yenile" Style="{StaticResource ActionBtn}" Click="Refresh_Click" Margin="12,0,0,0"/>
                    <Button Content="Disa Aktar" Style="{StaticResource ActionBtn}" Click="Export_Click" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: KPI Cards -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Hesap" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalAccountsText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#2855AC" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Aktif Hesap" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ActiveAccountsText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Ana Grup" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="MainGroupText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#FFC107" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Alt Hesap" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="SubAccountsText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#17A2B8" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 2: Accounts DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="8,4,8,8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Hesap Listesi" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="AccountsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserSortColumns="True" SelectionMode="Single"
                          AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          BorderThickness="0" FontSize="12" RowHeight="34" ColumnHeaderHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Hesap Kodu" Binding="{Binding AccountCode}" Width="120"/>
                        <DataGridTextColumn Header="Hesap Adi" Binding="{Binding AccountName}" Width="*"/>
                        <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="160"/>
                        <DataGridTextColumn Header="Ust Hesap" Binding="{Binding ParentCode}" Width="110"/>
                        <DataGridTextColumn Header="Borc Bakiye" Binding="{Binding DebitBalance, StringFormat='{}{0:N2} TL'}" Width="130"/>
                        <DataGridTextColumn Header="Alacak Bakiye" Binding="{Binding CreditBalance, StringFormat='{}{0:N2} TL'}" Width="130"/>
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#2855AC"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="2" Visibility="Collapsed" Background="White" CornerRadius="12" Margin="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Hesap plani verisi bulunamadi" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Hesap plani tanimlandiginda burada listelenecektir" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="3" Visibility="Collapsed" Background="White" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#DC3545" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="Tekrar Dene" Click="RetryButton_Click" Margin="0,12,0,0" Padding="16,8" Background="#2855AC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
