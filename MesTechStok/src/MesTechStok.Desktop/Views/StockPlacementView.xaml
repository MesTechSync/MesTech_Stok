<UserControl x:Class="MesTechStok.Desktop.Views.StockPlacementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ip="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    
    <UserControl.Resources>
        <!-- Modern Card Style -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#20000000" Direction="270" ShadowDepth="3" BlurRadius="8" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Dashboard Card Style -->
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#20000000" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Quick Access Button Style -->
        <Style x:Key="QuickAccessButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12"
                                Effect="{TemplateBinding Effect}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#40000000" Direction="270" ShadowDepth="6" BlurRadius="16" Opacity="0.2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="#F5F5F5">
        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Background="#80FFFFFF" Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#2196F3"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Visibility="Collapsed" Background="#F5F5F5" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Stok yerlesim verisi yok" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Depo ve konum bilgileri yuklendiginde goruntulenecektir" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Visibility="Collapsed" Background="#F5F5F5" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#DC3545" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="Tekrar Dene" Click="RetryButton_Click" Margin="0,12,0,0" Padding="16,8" Background="#2196F3" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                
                <!-- Header Section -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="24" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🏭 STOK YERLEŞİM SİSTEMİ" 
                                       FontSize="28" FontWeight="Bold" 
                                       Foreground="#1976D2" Margin="0,0,0,8"/>
                            <TextBlock Text="Akıllı konum yönetimi ve depo optimizasyonu" 
                                       FontSize="16" Foreground="#666" Margin="0,0,0,16"/>
                            <TextBlock Text="Depo organizasyonu, konum takibi, QR kod entegrasyonu ve mobil yönetim" 
                                       FontSize="14" Foreground="#888"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="📊 Sistem Durumu" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#4CAF50" CornerRadius="8" Padding="12,6">
                                <TextBlock Text="✅ AKTİF" Foreground="White" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Quick Access Section -->
                <TextBlock Text="🚀 Hızlı Erişim" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" Foreground="#333"/>
                <WrapPanel Margin="0,0,0,32">
                    <Button Style="{StaticResource QuickAccessButtonStyle}" 
                            Background="#4CAF50" Click="OpenWarehouseManagement_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏢" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Depo Yönetimi"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource QuickAccessButtonStyle}" 
                            Background="#FF9800" Click="OpenLocationTracking_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📍" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Konum Takibi"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource QuickAccessButtonStyle}" 
                            Background="#9C27B0" Click="OpenWarehouseMap_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗺️" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Depo Haritası"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource QuickAccessButtonStyle}" 
                            Background="#607D8B" Click="OpenMobileWarehouse_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📱" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Mobil Depo"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource QuickAccessButtonStyle}" 
                            Background="#795548" Click="OpenLocationReports_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="Konum Raporları"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
                
                <!-- Statistics Dashboard -->
                <TextBlock Text="📊 Genel İstatistikler" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" Foreground="#333"/>
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Total Zones -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardCardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🏗️" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Toplam Bölüm" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="#1976D2" HorizontalAlignment="Center"/>
                            <TextBlock Text="A, B, C Bölümleri" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Total Racks -->
                    <Border Grid.Column="1" Style="{StaticResource DashboardCardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="📦" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Toplam Raf" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="6" FontSize="24" FontWeight="Bold" Foreground="#FF9800" HorizontalAlignment="Center"/>
                            <TextBlock Text="Her bölümde 2 raf" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Total Bins -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardCardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🗃️" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Toplam Göz" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="54" FontSize="24" FontWeight="Bold" Foreground="#4CAF50" HorizontalAlignment="Center"/>
                            <TextBlock Text="Her rafta 9 göz" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Utilization Rate -->
                    <Border Grid.Column="3" Style="{StaticResource DashboardCardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="📈" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Doluluk Oranı" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="78.5%" FontSize="24" FontWeight="Bold" Foreground="#9C27B0" HorizontalAlignment="Center"/>
                            <TextBlock Text="Optimal seviyede" FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Recent Activities -->
                <TextBlock Text="🕒 Son Aktiviteler" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" Foreground="#333"/>
                <Border Style="{StaticResource ModernCardStyle}" Padding="24">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="#E3F2FD" CornerRadius="20" Padding="8,4" Margin="0,0,16,0">
                                <TextBlock Text="📍" FontSize="16"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ürün A-001 yerleştirildi" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="A-01-01-01 konumuna 15 adet ürün yerleştirildi" FontSize="14" Foreground="#666"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Column="2" Text="2 saat önce" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="#FFF3E0" CornerRadius="20" Padding="8,4" Margin="0,0,16,0">
                                <TextBlock Text="🔄" FontSize="16"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Ürün B-002 taşındı" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="B-02-01-03 konumundan B-02-02-01 konumuna taşındı" FontSize="14" Foreground="#666"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Column="2" Text="4 saat önce" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Background="#E8F5E8" CornerRadius="20" Padding="8,4" Margin="0,0,16,0">
                                <TextBlock Text="📱" FontSize="16"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="QR kod tarandı" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="C-01-01-01 konumu mobil cihazdan tarandı" FontSize="14" Foreground="#666"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Column="2" Text="6 saat önce" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- System Information -->
                <TextBlock Text="ℹ️ Sistem Bilgileri" FontSize="20" FontWeight="Bold" Margin="0,24,0,16" Foreground="#333"/>
                <Border Style="{StaticResource ModernCardStyle}" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🔧 Teknik Detaylar" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Text="• .NET 9 WPF Desktop Application" FontSize="14" Margin="0,0,0,4" Foreground="#666"/>
                            <TextBlock Text="• Entity Framework Core" FontSize="14" Margin="0,0,0,4" Foreground="#666"/>
                            <TextBlock Text="• SQL Server LocalDB" FontSize="14" Margin="0,0,0,4" Foreground="#666"/>
                            <TextBlock Text="• Dependency Injection" FontSize="14" Margin="0,0,0,4" Foreground="#666"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="📋 Özellikler" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Text="• Akıllı konum önerileri" FontSize="14" Margin="0,0,0,4" Foreground="#666"/>
                            <TextBlock Text="• QR kod entegrasyonu" FontSize="14" Margin="0,0,0,4" Foreground="#666"/>
                            <TextBlock Text="• Mobil depo yönetimi" FontSize="14" Margin="0,0,0,4" Foreground="#666"/>
                            <TextBlock Text="• Gerçek zamanlı raporlama" FontSize="14" Margin="0,0,0,4" Foreground="#666"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Footer -->
                <TextBlock Text="© 2025 MesTech Stok Takip Sistemi - STOK YERLEŞİM SİSTEMİ v2.0" 
                           FontSize="12" Foreground="#999" HorizontalAlignment="Center" Margin="0,32,0,0"/>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
