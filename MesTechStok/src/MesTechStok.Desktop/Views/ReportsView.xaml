<UserControl x:Class="MesTechStok.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Modern Card Style -->
        <Style x:Key="ReportCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Chart Card Style -->
        <Style x:Key="ChartCard" TargetType="Border" BasedOn="{StaticResource ReportCard}">
            <Setter Property="MinHeight" Value="300"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F0F7FF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Button Styles -->
        <Style x:Key="ReportButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005a9e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004578"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="#F5F7FA" Margin="20" SnapsToDevicePixels="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="20" Margin="10">
            <StackPanel>
                <TextBlock Text="📊 Raporlar ve Analiz" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Detaylı stok analizi ve performans raporları" FontSize="14" Foreground="#6C757D" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Quick Stats -->
        <Grid Grid.Row="1" Margin="10,10,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Total Revenue -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="15" Margin="5">
                <StackPanel>
                    <TextBlock Text="💰 Toplam Gelir" FontSize="12" Foreground="#6C757D"/>
                    <TextBlock x:Name="TotalRevenueText" Text="₺125,450" FontSize="20" FontWeight="Bold" Foreground="#28A745"/>
                    <TextBlock Text="↗️ +12.5%" FontSize="10" Foreground="#28A745"/>
                </StackPanel>
            </Border>
            
            <!-- Total Sales -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15" Margin="5">
                <StackPanel>
                    <TextBlock Text="🛍️ Toplam Satış" FontSize="12" Foreground="#6C757D"/>
                    <TextBlock x:Name="TotalSalesText" Text="1,247" FontSize="20" FontWeight="Bold" Foreground="#007ACC"/>
                    <TextBlock Text="↗️ +8.3%" FontSize="10" Foreground="#28A745"/>
                </StackPanel>
            </Border>
            
            <!-- Stock Value -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="15" Margin="5">
                <StackPanel>
                    <TextBlock Text="📦 Stok Değeri" FontSize="12" Foreground="#6C757D"/>
                    <TextBlock x:Name="StockValueText" Text="₺89,320" FontSize="20" FontWeight="Bold" Foreground="#6F42C1"/>
                    <TextBlock Text="↘️ -2.1%" FontSize="10" Foreground="#DC3545"/>
                </StackPanel>
            </Border>
            
            <!-- Low Stock -->
            <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="15" Margin="5">
                <StackPanel>
                    <TextBlock Text="⚠️ Düşük Stok" FontSize="12" Foreground="#6C757D"/>
                    <TextBlock x:Name="LowStockCountText" Text="12" FontSize="20" FontWeight="Bold" Foreground="#FFC107"/>
                    <TextBlock Text="ürün" FontSize="10" Foreground="#6C757D"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Content -->
        <Grid Grid.Row="2" Margin="10,15,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - Charts -->
            <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20" Margin="0,0,10,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="📈 Satış Performansı" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                    
                    <!-- Simple Chart Area -->
                    <Border Grid.Row="1" Background="#F8FFFE" CornerRadius="8" Padding="10">
                        <Canvas x:Name="SalesChart" Background="Transparent"/>
                    </Border>
                    
                    <!-- Chart Controls -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0">
                        <ComboBox x:Name="DateRangeComboBox" Width="120" Margin="0,0,10,0" SelectionChanged="DateRange_Changed">
                            <ComboBoxItem Content="Bu Hafta" IsSelected="True"/>
                            <ComboBoxItem Content="Bu Ay"/>
                            <ComboBoxItem Content="Son 3 Ay"/>
                        </ComboBox>
                        <Button Content="🔄 Yenile" Padding="8,4" Margin="0,0,10,0" Click="RefreshReports_Click"/>
                        <Button Content="📤 CSV" Padding="8,4" Margin="0,0,10,0" Click="ExportCsv_Click"
                                Visibility="{Binding CanExportReports, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="📊 Excel" Padding="8,4" Margin="0,0,10,0" Click="ExportExcel_Click"
                                Visibility="{Binding CanExportReports, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="📄 PDF" Padding="8,4" Click="ExportPDF_Click"
                                Visibility="{Binding CanExportReports, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <!-- Right Panel - Tables -->
            <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="20" Margin="10,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Top Products -->
                    <TextBlock Grid.Row="0" Text="🏆 En Çok Satan" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                    <DataGrid Grid.Row="1" x:Name="TopProductsDataGrid" 
                             AutoGenerateColumns="False" 
                             Background="Transparent"
                             BorderThickness="0"
                             GridLinesVisibility="None"
                             HeadersVisibility="None"
                             Margin="0,10,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Sales}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Low Stock -->
                    <TextBlock Grid.Row="2" Text="⚠️ Stok Uyarıları" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                    <DataGrid Grid.Row="3" x:Name="LowStockDataGrid"
                             AutoGenerateColumns="False" 
                             Background="Transparent"
                             BorderThickness="0"
                             GridLinesVisibility="None"
                             HeadersVisibility="None"
                             Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Stock}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Profil Yöneticisi (Filtre & Kolon) -->
            <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="20" Margin="10,310,0,10">
                <StackPanel>
                    <TextBlock Text="⚙️ Profil Yöneticisi" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="Ürünler görünümündeki filtre ve kolon profillerini yönetin" Foreground="#6C757D" Margin="0,2,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="📂 Profil Yükle" Style="{StaticResource ReportButton}" Margin="0,0,6,0" Click="LoadProductsProfiles_Click"/>
                        <Button Content="💾 Profil Kaydet" Style="{StaticResource ReportButton}" Margin="0,0,6,0" Click="SaveProductsProfiles_Click"/>
                        <Button Content="↺ Varsayılan" Style="{StaticResource ReportButton}" Click="ResetProductsProfiles_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#99FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12"/>
                <TextBlock Text="Rapor verileri yükleniyor..." FontSize="14" Foreground="#555" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="2" Background="#F5F7FA" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x1F4CA;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Rapor verisi bulunamadı" FontSize="16" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Ürün veya stok hareketi ekledikten sonra raporlar oluşacaktır." FontSize="12" Foreground="#AAA" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.Row="0" Grid.RowSpan="3" Background="#F5F7FA" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x26A0;" FontSize="48" HorizontalAlignment="Center" Foreground="#E53935" Margin="0,0,0,8"/>
                <TextBlock x:Name="ReportErrorText" Text="Raporlar yüklenemedi" FontSize="14" Foreground="#E53935" HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap" MaxWidth="400"/>
                <Button Content="Tekrar Dene" Padding="16,6" Click="RetryReports_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>