<UserControl x:Class="MesTechStok.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Modern Card Style -->
        <Style x:Key="ReportCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chart Card Style -->
        <Style x:Key="ChartCard" TargetType="Border" BasedOn="{StaticResource ReportCard}">
            <Setter Property="MinHeight" Value="300"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F0F7FF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="ReportButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005a9e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004578"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F5F7FA" SnapsToDevicePixels="True">
        <!-- Wrap all content in ScrollViewer for new chart panels -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto" MinHeight="350"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="White" CornerRadius="15" Padding="20" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Raporlar ve Analiz" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}"/>
                        <TextBlock Text="Detayli stok analizi ve performans raporlari" FontSize="14" Foreground="#6C757D" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Quick Stats -->
                <Grid Grid.Row="1" Margin="10,10,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Revenue -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="15" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Toplam Gelir" FontSize="12" Foreground="#6C757D"/>
                            <TextBlock x:Name="TotalRevenueText" Text="&#8378;125,450" FontSize="20" FontWeight="Bold" Foreground="#28A745"/>
                            <TextBlock x:Name="RevenueChangeText" Text="+12.5%" FontSize="10" Foreground="#28A745"/>
                        </StackPanel>
                    </Border>

                    <!-- Total Sales -->
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Toplam Satis" FontSize="12" Foreground="#6C757D"/>
                            <TextBlock x:Name="TotalSalesText" Text="1,247" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}"/>
                            <TextBlock x:Name="SalesChangeText" Text="+8.3%" FontSize="10" Foreground="#28A745"/>
                        </StackPanel>
                    </Border>

                    <!-- Stock Value -->
                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="15" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Stok Degeri" FontSize="12" Foreground="#6C757D"/>
                            <TextBlock x:Name="StockValueText" Text="&#8378;89,320" FontSize="20" FontWeight="Bold" Foreground="#6F42C1"/>
                            <TextBlock x:Name="StockChangeText" Text="-2.1%" FontSize="10" Foreground="#DC3545"/>
                        </StackPanel>
                    </Border>

                    <!-- Low Stock -->
                    <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="15" Margin="5">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Dusuk Stok" FontSize="12" Foreground="#6C757D"/>
                            <TextBlock x:Name="LowStockCountText" Text="12" FontSize="20" FontWeight="Bold" Foreground="#FFC107"/>
                            <TextBlock Text="urun" FontSize="10" Foreground="#6C757D"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Content (existing Canvas chart + tables) -->
                <Grid Grid.Row="2" Margin="10,15,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel - Canvas Chart (existing) -->
                    <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20" Margin="0,0,10,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Satis Performansi" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}" Margin="0,0,0,15"/>

                            <!-- Simple Chart Area -->
                            <Border Grid.Row="1" Background="#F8FFFE" CornerRadius="8" Padding="10">
                                <Canvas x:Name="SalesChart" Background="Transparent"/>
                            </Border>

                            <!-- Chart Controls -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,0">
                                <ComboBox x:Name="DateRangeComboBox" Width="120" Margin="0,0,10,0" SelectionChanged="DateRange_Changed">
                                    <ComboBoxItem Content="Bu Hafta" IsSelected="True"/>
                                    <ComboBoxItem Content="Bu Ay"/>
                                    <ComboBoxItem Content="Son 3 Ay"/>
                                </ComboBox>
                                <Button Content="Yenile" Padding="8,4" Margin="0,0,10,0" Click="RefreshReports_Click" Style="{StaticResource ReportButton}"/>
                                <Button Content="CSV" Padding="8,4" Margin="0,0,10,0" Click="ExportCsv_Click" Style="{StaticResource ReportButton}"
                                        Visibility="{Binding CanExportReports, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                                <Button Content="Excel" Padding="8,4" Margin="0,0,10,0" Click="ExportExcel_Click" Style="{StaticResource ReportButton}"
                                        Visibility="{Binding CanExportReports, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                                <Button Content="PDF" Padding="8,4" Click="ExportPDF_Click" Style="{StaticResource ReportButton}"
                                        Visibility="{Binding CanExportReports, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Right Panel - Tables -->
                    <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="20" Margin="10,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Top Products -->
                            <TextBlock Grid.Row="0" Text="En Cok Satan" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}"/>
                            <DataGrid Grid.Row="1" x:Name="TopProductsDataGrid"
                                     AutoGenerateColumns="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     GridLinesVisibility="None"
                                     HeadersVisibility="None"
                                     Margin="0,10,0,15">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Binding="{Binding Sales}" Width="50"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Low Stock -->
                            <TextBlock Grid.Row="2" Text="Stok Uyarilari" FontSize="14" FontWeight="Bold" Foreground="#DC3545"/>
                            <DataGrid Grid.Row="3" x:Name="LowStockDataGrid"
                                     AutoGenerateColumns="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     GridLinesVisibility="None"
                                     HeadersVisibility="None"
                                     Margin="0,10,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Binding="{Binding Stock}" Width="50"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- Profil Yoneticisi (Filtre & Kolon) -->
                    <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="20" Margin="10,310,0,10">
                        <StackPanel>
                            <TextBlock Text="Profil Yoneticisi" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}"/>
                            <TextBlock Text="Urunler gorunumundeki filtre ve kolon profillerini yonetin" Foreground="#6C757D" Margin="0,2,0,10"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Profil Yukle" Style="{StaticResource ReportButton}" Margin="0,0,6,0" Click="LoadProductsProfiles_Click"/>
                                <Button Content="Profil Kaydet" Style="{StaticResource ReportButton}" Margin="0,0,6,0" Click="SaveProductsProfiles_Click"/>
                                <Button Content="Varsayilan" Style="{StaticResource ReportButton}" Click="ResetProductsProfiles_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ========================================================= -->
                <!-- LiveCharts2 CHARTS — B2 Emirname: Real Charts (Additive)  -->
                <!-- ========================================================= -->

                <!-- Row 3: Monthly Revenue/Expense Bar Chart + Platform Pie Chart -->
                <Grid Grid.Row="3" Margin="10,5,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Aylik Gelir-Gider Bar Chart -->
                    <Border Grid.Column="0" Style="{StaticResource ChartCard}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Aylik Gelir-Gider Karsilastirmasi" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}"/>
                                <TextBlock Text="Son 12 aylik gelir ve gider dagilimi" FontSize="11" Foreground="#6C757D" Margin="0,3,0,0"/>
                            </StackPanel>
                            <lvc:CartesianChart Grid.Row="1"
                                x:Name="MonthlyRevenueChart"
                                Series="{Binding MonthlyRevenueSeries, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                XAxes="{Binding MonthlyXAxes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                YAxes="{Binding MonthlyYAxes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                TooltipPosition="Top"
                                MinHeight="260"/>
                        </Grid>
                    </Border>

                    <!-- Platform Bazli Pasta Grafik -->
                    <Border Grid.Column="1" Style="{StaticResource ChartCard}" Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Platform Bazli Satis" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}"/>
                                <TextBlock Text="Pazaryeri satis dagilimi" FontSize="11" Foreground="#6C757D" Margin="0,3,0,0"/>
                            </StackPanel>
                            <lvc:PieChart Grid.Row="1"
                                x:Name="PlatformPieChart"
                                Series="{Binding PlatformSalesSeries, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                TooltipPosition="Top"
                                MinHeight="260"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Row 4: Weekly Trend Line Chart -->
                <Grid Grid.Row="4" Margin="10,5,10,20">
                    <Border Style="{StaticResource ChartCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Son 7 Gun Gelir Trendi" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}"/>
                                <TextBlock Text="Gunluk ciro akisi ve degisim trendi" FontSize="11" Foreground="#6C757D" Margin="0,3,0,0"/>
                            </StackPanel>
                            <lvc:CartesianChart Grid.Row="1"
                                x:Name="WeeklyTrendChart"
                                Series="{Binding WeeklyTrendSeries, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                XAxes="{Binding WeeklyXAxes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                YAxes="{Binding WeeklyYAxes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                TooltipPosition="Top"
                                MinHeight="220"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Background="#99FFFFFF" Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="4" Margin="0,0,0,12"/>
                <TextBlock Text="Rapor verileri yukleniyor..." FontSize="14" Foreground="#555" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Background="#F5F7FA" Visibility="Collapsed" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x1F4CA;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Rapor verisi bulunamadi" FontSize="16" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Urun veya stok hareketi ekledikten sonra raporlar olusacaktir." FontSize="12" Foreground="#AAA" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Background="#F5F7FA" Visibility="Collapsed" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x26A0;" FontSize="48" HorizontalAlignment="Center" Foreground="#E53935" Margin="0,0,0,8"/>
                <TextBlock x:Name="ReportErrorText" Text="Raporlar yuklenemedi" FontSize="14" Foreground="#E53935" HorizontalAlignment="Center" Margin="0,0,0,12" TextWrapping="Wrap" MaxWidth="400"/>
                <Button Content="Tekrar Dene" Padding="16,6" Click="RetryReports_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
