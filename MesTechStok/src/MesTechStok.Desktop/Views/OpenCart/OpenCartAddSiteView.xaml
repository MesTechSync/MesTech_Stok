<UserControl x:Class="MesTechStok.Desktop.Views.OpenCart.OpenCartAddSiteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#495057"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="WizardStepActive" TargetType="Border">
            <Setter Property="Background" Value="#E96B20"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        <Style x:Key="WizardStepInactive" TargetType="Border">
            <Setter Property="Background" Value="#DEE2E6"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E96B20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600" HorizontalAlignment="Center" Margin="8,20">
            <!-- Wizard Steps Indicator -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Style="{StaticResource WizardStepActive}">
                            <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Site Bilgisi" FontSize="10" Foreground="#495057" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Height="2" Width="60" Background="#DEE2E6" VerticalAlignment="Top" Margin="8,15,8,0"/>
                    <StackPanel HorizontalAlignment="Center">
                        <Border Style="{StaticResource WizardStepInactive}">
                            <TextBlock Text="2" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Veritabani" FontSize="10" Foreground="#ADB5BD" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Height="2" Width="60" Background="#DEE2E6" VerticalAlignment="Top" Margin="8,15,8,0"/>
                    <StackPanel HorizontalAlignment="Center">
                        <Border Style="{StaticResource WizardStepInactive}">
                            <TextBlock Text="3" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Test" FontSize="10" Foreground="#ADB5BD" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Step 1: Site Bilgileri -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Adim 1: Site Bilgileri" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Site Adi *"/>
                    <TextBox Style="{StaticResource FormTextBox}" Text="{Binding SiteName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Site URL *"/>
                    <TextBox Style="{StaticResource FormTextBox}" Text="{Binding SiteUrl, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="OpenCart Versiyon *"/>
                    <ComboBox Padding="10,8" FontSize="13" Margin="0,0,0,16"
                              SelectedItem="{Binding SelectedVersion}">
                        <ComboBoxItem Content="OpenCart 3.x"/>
                        <ComboBoxItem Content="OpenCart 4.x"/>
                    </ComboBox>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Admin Paneli URL"/>
                    <TextBox Style="{StaticResource FormTextBox}" Text="{Binding AdminUrl, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="Aciklama"/>
                    <TextBox Style="{StaticResource FormTextBox}" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="60"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Content="Ileri >" Command="{Binding NextStepCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
