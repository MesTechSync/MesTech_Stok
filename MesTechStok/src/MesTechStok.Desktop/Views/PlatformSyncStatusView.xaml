<UserControl x:Class="MesTechStok.Desktop.Views.PlatformSyncStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005a9e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#DC3545"/>
        </Style>
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style x:Key="SyncJobCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Header -->
            <Border Style="{StaticResource CardBorder}" Margin="8,8,8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Platform Senkronizasyon Durumu" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                        <TextBlock Text="Hangfire job durumu ve senkronizasyon istatistikleri" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Tumu Duraklat" Style="{StaticResource DangerBtn}" Click="PauseAll_Click" Margin="0,0,8,0"/>
                        <Button Content="Tumu Baslat" Style="{StaticResource SuccessBtn}" Click="ResumeAll_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sync Overview -->
            <Border Style="{StaticResource CardBorder}" Margin="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="8" Padding="14" Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Aktif Job" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="ActiveJobsText" Text="0 / 9" FontSize="22" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#E3F2FD" CornerRadius="8" Padding="14" Margin="3,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Bugun Sync" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TodaySyncCountText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#007ACC" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#FFF3E0" CornerRadius="8" Padding="14" Margin="3,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Basarisiz" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="FailedSyncText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#FF6000" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="#FFEBEE" CornerRadius="8" Padding="14" Margin="6,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Kuyrukta" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="QueuedItemsText" Text="0" FontSize="22" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Hangfire Recurring Jobs -->
            <Border Style="{StaticResource CardBorder}" Margin="8,4">
                <StackPanel>
                    <TextBlock Text="Recurring Jobs (Hangfire)" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>

                    <!-- Job List -->
                    <Border Style="{StaticResource SyncJobCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="TrendyolOrderSync" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="5 dk" FontSize="12" Foreground="#6C757D" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" x:Name="OrderSyncStatus" Background="#28A745" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Aktif" FontSize="10" Foreground="White" FontWeight="Medium"/>
                            </Border>
                            <TextBlock Grid.Column="3" x:Name="OrderSyncLastRun" Text="Son: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" x:Name="OrderSyncNextRun" Text="Sonraki: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <Button Grid.Column="5" Content="Calistir" Style="{StaticResource ActionBtn}" Padding="8,4" FontSize="10" Click="RunOrderSync_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SyncJobCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="TrendyolStockSync" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="30 dk" FontSize="12" Foreground="#6C757D" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Background="#28A745" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Aktif" FontSize="10" Foreground="White" FontWeight="Medium"/>
                            </Border>
                            <TextBlock Grid.Column="3" Text="Son: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Sonraki: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <Button Grid.Column="5" Content="Calistir" Style="{StaticResource ActionBtn}" Padding="8,4" FontSize="10" Click="RunStockSync_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SyncJobCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="TrendyolClaimSync" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="15 dk" FontSize="12" Foreground="#6C757D" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Background="#28A745" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Aktif" FontSize="10" Foreground="White" FontWeight="Medium"/>
                            </Border>
                            <TextBlock Grid.Column="3" Text="Son: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Sonraki: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <Button Grid.Column="5" Content="Calistir" Style="{StaticResource ActionBtn}" Padding="8,4" FontSize="10" Click="RunClaimSync_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SyncJobCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="OpenCartStockSync" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="30 dk" FontSize="12" Foreground="#6C757D" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Background="#28A745" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Aktif" FontSize="10" Foreground="White" FontWeight="Medium"/>
                            </Border>
                            <TextBlock Grid.Column="3" Text="Son: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Sonraki: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <Button Grid.Column="5" Content="Calistir" Style="{StaticResource ActionBtn}" Padding="8,4" FontSize="10" Click="RunOpenCartSync_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SyncJobCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="InvoiceRetryJob" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="10 dk" FontSize="12" Foreground="#6C757D" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Background="#28A745" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Aktif" FontSize="10" Foreground="White" FontWeight="Medium"/>
                            </Border>
                            <TextBlock Grid.Column="3" Text="Son: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Sonraki: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <Button Grid.Column="5" Content="Calistir" Style="{StaticResource ActionBtn}" Padding="8,4" FontSize="10" Click="RunInvoiceRetry_Click"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SyncJobCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="HealthCheckJob" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="1 dk" FontSize="12" Foreground="#6C757D" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Background="#28A745" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="Aktif" FontSize="10" Foreground="White" FontWeight="Medium"/>
                            </Border>
                            <TextBlock Grid.Column="3" Text="Son: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Sonraki: --" FontSize="11" Foreground="#9E9E9E" VerticalAlignment="Center"/>
                            <Button Grid.Column="5" Content="Calistir" Style="{StaticResource ActionBtn}" Padding="8,4" FontSize="10" Click="RunHealthCheck_Click"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Sync History -->
            <Border Style="{StaticResource CardBorder}" Margin="8,4,8,8">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Son Senkronizasyon Gecmisi" FontSize="16" FontWeight="Bold" Foreground="#212529"/>
                        <Button Content="Temizle" Style="{StaticResource DangerBtn}" HorizontalAlignment="Right" Padding="8,4" FontSize="10" Click="ClearHistory_Click"/>
                    </Grid>
                    <DataGrid x:Name="SyncHistoryGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" FontSize="11"
                              RowHeight="32" ColumnHeaderHeight="34"
                              MinHeight="120" MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Zaman" Binding="{Binding Timestamp}" Width="140"/>
                            <DataGridTextColumn Header="Job" Binding="{Binding JobName}" Width="160"/>
                            <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="90"/>
                            <DataGridTextColumn Header="Sonuc" Binding="{Binding Result}" Width="80"/>
                            <DataGridTextColumn Header="Sure (ms)" Binding="{Binding DurationMs}" Width="80"/>
                            <DataGridTextColumn Header="Islenen" Binding="{Binding ItemsProcessed}" Width="70"/>
                            <DataGridTextColumn Header="Hata" Binding="{Binding ErrorCount}" Width="60"/>
                            <DataGridTextColumn Header="Mesaj" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>

    <!-- Loading State -->
    <Border x:Name="LoadingOverlay"
            Background="#80000000"
            Visibility="Collapsed"
            Panel.ZIndex="100">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
            <TextBlock Text="Yukleniyor..." Margin="0,12,0,0"
                       HorizontalAlignment="Center" Foreground="White" FontSize="14"/>
        </StackPanel>
    </Border>

    <!-- Empty State -->
    <Border x:Name="EmptyState"
            Background="#F5F7FA"
            Visibility="Collapsed"
            Panel.ZIndex="50">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="&#x1F504;" FontSize="48" HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8"/>
            <TextBlock Text="Platform senkron verisi yok" FontSize="16" Foreground="#6C757D"
                       HorizontalAlignment="Center" Opacity="0.7"/>
        </StackPanel>
    </Border>

    <!-- Error State -->
    <Border x:Name="ErrorState"
            Background="#F5F7FA"
            Visibility="Collapsed"
            Panel.ZIndex="50">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="&#x26A0;" FontSize="48" HorizontalAlignment="Center"
                       Foreground="#F44336" Margin="0,0,0,8"/>
            <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="14"
                       Foreground="#F44336" HorizontalAlignment="Center"
                       Margin="0,0,0,12" TextWrapping="Wrap" MaxWidth="400"/>
            <Button x:Name="RetryButton" Content="Tekrar Dene"
                    Click="RetryButton_Click"
                    Padding="12,8" Background="#007ACC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Border>
    </Grid>
</UserControl>
