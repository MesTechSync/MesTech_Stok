<UserControl x:Class="MesTechStok.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:components="clr-namespace:MesTechStok.Desktop.Components"
             mc:Ignorable="d"
             d:DesignHeight="800"
        d:DesignWidth="1200"
             KeyDown="View_KeyDown"
             Focusable="True">

    <UserControl.Resources>
        <!-- Modern Card Style -->
        <Style x:Key="KPICardStyle"
                TargetType="Border">
            <Setter Property="Background"
                    Value="White"/>
            <Setter Property="CornerRadius"
                    Value="12"/>
            <Setter Property="BorderBrush"
                    Value="#E0E6ED"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Margin"
                    Value="8"/>
            <Setter Property="Padding"
                    Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15"
                            Color="#E0E6ED"
                            Opacity="0.3"
                            ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- KPI Number Style -->
        <Style x:Key="KPINumberStyle"
                TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="32"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="Foreground"
                    Value="#2563EB"/>
            <Setter Property="HorizontalAlignment"
                    Value="Center"/>
        </Style>

        <!-- KPI Label Style -->
        <Style x:Key="KPILabelStyle"
                TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Foreground"
                    Value="#64748B"/>
            <Setter Property="HorizontalAlignment"
                    Value="Center"/>
            <Setter Property="Margin"
                    Value="0,8,0,0"/>
        </Style>

        <!-- Icon Style -->
        <Style x:Key="KPIIconStyle"
                TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="24"/>
            <Setter Property="HorizontalAlignment"
                    Value="Right"/>
            <Setter Property="VerticalAlignment"
                    Value="Top"/>
            <Setter Property="Margin"
                    Value="0,0,8,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAFC"
            Opacity="0"
            RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TranslateTransform Y="20"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard Storyboard="{StaticResource PageEnterAnimation}"/>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E0E6ED"
                BorderThickness="0,0,0,1"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📊 Kontrol Paneli"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="#1E293B"/>
                    <TextBlock Text="Stok ve işlem durum özeti"
                            FontSize="14"
                            Foreground="#64748B"
                            Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                    <Button Name="RefreshButton"
                            Content="🔄 Yenile"
                            Padding="12,8"
                            Margin="8,0"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            Click="RefreshButton_Click"
                            Cursor="Hand"/>
                    <TextBlock Name="LastUpdatedText"
                            Text="Son Güncelleme: --:--"
                               VerticalAlignment="Center"
                            Margin="16,0,0,0"
                            Foreground="#64748B"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 🎨 BRAVO TİMİ - Modern KPI Widgets -->
        <Grid Grid.Row="1"
                Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Products KPI Widget -->
            <components:KPIWidget Grid.Column="0"
                                  x:Name="TotalProductsWidget"
                                  Title="Toplam Ürün"
                                  Value="0"
                                  Icon="📦"
                                  Description="Sistemdeki aktif ürün sayısı"
                                  ShowTrend="True"
                                  TrendText="+5%"
                                  IsPositiveTrend="True"/>

            <!-- Total Stock Value KPI Widget -->
            <components:KPIWidget Grid.Column="1"
                                  x:Name="TotalStockValueWidget"
                                  Title="Toplam Stok Değeri"
                                  Value="₺0"
                                  Icon="💰"
                                  Description="Toplam stok değeri"
                                  ShowTrend="True"
                                  TrendText="+12%"
                                  IsPositiveTrend="True"/>

            <!-- Low Stock Items KPI Widget -->
            <components:KPIWidget Grid.Column="2"
                                  x:Name="LowStockWidget"
                                  Title="Düşük Stok"
                                  Value="0"
                                  Icon="⚠️"
                                  Description="Kritik stok seviyesindeki ürünler"
                                  ShowTrend="True"
                                  TrendText="-8%"
                                  IsPositiveTrend="False"/>

            <!-- Active Categories KPI Widget -->
            <components:KPIWidget Grid.Column="3"
                                  x:Name="ActiveCategoriesWidget"
                                  Title="Aktif Kategori"
                                  Value="0"
                                  Icon="📂"
                                  Description="Aktif ürün kategorileri"
                                  ShowTrend="False"/>
        </Grid>

        <!-- 📈 ANALYTICS ROW - Sales Chart Integration -->
        <Grid Grid.Row="2"
                Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sales Analytics Chart -->
            <Border Grid.Column="0"
                    Style="{StaticResource KPICardStyle}"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,16">
                        <TextBlock Text="📈 Satış Analizi"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="#1E293B"/>
                        <TextBlock Text="Son 7 günlük satış trendi"
                                FontSize="12"
                                Foreground="#64748B"
                                Margin="16,6,0,0"/>
                    </StackPanel>

                    <!-- Embedded Sales Chart -->
                    <Canvas Grid.Row="1"
                            Name="SalesChartCanvas"
                            Background="#F8FAFC"
                            Height="200"
                            Margin="0,10">
                        <Grid Canvas.Left="0"
                                Canvas.Top="0"
                                Width="{Binding ActualWidth, ElementName=SalesChartCanvas}"
                              Height="{Binding ActualHeight, ElementName=SalesChartCanvas}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Günlük sales bars -->
                            <Grid Grid.Column="0"
                                    Margin="5">
                                <Rectangle Name="SalesBar1"
                                        Fill="#3B82F6"
                                        VerticalAlignment="Bottom"
                                           Height="120"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Opacity="0.8">
                                    <Rectangle.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="Pazartesi"
                                                        FontWeight="Bold"/>
                                                <TextBlock Name="SalesBar1Value"
                                                        Text="₺12,450"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Rectangle.ToolTip>
                                </Rectangle>
                            </Grid>

                            <Grid Grid.Column="1"
                                    Margin="5">
                                <Rectangle Name="SalesBar2"
                                        Fill="#3B82F6"
                                        VerticalAlignment="Bottom"
                                           Height="95"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Opacity="0.8">
                                    <Rectangle.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="Salı"
                                                        FontWeight="Bold"/>
                                                <TextBlock Name="SalesBar2Value"
                                                        Text="₺9,850"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Rectangle.ToolTip>
                                </Rectangle>
                            </Grid>

                            <Grid Grid.Column="2"
                                    Margin="5">
                                <Rectangle Name="SalesBar3"
                                        Fill="#3B82F6"
                                        VerticalAlignment="Bottom"
                                           Height="140"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Opacity="0.8">
                                    <Rectangle.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="Çarşamba"
                                                        FontWeight="Bold"/>
                                                <TextBlock Name="SalesBar3Value"
                                                        Text="₺15,200"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Rectangle.ToolTip>
                                </Rectangle>
                            </Grid>

                            <Grid Grid.Column="3"
                                    Margin="5">
                                <Rectangle Name="SalesBar4"
                                        Fill="#3B82F6"
                                        VerticalAlignment="Bottom"
                                           Height="110"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Opacity="0.8">
                                    <Rectangle.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="Perşembe"
                                                        FontWeight="Bold"/>
                                                <TextBlock Name="SalesBar4Value"
                                                        Text="₺11,750"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Rectangle.ToolTip>
                                </Rectangle>
                            </Grid>

                            <Grid Grid.Column="4"
                                    Margin="5">
                                <Rectangle Name="SalesBar5"
                                        Fill="#10B981"
                                        VerticalAlignment="Bottom"
                                           Height="165"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Opacity="0.8">
                                    <Rectangle.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="Cuma"
                                                        FontWeight="Bold"/>
                                                <TextBlock Name="SalesBar5Value"
                                                        Text="₺18,900"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Rectangle.ToolTip>
                                </Rectangle>
                            </Grid>

                            <Grid Grid.Column="5"
                                    Margin="5">
                                <Rectangle Name="SalesBar6"
                                        Fill="#3B82F6"
                                        VerticalAlignment="Bottom"
                                           Height="85"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Opacity="0.8">
                                    <Rectangle.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="Cumartesi"
                                                        FontWeight="Bold"/>
                                                <TextBlock Name="SalesBar6Value"
                                                        Text="₺8,650"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Rectangle.ToolTip>
                                </Rectangle>
                            </Grid>

                            <Grid Grid.Column="6"
                                    Margin="5">
                                <Rectangle Name="SalesBar7"
                                        Fill="#3B82F6"
                                        VerticalAlignment="Bottom"
                                           Height="75"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Opacity="0.8">
                                    <Rectangle.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="Pazar"
                                                        FontWeight="Bold"/>
                                                <TextBlock Name="SalesBar7Value"
                                                        Text="₺7,200"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Rectangle.ToolTip>
                                </Rectangle>
                            </Grid>
                        </Grid>

                        <!-- Target Line -->
                        <Line Name="SalesTargetLine"
                                X1="0"
                                Y1="120"
                                X2="500"
                                Y2="120"
                              Stroke="#10B981"
                                StrokeThickness="2"
                                StrokeDashArray="5,5"
                                Opacity="0.7"/>

                        <!-- Chart Labels -->
                        <StackPanel Canvas.Bottom="5"
                                Canvas.Left="0"
                                Canvas.Right="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                            <TextBlock Text="Pzt"
                                    FontSize="10"
                                    Foreground="#64748B"
                                    Width="60"
                                    TextAlignment="Center"/>
                            <TextBlock Text="Sal"
                                    FontSize="10"
                                    Foreground="#64748B"
                                    Width="60"
                                    TextAlignment="Center"/>
                            <TextBlock Text="Çar"
                                    FontSize="10"
                                    Foreground="#64748B"
                                    Width="60"
                                    TextAlignment="Center"/>
                            <TextBlock Text="Per"
                                    FontSize="10"
                                    Foreground="#64748B"
                                    Width="60"
                                    TextAlignment="Center"/>
                            <TextBlock Text="Cum"
                                    FontSize="10"
                                    Foreground="#64748B"
                                    Width="60"
                                    TextAlignment="Center"/>
                            <TextBlock Text="Cmt"
                                    FontSize="10"
                                    Foreground="#64748B"
                                    Width="60"
                                    TextAlignment="Center"/>
                            <TextBlock Text="Paz"
                                    FontSize="10"
                                    Foreground="#64748B"
                                    Width="60"
                                    TextAlignment="Center"/>
                        </StackPanel>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Performance Summary -->
            <Border Grid.Column="1"
                    Style="{StaticResource KPICardStyle}"
                    Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="🎯 Performans Özeti"
                            FontSize="16"
                            FontWeight="Bold"
                               Foreground="#1E293B"
                            Margin="0,0,0,16"/>

                    <!-- Weekly Performance -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                Text="Haftalık Toplam"
                                FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                Name="WeeklyTotalText"
                                Text="₺83,795"
                                FontWeight="Bold"
                                Foreground="#10B981"/>
                    </Grid>

                    <!-- Average Daily -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                Text="Günlük Ortalama"
                                FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                Name="DailyAverageText"
                                Text="₺11,971"
                                FontWeight="Bold"
                                Foreground="#3B82F6"/>
                    </Grid>

                    <!-- Best Day -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                Text="En İyi Gün"
                                FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                Text="Cuma"
                                FontWeight="Bold"
                                Foreground="#10B981"/>
                    </Grid>

                    <!-- Target Achievement -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                Text="Hedef Gerçekleşme"
                                FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                Name="TargetAchievementText"
                                Text="87%"
                                FontWeight="Bold"
                                Foreground="#F59E0B"/>
                    </Grid>

                    <!-- Progress Bar -->
                    <Border Background="#E5E7EB"
                            CornerRadius="10"
                            Height="8"
                            Margin="0,0,0,8">
                        <Border Name="ProgressBar"
                                Background="#10B981"
                                CornerRadius="10"
                                HorizontalAlignment="Left"
                                Width="175"/>
                    </Border>
                    <TextBlock Text="Haftalık hedefin %87'si gerçekleşti"
                            FontSize="10"
                               Foreground="#64748B"
                            TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="3"
                Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Recent Activities -->
            <Border Grid.Column="0"
                    Style="{StaticResource KPICardStyle}"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                            Text="📋 Son Aktiviteler"
                            FontSize="18"
                            FontWeight="Bold"
                               Foreground="#1E293B"
                            Margin="0,0,0,16"/>

                    <DataGrid Grid.Row="1"
                            Name="RecentActivitiesGrid"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              Background="Transparent"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#F8FAFC">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Zaman"
                                    Binding="{Binding Date, StringFormat='{}{0:HH:mm}'}"
                                    Width="80"/>
                            <DataGridTextColumn Header="İşlem"
                                    Binding="{Binding MovementType}"
                                    Width="80"/>
                            <DataGridTextColumn Header="Ürün"
                                    Binding="{Binding Product.Name}"
                                    Width="*"/>
                            <DataGridTextColumn Header="Miktar"
                                    Binding="{Binding Quantity}"
                                    Width="80"/>
                            <DataGridTextColumn Header="Sebep"
                                    Binding="{Binding Reason}"
                                    Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Quick Actions & Status -->
            <StackPanel Grid.Column="1"
                    Margin="8,0,0,0">

                <!-- Quick Actions -->
                <Border Style="{StaticResource KPICardStyle}"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="⚡ Hızlı İşlemler"
                                FontSize="16"
                                FontWeight="Bold"
                                   Foreground="#1E293B"
                                Margin="0,0,0,16"/>

                        <Button Name="QuickAddProductBtn"
                                Content="📦 Ürün Ekle"
                                Click="QuickAddProduct_Click"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Background="#10B981"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>

                        <Button Name="QuickBarcodeBtn"
                                Content="📱 Barkod Tara"
                                Click="QuickBarcode_Click"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Background="#3B82F6"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>

                        <Button Name="QuickStockBtn"
                                Content="📋 Stok Kontrolü"
                                Click="QuickStock_Click"
                                Margin="0,0,0,8"
                                Padding="12,8"
                                Background="#8B5CF6"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- System Status -->
                <Border Style="{StaticResource KPICardStyle}">
                    <StackPanel>
                        <TextBlock Text="🔧 Sistem Durumu"
                                FontSize="16"
                                FontWeight="Bold"
                                   Foreground="#1E293B"
                                Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Veritabanı"
                                    Grid.Column="0"/>
                            <Ellipse Name="DatabaseStatusIndicator"
                                    Grid.Column="1"
                                    Width="12"
                                    Height="12"
                                     Fill="#10B981"
                                    Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Barkod Tarayıcı"
                                    Grid.Column="0"/>
                            <Ellipse Name="BarcodeStatusIndicator"
                                    Grid.Column="1"
                                    Width="12"
                                    Height="12"
                                     Fill="#F59E0B"
                                    Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="OpenCart Sync"
                                    Grid.Column="0"/>
                            <Ellipse Name="OpenCartStatusIndicator"
                                    Grid.Column="1"
                                    Width="12"
                                    Height="12"
                                     Fill="#EF4444"
                                    Margin="8,0,0,0"/>
                        </Grid>

                        <TextBlock Name="DatabaseInfoText"
                                Text="Veritabanı bilgisi yükleniyor..."
                                   FontSize="12"
                                Foreground="#64748B"
                                Margin="0,16,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay"
                Grid.Row="0"
                Grid.RowSpan="4"
                Background="#99FFFFFF"
                Visibility="Collapsed"
                Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                        Width="240"
                        Height="4"
                        Margin="0,0,0,12"/>
                <TextBlock Text="Dashboard verileri yükleniyor..."
                        FontSize="14"
                        Foreground="#555"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState"
                Grid.Row="0"
                Grid.RowSpan="4"
                Background="#F8FAFC"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <TextBlock Text="&#x1F4AD;"
                        FontSize="48"
                        HorizontalAlignment="Center"
                        Opacity="0.5"
                        Margin="0,0,0,8"/>
                <TextBlock Text="Veri yok"
                        FontSize="16"
                        Foreground="#64748B"
                        HorizontalAlignment="Center"
                        Opacity="0.7"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState"
                Grid.Row="0"
                Grid.RowSpan="4"
                Background="#F8FAFC"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <TextBlock Text="&#x26A0;"
                        FontSize="48"
                        HorizontalAlignment="Center"
                        Foreground="#E53935"
                        Margin="0,0,0,8"/>
                <TextBlock x:Name="DashboardErrorText"
                        Text="Dashboard yüklenemedi"
                        FontSize="14"
                        Foreground="#E53935"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12"
                        TextWrapping="Wrap"
                        MaxWidth="400"/>
                <Button Content="Tekrar Dene"
                        Padding="16,6"
                        Click="RetryDashboard_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
