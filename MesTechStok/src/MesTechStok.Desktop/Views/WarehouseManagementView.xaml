<UserControl x:Class="MesTechStok.Desktop.Views.WarehouseManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:MesTechStok.Desktop.ViewModels"
             xmlns:converters="clr-namespace:MesTechStok.Desktop.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400">

    <UserControl.DataContext>
        <vm:WarehouseManagementViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- EMR-06: Depo doluluk oranı renk converter -->
        <converters:OccupancyRateToColorConverter x:Key="OccupancyRateToColorConverter"/>
    </UserControl.Resources>
    
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Section -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="24" Margin="24,24,24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🏢 DEPO YÖNETİMİ" 
                               FontSize="24" FontWeight="Bold" 
                               Foreground="#1976D2" Margin="0,0,0,8"/>
                    <TextBlock Text="Depo bölümleri, raflar, gözler ve konumları yönetin" 
                               FontSize="16" Foreground="#666" Margin="0,0,0,16"/>
                    <TextBlock Text="Hiyerarşik yapı ile depo organizasyonu, CRUD işlemleri ve detaylı yönetim" 
                               FontSize="14" Foreground="#888"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="📊 Depo Durumu" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="#4CAF50" CornerRadius="8" Padding="12,6">
                        <TextBlock Text="✅ AKTİF" Foreground="White" FontWeight="Bold"/>
                    </Border>
                    
                    <!-- CRUD Butonları -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="🔄 Yenile" Command="{Binding RefreshWarehouseStructureCommand}" 
                                Style="{StaticResource ModernButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="🏗️ Bölüm Ekle" Command="{Binding AddZoneCommand}" 
                                Style="{StaticResource ModernButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="📦 Raf Ekle" Command="{Binding AddRackCommand}" 
                                Style="{StaticResource ModernButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="📚 Seviye Ekle" Command="{Binding AddShelfCommand}" 
                                Style="{StaticResource ModernButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="🗃️ Göz Ekle" Command="{Binding AddBinCommand}" 
                                Style="{StaticResource ModernButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Panel - TreeView -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="🔍 Arama" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="12,8" BorderThickness="1" BorderBrush="#E0E0E0" 
                             Margin="0,0,0,16" ToolTip="Depo yapısında arama yapın..."/>
                    
                    <TextBlock Text="📋 Depo Yapısı" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                    <TreeView ItemsSource="{Binding WarehouseStructure}" Height="400" 
                              SelectedItemChanged="WarehouseTreeView_SelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" (" Foreground="#666"/>
                                    <TextBlock Text="{Binding Code}" Foreground="#666"/>
                                    <TextBlock Text=")" Foreground="#666"/>
                                    <!-- EMR-06: Inline capacity bar -->
                                    <ProgressBar Value="{Binding OccupancyRate, FallbackValue=0}"
                                                 Maximum="100" Width="60" Height="6"
                                                 Foreground="{Binding OccupancyRate, FallbackValue=0, Converter={StaticResource OccupancyRateToColorConverter}}"
                                                 Background="#E0E0E0"
                                                 Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </StackPanel>
            </Border>
            
            <!-- Right Panel - Details -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="📋 Detaylar" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    
                    <!-- Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Status Message -->
                            <Border Background="#E3F2FD" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="#1976D2"/>
                            </Border>
                            
                            <!-- Loading Indicator -->
                            <Border Background="#FFF3E0" CornerRadius="8" Padding="16" Margin="0,0,0,16" 
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Depo yapısı yükleniyor..." FontSize="14" Foreground="#F57C00"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- No Selection -->
                            <Border Background="#F5F5F5" CornerRadius="8" Padding="24" 
                                    Visibility="{Binding NoSelectionVisibility, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="Sol panelden bir öğe seçin" FontSize="16" FontWeight="SemiBold" 
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="Seçilen öğenin detayları burada görüntülenecek" 
                                               FontSize="14" Foreground="#666" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Zone Details -->
                            <Border Background="#E8F5E8" CornerRadius="8" Padding="16" Margin="0,0,0,16" 
                                    Visibility="{Binding ZoneDetailsVisibility, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="🏗️ BÖLÜM DETAYLARI" FontSize="16" FontWeight="Bold" 
                                               Foreground="#2E7D32" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ad:" FontWeight="SemiBold" Margin="0,0,16,8"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedZone.Name}" Margin="0,0,0,8"/>
                                        
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Kod:" FontWeight="SemiBold" Margin="0,0,16,8"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedZone.Code}" Margin="0,0,0,8"/>
                                        
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Durum:" FontWeight="SemiBold" Margin="0,0,16,8"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedZone.IsActive, Converter={StaticResource BooleanToActiveTextConverter}}" Margin="0,0,0,8"/>
                                    </Grid>

                                    <!-- EMR-06: Depo kapasite/doluluk gösterimi -->
                                    <TextBlock Text="Doluluk Oranı" FontWeight="SemiBold" Margin="0,12,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0"
                                                     Value="{Binding SelectedZone.OccupancyRate, FallbackValue=0}"
                                                     Maximum="100"
                                                     Height="8"
                                                     Foreground="{Binding SelectedZone.OccupancyRate, FallbackValue=0, Converter={StaticResource OccupancyRateToColorConverter}}"
                                                     Background="#E0E0E0"
                                                     Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{Binding SelectedZone.OccupancyRate, FallbackValue=0, Converter={StaticResource OccupancyRateToColorConverter}}">
                                            <TextBlock.Text>
                                                <Binding Path="SelectedZone.OccupancyRate" FallbackValue="0"
                                                         StringFormat="{}{0:F0}%"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Action Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="✏️ Düzenle" Command="{Binding EditCommand}" 
                                Style="{StaticResource ModernButtonStyle}" Margin="0,0,8,0"
                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <Button Content="💾 Kaydet" Command="{Binding SaveChangesCommand}" 
                                Style="{StaticResource ModernButtonStyle}" Margin="0,0,8,0"
                                Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <Button Content="❌ İptal" Command="{Binding CancelEditCommand}" 
                                Style="{StaticResource ModernButtonStyle}"
                                Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading State -->
        <Border x:Name="LoadingOverlay"
                Grid.RowSpan="2"
                Background="#80000000"
                Visibility="Collapsed"
                Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="Yukleniyor..." Margin="0,12,0,0"
                           HorizontalAlignment="Center" Foreground="White" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState"
                Grid.RowSpan="2"
                Background="#F5F5F5"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x1F3E2;" FontSize="48" HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8"/>
                <TextBlock Text="Depo verisi yok" FontSize="16" Foreground="#6C757D"
                           HorizontalAlignment="Center" Opacity="0.7"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState"
                Grid.RowSpan="2"
                Background="#F5F5F5"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x26A0;" FontSize="48" HorizontalAlignment="Center"
                           Foreground="#F44336" Margin="0,0,0,8"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="14"
                           Foreground="#F44336" HorizontalAlignment="Center"
                           Margin="0,0,0,12" TextWrapping="Wrap" MaxWidth="400"/>
                <Button x:Name="RetryButton" Content="Tekrar Dene"
                        Click="RetryButton_Click"
                        Padding="12,8" Background="#1976D2" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
