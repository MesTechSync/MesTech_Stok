<UserControl x:Class="MesTechStok.Desktop.Views.Finance.ProfitLossView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header with period navigation -->
        <Border Grid.Row="0" Background="#2855AC" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Kar / Zarar Raporu" Foreground="White"
                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="◀" Command="{Binding PrevMonthCommand}"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" FontSize="16" Padding="8,4"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                    <TextBlock Text="{Binding PeriodLabel}" Foreground="White"
                               FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="8,0"/>
                    <Button Content="▶" Command="{Binding NextMonthCommand}"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" FontSize="16" Padding="8,4"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: 4 Summary Cards -->
        <Border Grid.Row="1" Background="#F8FAFC" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1: Gelir -->
                <Border Grid.Column="0" Background="White" CornerRadius="12"
                        Padding="20" Margin="6">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Gelir" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding TotalRevenue, StringFormat='{}{0:N2} TL'}"
                                   FontSize="22" FontWeight="Bold" Foreground="#10B981"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Card 2: Gider -->
                <Border Grid.Column="1" Background="White" CornerRadius="12"
                        Padding="20" Margin="6">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Gider" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding TotalExpenses, StringFormat='{}{0:N2} TL'}"
                                   FontSize="22" FontWeight="Bold" Foreground="#EF4444"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Card 3: Net Kar -->
                <Border Grid.Column="2" Background="White" CornerRadius="12"
                        Padding="20" Margin="6">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Net Kar" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding NetProfit, StringFormat='{}{0:N2} TL'}"
                                   FontSize="22" FontWeight="Bold" Foreground="#2563EB"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Card 4: Kar Marji -->
                <Border Grid.Column="3" Background="White" CornerRadius="12"
                        Padding="20" Margin="6">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Kar Marji" FontSize="12" Foreground="#6B7280"/>
                        <TextBlock Text="{Binding ProfitMargin, StringFormat='%{0:N1}'}"
                                   FontSize="22" FontWeight="Bold" Foreground="#8B5CF6"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 2: Placeholder for future chart / detail table -->
        <Border Grid.Row="2" Background="White" Margin="16">
            <TextBlock Text="Detayli rapor tablosu — H29 sonrasinda aktif edilecek"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="#94A3B8"/>
        </Border>
    </Grid>
</UserControl>
