<UserControl x:Class="MesTechStok.Desktop.Views.Finance.ExpensesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="#2855AC" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Gider Yonetimi" Foreground="White"
                               FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Yeni Gider"
                        Command="{Binding CreateExpenseCommand}"
                        Background="White" Foreground="#2855AC" FontWeight="SemiBold"
                        Padding="16,8" BorderThickness="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </Grid>
        </Border>

        <!-- Row 1: Summary Strip -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding TotalThisMonth, StringFormat='Bu ay: {0:C0}'}"
                           FontWeight="SemiBold" Foreground="#EF4444" Margin="0,0,24,0"/>
                <TextBlock Text="{Binding PendingCount, StringFormat='Bekleyen: {0}'}"
                           Foreground="#F59E0B" Margin="0,0,24,0"/>
                <TextBlock Text="{Binding ApprovedCount, StringFormat='Onayli: {0}'}"
                           Foreground="#10B981"/>
            </StackPanel>
        </Border>

        <!-- Row 2: DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Expenses}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  RowHeight="52"
                  BorderThickness="0"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Baslik" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="120"/>
                <DataGridTextColumn Header="Tarih"
                    Binding="{Binding ExpenseDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Tutar"
                    Binding="{Binding Amount, StringFormat='{}{0:N2} TL'}" Width="100"/>

                <DataGridTemplateColumn Header="Durum" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,3"
                                    Background="{Binding StatusColor}">
                                <TextBlock Text="{Binding StatusLabel}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Islem" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Onayla" FontSize="11" Padding="8,3"
                                        Margin="0,0,4,0"
                                        Visibility="{Binding CanApprove, Converter={StaticResource BoolToVisibility}}"
                                        Command="{Binding DataContext.ApproveCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Id}"
                                        Background="#10B981" Foreground="White"
                                        BorderThickness="0"/>
                                <Button Content="Reddet" FontSize="11" Padding="8,3"
                                        Visibility="{Binding CanApprove, Converter={StaticResource BoolToVisibility}}"
                                        Command="{Binding DataContext.RejectCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Id}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="#EF4444" BorderBrush="#EF4444"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
