<UserControl x:Class="MesTechStok.Desktop.Views.Finance.FixedExpenseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource MesTechPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e3f80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="8,8,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Sabit Giderler" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                    <TextBlock Text="Aylik tekrarlayan sabit gider kalemleri" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Sabit Gider Ekle" Style="{StaticResource SuccessBtn}"
                        Click="AddFixedExpense_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Row 1: KPI Cards -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Aylik Toplam" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="MonthlyTotalText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Yillik Toplam" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AnnualTotalText" Text="0,00 TL" FontSize="18" FontWeight="Bold" Foreground="#8B5CF6" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Aktif Kalem" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ActiveCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Pasif Kalem" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="InactiveCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#6C757D" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 2: DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="8,4,8,8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Sabit Gider Listesi" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="FixedExpenseGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserSortColumns="True" SelectionMode="Single"
                          AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          BorderThickness="0" FontSize="12" RowHeight="38" ColumnHeaderHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Gider Adi" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="130"/>
                        <DataGridTextColumn Header="Aylik Tutar" Binding="{Binding MonthlyAmount, StringFormat='{}{0:N2} TL'}" Width="120"/>
                        <DataGridTextColumn Header="Odeme Gunu" Binding="{Binding PaymentDay}" Width="90"/>
                        <DataGridTemplateColumn Header="Aktif" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3" Background="{Binding ActiveColor}" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding ActiveLabel}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White" HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Baslangic" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Not" Binding="{Binding Note}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource MesTechPrimary}"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="2" Visibility="Collapsed" Background="White" CornerRadius="12" Margin="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Sabit gider kaydi bulunamadi" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Yeni sabit gider ekleyerek baslayabilirsiniz" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="3" Visibility="Collapsed" Background="White" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#DC3545" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="Tekrar Dene" Click="RetryButton_Click" Margin="0,12,0,0" Padding="16,8" Background="{DynamicResource MesTechPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
