<UserControl x:Class="MesTechStok.Desktop.Views.Tasks.KanbanBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2855AC" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Projeler" Command="{Binding BackCommand}"
                        Background="Transparent" Foreground="White" BorderThickness="0"/>
                <TextBlock Grid.Column="1" Text="{Binding ProjectName}" Foreground="White"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="+ Görev" Command="{Binding CreateTaskCommand}"
                        Background="White" Foreground="#2855AC" FontWeight="SemiBold"
                        Padding="14,8" BorderThickness="0"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" Background="#F4F6F9">
            <StackPanel Orientation="Horizontal" Margin="16">

                <!-- Backlog / Beklemede -->
                <Border Width="250" Margin="0,0,12,0" VerticalAlignment="Top"
                        Background="White" CornerRadius="8"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#64748B"
                                CornerRadius="8,8,0,0" Padding="12,8">
                            <TextBlock Text="Beklemede" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding BacklogTasks}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10"
                                            Background="#F8FAFC" CornerRadius="6"
                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat='Son: {0:dd.MM.yyyy}'}"
                                                       FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- Todo / Yapılacak -->
                <Border Width="250" Margin="0,0,12,0" VerticalAlignment="Top"
                        Background="White" CornerRadius="8"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#3B82F6"
                                CornerRadius="8,8,0,0" Padding="12,8">
                            <TextBlock Text="Yapılacak" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding TodoTasks}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10"
                                            Background="#F8FAFC" CornerRadius="6"
                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat='Son: {0:dd.MM.yyyy}'}"
                                                       FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- InProgress / Devam Ediyor -->
                <Border Width="250" Margin="0,0,12,0" VerticalAlignment="Top"
                        Background="White" CornerRadius="8"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F59E0B"
                                CornerRadius="8,8,0,0" Padding="12,8">
                            <TextBlock Text="Devam Ediyor" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding InProgressTasks}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10"
                                            Background="#F8FAFC" CornerRadius="6"
                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat='Son: {0:dd.MM.yyyy}'}"
                                                       FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- InReview / İncelemede -->
                <Border Width="250" Margin="0,0,12,0" VerticalAlignment="Top"
                        Background="White" CornerRadius="8"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#8B5CF6"
                                CornerRadius="8,8,0,0" Padding="12,8">
                            <TextBlock Text="İncelemede" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding InReviewTasks}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10"
                                            Background="#F8FAFC" CornerRadius="6"
                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat='Son: {0:dd.MM.yyyy}'}"
                                                       FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <!-- Done / Tamamlandı -->
                <Border Width="250" Margin="0,0,0,0" VerticalAlignment="Top"
                        Background="White" CornerRadius="8"
                        Effect="{StaticResource MaterialDesignShadowDepth1}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#10B981"
                                CornerRadius="8,8,0,0" Padding="12,8">
                            <TextBlock Text="Tamamlandı" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding DoneTasks}" Margin="8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10"
                                            Background="#F8FAFC" CornerRadius="6"
                                            BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat='Son: {0:dd.MM.yyyy}'}"
                                                       FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
