<UserControl x:Class="MesTechStok.Desktop.Views.UnifiedOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Modern Card Style -->
        <Style x:Key="OrderCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005a9e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#DC3545"/>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#FFC107"/>
            <Setter Property="Foreground" Value="#212529"/>
        </Style>

        <Style x:Key="InfoButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#17A2B8"/>
        </Style>

        <!-- Status Badge Styles -->
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- Platform Badge Style -->
        <Style x:Key="PlatformBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F3F4"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F7FA" Padding="0,0,0,10">
            <Grid Margin="15" SnapsToDevicePixels="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Header -->
                <Border Grid.Row="0" Style="{StaticResource OrderCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="&#x1F6D2;" FontSize="28" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="Birlesik Siparis Paneli"
                                          FontSize="24"
                                          FontWeight="Bold"
                                          Foreground="#2C3E50"/>
                                <TextBlock Text="Tum platformlarin siparisleri tek ekranda"
                                          FontSize="13"
                                          Foreground="#6C757D"
                                          Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="&#x1F4E5; Excel"
                                   Style="{StaticResource SuccessButton}"
                                   Click="ExportExcel_Click"
                                   Margin="5,0"/>
                            <Button Content="&#x1F4C4; CSV"
                                   Style="{StaticResource InfoButton}"
                                   Click="ExportCsv_Click"
                                   Margin="5,0"/>
                            <Button Content="&#x1F504; Yenile"
                                   Style="{StaticResource PrimaryButton}"
                                   Click="Refresh_Click"
                                   Margin="5,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Row 1: Platform Stats -->
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,10,0,0">
                    <!-- Trendyol -->
                    <Border CornerRadius="12" Padding="16" Margin="5" Background="#f27a1a">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Trendyol" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="TrendyolCountText" Text="0 siparis" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Ciceksepeti -->
                    <Border CornerRadius="12" Padding="16" Margin="5" Background="#6c3f99">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Ciceksepeti" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="CiceksepetiCountText" Text="0 siparis" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Hepsiburada -->
                    <Border CornerRadius="12" Padding="16" Margin="5" Background="#ff6000">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Hepsiburada" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="HepsiburadaCountText" Text="0 siparis" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- OpenCart -->
                    <Border CornerRadius="12" Padding="16" Margin="5" Background="#3498db">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="OpenCart" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="OpencartCountText" Text="0 siparis" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Row 2: Filters -->
                <Border Grid.Row="2" Style="{StaticResource OrderCard}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Platform Filters -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Platform Filtresi" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="ChkTrendyol" Content="Trendyol" IsChecked="True" Margin="0,0,10,0"
                                         FontSize="12" VerticalContentAlignment="Center"
                                         Checked="FilterChanged" Unchecked="FilterChanged"/>
                                <CheckBox x:Name="ChkCiceksepeti" Content="Ciceksepeti" IsChecked="True" Margin="0,0,10,0"
                                         FontSize="12" VerticalContentAlignment="Center"
                                         Checked="FilterChanged" Unchecked="FilterChanged"/>
                                <CheckBox x:Name="ChkHepsiburada" Content="Hepsiburada" IsChecked="True" Margin="0,0,10,0"
                                         FontSize="12" VerticalContentAlignment="Center"
                                         Checked="FilterChanged" Unchecked="FilterChanged"/>
                                <CheckBox x:Name="ChkOpencart" Content="OpenCart" IsChecked="True" Margin="0,0,10,0"
                                         FontSize="12" VerticalContentAlignment="Center"
                                         Checked="FilterChanged" Unchecked="FilterChanged"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Status Filter -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Durum" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,6"/>
                            <ComboBox x:Name="StatusFilterComboBox" Style="{StaticResource ModernComboBox}" Width="140"
                                     SelectionChanged="FilterChanged_ComboBox">
                                <ComboBoxItem Content="Tumu" IsSelected="True"/>
                                <ComboBoxItem Content="Bekleyen"/>
                                <ComboBoxItem Content="Isleniyor"/>
                                <ComboBoxItem Content="Kargoda"/>
                                <ComboBoxItem Content="Teslim"/>
                                <ComboBoxItem Content="Iptal"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Date Range -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Tarih Araligi" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <DatePicker x:Name="StartDatePicker" Width="130" FontSize="12" Margin="0,0,8,0"
                                           SelectedDateChanged="FilterChanged_Date"/>
                                <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#6C757D"/>
                                <DatePicker x:Name="EndDatePicker" Width="130" FontSize="12"
                                           SelectedDateChanged="FilterChanged_Date"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Search -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Arama" FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Margin="0,0,0,6"/>
                            <TextBox x:Name="SearchTextBox" Style="{StaticResource ModernTextBox}"
                                    TextChanged="SearchTextBox_TextChanged"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Row 3: DataGrid -->
                <Border Grid.Row="3" Style="{StaticResource OrderCard}" Margin="0,10,0,10">
                    <Grid>
                        <DataGrid x:Name="OrdersDataGrid"
                                 Style="{StaticResource ModernDataGrid}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                 MinHeight="300">
                            <DataGrid.Columns>
                                <!-- Platform Badge Column -->
                                <DataGridTemplateColumn Header="Platform" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource PlatformBadge}" x:Name="PlatformBorder">
                                                <TextBlock x:Name="PlatformText" Text="{Binding Platform}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Platform}" Value="Trendyol">
                                                    <Setter TargetName="PlatformBorder" Property="Background" Value="#f27a1a"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Platform}" Value="Ciceksepeti">
                                                    <Setter TargetName="PlatformBorder" Property="Background" Value="#6c3f99"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Platform}" Value="Hepsiburada">
                                                    <Setter TargetName="PlatformBorder" Property="Background" Value="#ff6000"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Platform}" Value="OpenCart">
                                                    <Setter TargetName="PlatformBorder" Property="Background" Value="#3498db"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderNumber}" Width="140" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Musteri" Binding="{Binding CustomerName}" Width="160" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Urun" Binding="{Binding ProductSummary}" Width="200" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Tutar" Binding="{Binding FormattedAmount}" Width="110" IsReadOnly="True"/>

                                <!-- Status Badge Column -->
                                <DataGridTemplateColumn Header="Durum" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource StatusBadge}" x:Name="StatusBorder">
                                                <TextBlock x:Name="StatusText" Text="{Binding Status}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Bekleyen">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#FFF3CD"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#856404"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Isleniyor">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#CCE5FF"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#004085"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Kargoda">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#D1ECF1"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#0C5460"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Teslim">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#D4EDDA"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#155724"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Iptal">
                                                    <Setter TargetName="StatusBorder" Property="Background" Value="#F8D7DA"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#721C24"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Tarih" Binding="{Binding FormattedDate}" Width="130" IsReadOnly="True"/>

                                <!-- Action Button Column -->
                                <DataGridTemplateColumn Header="Islem" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="&#x1F4CB; Detay"
                                                   Style="{StaticResource PrimaryButton}"
                                                   FontSize="10" Padding="6,4" Margin="2"
                                                   Click="ViewOrderDetail_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Loading Overlay -->
                        <Border x:Name="LoadingOverlay"
                               Background="#80FFFFFF"
                               Visibility="Collapsed"
                               Panel.ZIndex="999">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#x23F3;" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform CenterX="16" CenterY="16"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                   From="0" To="360" Duration="0:0:2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                                <TextBlock Text="Platformlardan siparisler yukleniyor..." FontSize="14" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Empty State -->
        <Border x:Name="EmptyState"
                Background="#F5F7FA"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x1F4E6;" FontSize="48" HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,8"/>
                <TextBlock Text="Siparis bulunamadi" FontSize="16" Foreground="#6C757D"
                           HorizontalAlignment="Center" Opacity="0.7"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState"
                Background="#F5F7FA"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x26A0;" FontSize="48" HorizontalAlignment="Center"
                           Foreground="#F44336" Margin="0,0,0,8"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="14"
                           Foreground="#F44336" HorizontalAlignment="Center"
                           Margin="0,0,0,12" TextWrapping="Wrap" MaxWidth="400"/>
                <Button x:Name="RetryButton" Content="Tekrar Dene"
                        Click="RetryButton_Click"
                        Padding="12,8" Background="#007ACC" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
