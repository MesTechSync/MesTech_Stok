<Window x:Class="MesTechStok.Desktop.Views.BulkCargoLabelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toplu Kargo Etiketi"
        Width="700" Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

  <Window.Resources>
    <Style x:Key="DialogPrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="#2196F3"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1976D2"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#BDBDBD"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DialogSecondaryButton" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButton}">
      <Setter Property="Background" Value="#607D8B"/>
    </Style>

    <Style x:Key="DialogSuccessButton" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButton}">
      <Setter Property="Background" Value="#4CAF50"/>
    </Style>

    <Style x:Key="DialogWarningButton" TargetType="Button" BasedOn="{StaticResource DialogPrimaryButton}">
      <Setter Property="Background" Value="#FB8C00"/>
    </Style>
  </Window.Resources>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <!-- Title -->
      <RowDefinition Height="Auto"/>
      <!-- Separator -->
      <RowDefinition Height="8"/>
      <!-- Format + Provider row -->
      <RowDefinition Height="Auto"/>
      <!-- Separator -->
      <RowDefinition Height="8"/>
      <!-- Shipments label -->
      <RowDefinition Height="Auto"/>
      <!-- DataGrid -->
      <RowDefinition Height="*"/>
      <!-- Summary bar -->
      <RowDefinition Height="Auto"/>
      <!-- Action row -->
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Row 0: Title -->
    <TextBlock Grid.Row="0"
               Text="Toplu Kargo Etiketi Yazdir"
               FontSize="18"
               FontWeight="Bold"
               Foreground="#1A1A2E"/>

    <!-- Row 2: Format selection (left) + Provider selection (right) -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="20"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Format selection -->
      <Border Grid.Column="0"
              Background="White"
              CornerRadius="8"
              Padding="14,10">
        <StackPanel>
          <TextBlock Text="Etiket Formati"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#6C757D"
                     Margin="0,0,0,8"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
            <RadioButton x:Name="FormatZpl"
                         Content="ZPL (Termal)"
                         IsChecked="True"
                         Margin="0,0,16,0"
                         VerticalContentAlignment="Center"/>
            <RadioButton x:Name="FormatPdf"
                         Content="PDF"
                         Margin="0,0,16,0"
                         VerticalContentAlignment="Center"/>
            <RadioButton x:Name="FormatPng"
                         Content="PNG"
                         VerticalContentAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Provider selection -->
      <Border Grid.Column="2"
              Background="White"
              CornerRadius="8"
              Padding="14,10">
        <StackPanel>
          <TextBlock Text="Kargo Firmasi"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#6C757D"
                     Margin="0,0,0,8"/>
          <ComboBox x:Name="CargoProvider"
                    SelectedIndex="0"
                    FontSize="13">
            <ComboBoxItem Content="Yurtici Kargo"/>
            <ComboBoxItem Content="Aras Kargo"/>
            <ComboBoxItem Content="Surat Kargo"/>
          </ComboBox>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Row 4: Shipments label -->
    <TextBlock Grid.Row="4"
               Text="Kargo Bekleyen Siparisler:"
               FontSize="13"
               FontWeight="SemiBold"
               Foreground="#37474F"
               Margin="0,0,0,4"/>

    <!-- Row 5: DataGrid -->
    <DataGrid x:Name="ShipmentsGrid"
              Grid.Row="5"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              IsReadOnly="False"
              SelectionMode="Single"
              GridLinesVisibility="Horizontal"
              HorizontalGridLinesBrush="#E0E0E0"
              Background="White"
              BorderBrush="#DEE2E6"
              BorderThickness="1"
              RowHeight="34"
              FontSize="13">
      <DataGrid.Columns>
        <DataGridCheckBoxColumn Header="Sec"
                                Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                Width="45"
                                IsReadOnly="False"/>
        <DataGridTextColumn Header="Siparis No"
                            Binding="{Binding OrderId}"
                            Width="130"
                            IsReadOnly="True"/>
        <DataGridTextColumn Header="Musteri"
                            Binding="{Binding CustomerName}"
                            Width="*"
                            IsReadOnly="True"/>
        <DataGridTextColumn Header="Platform"
                            Binding="{Binding Platform}"
                            Width="110"
                            IsReadOnly="True"/>
        <DataGridTextColumn Header="Kargo Takip"
                            Binding="{Binding TrackingNumber}"
                            Width="140"
                            IsReadOnly="True"/>
      </DataGrid.Columns>
    </DataGrid>

    <!-- Row 6: Summary bar -->
    <Border Grid.Row="6"
            Background="White"
            CornerRadius="6"
            Padding="12,8"
            Margin="0,8,0,0"
            BorderBrush="#DEE2E6"
            BorderThickness="1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="SelectionSummary"
                   Grid.Column="0"
                   Text="0 siparis secildi"
                   FontSize="13"
                   Foreground="#37474F"
                   VerticalAlignment="Center"/>

        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="Tumunu Sec"
                  Style="{StaticResource DialogPrimaryButton}"
                  Click="SelectAll_Click"
                  Margin="0,0,8,0"/>
          <Button Content="Secimi Kaldir"
                  Style="{StaticResource DialogSecondaryButton}"
                  Click="DeselectAll_Click"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Row 7: Action row -->
    <StackPanel Grid.Row="7"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="Iptal"
              Style="{StaticResource DialogSecondaryButton}"
              Click="Cancel_Click"
              Margin="0,0,10,0"/>
      <Button Content="Secilenleri Yazdir"
              Style="{StaticResource DialogSuccessButton}"
              Click="PrintLabels_Click"/>
    </StackPanel>
  </Grid>
</Window>
