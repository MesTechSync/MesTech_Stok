<Window x:Class="MesTechStok.Desktop.Views.ProductImportWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel İçe Aktarma Sihirbazı" Height="620" Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- File selection -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox x:Name="TxtFile" Width="560" IsReadOnly="True" Margin="0,0,8,0"/>
            <Button Content="Gözat..." Width="100" Click="Browse_Click" Margin="0,0,8,0"/>
            <Button Content="Yeniden Yükle" Width="120" Click="Reload_Click" Margin="0,0,8,0"/>
            <Button Content="📥 Örnek Şablon İndir" Width="170" Click="DownloadTemplate_Click"/>
        </StackPanel>

        <!-- Mapping grid -->
        <Border Grid.Row="1" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Sütun Eşleme" FontWeight="Bold" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkValidate" Content="Barkod formatını doğrula (EAN-13/EAN-8/UPC-A/UPC-E)" Margin="0,0,12,0"/>
                    <CheckBox x:Name="ChkSkipInvalid" Content="Geçersizleri atla"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,0,0,0">
                        <Button Content="Profili Yükle" Click="LoadProfile_Click" Margin="0,0,8,0"/>
                        <Button Content="Profili Kaydet" Click="SaveProfile_Click"/>
                    </StackPanel>
                </StackPanel>
                <DataGrid Grid.Row="1" x:Name="MappingGrid" AutoGenerateColumns="False" HeadersVisibility="Column"
                          CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="False"
                          ItemsSource="{Binding Mappings}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Alan" Binding="{Binding FieldName}" IsReadOnly="True" Width="200"/>
                        <DataGridTemplateColumn Header="Karşılık Gelen Sütun" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding Choices}" SelectedItem="{Binding HeaderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Zorunlu" Binding="{Binding RequiredDisplay}" IsReadOnly="True" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Preview -->
        <Border Grid.Row="2" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Önizleme (ilk 10 satır)" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox x:Name="PreviewList" Grid.Row="1"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="SummaryText" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button x:Name="BtnExportErrors" Content="Hataları Dışa Aktar" Click="ExportErrors_Click" Visibility="Collapsed" Margin="0,0,8,0"/>
            <Button Content="İptal" Click="Cancel_Click" Width="100" Margin="0,0,8,0"/>
            <Button x:Name="BtnImport" Content="İçe Aktar" Click="Import_Click" Width="120"/>
        </StackPanel>
        
        <!-- Busy overlay -->
        <Border x:Name="BusyOverlay" Background="#66000000" Visibility="Collapsed">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FFFFFFFF" Padding="16" CornerRadius="8">
                <StackPanel>
                    <TextBlock x:Name="BusyText" Text="İşlem yapılıyor…" FontSize="14" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Width="220" Height="6"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="4" Background="#80FFFFFF" Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#007BFF"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="2" Visibility="Collapsed" Background="White" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Ice aktarilacak veri yok" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Bir Excel dosyasi secmek icin Gozat butonunu kullanin" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="4" Visibility="Collapsed" Background="White" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#DC3545" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="Tekrar Dene" Click="RetryButton_Click" Margin="0,12,0,0" Padding="16,8" Background="#007BFF" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

