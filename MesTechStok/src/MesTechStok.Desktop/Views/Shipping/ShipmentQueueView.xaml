<UserControl x:Class="MesTechStok.Desktop.Views.Shipping.ShipmentQueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource MesTechPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e3f80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style x:Key="WarningBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#FFC107"/>
            <Setter Property="Foreground" Value="#212529"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="8,8,8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Gonderim Kuyrugu" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                    <TextBlock Text="Kargoya verilmeyi bekleyen siparisler ve toplu gonderim islemleri" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Kargo:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="#495057"/>
                    <ComboBox x:Name="CarrierFilter" Width="130" SelectedIndex="0" SelectionChanged="CarrierFilter_Changed">
                        <ComboBoxItem Content="Tumu"/>
                        <ComboBoxItem Content="Yurtici Kargo"/>
                        <ComboBoxItem Content="Aras Kargo"/>
                        <ComboBoxItem Content="Surat Kargo"/>
                        <ComboBoxItem Content="MNG Kargo"/>
                    </ComboBox>
                    <TextBlock Text="Oncelik:" VerticalAlignment="Center" Margin="16,0,8,0" FontSize="12" Foreground="#495057"/>
                    <ComboBox x:Name="PriorityFilter" Width="110" SelectedIndex="0" SelectionChanged="PriorityFilter_Changed">
                        <ComboBoxItem Content="Tumu"/>
                        <ComboBoxItem Content="Acil"/>
                        <ComboBoxItem Content="Normal"/>
                        <ComboBoxItem Content="Dusuk"/>
                    </ComboBox>
                    <Button Content="Toplu Gonder" Style="{StaticResource SuccessBtn}" Click="BulkShip_Click" Margin="12,0,0,0"/>
                    <Button Content="Etiket Yazdir" Style="{StaticResource WarningBtn}" Click="PrintLabels_Click" Margin="8,0,0,0"/>
                    <Button Content="Yenile" Style="{StaticResource ActionBtn}" Click="Refresh_Click" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: KPI Cards -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Kuyrukta" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="QueueCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource MesTechPrimary}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Acil" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="UrgentCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Bugun Gonderilen" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ShippedTodayText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Etiket Basilmamis" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="NoPrintText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#FFC107" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Ort. Bekleme" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AvgWaitText" Text="-" FontSize="18" FontWeight="Bold" Foreground="#17A2B8" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 2: Shipment Queue DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="8,4,8,8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Gonderim Bekleyenler" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" x:Name="ShipmentQueueGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserSortColumns="True" SelectionMode="Extended"
                          AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          BorderThickness="0" FontSize="12" RowHeight="34" ColumnHeaderHeight="36">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="30"/>
                        <DataGridTextColumn Header="Siparis No" Binding="{Binding OrderNo}" Width="140"/>
                        <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="110"/>
                        <DataGridTextColumn Header="Musteri" Binding="{Binding CustomerName}" Width="150"/>
                        <DataGridTextColumn Header="Urun Adedi" Binding="{Binding ItemCount}" Width="90"/>
                        <DataGridTextColumn Header="Kargo Firma" Binding="{Binding Carrier}" Width="110"/>
                        <DataGridTextColumn Header="Oncelik" Binding="{Binding Priority}" Width="80"/>
                        <DataGridTextColumn Header="Siparis Tarihi" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                        <DataGridTextColumn Header="Son Gonderim" Binding="{Binding Deadline, StringFormat=dd.MM.yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Etiket" Binding="{Binding LabelStatus}" Width="90"/>
                        <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource MesTechPrimary}"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.Row="2" Visibility="Collapsed" Background="White" CornerRadius="12" Margin="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Gonderim kuyrugu bos" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Kargoya verilmeyi bekleyen siparis bulunmamaktadir" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="3" Visibility="Collapsed" Background="White" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#DC3545" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="Tekrar Dene" Click="RetryButton_Click" Margin="0,12,0,0" Padding="16,8" Background="{DynamicResource MesTechPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
