<UserControl x:Class="MesTechStok.Desktop.Views.Store.StoreListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005a9e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style x:Key="StatusActive" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Fill" Value="#28A745"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="8,8,8,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="24" VerticalAlignment="Center" Foreground="#F27A1A" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Platform Magazalari" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                        <TextBlock Text="Tum pazaryeri magazalarini yonetin" FontSize="12" Foreground="#7F8C8D"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SuccessButton}" Content="+ Yeni Magaza Ekle" Margin="0,0,8,0"
                            Command="{Binding CreateStoreCommand}"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="Yenile" Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="8,4,8,0">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="250" Padding="8" FontSize="13" BorderBrush="#CED4DA" BorderThickness="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <ComboBox Width="180" Margin="12,0,0,0" Padding="8,6" FontSize="13"
                          SelectedItem="{Binding SelectedPlatformFilter}" ItemsSource="{Binding PlatformFilters}"/>
                <TextBlock Text="Toplam:" Margin="20,0,5,0" VerticalAlignment="Center" Foreground="#6C757D"/>
                <TextBlock Text="{Binding StoreCount}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#F27A1A"/>
            </StackPanel>
        </Border>

        <!-- Store List -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="8,4,8,8">
            <DataGrid ItemsSource="{Binding Stores}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      BorderThickness="0" Background="White" RowHeight="45" ColumnHeaderHeight="40"
                      SelectionMode="Single" SelectedItem="{Binding SelectedStore}">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F9FA"/>
                        <Setter Property="Foreground" Value="#495057"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderBrush" Value="#DEE2E6"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Magaza Adi" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="130"/>
                    <DataGridTextColumn Header="Tenant" Binding="{Binding TenantName}" Width="150"/>
                    <DataGridTextColumn Header="Durum" Binding="{Binding ConnectionStatus}" Width="120"/>
                    <DataGridTextColumn Header="Urun Sayisi" Binding="{Binding ProductCount}" Width="100"/>
                    <DataGridTextColumn Header="Son Sync" Binding="{Binding LastSync, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#007ACC"/>
                <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState" Grid.RowSpan="3" Background="White" Visibility="Collapsed" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                <TextBlock Text="Magaza bilgisi yok" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Yeni magaza ekleyerek baslayabilirsiniz" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState" Grid.RowSpan="3" Background="White" Visibility="Collapsed" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#F44336" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorMessage" Text="Bir hata olustu" FontSize="14" Foreground="#F44336" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap" MaxWidth="400"/>
                <Button x:Name="RetryButton" Content="Tekrar Dene" Margin="0,12,0,0" Padding="16,8" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand" Click="RetryButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
