<UserControl x:Class="MesTechStok.Desktop.Views.SimpleDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <UserControl.Resources>
        <!-- Dashboard Card Style -->
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Metric Text Style -->
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#6C757D"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="#F8F9FA">
        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay"
                Background="#99FFFFFF"
                Visibility="Collapsed"
                Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                        Width="240"
                        Height="4"
                        Margin="0,0,0,12"/>
                <TextBlock Text="Dashboard verileri yükleniyor..."
                        FontSize="14"
                        Foreground="#555"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Empty State -->
        <Border x:Name="EmptyState"
                Background="#F8F9FA"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <TextBlock Text="&#x1F4AD;"
                        FontSize="48"
                        HorizontalAlignment="Center"
                        Opacity="0.5"
                        Margin="0,0,0,8"/>
                <TextBlock Text="Henüz dashboard verisi bulunmuyor."
                        FontSize="16"
                        Foreground="#64748B"
                        HorizontalAlignment="Center"
                        Opacity="0.7"/>
            </StackPanel>
        </Border>

        <!-- Error State -->
        <Border x:Name="ErrorState"
                Background="#F8F9FA"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <TextBlock Text="&#x26A0;"
                        FontSize="48"
                        HorizontalAlignment="Center"
                        Foreground="#E53935"
                        Margin="0,0,0,8"/>
                <TextBlock x:Name="DashboardErrorText"
                        Text="Dashboard verileri yüklenemedi."
                        FontSize="14"
                        Foreground="#E53935"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12"
                        TextWrapping="Wrap"
                        MaxWidth="400"/>
                <Button Content="Tekrar Dene"
                        Padding="16,6"
                        Click="RefreshStock_Click"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="📊" FontSize="32" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="MesTech Dashboard" 
                          FontSize="28" 
                          FontWeight="Bold" 
                          Foreground="#2C3E50"
                          VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Metrics Cards Row -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Total Products Card -->
                <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalProductsText" Text="150" Style="{StaticResource MetricValue}"/>
                        <TextBlock Text="Toplam Ürün" Style="{StaticResource MetricLabel}"/>
                    </StackPanel>
                </Border>
                
                <!-- Low Stock Card -->
                <Border Grid.Column="1" Style="{StaticResource DashboardCard}">
                    <StackPanel>
                        <TextBlock Text="⚠️" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="LowStockText" Text="12" Style="{StaticResource MetricValue}" Foreground="#E74C3C"/>
                        <TextBlock Text="Düşük Stok" Style="{StaticResource MetricLabel}"/>
                    </StackPanel>
                </Border>
                
                <!-- Total Value Card -->
                <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalValueText" Text="₺25,000" Style="{StaticResource MetricValue}" Foreground="#27AE60"/>
                        <TextBlock Text="Toplam Değer" Style="{StaticResource MetricLabel}"/>
                    </StackPanel>
                </Border>
                
                <!-- System Status Card -->
                <Border Grid.Column="3" Style="{StaticResource DashboardCard}">
                    <StackPanel>
                        <TextBlock Text="🚀" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="Aktif" Style="{StaticResource MetricValue}" Foreground="#3498DB"/>
                        <TextBlock Text="Sistem Durumu" Style="{StaticResource MetricLabel}"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <!-- Quick Actions -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Quick Actions Panel -->
                <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock Text="⚡" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Hızlı İşlemler" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                        </StackPanel>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Quick Action Buttons -->
                            <Button Grid.Row="0" Grid.Column="0" 
                                   Content="📝 Yeni Ürün Ekle" 
                                   Margin="5" Padding="15,10" 
                                   Background="#3498DB" Foreground="White"
                                   BorderThickness="0" 
                                   Click="AddProduct_Click"/>
                            
                            <Button Grid.Row="0" Grid.Column="1" 
                                   Content="📱 Barkod Tara" 
                                   Margin="5" Padding="15,10"
                                   Background="#E67E22" Foreground="White"
                                   BorderThickness="0"
                                   Click="ScanBarcode_Click"/>
                            
                            <Button Grid.Row="0" Grid.Column="2" 
                                   Content="📊 Raporlar" 
                                   Margin="5" Padding="15,10"
                                   Background="#9B59B6" Foreground="White"
                                   BorderThickness="0"
                                   Click="ShowReports_Click"/>
                            
                            <Button Grid.Row="1" Grid.Column="0" 
                                   Content="🔄 Stok Yenile" 
                                   Margin="5" Padding="15,10"
                                   Background="#1ABC9C" Foreground="White"
                                   BorderThickness="0"
                                   Click="RefreshStock_Click"/>
                            
                            <Button Grid.Row="1" Grid.Column="1" 
                                   Content="🛒 OpenCart Sync" 
                                   Margin="5" Padding="15,10"
                                   Background="#E74C3C" Foreground="White"
                                   BorderThickness="0"
                                   Click="OpenCartSync_Click"/>
                            
                            <Button Grid.Row="1" Grid.Column="2" 
                                   Content="⚙️ Ayarlar" 
                                   Margin="5" Padding="15,10"
                                   Background="#95A5A6" Foreground="White"
                                   BorderThickness="0"
                                   Click="ShowSettings_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Recent Activity -->
                <Border Grid.Column="1" Style="{StaticResource DashboardCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="📈" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Son Aktiviteler" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                        </StackPanel>
                        
                        <StackPanel x:Name="ActivityPanel">
                            <TextBlock Text="🔄 Sistem başlatıldı" FontSize="12" Margin="0,2" Foreground="#6C757D"/>
                            <TextBlock Text="📦 150 ürün yüklendi" FontSize="12" Margin="0,2" Foreground="#6C757D"/>
                            <TextBlock Text="⚠️ 12 düşük stok uyarısı" FontSize="12" Margin="0,2" Foreground="#E74C3C"/>
                            <TextBlock Text="💰 Toplam değer hesaplandı" FontSize="12" Margin="0,2" Foreground="#27AE60"/>
                            <TextBlock Text="🌡️ Widget'lar aktif" FontSize="12" Margin="0,2" Foreground="#3498DB"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
    </Grid>
</UserControl>