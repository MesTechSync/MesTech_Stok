<UserControl x:Class="MesTechStok.Desktop.Views.ApiHealthDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HealthCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="MinHeight" Value="120"/>
        </Style>
        <Style x:Key="RefreshBtn" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005a9e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Header -->
            <Border Style="{StaticResource CardBorder}" Margin="8,8,8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="API Saglik Durumu" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                        <TextBlock x:Name="LastCheckText" Text="Son kontrol: --" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="AutoRefreshCheck" Content="Otomatik yenile (60s)" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="Simdi Kontrol Et" Style="{StaticResource RefreshBtn}" Click="RefreshHealth_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Overall Status -->
            <Border x:Name="OverallStatusBorder" Style="{StaticResource CardBorder}" Background="#E8F5E9" Margin="8,4">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="OverallStatusIcon" Text="OK" FontSize="36" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="OverallStatusText" Text="Tum sistemler calisiyor" FontSize="16" Foreground="#2E7D32" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Platform Health Cards -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Trendyol -->
                <Border Grid.Column="0" Style="{StaticResource HealthCard}" Background="#FFF3E0">
                    <StackPanel>
                        <TextBlock Text="Trendyol API" FontSize="16" FontWeight="Bold" Foreground="#E65100"/>
                        <Border Background="#FF6000" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock x:Name="TrendyolStatusText" Text="Kontrol ediliyor..." FontSize="11" Foreground="White" FontWeight="Medium"/>
                        </Border>
                        <TextBlock x:Name="TrendyolLatencyText" Text="Gecikme: -- ms" FontSize="12" Foreground="#795548" Margin="0,10,0,0"/>
                        <TextBlock x:Name="TrendyolLastSyncText" Text="Son sync: --" FontSize="11" Foreground="#9E9E9E" Margin="0,4,0,0"/>
                        <TextBlock x:Name="TrendyolRateLimitText" Text="Rate limit: --" FontSize="11" Foreground="#9E9E9E" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- OpenCart -->
                <Border Grid.Column="1" Style="{StaticResource HealthCard}" Background="#E3F2FD">
                    <StackPanel>
                        <TextBlock Text="OpenCart API" FontSize="16" FontWeight="Bold" Foreground="#0D47A1"/>
                        <Border Background="#007ACC" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock x:Name="OpenCartStatusText" Text="Kontrol ediliyor..." FontSize="11" Foreground="White" FontWeight="Medium"/>
                        </Border>
                        <TextBlock x:Name="OpenCartLatencyText" Text="Gecikme: -- ms" FontSize="12" Foreground="#37474F" Margin="0,10,0,0"/>
                        <TextBlock x:Name="OpenCartLastSyncText" Text="Son sync: --" FontSize="11" Foreground="#9E9E9E" Margin="0,4,0,0"/>
                        <TextBlock x:Name="OpenCartProductCountText" Text="Urun: --" FontSize="11" Foreground="#9E9E9E" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- e-Fatura -->
                <Border Grid.Column="2" Style="{StaticResource HealthCard}" Background="#F3E5F5">
                    <StackPanel>
                        <TextBlock Text="e-Fatura Servisi" FontSize="16" FontWeight="Bold" Foreground="#4A148C"/>
                        <Border Background="#7B1FA2" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock x:Name="InvoiceServiceStatusText" Text="Kontrol ediliyor..." FontSize="11" Foreground="White" FontWeight="Medium"/>
                        </Border>
                        <TextBlock x:Name="InvoiceServiceLatencyText" Text="Gecikme: -- ms" FontSize="12" Foreground="#4A148C" Margin="0,10,0,0"/>
                        <TextBlock x:Name="InvoiceTodayCountText" Text="Bugun: 0 fatura" FontSize="11" Foreground="#9E9E9E" Margin="0,4,0,0"/>
                        <TextBlock x:Name="InvoiceErrorCountText" Text="Hatali: 0" FontSize="11" Foreground="#9E9E9E" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Infrastructure Health Cards -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- PostgreSQL -->
                <Border Grid.Column="0" Style="{StaticResource HealthCard}" Background="#E8F5E9">
                    <StackPanel>
                        <TextBlock Text="PostgreSQL" FontSize="16" FontWeight="Bold" Foreground="#1B5E20"/>
                        <Border Background="#28A745" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock x:Name="PostgresStatusText" Text="Kontrol ediliyor..." FontSize="11" Foreground="White" FontWeight="Medium"/>
                        </Border>
                        <TextBlock x:Name="PostgresConnectionsText" Text="Baglantilar: --" FontSize="12" Foreground="#1B5E20" Margin="0,10,0,0"/>
                        <TextBlock x:Name="PostgresDbSizeText" Text="DB boyut: --" FontSize="11" Foreground="#9E9E9E" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Redis -->
                <Border Grid.Column="1" Style="{StaticResource HealthCard}" Background="#FFEBEE">
                    <StackPanel>
                        <TextBlock Text="Redis Cache" FontSize="16" FontWeight="Bold" Foreground="#B71C1C"/>
                        <Border Background="#DC3545" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock x:Name="RedisStatusText" Text="Kontrol ediliyor..." FontSize="11" Foreground="White" FontWeight="Medium"/>
                        </Border>
                        <TextBlock x:Name="RedisMemoryText" Text="Bellek: --" FontSize="12" Foreground="#B71C1C" Margin="0,10,0,0"/>
                        <TextBlock x:Name="RedisHitRateText" Text="Hit orani: --" FontSize="11" Foreground="#9E9E9E" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- RabbitMQ -->
                <Border Grid.Column="2" Style="{StaticResource HealthCard}" Background="#FFF8E1">
                    <StackPanel>
                        <TextBlock Text="RabbitMQ" FontSize="16" FontWeight="Bold" Foreground="#F57F17"/>
                        <Border Background="#FFC107" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock x:Name="RabbitMqStatusText" Text="Kontrol ediliyor..." FontSize="11" Foreground="#212529" FontWeight="Medium"/>
                        </Border>
                        <TextBlock x:Name="RabbitMqQueuesText" Text="Kuyruklar: --" FontSize="12" Foreground="#F57F17" Margin="0,10,0,0"/>
                        <TextBlock x:Name="RabbitMqMessagesText" Text="Bekleyen: --" FontSize="11" Foreground="#9E9E9E" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Health Events -->
            <Border Style="{StaticResource CardBorder}" Margin="8,12,8,8">
                <StackPanel>
                    <TextBlock Text="Son Saglik Olaylari" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,12"/>
                    <ListBox x:Name="HealthEventsList" MinHeight="100" MaxHeight="200" BorderBrush="#E9ECEF" BorderThickness="1" FontSize="12" FontFamily="Consolas"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
