<UserControl x:Class="MesTechStok.Desktop.Views.Notifications.NotificationDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2855AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e3f80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2855AC"/>
            <Setter Property="BorderBrush" Value="#2855AC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8EDF5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="AlternatingRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="8,8,8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Bildirim Paneli" FontSize="22" FontWeight="Bold" Foreground="#212529"/>
                        <TextBlock Text="WhatsApp, Telegram, Email, Push ve SMS bildirim yonetimi" FontSize="13" Foreground="#6C757D" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Yeni Bildirim" Style="{StaticResource ActionBtn}" Click="NewNotification_Click" Margin="0,0,8,0"/>
                        <Button Content="Yenile" Style="{StaticResource ActionBtn}" Click="Refresh_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Row 1: Stat Cards -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="8,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="BellOutline" Width="24" Height="24" Foreground="#2855AC" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Toplam Bildirim" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TotalCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#2855AC" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource StatCard}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="EmailNewsletter" Width="24" Height="24" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Okunmamis" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="UnreadCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="CheckCircleOutline" Width="24" Height="24" Foreground="#28A745" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Basarili" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="SuccessCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource StatCard}">
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="24" Height="24" Foreground="#DC3545" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Basarisiz" FontSize="11" Foreground="#6C757D" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="FailedCountText" Text="0" FontSize="18" FontWeight="Bold" Foreground="#DC3545" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Row 2: Filter Bar -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12" Margin="8,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Kanal:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="#495057"/>
                    <ComboBox x:Name="ChannelFilter" Width="140" SelectedIndex="0" SelectionChanged="ChannelFilter_Changed">
                        <ComboBoxItem Content="Tumu"/>
                        <ComboBoxItem Content="WhatsApp"/>
                        <ComboBoxItem Content="Telegram"/>
                        <ComboBoxItem Content="Email"/>
                        <ComboBoxItem Content="Push"/>
                        <ComboBoxItem Content="SMS"/>
                    </ComboBox>
                    <TextBlock Text="Durum:" VerticalAlignment="Center" Margin="16,0,8,0" FontSize="12" Foreground="#495057"/>
                    <ComboBox x:Name="StatusFilter" Width="140" SelectedIndex="0" SelectionChanged="StatusFilter_Changed">
                        <ComboBoxItem Content="Tumu"/>
                        <ComboBoxItem Content="Pending"/>
                        <ComboBoxItem Content="Sent"/>
                        <ComboBoxItem Content="Delivered"/>
                        <ComboBoxItem Content="Failed"/>
                        <ComboBoxItem Content="Read"/>
                    </ComboBox>
                    <TextBlock Text="Baslangic:" VerticalAlignment="Center" Margin="16,0,8,0" FontSize="12" Foreground="#495057"/>
                    <DatePicker x:Name="StartDatePicker" Width="130" SelectedDateChanged="DateFilter_Changed"/>
                    <TextBlock Text="Bitis:" VerticalAlignment="Center" Margin="16,0,8,0" FontSize="12" Foreground="#495057"/>
                    <DatePicker x:Name="EndDatePicker" Width="130" SelectedDateChanged="DateFilter_Changed"/>
                </StackPanel>
            </Border>

            <!-- Row 3: DataGrid -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="8,4,8,8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Bildirim Listesi" FontSize="16" FontWeight="Bold" Foreground="#212529" Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="1" x:Name="NotificationGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" SelectionMode="Single"
                              AlternationCount="2" RowStyle="{StaticResource AlternatingRowStyle}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" FontSize="12" RowHeight="38" ColumnHeaderHeight="36"
                              MinHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding SentAtText}" Width="140"/>
                            <DataGridTemplateColumn Header="Kanal" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{Binding ChannelColor}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Channel}" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Alici" Binding="{Binding Recipient}" Width="160"/>
                            <DataGridTextColumn Header="Sablon" Binding="{Binding TemplateName}" Width="140"/>
                            <DataGridTextColumn Header="Icerik" Binding="{Binding ContentPreview}" Width="*"/>
                            <DataGridTemplateColumn Header="Durum" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBackground}" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding StatusForeground}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Islem" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="Okundu" Style="{StaticResource SmallBtn}" Tag="{Binding Id}"
                                                    Click="MarkRead_Click" Margin="0,0,4,0"
                                                    Visibility="{Binding MarkReadVisibility}"/>
                                            <Button Content="Detay" Style="{StaticResource SmallBtn}" Tag="{Binding Id}"
                                                    Click="Detail_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Loading Overlay -->
            <Border x:Name="LoadingOverlay" Grid.RowSpan="4" Background="#80FFFFFF" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#2855AC"/>
                    <TextBlock Text="Yukleniyor..." FontSize="13" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Empty State -->
            <Border x:Name="EmptyState" Grid.Row="3" Visibility="Collapsed" Background="White" CornerRadius="12" Margin="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="BellOffOutline" Width="48" Height="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                    <TextBlock Text="Henuz bildirim bulunamadi" FontSize="15" Foreground="#6C757D" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="Yeni bildirim gondermek icin yukaridaki butonu kullanin" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
