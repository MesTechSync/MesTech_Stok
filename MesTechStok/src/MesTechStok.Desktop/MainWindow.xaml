<mah:MetroWindow x:Class="MesTechStok.Desktop.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:local="clr-namespace:MesTechStok.Desktop"
                 xmlns:components="clr-namespace:MesTechStok.Desktop.Components"
                 xmlns:ip="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                 mc:Ignorable="d"
                 Title="MesTech Stok Takip Sistemi v2.0"
                 Height="900"
        Width="1600"
                 MinHeight="800"
        MinWidth="1200"
                 WindowState="Maximized"
                 WindowStartupLocation="CenterScreen"
                 Background="#F5F7FA"
                 ShowInTaskbar="True"
                 Topmost="False"
                 ResizeMode="CanResize"
                 GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
                 TitleCharacterCasing="Normal"
                 TitleBarHeight="36"
                 WindowTransitionsEnabled="True"
                 ShowTitleBar="True"
                 BorderThickness="0">

    <mah:MetroWindow.Resources>
        <!-- Welcome Mini Nav Button for Screensaver Mode -->
        <Style x:Key="WelcomeMenuButtonStyle"
                TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="12,10"/>
            <Setter Property="Margin"
                    Value="0,6,0,6"/>
            <Setter Property="HorizontalAlignment"
                    Value="Stretch"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PART_Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1"
                                        ScaleY="1"/>
                            </Border.RenderTransform>
                            <Grid>
                                <!-- Left accent bar -->
                                <Border x:Name="PART_LeftAccent"
                                        Width="0"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource OrangePrimaryBrush}"
                                        Opacity="0.95"/>
                                <!-- Hover overlay -->
                                <Border x:Name="PART_Hover"
                                        CornerRadius="12"
                                        Opacity="0"
                                        Background="{StaticResource OrangeHoverGradientBrush}"/>
                                <!-- Content -->
                                <ContentPresenter HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="PART_Hover"
                                        Property="Opacity"
                                        Value="0.85"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_Root"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="1.03"
                                                    Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="PART_Root"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="1.03"
                                                    Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="PART_LeftAccent"
                                                    Storyboard.TargetProperty="Width"
                                                    To="4"
                                                    Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_Root"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="1.0"
                                                    Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="PART_Root"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="1.0"
                                                    Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="PART_LeftAccent"
                                                    Storyboard.TargetProperty="Width"
                                                    To="0"
                                                    Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle"
                TargetType="Button">
            <Setter Property="Background"
                    Value="#FB8C00"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="16,8"/>
            <Setter Property="Margin"
                    Value="4"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#F57C00"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#EF6C00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Navigation Menu Item Style -->
        <Style x:Key="NavMenuItemStyle"
                TargetType="Button">
            <Setter Property="Background"
                    Value="White"/>
            <Setter Property="Foreground"
                    Value="Black"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="BorderBrush"
                    Value="#E0E0E0"/>
            <Setter Property="Padding"
                    Value="16,12"/>
            <Setter Property="Margin"
                    Value="2,1"/>
            <Setter Property="HorizontalAlignment"
                    Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Sol aktif şerit -->
                                <Border x:Name="PART_LeftStrip"
                                        Grid.Column="0"
                                        Background="#FB8C00"
                                        CornerRadius="6,0,0,6"
                                        Visibility="Collapsed"/>

                                <!-- İçerik + Badge alanı -->
                                <Border Grid.Column="1"
                                        Margin="0"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Kullanıcı içeriği (ikon+metin) -->
                                        <ContentPresenter Grid.Column="0"
                                                VerticalAlignment="Center"/>
                                        <!-- Badge -->
                                        <Border x:Name="PART_Badge"
                                                Grid.Column="1"
                                                Background="#E53935"
                                                CornerRadius="10"
                                                Padding="8,2"
                                                Margin="10,0,0,0"
                                                Visibility="Collapsed">
                                            <TextBlock x:Name="PART_BadgeText"
                                                    Foreground="White"
                                                    FontSize="12"
                                                    FontWeight="Bold">
                                                <TextBlock.Text>
                                                    <Binding RelativeSource="{RelativeSource TemplatedParent}"
                                                            Path="(local:NavProperties.BadgeText)"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#F0F0F0"/>
                                <Setter Property="BorderBrush"
                                        Value="#FB8C00"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#E0E0E0"/>
                                <Setter Property="BorderBrush"
                                        Value="#EF6C00"/>
                            </Trigger>
                            <!-- Aktif durum -->
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(local:NavProperties.IsActive)}"
                                    Value="True">
                                <Setter TargetName="PART_LeftStrip"
                                        Property="Visibility"
                                        Value="Visible"/>
                                <Setter Property="Background"
                                        Value="#FFF3E0"/>
                                <Setter Property="BorderBrush"
                                        Value="#FB8C00"/>
                            </DataTrigger>
                            <!-- Badge görünürlüğü: HasBadge True ise göster -->
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(local:NavProperties.HasBadge)}"
                                    Value="True">
                                <Setter TargetName="PART_Badge"
                                        Property="Visibility"
                                        Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slide Animation for Gallery Panel -->
        <Storyboard x:Key="SlideInGallery">
            <DoubleAnimation Storyboard.TargetName="BackgroundGalleryPanel"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="350"
                    To="0"
                    Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BackgroundGalleryPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                    To="1"
                    Duration="0:0:0.3"/>
        </Storyboard>

        <Storyboard x:Key="SlideOutGallery">
            <DoubleAnimation Storyboard.TargetName="BackgroundGalleryPanel"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0"
                    To="350"
                    Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BackgroundGalleryPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="1"
                    To="0"
                    Duration="0:0:0.3"/>
        </Storyboard>

        <!-- Gallery Button Style -->
        <Style x:Key="GalleryToggleButtonStyle"
                TargetType="Button">
            <Setter Property="Background"
                    Value="#FB8C00"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Width"
                    Value="50"/>
            <Setter Property="Height"
                    Value="50"/>
            <Setter Property="FontSize"
                    Value="20"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="25">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15"
                                        ShadowDepth="3"
                                        Color="Black"
                                        Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#F57C00"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#EF6C00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid>
        <!-- Ana Layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="30"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Main Content -->
        </Grid.ColumnDefinitions>

        <!-- Header Bar - Firma/Sürüm/Veritabanı bilgisi -->
        <Border x:Name="HeaderBar"
                Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                    <ip:PackIconMaterial Kind="OfficeBuildingOutline"
                            Width="16"
                            Height="16"
                            Foreground="#2C3E50"
                            Margin="0,0,8,0"/>
                    <TextBlock x:Name="HeaderCompanyName"
                            Text="MesTech Teknoloji"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#2C3E50"/>
                    <TextBlock Text="  •  "
                            FontSize="14"
                            Foreground="#7F8C8D"/>
                    <TextBlock Text="MesTech Stok"
                            FontSize="14"
                            Foreground="#7F8C8D"/>
                    <TextBlock Text="  v2.0"
                            FontSize="14"
                            Foreground="#7F8C8D"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                    <ip:PackIconMaterial Kind="DatabaseOutline"
                            Width="14"
                            Height="14"
                            Foreground="#7F8C8D"
                            Margin="0,0,6,0"/>
                    <TextBlock x:Name="HeaderDbInfo"
                            Text="MesTech_stok – PostgreSQL (Docker)"
                            FontSize="12"
                            Foreground="#7F8C8D"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Layout Grid -->
        <Grid x:Name="MainLayoutGrid"
                Grid.Row="1">
            <!-- Welcome Mode Background Image (kept collapsed for code-behind compatibility) -->
            <Image x:Name="WelcomeBackgroundImage"
                   Stretch="UniformToFill"
                   Visibility="Collapsed"
                   Panel.ZIndex="1"/>

            <!-- Dark Overlay for Welcome Mode (kept collapsed) -->
            <Rectangle x:Name="WelcomeOverlay"
                       Fill="#B3000000"
                       Visibility="Collapsed"
                       Panel.ZIndex="2"/>

            <!-- Password Login Overlay (disabled by default) -->
            <Grid x:Name="PasswordOverlay"
                  Background="#AA000000"
                  Visibility="Collapsed"
                  Panel.ZIndex="10">
                <!-- Password Login Panel -->
                <Border Background="#FFFFFF"
                        CornerRadius="20"
                        Width="450"
                        Height="350"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30"
                                ShadowDepth="15"
                                Color="Black"
                                Opacity="0.4"/>
                    </Border.Effect>

                    <Grid Margin="40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Logo ve Başlık -->
                        <StackPanel Grid.Row="0"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,20">
                            <Border Background="#2196F3"
                                    CornerRadius="10"
                                    Padding="15,8"
                                    HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔐"
                                            FontSize="24"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="MesTech Güvenlik"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Açıklama -->
                        <TextBlock Grid.Row="1"
                                   Text="Sistem erişimi için şifrenizi giriniz"
                                   FontSize="14"
                                   Foreground="#666666"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,25"/>

                        <!-- Şifre Kutusu -->
                        <Border Grid.Row="2"
                                Background="#F8F9FA"
                                BorderBrush="#E0E0E0"
                                BorderThickness="2"
                                CornerRadius="8"
                                Margin="0,0,0,20">
                            <PasswordBox x:Name="PasswordBox"
                                         FontSize="16"
                                         Padding="15,12"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         PasswordChar="●"/>
                        </Border>

                        <!-- Giriş Butonu -->
                        <Button Grid.Row="3"
                                x:Name="LoginButton"
                                Content="Giriş Yap"
                                Background="#4CAF50"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                Padding="20,12"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,0,15"
                                Click="LoginButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                            Value="True">
                                                        <Setter Property="Background"
                                                                Value="#45A049"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed"
                                                            Value="True">
                                                        <Setter Property="Background"
                                                                Value="#3E8E41"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Hata Mesajı -->
                        <TextBlock Grid.Row="4"
                                   x:Name="ErrorMessage"
                                   Text=""
                                   FontSize="12"
                                   Foreground="#F44336"
                                   HorizontalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Welcome content moved to standalone Views/WelcomeWindow; placeholder collapsed root to keep names if referenced -->
            <Grid x:Name="WelcomeContent"
                    Visibility="Collapsed"
                    Panel.ZIndex="3">

                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <!-- Header -->
                    <RowDefinition Height="*"/>
                    <!-- Content -->
                    <RowDefinition Height="120"/>
                    <!-- Footer Controls -->
                </Grid.RowDefinitions>

                <!-- Header with Logo -->
                <Grid Grid.Row="0"
                        Margin="40,20">
                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                        <!-- 3D Logo -->
                        <Border Background="#FB8C00"
                                CornerRadius="15"
                                Padding="20,10"
                                Margin="0,0,20,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15"
                                        ShadowDepth="5"
                                        Color="Black"
                                        Opacity="0.4"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏢"
                                        FontSize="32"
                                        Margin="0,0,10,0"/>
                                <TextBlock Text="MesTech"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Stok Takip Sistemi"
                                   FontSize="24"
                                   FontWeight="Light"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,5,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="5"
                                        ShadowDepth="2"
                                        Color="Black"
                                        Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Floating Action Button removed in MainWindow welcome placeholder -->

                <!-- Main Content Area -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <!-- Left Mini Menu -->
                        <ColumnDefinition Width="*"/>
                        <!-- Center Content -->
                        <ColumnDefinition Width="350"/>
                        <!-- Right Panel -->
                    </Grid.ColumnDefinitions>

                    <!-- Center Content - Ana Karşılama -->
                    <!-- Left Mini Menu Panel -->
                    <Border Grid.Column="0"
                            Background="#B3000000"
                            CornerRadius="25"
                            Margin="40,60,20,60"
                            Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="25"
                                    ShadowDepth="8"
                                    Color="Black"
                                    Opacity="0.45"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,12"
                                    HorizontalAlignment="Left">
                                <ip:PackIconMaterial Kind="OfficeBuildingOutline"
                                        Width="18"
                                        Height="18"
                                        Foreground="White"
                                        Margin="0,0,8,0"/>
                                <TextBlock Text="MesTech Stok"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="White"/>
                            </StackPanel>
                            <Separator Background="#40FFFFFF"
                                    Margin="0,0,0,10"/>
                            <Button Style="{StaticResource WelcomeMenuButtonStyle}"
                                    ToolTip="Ürünleri görüntüleyin ve yönetin"
                                    Click="NavProducts_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ip:PackIconMaterial Kind="PackageVariantClosed"
                                            Width="16"
                                            Height="16"
                                            Foreground="White"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Ürünler"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource WelcomeMenuButtonStyle}"
                                    ToolTip="Depo ve stok hareketlerini takip edin"
                                    Click="NavStock_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ip:PackIconMaterial Kind="Warehouse"
                                            Width="16"
                                            Height="16"
                                            Foreground="White"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Stok Takibi"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource WelcomeMenuButtonStyle}"
                                    ToolTip="Raporları inceleyin"
                                    Click="NavReports_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ip:PackIconMaterial Kind="ChartAreaspline"
                                            Width="16"
                                            Height="16"
                                            Foreground="White"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Raporlar"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- STOK YERLEŞİM SİSTEMİ Ana Menü -->
                            <Button x:Name="NavStockPlacement"
                                    Style="{StaticResource WelcomeMenuButtonStyle}"
                                    ToolTip="Stok yerleşim sistemini yönetin"
                                    Click="NavStockPlacement_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ip:PackIconMaterial Kind="MapMarkerMultiple"
                                            Width="16"
                                            Height="16"
                                            Foreground="White"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="STOK YERLEŞİM"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- STOK YERLEŞİM SİSTEMİ Alt Menüleri -->
                            <Button Style="{StaticResource WelcomeMenuButtonStyle}"
                                    ToolTip="Depo yönetimi"
                                    Click="NavWarehouseManagement_Click"
                                    Margin="20,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <ip:PackIconMaterial Kind="Warehouse"
                                            Width="14"
                                            Height="14"
                                            Foreground="White"
                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Depo Yönetimi"
                                            VerticalAlignment="Center"
                                            FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource WelcomeMenuButtonStyle}"
                                    ToolTip="Konum takibi"
                                    Click="NavLocationTracking_Click"
                                    Margin="20,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <ip:PackIconMaterial Kind="CrosshairsGps"
                                            Width="14"
                                            Height="14"
                                            Foreground="White"
                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Konum Takibi"
                                            VerticalAlignment="Center"
                                            FontSize="12"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource WelcomeMenuButtonStyle}"
                                    ToolTip="Depo haritası"
                                    Click="NavWarehouseMap_Click"
                                    Margin="20,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <ip:PackIconMaterial Kind="Map"
                                            Width="14"
                                            Height="14"
                                            Foreground="White"
                                            Margin="0,0,8,0"/>
