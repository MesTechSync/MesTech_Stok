                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavApiHealthDashboard"
                                        Style="{StaticResource NavMenuItemStyle}"
                                        Click="NavApiHealthDashboard_Click"
                                        ToolTipService.Placement="Right"
                                        ToolTip="API Sağlık Durumu">
                                    <StackPanel Orientation="Horizontal">
                                        <ip:PackIconMaterial Kind="HeartPulse"
                                                Width="20"
                                                Height="20"
                                                Foreground="#F57C00"
                                                Margin="0,0,12,0"/>
                                        <TextBlock Text="API Sağlık"
                                                VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SidebarToggle, Path=IsChecked}"
                                                                Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavPlatformSyncStatus"
                                        Style="{StaticResource NavMenuItemStyle}"
                                        Click="NavPlatformSyncStatus_Click"
                                        ToolTipService.Placement="Right"
                                        ToolTip="Sync Durumu">
                                    <StackPanel Orientation="Horizontal">
                                        <ip:PackIconMaterial Kind="SyncCircle"
                                                Width="20"
                                                Height="20"
                                                Foreground="#F57C00"
                                                Margin="0,0,12,0"/>
                                        <TextBlock Text="Sync Durumu"
                                                VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SidebarToggle, Path=IsChecked}"
                                                                Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavLogs"
                                        Style="{StaticResource NavMenuItemStyle}"
                                        Click="NavLogs_Click"
                                        ToolTipService.Placement="Right"
                                        ToolTip="Log Takip">
                                    <StackPanel Orientation="Horizontal">
                                        <ip:PackIconMaterial Kind="FileDocumentOutline"
                                                Width="20"
                                                Height="20"
                                                Foreground="#F57C00"
                                                Margin="0,0,12,0"/>
                                        <TextBlock Text="Log Takip"
                                                VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SidebarToggle, Path=IsChecked}"
                                                                Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavTasksProjects"
                                        Style="{StaticResource NavMenuItemStyle}"
                                        Click="NavTasksProjects_Click"
                                        ToolTipService.Placement="Right"
                                        ToolTip="Projeler">
                                    <StackPanel Orientation="Horizontal">
                                        <ip:PackIconMaterial Kind="FolderOutline"
                                                Width="20"
                                                Height="20"
                                                Foreground="#F57C00"
                                                Margin="0,0,12,0"/>
                                        <TextBlock Text="Projeler"
                                                VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SidebarToggle, Path=IsChecked}"
                                                                Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavCalendar"
                                        Style="{StaticResource NavMenuItemStyle}"
                                        Click="NavCalendar_Click"
                                        ToolTipService.Placement="Right"
                                        ToolTip="Takvim">
                                    <StackPanel Orientation="Horizontal">
                                        <ip:PackIconMaterial Kind="CalendarOutline"
                                                Width="20"
                                                Height="20"
                                                Foreground="#F57C00"
                                                Margin="0,0,12,0"/>
                                        <TextBlock Text="Takvim"
                                                VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SidebarToggle, Path=IsChecked}"
                                                                Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="NavHrEmployees"
                                        Style="{StaticResource NavMenuItemStyle}"
                                        Click="NavHrEmployees_Click"
                                        ToolTipService.Placement="Right"
                                        ToolTip="İnsan Kaynakları">
                                    <StackPanel Orientation="Horizontal">
                                        <ip:PackIconMaterial Kind="AccountHardHatOutline"
                                                Width="20"
                                                Height="20"
                                                Foreground="#F57C00"
                                                Margin="0,0,12,0"/>
                                        <TextBlock Text="İnsan Kaynakları"
                                                VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SidebarToggle, Path=IsChecked}"
                                                                Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <!-- ═══ Ana Ekrana Dön ═══ -->
                                <Separator Margin="16,10" Background="#E0E0E0"/>

                                <Button x:Name="NavReturnToWelcome"
                                        Style="{StaticResource NavMenuItemStyle}"
                                        Click="NavReturnToWelcome_Click"
                                        ToolTipService.Placement="Right"
                                        ToolTip="Ana Ekrana Dön">
                                    <StackPanel Orientation="Horizontal">
                                        <ip:PackIconMaterial Kind="HomeOutline"
                                                Width="20"
                                                Height="20"
                                                Foreground="#F57C00"
                                                Margin="0,0,12,0"/>
                                        <TextBlock Text="Ana Ekrana Dön"
                                                VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=SidebarToggle, Path=IsChecked}"
                                                                Value="True">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- User Info -->
                        <Border Grid.Row="2"
                                Background="#E6E9EE"
                                BorderBrush="#E0E0E0"
                                BorderThickness="0,1,0,0"
                                Padding="20,15">
                            <StackPanel Orientation="Horizontal">
                                <ip:PackIconMaterial Kind="AccountCircleOutline"
                                        Width="16"
                                        Height="16"
                                        Foreground="#555"
                                        Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="Admin User"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="Black"/>
                                    <TextBlock Text="Sistem Yöneticisi"
                                               FontSize="10"
                                               Foreground="#555"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Main Content Area -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Breadcrumb - Auto height -->
                        <RowDefinition Height="*"/>
                        <!-- Content - Fill remaining space -->
                    </Grid.RowDefinitions>

                    <!-- Breadcrumb/Title Bar -->
                    <Border Grid.Row="0"
                            Background="#FFFFFF"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1"
                            Padding="25,12"
                            MinHeight="50">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                <TextBlock Text="📊"
                                        FontSize="16"
                                        Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding CurrentModule, FallbackValue='Ana Sayfa'}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                <Button Content="🏠"
                                        FontSize="14"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Background="Transparent"
                                        Foreground="#7F8C8D"
                                        Command="{Binding ShowDashboardCommand}"
                                        ToolTip="Ana Sayfaya Dön"
                                        Margin="0,0,10,0"/>
                                <Button Content="🔄"
                                        FontSize="14"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Background="Transparent"
                                        Foreground="#7F8C8D"
                                        Command="{Binding RefreshCommand}"
                                        ToolTip="Yenile"/>
                            </StackPanel>

                            <!-- Gallery Toggle removed -->
                        </Grid>
                    </Border>

                    <!-- Content Frame - FIXED: Now in correct grid column with proper sizing -->
                    <Frame Grid.Row="1"
                           x:Name="MainContentFrame"
                           NavigationUIVisibility="Hidden"
                           Content="{Binding CurrentView}"
                           Background="#F8F9FA"
                           Margin="10"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           ClipToBounds="False"/>
                </Grid>

                <!-- Background Gallery Panel removed -->
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="#F8F9FA"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                        Text="🚀 MesTech Stok Takip Sistemi v2.0"
                        FontSize="12"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"/>

                <!-- Status Info -->
                <TextBlock Grid.Column="1"
                        Text="🌡️ Hava Durumu &amp; Saat Widget Aktif"
                        FontSize="11"
                        Margin="10,0"
                        VerticalAlignment="Center"
                        Foreground="#666"/>

                <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="15,0,0,0">
                    <TextBlock Text="👤 Admin"
                            FontSize="11"
                            Margin="0,0,15,0"
                            VerticalAlignment="Center"
                            Foreground="#666"/>
                    <Button x:Name="LogoutButton"
                            Content="🚪 Çıkış"
                            FontSize="11"
                            Padding="10,4"
                            Margin="10,0,0,0"
                            Cursor="Hand"
                            Background="#EF5350"
                            Foreground="White"
                            BorderThickness="0"
                            Click="LogoutButton_Click"/>
                    <TextBlock x:Name="VersionProLink"
                               Text="📊 v2.0 PRO"
                               FontSize="11"
                               Margin="0,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#666"
                               Cursor="Hand"
                               TextDecorations="Underline"
                               MouseLeftButtonDown="VersionProLink_MouseLeftButtonDown"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toast Container - Bottom Right Position Fixed -->
        <ItemsControl x:Name="ToastItemsControl"
                      Panel.ZIndex="1000"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="20,0,20,70">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"
                            IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="LightGray"
                            CornerRadius="5"
                            Padding="10"
                            Margin="5">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                    FontWeight="Bold"/>
                            <TextBlock Text="{Binding Message}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</mah:MetroWindow>
