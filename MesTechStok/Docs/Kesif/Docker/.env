# ═══════════════════════════════════════════════════════════
# MesTech Entegratör Stok — Ortam Değişkenleri Şablonu
# ═══════════════════════════════════════════════════════════
#
# KULLANIM:
#   1. Bu dosyayı .env olarak kopyalayın: cp .env.example .env
#   2. Şifreleri güncelleyin (mestech_redis_dev kısımlarını)
#   3. docker compose up -d
#
# ÖNEMLİ: .env dosyası git'e ASLA commit edilmez!
# ═══════════════════════════════════════════════════════════

# ─── PostgreSQL ───
POSTGRES_DB=mestech_stok
POSTGRES_USER=mestech_user
POSTGRES_PASSWORD=mestech_postgres_dev
POSTGRES_PORT=5432

# ─── Redis ───
REDIS_PASSWORD=mestech_redis_dev
REDIS_PORT=6379

# ─── RabbitMQ ───
RABBITMQ_USER=mestech_mq
RABBITMQ_DEFAULT_PASS=mestech_mq_dev
RABBITMQ_VHOST=mestech
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
