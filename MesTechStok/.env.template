# MesTech Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials

# ── PostgreSQL ──────────────────────────────────────
MESTECH_PG_CONNECTION=Host=localhost;Port=5432;Database=mestech_stok;Username=mestech_user;Password=YOUR_PASSWORD_HERE

# ── RabbitMQ ────────────────────────────────────────
RabbitMQ__Host=localhost
RabbitMQ__Port=5672
RabbitMQ__Username=YOUR_RABBITMQ_USER
RabbitMQ__Password=YOUR_RABBITMQ_PASSWORD

# ── Redis ───────────────────────────────────────────
Redis__Configuration=localhost:6379

# ── Trendyol API ────────────────────────────────────
Trendyol__ApiKey=YOUR_TRENDYOL_API_KEY
Trendyol__ApiSecret=YOUR_TRENDYOL_API_SECRET
Trendyol__SupplierId=YOUR_SUPPLIER_ID

# ── OpenCart ────────────────────────────────────────
OpenCart__BaseUrl=https://your-opencart-store.com
OpenCart__ApiKey=YOUR_OPENCART_API_KEY

# ── Hangfire ────────────────────────────────────────
Hangfire__PostgresConnection=Host=localhost;Port=5432;Database=mestech_hangfire;Username=mestech_user;Password=YOUR_PASSWORD_HERE

# ── MESA OS (AI Bridge) ────────────────────────────
MesaOs__BaseUrl=http://localhost:3100
MesaOs__ApiKey=YOUR_MESA_API_KEY

# ── Ciceksepeti (Sandbox) ─────────────────────
Ciceksepeti__BaseUrl=https://sandbox-apis.ciceksepeti.com/api/v1/
Ciceksepeti__ApiKey=YOUR_CS_SANDBOX_API_KEY

# ── Hepsiburada (Sandbox) ─────────────────────
Hepsiburada__BaseUrl=https://sandbox-api.hepsiburada.com/
Hepsiburada__MerchantId=YOUR_HB_MERCHANT_ID
Hepsiburada__ApiKey=YOUR_HB_API_KEY
Hepsiburada__ApiSecret=YOUR_HB_API_SECRET

# ── Kargo Firmalari ───────────────────────────
Cargo__Yurtici__UserName=YOUR_YURTICI_USERNAME
Cargo__Yurtici__Password=YOUR_YURTICI_PASSWORD
Cargo__Yurtici__BaseUrl=http://testwebservices.yurticikargo.com:9090
Cargo__Aras__ApiKey=YOUR_ARAS_API_KEY
Cargo__Aras__BaseUrl=https://customerservicestest.araskargo.com.tr
Cargo__Surat__ApiKey=YOUR_SURAT_API_KEY
Cargo__Surat__BaseUrl=https://testapi.suratkargo.com.tr

# ── Pazarama (Sandbox) ──────────────────────
Pazarama__BaseUrl=https://sandbox-api.pazarama.com/api/v1/
Pazarama__ApiKey=YOUR_PAZARAMA_API_KEY

# ── E-Fatura (Sovos / Foriba) ───────────────
Invoice__Sovos__ApiKey=YOUR_SOVOS_API_KEY
Invoice__Sovos__CertificatePath=/app/certs/mali-muhur.pfx
Invoice__Sovos__CertificatePassword=YOUR_PFX_PASSWORD
Invoice__Sovos__SenderTaxNumber=YOUR_TAX_NUMBER

# ── E-Fatura (Parasut) ──────────────────────
Invoice__Parasut__ClientId=YOUR_PARASUT_CLIENT_ID
Invoice__Parasut__ClientSecret=YOUR_PARASUT_CLIENT_SECRET
Invoice__Parasut__CompanyId=YOUR_PARASUT_COMPANY_ID

# ── E-Logo (EDM Bilisim) ──────────────────────
Invoice__ELogo__BaseUrl=https://efatura-api.edmbilisim.com/v1/
Invoice__ELogo__Username=YOUR_ELOGO_USERNAME
Invoice__ELogo__Password=YOUR_ELOGO_PASSWORD
Invoice__ELogo__VKN=YOUR_VKN

# ── BirFatura ──────────────────────────────────
Invoice__BirFatura__BaseUrl=https://api.birfatura.com/v2/
Invoice__BirFatura__ApiKey=YOUR_BIRFATURA_API_KEY
Invoice__BirFatura__TaxNumber=YOUR_VKN

# ── Dijital Planet ─────────────────────────────
Invoice__DijiitalPlanet__BaseUrl=https://api.dijitalplanet.com.tr/efatura/
Invoice__DijiitalPlanet__ClientId=YOUR_DP_CLIENT_ID
Invoice__DijiitalPlanet__ClientSecret=YOUR_DP_CLIENT_SECRET

# ── GIB Portal ─────────────────────────────────
Invoice__GibPortal__BaseUrl=https://earsivportal.efatura.gov.tr/
Invoice__GibPortal__VKN=YOUR_VKN
Invoice__GibPortal__Password=YOUR_GIB_PORTAL_PASSWORD

# ── Hepsiburada Fatura ─────────────────────────
Invoice__HBFatura__BaseUrl=https://listing-external.hepsiburada.com/
Invoice__HBFatura__Username=YOUR_HB_MERCHANT_ID
Invoice__HBFatura__ApiKey=YOUR_HB_API_KEY

# ── MesTech Web API Security (IP-6) ───────────
ApiSecurity__ValidApiKeys__0=YOUR_MESA_OS_API_KEY
ApiSecurity__ValidApiKeys__1=YOUR_ADMIN_API_KEY
