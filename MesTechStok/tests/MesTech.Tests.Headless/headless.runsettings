<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <!-- Headless testler icin 5 dakika timeout — Testcontainers PostgreSQL startup dahil -->
    <TestSessionTimeout>300000</TestSessionTimeout>
  </RunConfiguration>
  <LoggerRunSettings>
    <Loggers>
      <Logger friendlyName="trx" enabled="True" />
    </Loggers>
  </LoggerRunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <!-- Hang dump collector DEVRE DISI — 522MB dump dosyalari onleniyor -->
      <DataCollector friendlyName="blame" enabled="false" />
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
