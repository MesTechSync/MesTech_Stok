# ============================================================
#  MesTech — ÜRETİM ORTAMI AYAR ŞABLONu
#  Coolify → Environment Variables panosuna bu içeriği girin.
#
#  KULLANIM:
#    1. Bu dosyayı .env.production olarak kopyalayın.
#    2. Tüm DEGISTIRILECEK değerlerini gerçek değerlerle doldurun.
#    3. Coolify panosuna yapıştırın VEYA sunucuya güvenli şekilde taşıyın.
#
#  ⚠  ASLA commit etmeyin — .env.production dosyası git'e girmez.
#  ⚠  Bu şablon dosyası (.env.production.template) commit edilir.
# ============================================================

# ── VERİTABANI (PostgreSQL) ──────────────────────────────────
POSTGRES_USER=mestech_user
POSTGRES_PASSWORD=DEGISTIRILECEK
POSTGRES_DB=mestech_production

# ── MESAJ KUYRUGU (RabbitMQ) ────────────────────────────────
RABBITMQ_USER=DEGISTIRILECEK
RABBITMQ_PASSWORD=DEGISTIRILECEK
RABBITMQ_DEFAULT_VHOST=/production

# ── ÖNBELLEK (Redis) ────────────────────────────────────────
# Production ortamında Redis şifre koruması zorunludur.
REDIS_PASSWORD=DEGISTIRILECEK

# ── MYSQL (OpenCart) ────────────────────────────────────────
MYSQL_ROOT_PASSWORD=DEGISTIRILECEK

# ── TRAEFIK / SSL / DOMAIN ──────────────────────────────────
# Let's Encrypt bildirimleri için geçerli bir e-posta adresi.
LETSENCRYPT_EMAIL=DEGISTIRILECEK
DOMAIN=dropmes.tr

# ── SEQ YAPILANDIRMASI ──────────────────────────────────────
SEQ_ADMIN_PASSWORD=DEGISTIRILECEK

# ── GRAFANA ─────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=DEGISTIRILECEK

# ── WEB API GÜVENLİK ────────────────────────────────────────
# MESA OS bridge ve yönetici çağrıları için ayrı API anahtarları.
MESA_OS_API_KEY=DEGISTIRILECEK
ADMIN_API_KEY=DEGISTIRILECEK
WEBAPI_API_KEY=${MESA_OS_API_KEY}
WEBAPI_IMAGE_TAG=latest

# ── TRENDYOL API ────────────────────────────────────────────
Trendyol__ApiKey=DEGISTIRILECEK
Trendyol__ApiSecret=DEGISTIRILECEK
Trendyol__SupplierId=1076956

# ── OPENCART ────────────────────────────────────────────────
OpenCart__BaseUrl=https://DEGISTIRILECEK
OpenCart__ApiKey=DEGISTIRILECEK

# ── ÇİÇEKSEPETİ ─────────────────────────────────────────────
# Production URL (sandbox değil).
